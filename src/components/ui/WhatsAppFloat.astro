---
/**
 * Botón flotante de WhatsApp — siempre visible en todas las páginas
 * Se incluye desde BaseLayout.astro
 */
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath } from '@utils/i18n';

const lang: Locale = ((Astro as any).currentLocale ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

const i18n = {
  es: {
    message: 'Hola, me gustaría reservar el descenso del Sella.',
    ariaLabel: 'Contactar por WhatsApp',
    title: 'Escríbenos por WhatsApp',
  },
  en: {
    message: 'Hi, I have a question about the Sella River descent.',
    ariaLabel: 'Contact us on WhatsApp',
    title: 'Message us on WhatsApp',
  },
  fr: {
    message: 'Bonjour, j\'ai une question sur la descente du Sella.',
    ariaLabel: 'Nous contacter sur WhatsApp',
    title: 'Écris-nous sur WhatsApp',
  },
  pt: {
    message: 'Olá, tenho uma questão sobre a descida do Sella.',
    ariaLabel: 'Contactar via WhatsApp',
    title: 'Escreve-nos no WhatsApp',
  },
} as const;
const t = i18n[lang] ?? i18n.es;

const phone = '34681093673';
const defaultMessage = encodeURIComponent(t.message);
---

<a
  href={`https://wa.me/${phone}?text=${defaultMessage}`}
  class="whatsapp-float"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={t.ariaLabel}
  title={t.title}
>
  <span class="whatsapp-float__pulse" aria-hidden="true"></span>
  <svg class="whatsapp-float__icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
  </svg>
  <span class="whatsapp-float__label" aria-hidden="true">WhatsApp</span>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: clamp(1rem, 3vw, 1.5rem);
    right: clamp(1rem, 3vw, 1.5rem);
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.25rem 0.875rem 1rem;
    background: #25d366;
    color: #ffffff;
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35), 0 4px 10px rgba(0, 0, 0, 0.12);
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.2px;
    text-decoration: none;
    transition: transform 220ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
                box-shadow 220ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
                background-color 220ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .whatsapp-float:hover {
    background: #1ebe57;
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(37, 211, 102, 0.5), 0 6px 14px rgba(0, 0, 0, 0.18);
  }

  .whatsapp-float__icon {
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.15));
  }

  .whatsapp-float__label {
    white-space: nowrap;
  }

  /* Pulse animation (halo detrás del botón) */
  .whatsapp-float__pulse {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: #25d366;
    z-index: -1;
    animation: whatsapp-pulse 2.4s ease-out infinite;
    opacity: 0;
  }

  @keyframes whatsapp-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float__pulse { animation: none; display: none; }
    .whatsapp-float { transition: none; }
    .whatsapp-float:hover { transform: none; }
  }

  /* En móviles pequeños: esconder el texto, dejar solo el icono en un círculo */
  @media (max-width: 480px) {
    .whatsapp-float {
      padding: 0;
      width: 56px;
      height: 56px;
      justify-content: center;
      border-radius: 50%;
    }
    .whatsapp-float__label { display: none; }
  }

  /* Accesibilidad foco */
  .whatsapp-float:focus-visible {
    outline: 3px solid #fff;
    outline-offset: 3px;
  }
</style>
