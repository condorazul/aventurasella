</header>

<script>
  /* Dropdown desktop · hover + focus + click + Esc */
  (function () {
    const dropdowns = document.querySelectorAll<HTMLElement>('[data-dropdown]');
    dropdowns.forEach((dd) => {
      const trigger = dd.querySelector<HTMLElement>('[data-dropdown-trigger]');
      const panel = dd.querySelector<HTMLElement>('[data-dropdown-panel]');
      if (!trigger || !panel) return;
      const isLink = trigger.tagName === 'A';

      let closeTimer: number | undefined;
      const open = () => {
        window.clearTimeout(closeTimer);
        /* Cierra otros dropdowns al abrir este */
        dropdowns.forEach(o => {
          if (o !== dd) {
            o.classList.remove('is-open');
            const t = o.querySelector<HTMLElement>('[data-dropdown-trigger]');
            if (t) t.setAttribute('aria-expanded', 'false');
          }
        });
        dd.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      };
      const close = () => {
        dd.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      };
      const scheduleClose = () => { closeTimer = window.setTimeout(close, 200); };

      dd.addEventListener('mouseenter', open);
      dd.addEventListener('mouseleave', scheduleClose);

      trigger.addEventListener('click', (e) => {
        // Si el trigger es un <a> (Blog), dejar navegar al click; el dropdown sigue abriendo en hover/focus.
        if (isLink) return;
        e.preventDefault();
        if (dd.classList.contains('is-open')) close();
        else open();
      });

      trigger.addEventListener('focus', open);
      panel.querySelectorAll('a').forEach((a) => {
        a.addEventListener('blur', () => {
          window.setTimeout(() => {
            if (!dd.contains(document.activeElement)) close();
          }, 60);
        });
      });

      dd.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') { close(); trigger.focus(); }
      });
    });

    /* Click fuera cierra todos */
    document.addEventListener('click', (e) => {
      dropdowns.forEach((dd) => {
        if (!dd.contains(e.target as Node)) {
          dd.classList.remove('is-open');
          const t = dd.querySelector<HTMLElement>('[data-dropdown-trigger]');
          if (t) t.setAttribute('aria-expanded', 'false');
        }
      });
    });
  })();

  /* Mobile drawer */
  (function () {
    const btn = document.getElementById('hdr-toggle');
    const drawer = document.getElementById('hdr-drawer');
    const header = document.getElementById('hdr');
    if (!btn || !drawer || !header) return;
    // Labels i18n inyectados desde Astro vía data-attrs (resuelve "Abrir / Cerrar menú" en el idioma actual).
    const labelOpen = header.getAttribute('data-label-open-menu') || 'Abrir menú';
    const labelClose = header.getAttribute('data-label-close-menu') || 'Cerrar menú';
    let open = false;
    const toggle = () => {
      open = !open;
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      header.classList.toggle('hdr--drawerOpen', open);
      btn.setAttribute('aria-label', open ? labelClose : labelOpen);
      document.body.style.overflow = open ? 'hidden' : '';
    };
    btn.addEventListener('click', toggle);
    drawer.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) { toggle(); }
    });
  })();

  /* Scroll · pill se compacta y el bg se vuelve sólido al hacer scroll · umbral muy bajo para transición inmediata */
  (function () {
    const header = document.getElementById('hdr');
    if (!header) return;
    let ticking = false;
    const upd = () => {
      ticking = false;
      if (window.scrollY > 4) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(upd); ticking = true; }
    }, { passive: true });
    upd();
  })();
</script>

