---
import { BLOG_POSTS } from '@data/blog-posts';
import { BLOG_POSTS_EN } from '@data/blog-posts-en';
import { BLOG_POSTS_FR } from '@data/blog-posts-fr';
import { BLOG_POSTS_PT } from '@data/blog-posts-pt';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { t, getAlternates, isLocaleReady, localizeUrl, getLocalePath } from '@utils/i18n';
import type { TranslationKey } from '@i18n/slugs';

interface Props {
  currentPath?: string;
  theme?: 'light' | 'dark';
  translationKey?: TranslationKey;
}

const { currentPath = '/', theme = 'dark', translationKey } = Astro.props;

// ==================== i18n · locale actual ====================
// El BaseLayout pasa el locale actual + translationKey vía Astro.locals,
// o caemos en detección por URL como fallback.
const currentLocale: Locale = ((Astro as any).currentLocale ?? Astro.url.pathname.match(/^\/(en|fr|pt)(\/|$)/)?.[1] ?? DEFAULT_LOCALE) as Locale;

// ==================== i18n local · sub-textos de los dropdown items ====================
// Strings cortos específicos del header que no merecen vivir en ui.ts (sólo se usan aquí).
const headerI18n = {
  es: {
    sellaItems: {
      recorrido:    { label: 'Recorrido y mapa',       sub: '14,5 km · 8 hitos' },
      premium:      { label: 'Reserva Premium',        sub: 'Todo incluido · picnic' },
      conNinos:     { label: 'Con niños',              sub: 'Desde 5 años · 1,15 m' },
      conPerro:     { label: 'Con perro',              sub: 'Mascotas gratis' },
      internacional:{ label: 'Descenso Internacional', sub: 'El gran evento del Sella' },
      opiniones:    { label: 'Opiniones',              sub: '4,5★ · 147 reseñas' },
    },
    guiasItems: {
      cuantoDura:   { label: 'Cuánto dura',  sub: '2-5 h · tiempos reales' },
      mejorEpoca:   { label: 'Mejor época',  sub: 'Clima · caudal · afluencia' },
      comoLlegar:   { label: 'Cómo llegar',  sub: 'Coche · ALSA · Renfe' },
    },
    blogMinPrefix: 'min',
  },
  en: {
    sellaItems: {
      recorrido:    { label: 'Route and map',          sub: '14.5 km · 8 highlights' },
      premium:      { label: 'Premium Booking',        sub: 'All inclusive · picnic' },
      conNinos:     { label: 'With kids',              sub: 'From age 5 · 1.15 m' },
      conPerro:     { label: 'With dog',               sub: 'Pets free' },
      internacional:{ label: 'International Descent',  sub: "The Sella's big event" },
      opiniones:    { label: 'Reviews',                sub: '4.5★ · 147 reviews' },
    },
    guiasItems: {
      cuantoDura:   { label: 'How long does it take', sub: '2-5 h · real times' },
      mejorEpoca:   { label: 'Best time',             sub: 'Climate · flow · crowds' },
      comoLlegar:   { label: 'How to get there',      sub: 'Car · ALSA · Renfe' },
    },
    blogMinPrefix: 'min',
  },
  fr: {
    sellaItems: {
      recorrido:    { label: 'Parcours et carte',          sub: '14,5 km · 8 points clés' },
      premium:      { label: 'Réservation Premium',        sub: 'Tout inclus · pique-nique' },
      conNinos:     { label: 'Avec enfants',               sub: 'Dès 5 ans · 1,15 m' },
      conPerro:     { label: 'Avec chien',                 sub: 'Animaux gratuits' },
      internacional:{ label: 'Descente Internationale',    sub: 'Le grand événement du Sella' },
      opiniones:    { label: 'Avis',                       sub: '4,5★ · 147 avis' },
    },
    guiasItems: {
      cuantoDura:   { label: 'Durée',             sub: '2-5 h · temps réels' },
      mejorEpoca:   { label: 'Meilleure période', sub: 'Climat · débit · affluence' },
      comoLlegar:   { label: 'Comment arriver',   sub: 'Voiture · ALSA · Renfe' },
    },
    blogMinPrefix: 'min',
  },
  pt: {
    sellaItems: {
      recorrido:    { label: 'Percurso e mapa',         sub: '14,5 km · 8 pontos' },
      premium:      { label: 'Reserva Premium',         sub: 'Tudo incluído · piquenique' },
      conNinos:     { label: 'Com crianças',            sub: 'A partir dos 5 anos · 1,15 m' },
      conPerro:     { label: 'Com cão',                 sub: 'Animais grátis' },
      internacional:{ label: 'Descida Internacional',   sub: 'O grande evento do Sella' },
      opiniones:    { label: 'Opiniões',                sub: '4,5★ · 147 avaliações' },
    },
    guiasItems: {
      cuantoDura:   { label: 'Quanto tempo dura', sub: '2-5 h · tempos reais' },
      mejorEpoca:   { label: 'Melhor época',      sub: 'Clima · caudal · afluência' },
      comoLlegar:   { label: 'Como chegar',       sub: 'Carro · ALSA · Renfe' },
    },
    blogMinPrefix: 'min',
  },
} as const;

const hi = headerI18n[currentLocale];

// Dropdown principal · Descenso del Sella (primary pill dark) · rutas y modalidades
const ddSella = {
  label: t('nav_descenso', currentLocale),
  eyebrow: t('nav_dd_sella_eyebrow', currentLocale),
  items: [
    { label: hi.sellaItems.recorrido.label,     href: getLocalePath('recorrido_mapa', currentLocale),         sub: hi.sellaItems.recorrido.sub },
    { label: hi.sellaItems.premium.label,       href: getLocalePath('reserva_premium', currentLocale),        sub: hi.sellaItems.premium.sub },
    { label: hi.sellaItems.conNinos.label,      href: getLocalePath('con_ninos', currentLocale),              sub: hi.sellaItems.conNinos.sub },
    { label: hi.sellaItems.conPerro.label,      href: getLocalePath('con_perro', currentLocale),              sub: hi.sellaItems.conPerro.sub },
    { label: hi.sellaItems.internacional.label, href: getLocalePath('descenso_internacional', currentLocale), sub: hi.sellaItems.internacional.sub },
    { label: hi.sellaItems.opiniones.label,     href: getLocalePath('opiniones', currentLocale),              sub: hi.sellaItems.opiniones.sub },
  ],
};

// Dropdown secundario · Guías (sin Blog · Blog ahora tiene su propio dropdown)
const ddGuias = {
  label: t('nav_guias', currentLocale),
  eyebrow: t('nav_dd_guias_eyebrow', currentLocale),
  items: [
    { label: hi.guiasItems.cuantoDura.label, href: getLocalePath('cuanto_dura', currentLocale), sub: hi.guiasItems.cuantoDura.sub },
    { label: hi.guiasItems.mejorEpoca.label, href: getLocalePath('mejor_epoca', currentLocale), sub: hi.guiasItems.mejorEpoca.sub },
    { label: hi.guiasItems.comoLlegar.label, href: getLocalePath('como_llegar', currentLocale), sub: hi.guiasItems.comoLlegar.sub },
  ],
};

// Dropdown Blog · últimas 4 entradas + "Ver todas"
// Selecciona la fuente de datos según locale para mostrar slugs/labels SEO
// localizados en cada idioma.
const blogPostsByLang: Record<Locale, readonly any[]> = {
  es: BLOG_POSTS,
  en: BLOG_POSTS_EN,
  fr: BLOG_POSTS_FR,
  pt: BLOG_POSTS_PT,
};
const blogPostsForLang = blogPostsByLang[currentLocale] ?? BLOG_POSTS;
const blogBasePath = getLocalePath('blog', currentLocale); // "/blog/" o "/en/blog/" etc.

const ddBlog = {
  label: t('nav_blog', currentLocale),
  eyebrow: t('nav_dd_blog_eyebrow', currentLocale),
  items: [...blogPostsForLang]
    .sort((a, b) => b.datePublished.localeCompare(a.datePublished))
    .slice(0, 4)
    .map(p => ({
      label: p.h1,
      href: `${blogBasePath}${p.slug}/`,
      sub: `${p.readingTime} ${hi.blogMinPrefix} · ${p.category}`,
    })),
};

const tel = '+34681093673';
const telDisplay = '681 093 673';

// URLs localizadas reutilizadas en varias partes del header
const urlPrecios    = getLocalePath('precios', currentLocale);
const urlQuienes    = getLocalePath('quienes_somos', currentLocale);
const urlContacto   = getLocalePath('contacto', currentLocale);
const urlBlog       = getLocalePath('blog', currentLocale);
const urlHome       = getLocalePath('home', currentLocale);

// Helpers · marcar activo si currentPath está en el dropdown
const isSellaActive = ddSella.items.some(i => i.href === currentPath);
const isGuiasActive = ddGuias.items.some(i => i.href === currentPath);
const isBlogActive = currentPath.startsWith('/blog') || currentPath.startsWith(urlBlog);

// ==================== i18n · selector de idioma ====================

// Si la página declaró translationKey (vía BaseLayout), usamos getAlternates
// para resolver URLs correctas por idioma. Si no, fallback a localizeUrl genérico.
const alternates = translationKey ? getAlternates(translationKey) : null;

const buildLangUrl = (locale: Locale): string => {
  if (alternates) return alternates[locale];
  return localizeUrl(Astro.url.pathname || '/', locale);
};

const langs = [
  { code: 'es' as Locale, label: 'ES', name: 'Español'   },
  { code: 'en' as Locale, label: 'EN', name: 'English'   },
  { code: 'fr' as Locale, label: 'FR', name: 'Français'  },
  { code: 'pt' as Locale, label: 'PT', name: 'Português' },
];

// Banderas emoji para el drawer mobile · más visual que solo el código (ES/EN/FR/PT)
const flags: Record<Locale, string> = {
  es: '🇪🇸',
  en: '🇬🇧',
  fr: '🇫🇷',
  pt: '🇵🇹',
};

const currentLang = langs.find(l => l.code === currentLocale) ?? langs[0];
---

<header class={`hdr hdr--${theme}`} id="hdr" data-theme={theme} data-label-open-menu={t('nav_open_menu', currentLocale)} data-label-close-menu={t('nav_close_menu', currentLocale)}>
  <div class="hdr__pill" role="navigation" aria-label={t('nav_main_aria', currentLocale)}>

    <!-- LOGO (izquierda) -->
    <a href={urlHome} class="hdr__logo" aria-label={t('nav_logo_aria', currentLocale)}>
      <span class="hdr__logoBadge">
        <img src="/images/logo/logo_sella_black.svg" alt="" width="40" height="40" loading="eager" aria-hidden="true" />
      </span>
      <span class="hdr__wordmark">
        <span class="hdr__wordmark-l1">Aventura</span>
        <span class="hdr__wordmark-l2">en el Sella</span>
      </span>
    </a>

    <!-- NAV principal (desktop) -->
    <nav class="hdr__nav" aria-label={t('nav_sections_aria', currentLocale)}>
      <ul class="hdr__list">

        <!-- Primary dropdown · Descenso del Sella (dark pill) -->
        <li class="hdr__item hdr__item--hasDropdown hdr__item--primary" data-dropdown>
          <button
            type="button"
            class:list={['hdr__primary', isSellaActive && 'is-active']}
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger
          >
            <svg class="hdr__primaryIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 14c3 3 7 4 9 4s6-1 9-4"/><path d="M5 14l2-8h10l2 8"/><line x1="12" y1="6" x2="12" y2="14"/></svg>
            <span>{ddSella.label}</span>
            <svg class="hdr__chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>

          <div class="hdr__panel" role="menu" data-dropdown-panel>
            <div class="hdr__panelInner">
              <span class="hdr__panelEyebrow">— {ddSella.eyebrow}</span>
              <ul class="hdr__panelList">
                {ddSella.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={['hdr__panelLink', currentPath === item.href && 'is-active']}
                      role="menuitem"
                    >
                      <div class="hdr__panelLinkBody">
                        <strong>{item.label}</strong>
                        <span>{item.sub}</span>
                      </div>
                      <svg class="hdr__panelArrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  </li>
                ))}
              </ul>

            </div>
          </div>
        </li>

        <!-- Precios -->
        <li class="hdr__item">
          <a
            href={urlPrecios}
            class:list={['hdr__link', currentPath === urlPrecios && 'is-active']}
          >
            <svg class="hdr__linkIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6a7 7 0 1 0 0 12"/><line x1="4" y1="10" x2="13" y2="10"/><line x1="4" y1="14" x2="13" y2="14"/></svg>
            <span>{t('nav_precios', currentLocale)}</span>
          </a>
        </li>

        <!-- Secondary dropdown · Guías -->
        <li class="hdr__item hdr__item--hasDropdown" data-dropdown>
          <button
            type="button"
            class:list={['hdr__link hdr__link--dropdown', isGuiasActive && 'is-active']}
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger
          >
            <svg class="hdr__linkIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <span>{ddGuias.label}</span>
            <svg class="hdr__chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>

          <div class="hdr__panel hdr__panel--compact" role="menu" data-dropdown-panel>
            <div class="hdr__panelInner hdr__panelInner--compact">
              <span class="hdr__panelEyebrow">— {ddGuias.eyebrow}</span>
              <ul class="hdr__panelList">
                {ddGuias.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={['hdr__panelLink', currentPath === item.href && 'is-active']}
                      role="menuitem"
                    >
                      <div class="hdr__panelLinkBody">
                        <strong>{item.label}</strong>
                        <span>{item.sub}</span>
                      </div>
                      <svg class="hdr__panelArrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>

        <!-- Blog dropdown · click navega a /blog/ · hover abre lista de últimas entradas -->
        <li class="hdr__item hdr__item--hasDropdown" data-dropdown>
          <a
            href={urlBlog}
            class:list={['hdr__link hdr__link--dropdown', isBlogActive && 'is-active']}
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger
          >
            <svg class="hdr__linkIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h13a3 3 0 0 1 3 3v13H7a3 3 0 0 1-3-3z"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/></svg>
            <span>{ddBlog.label}</span>
            <svg class="hdr__chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </a>

          <div class="hdr__panel hdr__panel--blog" role="menu" data-dropdown-panel>
            <div class="hdr__panelInner">
              <span class="hdr__panelEyebrow">— {ddBlog.eyebrow}</span>
              <ul class="hdr__panelList">
                {ddBlog.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={['hdr__panelLink', currentPath === item.href && 'is-active']}
                      role="menuitem"
                    >
                      <div class="hdr__panelLinkBody">
                        <strong>{item.label}</strong>
                        <span>{item.sub}</span>
                      </div>
                      <svg class="hdr__panelArrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  </li>
                ))}
              </ul>

              <a href={urlBlog} class="hdr__panelFooter" role="menuitem">
                <span>{t('nav_view_all_guides', currentLocale)}</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </li>

        <!-- Quiénes somos -->
        <li class="hdr__item hdr__item--spaced">
          <a
            href={urlQuienes}
            class:list={['hdr__link', currentPath === urlQuienes && 'is-active']}
          >
            <svg class="hdr__linkIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5 21v-2a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2"/></svg>
            <span>{t('nav_quienes', currentLocale)}</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Separador vertical sutil -->
    <span class="hdr__sep" aria-hidden="true"></span>

    <!-- ACTIONS (derecha) · lang + phone + contacto + reservar -->
    <div class="hdr__actions">

      <!-- Language switcher · selector i18n dinámico (Astro.currentLocale + translationKey) -->
      <div class="hdr__item hdr__item--hasDropdown hdr__lang" data-dropdown>
        <button
          type="button"
          class="hdr__langBtn"
          aria-haspopup="true"
          aria-expanded="false"
          aria-label={t('nav_lang_change', currentLocale)}
          data-dropdown-trigger
        >
          <svg class="hdr__langGlobe" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="3" y1="12" x2="21" y2="12"/><path d="M12 3a15 15 0 0 1 4 9 15 15 0 0 1-4 9 15 15 0 0 1-4-9 15 15 0 0 1 4-9z"/></svg>
          <span class="hdr__langCode">{currentLang.label}</span>
          <svg class="hdr__chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="hdr__panel hdr__panel--lang" role="menu" data-dropdown-panel>
          <div class="hdr__panelInner">
            <span class="hdr__panelEyebrow">{t('nav_lang_eyebrow', currentLocale)}</span>
            <ul class="hdr__panelList hdr__langList">
              {langs.map(l => {
                const isCurrent = l.code === currentLocale;
                // Idioma listo si: (a) tiene translationKey y está disponible · (b) no tiene key pero está en la lista global de listos
                const isReady = translationKey ? isLocaleReady(translationKey, l.code) : l.code === DEFAULT_LOCALE;
                const subtitleCurrent = t('lang_current', l.code);
                const subtitlePending = t('lang_coming_soon', l.code);
                if (isCurrent) {
                  return <li><a href={buildLangUrl(l.code)} class="hdr__panelLink is-active" role="menuitem" hreflang={l.code}><div class="hdr__panelLinkBody"><strong>{l.name}</strong><span>{l.label} · {subtitleCurrent}</span></div></a></li>;
                }
                if (isReady) {
                  return <li><a href={buildLangUrl(l.code)} class="hdr__panelLink" role="menuitem" hreflang={l.code}><div class="hdr__panelLinkBody"><strong>{l.name}</strong><span>{l.label}</span></div></a></li>;
                }
                return <li><a href="#" class="hdr__panelLink is-pending" role="menuitem" aria-disabled="true" tabindex="-1"><div class="hdr__panelLinkBody"><strong>{l.name}</strong><span>{l.label} · {subtitlePending}</span></div></a></li>;
              })}
            </ul>
          </div>
        </div>
      </div>

      <a href={`tel:${tel}`} class="hdr__phone" aria-label={`${t('nav_call_phone', currentLocale)} ${telDisplay}`} title={`${t('nav_call_title', currentLocale)} ${telDisplay}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>

      <a
        href={urlContacto}
        class:list={['hdr__contact', currentPath === urlContacto && 'is-active']}
      >
        {t('nav_contact', currentLocale)}
      </a>

      <a href={getLocalePath('reservar', currentLocale)} class="hdr__cta">
        <svg class="hdr__ctaIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>{t('nav_book_now', currentLocale)}</span>
      </a>
    </div>

    <!-- Hamburger mobile -->
    <button class="hdr__toggle" aria-label={t('nav_open_menu', currentLocale)} id="hdr-toggle" aria-expanded="false" aria-controls="hdr-drawer">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- MOBILE DRAWER -->
  <div class="hdr__drawer" id="hdr-drawer" aria-hidden="true">
    <div class="hdr__drawerInner">

      <!-- 1) Brand badge AL TOP · ocupa el espacio libre superior (clic = Home) -->
      <a href={urlHome} class:list={['hdr__drawerBrand', currentPath === urlHome && 'is-active']} aria-label={`${t('nav_home', currentLocale)} · Aventura en el Sella`}>
        <img src="/images/logo/logo_sella_black.svg" alt="Aventura en el Sella" width="120" height="40" loading="eager" />
      </a>

      <!-- 2) Banderas circulares · justo debajo del brand · sutiles -->
      <div class="hdr__drawerFlags" role="group" aria-label={t('nav_lang_change', currentLocale)}>
        {langs.map(l => {
          const isCurrent = l.code === currentLocale;
          const isReady = translationKey ? isLocaleReady(translationKey, l.code) : l.code === DEFAULT_LOCALE;
          const flagIcon = flags[l.code];
          if (isCurrent) {
            return <a href={buildLangUrl(l.code)} class="hdr__drawerFlag is-active" hreflang={l.code} aria-current="true" aria-label={`${l.name} · ${t('lang_current', l.code)}`}><span class="hdr__drawerFlagIcon" aria-hidden="true">{flagIcon}</span><span class="hdr__drawerFlagCode">{l.label}</span></a>;
          }
          if (isReady) {
            return <a href={buildLangUrl(l.code)} class="hdr__drawerFlag" hreflang={l.code} aria-label={l.name}><span class="hdr__drawerFlagIcon" aria-hidden="true">{flagIcon}</span><span class="hdr__drawerFlagCode">{l.label}</span></a>;
          }
          return <span class="hdr__drawerFlag is-pending" aria-disabled="true" aria-label={`${l.name} · ${t('lang_coming_soon', l.code)}`}><span class="hdr__drawerFlagIcon" aria-hidden="true">{flagIcon}</span><span class="hdr__drawerFlagCode">{l.label}</span></span>;
        })}
      </div>

