---
/**
 * CTA de reserva — Opción A (copy literal del cliente)
 */
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath, getLocalePath } from '@utils/i18n';

const lang: Locale = ((Astro as any).currentLocale ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

const i18n = {
  es: {
    eyebrow: 'Aventura en el Sella',
    titleLine1: 'Tu reserva Premium todo incluido y',
    titleLine2Pre: 'empieza tu descenso ',
    titleEm: 'sin complicaciones',
    subtitle: 'Tres formas fáciles de reservar. Tú eliges.',
    bookNow: 'Reservar ahora',
    whatsapp: 'WhatsApp',
    callTag: 'Llamar',
    emailLead: 'O escríbenos a',
  },
  en: {
    eyebrow: 'Aventura en el Sella',
    titleLine1: 'Your Premium all-inclusive booking and',
    titleLine2Pre: 'start your descent ',
    titleEm: 'with no hassle',
    subtitle: 'Three easy ways to book. You choose.',
    bookNow: 'Book now',
    whatsapp: 'WhatsApp',
    callTag: 'Call',
    emailLead: 'Or write to us at',
  },
  fr: {
    eyebrow: 'Aventura en el Sella',
    titleLine1: 'Ta réservation Premium tout inclus et',
    titleLine2Pre: 'commence ta descente ',
    titleEm: 'sans complications',
    subtitle: 'Trois façons faciles de réserver. À toi de choisir.',
    bookNow: 'Réserver maintenant',
    whatsapp: 'WhatsApp',
    callTag: 'Appeler',
    emailLead: 'Ou écris-nous à',
  },
  pt: {
    eyebrow: 'Aventura en el Sella',
    titleLine1: 'A tua reserva Premium tudo incluído e',
    titleLine2Pre: 'começa a tua descida ',
    titleEm: 'sem complicações',
    subtitle: 'Três formas fáceis de reservar. Tu escolhes.',
    bookNow: 'Reservar agora',
    whatsapp: 'WhatsApp',
    callTag: 'Ligar',
    emailLead: 'Ou escreve-nos para',
  },
} as const;
const t = i18n[lang] ?? i18n.es;
---

<section class="ctaA">
  <div class="ctaA__inner">
    <span class="ctaA__eyebrow">{t.eyebrow}</span>
    <h2 class="ctaA__title">
      {t.titleLine1}<br/>
      {t.titleLine2Pre}<span class="ctaA__title-em">{t.titleEm}</span>
    </h2>
    <p class="ctaA__subtitle">{t.subtitle}</p>

    <div class="ctaA__buttons">
      <a href={getLocalePath('reservar', lang)} class="ctaA__btn ctaA__btn--primary">
        <span>{t.bookNow}</span>
        <span class="ctaA__btn-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>

      <a href="https://wa.me/34681093673" class="ctaA__btn ctaA__btn--ghost" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        <span>{t.whatsapp}</span>
      </a>

      <a href="tel:+34681093673" class="ctaA__btn ctaA__btn--phone">
        <span class="ctaA__btn-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </span>
        <span class="ctaA__btn-phone-inner">
          <span class="ctaA__btn-phone-num">+34 681 09 36 73</span>
          <span class="ctaA__btn-phone-tag">{t.callTag}</span>
        </span>
      </a>
    </div>

    <p class="ctaA__email">
      {t.emailLead}
      <a href="mailto:reservas@aventuraenelsella.es">reservas@aventuraenelsella.es</a>
    </p>
  </div>
</section>

<style>
  .ctaA {
    background: var(--color-bg-dark, #1a1f2e);
    color: var(--color-text-on-dark);
    padding-block: clamp(4rem, 10vw, 7rem);
    padding-inline: clamp(1.5rem, 4vw, 4rem);
  }

  .ctaA__inner {
    max-width: 820px;
    margin-inline: auto;
    text-align: center;
  }

  .ctaA__eyebrow {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(251, 248, 241, 0.5);
    margin-bottom: var(--s-5);
  }

  .ctaA__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-text-on-dark);
    margin: 0 0 var(--s-5);
    text-wrap: balance;
  }

  .ctaA__title-em {
    color: var(--color-primary-soft);
    font-style: italic;
    font-weight: 400;
    font-family: var(--font-serif);
    letter-spacing: -0.01em;
  }

  .ctaA__subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: rgba(251, 248, 241, 0.7);
    margin: 0 0 var(--s-8);
  }

  .ctaA__buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--s-3);
    margin-bottom: var(--s-6);
  }

  .ctaA__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.2px;
    text-decoration: none;
    transition: all var(--duration-base) var(--ease-out);
    white-space: nowrap;
  }

  .ctaA__btn--primary {
    background: var(--color-bg-base);
    color: var(--color-text-primary);
    padding: 0.75rem 0.75rem 0.75rem 1.5rem;
  }

  .ctaA__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(251, 248, 241, 0.12);
  }

  .ctaA__btn-arrow {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-text-primary);
    color: var(--color-text-on-dark);
    border-radius: 50%;
  }

  .ctaA__btn--ghost {
    background: transparent;
    color: var(--color-text-on-dark);
    border: 1.5px solid rgba(251, 248, 241, 0.28);
  }

  .ctaA__btn--ghost:hover {
    background: rgba(251, 248, 241, 0.08);
    border-color: rgba(251, 248, 241, 0.55);
  }

  .ctaA__btn--phone {
    background: rgba(251, 248, 241, 0.08);
    color: var(--color-text-on-dark);
    border: 1.5px solid rgba(251, 248, 241, 0.22);
    padding: 0.5rem 1.25rem 0.5rem 0.5rem;
  }

  .ctaA__btn--phone:hover {
    background: rgba(251, 248, 241, 0.14);
    border-color: rgba(251, 248, 241, 0.45);
  }

  .ctaA__btn-icon {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(251, 248, 241, 0.14);
    border-radius: 50%;
  }

  .ctaA__btn-phone-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.05;
  }

  .ctaA__btn-phone-num {
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .ctaA__btn-phone-tag {
    font-size: 0.5625rem;
    letter-spacing: 1.6px;
    color: rgba(251, 248, 241, 0.55);
    text-transform: uppercase;
    margin-top: 2px;
  }

  .ctaA__email {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: rgba(251, 248, 241, 0.55);
    margin: 0;
  }

  .ctaA__email a {
    color: var(--color-primary-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ctaA__email a:hover { color: var(--color-primary); }
</style>
