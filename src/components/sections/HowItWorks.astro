---
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath } from '@utils/i18n';

const lang: Locale = ((Astro as any).currentLocale ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

const i18n = {
  es: {
    eyebrow: '— 04 / Cómo funciona',
    title_l1: 'Tu día en el Sella,',
    title_l2: 'paso a paso.',
    lead: 'Hemos pensado cada detalle para que solo tengas que concentrarte en pasarlo bien.',
    facts: {
      duration: { label: 'Duración', value: '2 — 5 h' },
      distance: { label: 'Distancia', value: '7 — 15 km' },
      stops: { label: 'Paradas', value: 'Las que quieras' },
      from: { label: 'Desde', value: '30 €' },
    },
    step_label: 'Paso',
    pagination_aria: 'Paginación',
    prev_aria: 'Anterior',
    next_aria: 'Siguiente',
    go_to_step_aria: (n: number) => `Ir al paso ${n}`,
    steps: [
      {
        badge: 'INICIO',
        title: 'Llegas',
        text: 'Te recibimos en nuestras instalaciones de Arriondas. Haces el check-in y te entregamos el picnic asturiano de regalo —empanada de bonito, bollín preñao y agua— junto con el bidón estanco, el chaleco y el neopreno si el agua lo pide.',
      },
      {
        badge: 'SALIDA',
        title: 'Te equipamos',
        text: 'Aparcas en nuestro parking privado y vigilado, recibes una breve clase explicativa y te damos canoa insumergible y pala doble. Eliges cómo arrancar: por nuestra rampa o a la vera del río.',
      },
      {
        badge: 'DISFRUTAS',
        title: 'Remas a tu ritmo',
        text: 'Tú marcas el ritmo. El Sella te lleva entre bosque y paisaje, con aguas tranquilas y algún tramo con pulso. Paras donde quieres, te bañas, respiras.',
      },
      {
        badge: 'PICNIC',
        title: 'Paras donde quieres',
