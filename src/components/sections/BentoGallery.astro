---
import Picture from '@components/ui/Picture.astro';
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath } from '@utils/i18n';

const lang: Locale = ((Astro as any).currentLocale ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

const i18n = {
  es: {
    eyebrow: '— 02 / La experiencia',
    titleLine1: 'Así se vive el',
    titleLine2: 'descenso del Sella',
    quoteLine1: 'Ven al Sella.',
    quoteLine2: 'Y que empiece el día.',
    items: [
      { src: 'rio-sella',      alt: 'Vista panorámica del río Sella entre las montañas asturianas',                                 tag: 'Río Sella',      size: 'tall'   },
      { src: 'con-peques',     alt: 'Familia con niños disfrutando del descenso del Sella en canoa',                                tag: 'Con peques',     size: 'wide'   },
      { src: 'mini-sella',     alt: 'Ruta del Mini Sella, descenso corto del río Sella ideal para familias',                        tag: 'Mini Sella',     size: 'normal' },
      { src: 'orilla-del-rio', alt: 'Orilla del río Sella, punto de salida para el descenso en canoa',                              tag: 'Orilla del Río', size: 'normal' },
      { src: 'la-rampa',       alt: 'Rampa de salida al río Sella desde las instalaciones de Aventura en el Sella',                tag: 'La Rampa',       size: 'wide'   },
      { src: 'asturias',       alt: 'Paisaje de Asturias que rodea el recorrido del descenso del Sella',                            tag: 'Asturias',       size: 'tall'   },
    ],
  },
  en: {
    eyebrow: '— 02 / The experience',
    titleLine1: 'This is the',
    titleLine2: 'Sella River descent',
    quoteLine1: 'Come to the Sella.',
    quoteLine2: 'Let the day begin.',
    items: [
      { src: 'rio-sella',      alt: 'Panoramic view of the Sella river winding through the Asturian mountains',                     tag: 'Sella River',    size: 'tall'   },
      { src: 'con-peques',     alt: 'Family with kids enjoying the Sella River descent by canoe',                                   tag: 'With kids',      size: 'wide'   },
      { src: 'mini-sella',     alt: 'Mini Sella route, a short descent of the Sella river ideal for families',                      tag: 'Mini Sella',     size: 'normal' },
      { src: 'orilla-del-rio', alt: 'Banks of the Sella river, the starting point of the canoe descent',                            tag: 'Riverside',      size: 'normal' },
      { src: 'la-rampa',       alt: 'Launch ramp into the Sella river from the Aventura en el Sella base',                          tag: 'The Ramp',       size: 'wide'   },
      { src: 'asturias',       alt: 'Asturian landscape surrounding the Sella River descent route',                                  tag: 'Asturias',       size: 'tall'   },
    ],
  },
  fr: {
    eyebrow: '— 02 / L’expérience',
    titleLine1: 'Voilà comment se vit',
    titleLine2: 'la descente du Sella',
    quoteLine1: 'Viens au Sella.',
    quoteLine2: 'Et que la journée commence.',
    items: [
      { src: 'rio-sella',      alt: 'Vue panoramique de la rivière Sella entre les montagnes asturiennes',                          tag: 'Rivière Sella',  size: 'tall'   },
      { src: 'con-peques',     alt: 'Famille avec enfants profitant de la descente du Sella en canoë',                              tag: 'Avec enfants',   size: 'wide'   },
      { src: 'mini-sella',     alt: 'Parcours Mini Sella, descente courte du Sella idéale pour les familles',                       tag: 'Mini Sella',     size: 'normal' },
      { src: 'orilla-del-rio', alt: 'Rive du Sella, point de départ pour la descente en canoë',                                     tag: 'Bord de rivière', size: 'normal' },
      { src: 'la-rampa',       alt: 'Rampe de mise à l’eau du Sella depuis la base d’Aventura en el Sella',                         tag: 'La Rampe',       size: 'wide'   },
      { src: 'asturias',       alt: 'Paysage des Asturies entourant le parcours de la descente du Sella',                            tag: 'Asturies',       size: 'tall'   },
    ],
  },
  pt: {
    eyebrow: '— 02 / A experiência',
    titleLine1: 'Assim se vive a',
    titleLine2: 'descida do Sella',
    quoteLine1: 'Vem ao Sella.',
    quoteLine2: 'E que comece o dia.',
    items: [
      { src: 'rio-sella',      alt: 'Vista panorâmica do rio Sella entre as montanhas asturianas',                                  tag: 'Rio Sella',      size: 'tall'   },
      { src: 'con-peques',     alt: 'Família com crianças a desfrutar da descida do Sella em canoa',                                tag: 'Com crianças',   size: 'wide'   },
      { src: 'mini-sella',     alt: 'Percurso Mini Sella, descida curta do rio Sella ideal para famílias',                          tag: 'Mini Sella',     size: 'normal' },
      { src: 'orilla-del-rio', alt: 'Margem do rio Sella, ponto de partida para a descida em canoa',                                tag: 'Margem do Rio',  size: 'normal' },
      { src: 'la-rampa',       alt: 'Rampa de saída ao rio Sella desde as instalações de Aventura en el Sella',                     tag: 'A Rampa',        size: 'wide'   },
      { src: 'asturias',       alt: 'Paisagem das Astúrias que rodeia o percurso da descida do Sella',                              tag: 'Astúrias',       size: 'tall'   },
    ],
  },
} as const;
const t = i18n[lang] ?? i18n.es;
const items = t.items;
---

<section class="bento">
  <div class="container container--xl">
    <header class="bento__header">
      <span class="eyebrow bento__eyebrow" data-reveal>{t.eyebrow}</span>
      <h2 class="bento__title" data-reveal data-reveal-delay="1">
        {t.titleLine1}<br/>
        <span class="serif-italic">{t.titleLine2}</span>
      </h2>
    </header>

    <div class="bento__grid">
      {items.map((item, i) => (
        <figure class:list={['bento__item', `bento__item--${item.size}`]} data-reveal data-reveal-type="slide-right" data-reveal-delay={(i % 5) + 1}>
          <Picture
            src={item.src}
            alt={item.alt}
            sizes="(min-width: 960px) 25vw, (min-width: 640px) 50vw, 100vw"
            bare={true}
          />
          <figcaption class="bento__caption">
            <span class="bento__tag">{item.tag}</span>
          </figcaption>
        </figure>
      ))}

      <!-- Quote tile: texto editorial suelto, sin bloque de color -->
      <div class="bento__quote" data-reveal data-reveal-delay="5">
        <p class="bento__quote-text">
          {t.quoteLine1}<br/>
          {t.quoteLine2}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .bento {
    padding-block: var(--section-padding-lg);
    background: var(--color-bg-warm);
  }

  .bento__header {
    margin-bottom: var(--s-16);
    max-width: 820px;
  }

  .bento__eyebrow {
    display: inline-block;
    color: var(--color-primary);
    margin-bottom: var(--s-5);
  }

  .bento__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    font-weight: var(--fw-black);
    line-height: 0.95;
    letter-spacing: var(--ls-tightest);
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .bento__title .serif-italic {
    color: var(--color-primary);
    font-weight: var(--fw-regular);
    text-transform: none;
    letter-spacing: -0.01em;
  }

  /* ============== GRID ============== */
  .bento__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: clamp(180px, 22vw, 260px);
    gap: var(--s-4);
  }

  @media (min-width: 960px) {
    .bento__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--s-5);
    }
  }

  .bento__item {
    position: relative;
    margin: 0;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-bg-muted);
    box-shadow: var(--shadow-md);
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
  }

  .bento__item:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .bento__item :global(picture),
  .bento__item :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bento__item :global(img) {
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .bento__item:hover :global(img) {
    transform: scale(1.08);
  }

  .bento__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(26,31,46,0.55) 100%);
    pointer-events: none;
  }

  .bento__item--tall {
    grid-row: span 2;
  }

  .bento__item--wide {
    grid-column: span 2;
  }

  @media (max-width: 959px) {
    .bento__item--tall { grid-row: span 1; }
    .bento__item--wide { grid-column: span 2; }
  }

  .bento__caption {
    position: absolute;
    left: var(--s-5);
    bottom: var(--s-5);
    z-index: 1;
  }

  /* ============== QUOTE TILE ============== */
  .bento__quote {
    grid-column: span 2;
    grid-row: span 1;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    background: transparent;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  @media (min-width: 960px) {
    .bento__quote {
      grid-column: span 3;
      grid-row: span 2;
    }
  }

  .bento__quote-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.875rem, 6vw, 5rem);
    font-weight: var(--fw-regular);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }

  .bento__tag {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    background: rgba(251, 248, 241, 0.92);
    color: var(--color-text-primary);
    border-radius: var(--radius-pill);
    font-size: 0.625rem;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>
