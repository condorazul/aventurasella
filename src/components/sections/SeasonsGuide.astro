        statValues: ['18–24°', '14–15h', '25–45'],
        highlights: [
          'Agua más templada',
          'Días largos de sol',
          'Caudal perfecto para canoa',
          'Ambiente del Descenso Internacional',
        ],
        linkLabel: 'Guía del Descenso Internacional',
        recommended: 'Familias · grupos · niños',
      },
      {
        key: 'otono',
        range: 'sep — nov',
        label: 'Otoño',
        badge: 'LA 2ª MEJOR',
        top: true,
        intro: 'Luz dorada y bosques ocres.',
        statValues: ['12–20°', '11–13h', '35–80'],
        highlights: [
          'Colores ocres espectaculares',
          'Afluencia baja',
          'Gastronomía de temporada',
        ],
        recommended: 'Fotografía · gastronomía · calma',
      },
      {
        key: 'invierno',
        range: 'dic — feb',
        label: 'Invierno',
        badge: 'CERRADO',
        top: false,
        intro: 'Fuera de temporada recreativa.',
        statValues: ['4–12°', '9–10h', '100+'],
        highlights: [
          'Actividad no disponible',
          'Caudal alto · agua fría',
          'Reserva tu plaza de temporada',
        ],
        recommended: 'Planificar para mar–nov',
      },
    ],
  },
  en: {
    eyebrow: '— Quick season guide',
    title1: 'When to do the',
    title2: 'Sella descent',
    titleEnd: '?',
    kicker: 'Each season has its magic.',
    leadPart1: 'The ',
    leadPart2: 'Sella is paddled from March to November',
    leadPart3: '. All the info at a glance — temperature, daylight, river flow and what you\'ll live in each season.',
    statLabels: {
      thermo: 'Air temp.',
      sunmoon: 'Daylight',
      river: 'Flow m³/s',
    },
    seasons: [
      {
        key: 'primavera',
        range: 'mar — jun',
        label: 'Spring',
        badge: 'OPEN',
        top: false,
        intro: 'Lively river and very little footfall.',
        statValues: ['13–18°', '12–14h', '80–120'],
        highlights: [
          'Explosive green forests',
          'Mild temperature',
          'Very low crowds',
        ],
        recommended: 'Couples · photographers · quiet',
      },
      {
        key: 'verano',
        range: 'jul — aug',
        label: 'Summer',
        badge: 'THE BEST',
        top: true,
        intro: 'Warm water, sunshine and ideal flow.',
        statValues: ['18–24°', '14–15h', '25–45'],
        highlights: [
          'Warmer water',
          'Long sunny days',
          'Perfect flow for canoeing',
          'Atmosphere of the International Descent',
        ],
        linkLabel: 'International Descent guide',
        recommended: 'Families · groups · kids',
      },
      {
        key: 'otono',
        range: 'sep — nov',
        label: 'Autumn',
        badge: '2ND BEST',
        top: true,
        intro: 'Golden light and ochre forests.',
        statValues: ['12–20°', '11–13h', '35–80'],
        highlights: [
          'Spectacular ochre colours',
          'Low crowds',
          'Seasonal gastronomy',
        ],
        recommended: 'Photography · food · calm',
      },
      {
        key: 'invierno',
        range: 'dec — feb',
        label: 'Winter',
        badge: 'CLOSED',
        top: false,
        intro: 'Outside the recreational season.',
        statValues: ['4–12°', '9–10h', '100+'],
        highlights: [
          'Activity not available',
          'High flow · cold water',
          'Book your spot for the next season',
        ],
        recommended: 'Plan for mar–nov',
      },
    ],
  },
  fr: {
    eyebrow: '— Guide rapide par saisons',
    title1: 'Quand faire la',
    title2: 'descente du Sella',
    titleEnd: ' ?',
    kicker: 'Chaque saison a sa magie.',
    leadPart1: 'Le ',
    leadPart2: 'Sella se navigue de mars à novembre',
    leadPart3: '. Toute l\'info en un coup d\'œil — température, heures de lumière, débit et ce que tu vivras à chaque époque.',
    statLabels: {
      thermo: 'Temp. ambiante',
      sunmoon: 'Lumière',
      river: 'Débit m³/s',
    },
    seasons: [
      {
        key: 'primavera',
        range: 'mar — juin',
        label: 'Printemps',
        badge: 'OUVERT',
        top: false,
        intro: 'Rivière vive et très peu d\'affluence.',
        statValues: ['13–18°', '12–14h', '80–120'],
        highlights: [
          'Forêts d\'un vert explosif',
          'Température douce',
          'Affluence très basse',
        ],
        recommended: 'Couples · photographes · silence',
      },
      {
        key: 'verano',
        range: 'juil — août',
        label: 'Été',
        badge: 'LA MEILLEURE',
        top: true,
        intro: 'Eau chaude, soleil et débit idéal.',
        statValues: ['18–24°', '14–15h', '25–45'],
        highlights: [
          'Eau plus tempérée',
          'Longues journées ensoleillées',
          'Débit parfait pour le canoë',
          'Ambiance de la Descente Internationale',
        ],
        linkLabel: 'Guide de la Descente Internationale',
        recommended: 'Familles · groupes · enfants',
      },
      {
        key: 'otono',
        range: 'sept — nov',
        label: 'Automne',
        badge: 'LA 2E MEILLEURE',
        top: true,
        intro: 'Lumière dorée et forêts ocres.',
        statValues: ['12–20°', '11–13h', '35–80'],
        highlights: [
          'Couleurs ocres spectaculaires',
          'Affluence basse',
          'Gastronomie de saison',
        ],
        recommended: 'Photographie · gastronomie · calme',
      },
      {
        key: 'invierno',
        range: 'déc — fév',
        label: 'Hiver',
        badge: 'FERMÉ',
        top: false,
        intro: 'Hors saison récréative.',
        statValues: ['4–12°', '9–10h', '100+'],
        highlights: [
          'Activité non disponible',
          'Débit haut · eau froide',
          'Réserve ta place pour la saison',
        ],
        recommended: 'Planifier pour mars–nov',
      },
    ],
  },
  pt: {
    eyebrow: '— Guia rápido por épocas',
    title1: 'Quando fazer a',
    title2: 'descida do Sella',
    titleEnd: '?',
    kicker: 'Cada época tem a sua magia.',
    leadPart1: 'O ',
    leadPart2: 'Sella navega-se de março a novembro',
    leadPart3: '. Toda a info de um relance — temperatura, horas de luz, caudal e o que vais viver em cada época.',
    statLabels: {
      thermo: 'Temp. ambiente',
      sunmoon: 'Luz solar',
      river: 'Caudal m³/s',
    },
    seasons: [
      {
        key: 'primavera',
        range: 'mar — jun',
        label: 'Primavera',
        badge: 'ABERTO',
        top: false,
        intro: 'Rio vivo e muito pouca afluência.',
        statValues: ['13–18°', '12–14h', '80–120'],
        highlights: [
          'Bosques verdes explosivos',
          'Temperatura suave',
          'Afluência muito baixa',
        ],
        recommended: 'Casais · fotógrafos · silêncio',
      },
      {
        key: 'verano',
        range: 'jul — ago',
        label: 'Verão',
        badge: 'A MELHOR',
        top: true,
        intro: 'Água quente, sol e caudal ideal.',
        statValues: ['18–24°', '14–15h', '25–45'],
        highlights: [
          'Água mais temperada',
          'Dias longos de sol',
          'Caudal perfeito para canoa',
          'Ambiente da Descida Internacional',
        ],
        linkLabel: 'Guia da Descida Internacional',
        recommended: 'Famílias · grupos · crianças',
      },
      {
        key: 'otono',
        range: 'set — nov',
        label: 'Outono',
        badge: 'A 2.ª MELHOR',
        top: true,
        intro: 'Luz dourada e bosques ocres.',
        statValues: ['12–20°', '11–13h', '35–80'],
        highlights: [
          'Cores ocres espetaculares',
          'Afluência baixa',
          'Gastronomia de época',
        ],
        recommended: 'Fotografia · gastronomia · calma',
      },
      {
        key: 'invierno',
        range: 'dez — fev',
        label: 'Inverno',
        badge: 'FECHADO',
        top: false,
        intro: 'Fora de época recreativa.',
        statValues: ['4–12°', '9–10h', '100+'],
        highlights: [
          'Atividade não disponível',
          'Caudal alto · água fria',
          'Reserva o teu lugar da época',
        ],
        recommended: 'Planear para mar–nov',
      },
    ],
  },
} as const;
const t = i18n[lang] ?? i18n.es;

// Estructura visual (iconos, gradientes, links) · independiente de idioma
// linkHref localizado para que el CTA del verano apunte al Descenso Internacional en el idioma actual
const seasonsMeta = [
  { icon: 'flower', gradient: 'sage'  },
  { icon: 'sun',    gradient: 'ochre', linkHref: getLocalePath('descenso_internacional', lang) },
  { icon: 'leaves', gradient: 'coral' },
  { icon: 'snow',   gradient: 'cool'  },
];

// Mezclamos copy + meta para renderizado
const seasons = t.seasons.map((s, idx) => {
  const meta = seasonsMeta[idx];
  return {
    ...s,
    icon: meta.icon,
    gradient: meta.gradient,
    stats: [
      { value: s.statValues[0], label: t.statLabels.thermo,  icon: 'thermo'  },
      { value: s.statValues[1], label: t.statLabels.sunmoon, icon: 'sunmoon' },
      { value: s.statValues[2], label: t.statLabels.river,   icon: 'river'   },
    ],
    link: meta.linkHref && 'linkLabel' in s
      ? { href: meta.linkHref, label: (s as any).linkLabel as string }
      : undefined,
  };
});
---

<section class="seasonsC">
  <div class="container container--xl">
    <header class="seasonsC__header">
      <span class="seasonsC__eyebrow">{t.eyebrow}</span>
      <h2 class="seasonsC__title">
        {t.title1}<br/><span class="serif-italic">{t.title2}</span>{t.titleEnd}
      </h2>
      <p class="seasonsC__kicker">{t.kicker}</p>
      <p class="seasonsC__lead">
        {t.leadPart1}<strong>{t.leadPart2}</strong>{t.leadPart3}
      </p>
    </header>

    <div class="seasonsC__grid">
      {seasons.map((s, i) => (
        <article class={`seasonC seasonC--${s.gradient}`} style={`--i: ${i}`}>
          <div class="seasonC__particles" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="seasonC__shimmer" aria-hidden="true"></div>

          <header class="seasonC__head">
            <div class="seasonC__top-slot">
              {s.top && (
                <span class="seasonC__top">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  TOP
                </span>
              )}
            </div>
            <span class="seasonC__label">{s.badge}</span>
          </header>

          <div class="seasonC__icon" aria-hidden="true">
            {s.icon === 'flower' && (
              <svg width="120" height="120" viewBox="0 0 140 140" fill="none">
                <defs>
                  <radialGradient id="sCBall" cx="30%" cy="30%" r="70%"><stop offset="0%" stop-color="#FFE7A3"/><stop offset="55%" stop-color="#F5B54B"/><stop offset="100%" stop-color="#D68A1E"/></radialGradient>
                  <radialGradient id="sCPetal" cx="30%" cy="25%" r="75%"><stop offset="0%" stop-color="#FFE0E7"/><stop offset="45%" stop-color="#F8A9B8"/><stop offset="100%" stop-color="#C96A7B"/></radialGradient>
                  <radialGradient id="sCCore" cx="35%" cy="30%" r="70%"><stop offset="0%" stop-color="#FFE7A3"/><stop offset="60%" stop-color="#F5B54B"/><stop offset="100%" stop-color="#A66318"/></radialGradient>
                </defs>
                <ellipse cx="28" cy="42" rx="14" ry="3" fill="#000" opacity="0.08"/>
                <ellipse cx="88" cy="118" rx="30" ry="4" fill="#000" opacity="0.1"/>
                <circle cx="28" cy="30" r="16" fill="url(#sCBall)"/>
                <ellipse cx="22" cy="24" rx="6" ry="4" fill="#FFFFFF" opacity="0.45"/>
                <g transform="translate(88,80)">
                  <g class="flower-rotate">
                    <ellipse cx="-25" cy="0" rx="18" ry="14" fill="url(#sCPetal)"/>
                    <ellipse cx="25" cy="0" rx="18" ry="14" fill="url(#sCPetal)"/>
                    <ellipse cx="0" cy="-25" rx="14" ry="18" fill="url(#sCPetal)"/>
                    <ellipse cx="0" cy="25" rx="14" ry="18" fill="url(#sCPetal)"/>
                    <circle cx="0" cy="0" r="12" fill="url(#sCCore)"/>
                    <ellipse cx="-3" cy="-3" rx="4" ry="3" fill="#FFFFFF" opacity="0.6"/>
                  </g>
                </g>
              </svg>
            )}
            {s.icon === 'sun' && (
              <svg width="120" height="120" viewBox="0 0 140 140" fill="none">
                <defs>
                  <radialGradient id="sCSun" cx="32%" cy="30%" r="70%"><stop offset="0%" stop-color="#FFF0C4"/><stop offset="45%" stop-color="#F8C860"/><stop offset="100%" stop-color="#C97816"/></radialGradient>
                  <radialGradient id="sCCloud" cx="35%" cy="30%" r="75%"><stop offset="0%" stop-color="#FFFFFF"/><stop offset="70%" stop-color="#F5F5F5"/><stop offset="100%" stop-color="#C8D0D6"/></radialGradient>
                </defs>
                <ellipse cx="46" cy="122" rx="30" ry="4" fill="#000" opacity="0.1"/>
                <ellipse cx="95" cy="118" rx="30" ry="3" fill="#000" opacity="0.08"/>
                <g class="sun-rays" transform-origin="46 50" stroke="#F5B54B" stroke-width="5" stroke-linecap="round">
                  <line x1="46" y1="10" x2="46" y2="22"/><line x1="46" y1="78" x2="46" y2="90"/>
                  <line x1="6" y1="50" x2="18" y2="50"/><line x1="74" y1="50" x2="86" y2="50"/>
                  <line x1="18" y1="22" x2="26" y2="30"/><line x1="66" y1="70" x2="74" y2="78"/>
                  <line x1="18" y1="78" x2="26" y2="70"/><line x1="66" y1="30" x2="74" y2="22"/>
                </g>
                <g class="sun-core" transform-origin="46 50">
                  <circle cx="46" cy="50" r="25" fill="url(#sCSun)"/>
                  <ellipse cx="38" cy="42" rx="9" ry="6" fill="#FFFFFF" opacity="0.55"/>
                </g>
                <g class="cloud-float">
                  <ellipse cx="96" cy="86" rx="30" ry="16" fill="url(#sCCloud)"/>
                  <ellipse cx="76" cy="90" rx="18" ry="12" fill="url(#sCCloud)"/>
                  <ellipse cx="112" cy="80" rx="16" ry="10" fill="url(#sCCloud)"/>
                </g>
              </svg>
            )}
            {s.icon === 'leaves' && (
              <svg width="120" height="120" viewBox="0 0 140 140" fill="none">
                <defs>
                  <radialGradient id="sCCAut" cx="35%" cy="30%" r="75%"><stop offset="0%" stop-color="#FFFFFF"/><stop offset="70%" stop-color="#F5F5F5"/><stop offset="100%" stop-color="#C8D0D6"/></radialGradient>
                  <linearGradient id="sCLeafR" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F5A27A"/><stop offset="50%" stop-color="#E8855F"/><stop offset="100%" stop-color="#9C3D28"/></linearGradient>
                  <linearGradient id="sCLeafA" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F5D27A"/><stop offset="50%" stop-color="#E8B24F"/><stop offset="100%" stop-color="#8E5F20"/></linearGradient>
                </defs>
                <ellipse cx="44" cy="118" rx="18" ry="3" fill="#000" opacity="0.1"/>
                <ellipse cx="90" cy="125" rx="18" ry="3" fill="#000" opacity="0.1"/>
                <g class="cloud-float">
                  <ellipse cx="98" cy="38" rx="32" ry="18" fill="url(#sCCAut)"/>
                  <ellipse cx="70" cy="44" rx="22" ry="14" fill="url(#sCCAut)"/>
                  <ellipse cx="116" cy="32" rx="16" ry="10" fill="url(#sCCAut)"/>
                </g>
                <g class="leaf leaf--1" transform="translate(40,80) rotate(-20)">
                  <g class="leaf__inner">
                    <path d="M 0 0 Q 6 -16 18 -14 Q 20 0 10 8 Q -2 10 0 0 Z" fill="url(#sCLeafR)"/>
                    <path d="M 2 -2 Q 8 -14 18 -12" stroke="#5E2214" stroke-width="1.2" fill="none" stroke-linecap="round"/>
                  </g>
                </g>
                <g class="leaf leaf--2" transform="translate(92,108) rotate(30)">
                  <g class="leaf__inner">
                    <path d="M 0 0 Q 6 -16 18 -14 Q 20 0 10 8 Q -2 10 0 0 Z" fill="url(#sCLeafA)"/>
                    <path d="M 2 -2 Q 8 -14 18 -12" stroke="#4B3410" stroke-width="1.2" fill="none" stroke-linecap="round"/>
                  </g>
                </g>
              </svg>
            )}
            {s.icon === 'snow' && (
              <svg width="120" height="120" viewBox="0 0 140 140" fill="none">
                <defs>
                  <radialGradient id="sCCWin" cx="35%" cy="30%" r="75%"><stop offset="0%" stop-color="#FFFFFF"/><stop offset="70%" stop-color="#EEF1F4"/><stop offset="100%" stop-color="#B8C6D6"/></radialGradient>
                </defs>
                <ellipse cx="78" cy="122" rx="40" ry="4" fill="#000" opacity="0.08"/>
                <g class="cloud-float">
                  <ellipse cx="80" cy="42" rx="38" ry="20" fill="url(#sCCWin)"/>
                  <ellipse cx="50" cy="48" rx="22" ry="14" fill="url(#sCCWin)"/>
                  <ellipse cx="108" cy="38" rx="20" ry="12" fill="url(#sCCWin)"/>
                </g>
                <g class="snow snow--1">
                  <g stroke="#6FA3CC" stroke-width="2.6" stroke-linecap="round">
                    <line x1="46" y1="88" x2="66" y2="88"/>
                    <line x1="56" y1="78" x2="56" y2="98"/>
                    <line x1="49" y1="81" x2="63" y2="95"/>
                    <line x1="63" y1="81" x2="49" y2="95"/>
                  </g>
                </g>
                <g class="snow snow--2" fill="#8FB4D8">
                  <circle cx="82" cy="88" r="2.5"/>
                  <circle cx="96" cy="78" r="2"/>
                </g>
                <g class="snow snow--3" fill="#8FB4D8">
                  <circle cx="100" cy="100" r="2.2"/>
                  <circle cx="90" cy="110" r="1.8"/>
                </g>
              </svg>
            )}
          </div>

          <div class="seasonC__body">
            <h3 class="seasonC__range">{s.range}</h3>
            <span class="seasonC__season">{s.label}</span>
            <p class="seasonC__intro">{s.intro}</p>

            <div class="seasonC__stats">
              {s.stats.map(st => (
                <div class="seasonC__stat">
                  <span class="seasonC__stat-icon" aria-hidden="true">
                    {st.icon === 'thermo' && (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
                        <circle cx="11.5" cy="18" r="1.6" fill="currentColor"/>
                      </svg>
                    )}
                    {st.icon === 'sunmoon' && (
                      <svg width="18" height="16" viewBox="0 0 28 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8" cy="12" r="3.5"/>
                        <line x1="8" y1="4" x2="8" y2="6.5"/><line x1="8" y1="17.5" x2="8" y2="20"/>
                        <line x1="2" y1="12" x2="4" y2="12"/><line x1="12.5" y1="12" x2="14.5" y2="12"/>
                        <line x1="3.5" y1="7.5" x2="5" y2="9"/><line x1="11" y1="15" x2="12.5" y2="16.5"/>
                        <line x1="3.5" y1="16.5" x2="5" y2="15"/><line x1="11" y1="9" x2="12.5" y2="7.5"/>
                        <path d="M24 14.5a5.5 5.5 0 1 1-6-7.8 4.5 4.5 0 0 0 6 7.8z"/>
                      </svg>
                    )}
                    {st.icon === 'river' && (
                      <svg width="18" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 7 Q 6 3 10 7 T 18 7 T 22 7"/>
                        <path d="M2 13 Q 6 9 10 13 T 18 13 T 22 13"/>
                        <path d="M2 19 Q 6 15 10 19 T 18 19 T 22 19"/>
                      </svg>
                    )}
                  </span>
                  <span class="seasonC__stat-value">{st.value}</span>
                  <span class="seasonC__stat-label">{st.label}</span>
                </div>
              ))}
            </div>

            <ul class="seasonC__highlights">
              {s.highlights.map(h => (
                <li>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
