---
/**
 * SeasonsGuideC — Layout compacto (4 cards en fila como A) + info completa (como B)
 * Bubble cards pastel + iconos animados Lottie-style + stats + highlights + recomendado
 */
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath, getLocalePath } from '@utils/i18n';

const lang: Locale = ((Astro as any).currentLocale ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

const i18n = {
  es: {
    eyebrow: '— Guía rápida por temporadas',
    title1: '¿Cuándo hacer el',
    title2: 'descenso del Sella',
    titleEnd: '?',
    kicker: 'Cada estación tiene su magia.',
    leadPart1: 'El ',
    leadPart2: 'Sella se navega de marzo a noviembre',
    leadPart3: '. Toda la info a un vistazo — temperatura, horas de luz, caudal y lo que vivirás en cada época.',
    statLabels: {
      thermo: 'Temp. ambiente',
      sunmoon: 'Luz solar',
      river: 'Caudal m³/s',
    },
    seasons: [
      {
        key: 'primavera',
        range: 'mar — jun',
        label: 'Primavera',
        badge: 'PRACTICABLE',
        top: false,
        intro: 'Río vivo y muy poca afluencia.',
        statValues: ['13–18°', '12–14h', '80–120'],
        highlights: [
          'Bosques verdes explosivos',
          'Temperatura suave',
          'Afluencia muy baja',
