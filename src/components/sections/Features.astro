---
const features = [
  {
    number: '02',
    title: 'En familia',
    highlight: 'sin prisa',
    text: 'Edad mínima 5 años. Mini Sella de 7 km ideal para los más pequeños, con ritmo tranquilo y todas las paradas que necesitéis.',
    href: '/con-ninos/',
    cta: 'Ver opción familiar',
    image: '/images/home/feature-familia.jpg',
  },
  {
    number: '03',
    title: 'Con tu perro',
    highlight: 'dog friendly',
    text: 'Cada vez más clientes disfrutan del río con su mascota. Te contamos cómo hacerlo bien: seguridad, equipamiento y consejos reales.',
    href: '/con-perro/',
    cta: 'Ver guía con perro',
    image: '/images/home/feature-perro.jpg',
  },
  {
    number: '04',
    title: 'Ruta completa',
    highlight: 'a tu ritmo',
    text: '15 km desde Arriondas hasta Fríes. Naturaleza, libertad y paradas para bañarse y comer durante 4-5 horas de aventura.',
    href: '/recorrido-y-mapa/',
    cta: 'Ver mapa y paradas',
    image: '/images/home/feature-recorrido.jpg',
  },
];
---

<section class="features">
  <div class="container container--lg">
    <header class="features__header">
      <span class="eyebrow features__eyebrow" data-reveal>— Elige tu experiencia</span>
      <h2 class="features__title" data-reveal data-reveal-delay="1">
        Una aventura<br/>
        <span class="serif-italic">adaptada a ti</span>
      </h2>
    </header>

    <div class="features__grid">
      {features.map((f, i) => (
        <a href={f.href} class="feature" data-reveal data-reveal-delay={i + 1}>
          <div class="feature__media">
            <img src={f.image} alt="" loading="lazy" />
            <div class="feature__media-overlay"></div>
            <span class="feature__number mono">{f.number}</span>
          </div>
          <div class="feature__body">
            <h3 class="feature__title">
              {f.title} <span class="serif-italic">{f.highlight}</span>
            </h3>
            <p class="feature__text">{f.text}</p>
            <span class="feature__cta">
              {f.cta}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--section-padding-lg);
    background: var(--color-bg-warm);
  }

  .features__header {
    display: grid;
    gap: var(--s-6);
    margin-bottom: var(--s-16);
    max-width: 820px;
  }

  .features__eyebrow {
    display: inline-block;
    color: var(--color-primary);
  }

  .features__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    font-weight: var(--fw-black);
    line-height: 1;
    letter-spacing: var(--ls-tightest);
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .features__title .serif-italic {
    color: var(--color-sage);
    text-transform: none;
    font-weight: var(--fw-regular);
    letter-spacing: -0.01em;
  }

  .features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }

  @media (min-width: 768px) {
    .features__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-6);
    }
  }

  /* ========== FEATURE CARD ========== */
  .feature {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg-elevated);
    border-radius: var(--radius-3xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
    color: inherit;
    text-decoration: none;
  }

  .feature:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
  }

  .feature__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .feature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .feature:hover .feature__media img {
    transform: scale(1.07);
  }

  .feature__media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(26,31,46,0.5) 100%);
  }

  .feature__number {
    position: absolute;
    top: var(--s-6);
    left: var(--s-6);
    padding: 0.5rem 0.75rem;
    background: rgba(244, 240, 232, 0.92);
    color: var(--color-text-primary);
    border-radius: var(--radius-pill);
    font-size: 0.625rem;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-widest);
  }

  .feature__body {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    padding: var(--s-8) var(--s-7);
  }

  .feature__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: var(--fw-bold);
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--color-text-primary);
    text-transform: none;
  }

  .feature__title .serif-italic {
    color: var(--color-primary);
    font-weight: var(--fw-regular);
  }

  .feature__text {
    font-size: var(--fs-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--lh-body);
    flex: 1;
  }

  .feature__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.6875rem;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-text-primary);
    padding-top: var(--s-4);
    border-top: 1px solid var(--color-border-subtle);
    transition: gap var(--duration-base) var(--ease-out);
  }

  .feature:hover .feature__cta {
    gap: var(--s-4);
    color: var(--color-primary);
  }
</style>
