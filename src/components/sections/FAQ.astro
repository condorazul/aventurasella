        q: 'O que inclui a reserva? Há que pagar algo mais à chegada?',
        a: 'A reserva inclui <strong>tudo</strong>: canoa insubmersível K1/K2/K3, remo duplo, colete salva-vidas, bidão estanque, neopreno em datas frias, mini-aula com monitor titulado, transfer de regresso desde Toraño ou Fríes, piquenique asturiano (empada de bonito, bolinho asturiano e água), balneários com duches, cacifos com chave, <strong>estacionamento privado vigiado (300 lugares · também para autocaravanas)</strong> e seguros. <strong>Sem surpresas nem extras</strong> no dia da atividade.',
      },
      {
        q: 'Como se reserva a descida do Sella?',
        a: 'Trabalhamos <strong>apenas com reserva antecipada</strong>. Podes reservar online a partir do nosso site em 2 minutos, ou diretamente por WhatsApp (+34 681 09 36 73) ou email (reservas@aventuraenelsella.es). <strong>Sem pagar adiantado</strong> — pagas <strong>no dia da atividade ao recolher a canoa</strong> ou <strong>com cartão antecipado</strong>, o que te for mais cómodo. Podes <strong>alterar ou cancelar</strong> a qualquer momento antes do dia da atividade; se pagaste com cartão, o reembolso requer pelo menos <strong>24 h de antecedência</strong>.',
      },
    ],
  },
} as const;

const t = i18n[lang] ?? i18n.es;

// Localiza los href ES que viven embebidos en los textos i18n de las respuestas
// (atajo a páginas internas mencionadas dentro del párrafo).
const urlInternacional = getLocalePath('descenso_internacional', lang);
const urlContacto = getLocalePath('contacto', lang);

const faqs = t.faqs.map(faq => ({
  q: faq.q,
  a: faq.a
    .replace(/href="\/descenso-internacional-del-sella\/"/g, `href="${urlInternacional}"`)
    .replace(/href="\/contacto\/"/g, `href="${urlContacto}"`),
}));

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${baseUrl}/#faq`,
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section class="faqE">
  <div class="container container--xl">
    <div class="faqE__grid">
      <!-- Sidebar -->
      <aside class="faqE__aside">
        <span class="faqE__eyebrow">{t.eyebrow}</span>
        <h2 class="faqE__title">{t.title_a}<em>{t.title_em}</em></h2>
        <p class="faqE__lead" set:html={t.lead}></p>

        <div class="faqE__badges">
          <span class="faqE__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span set:html={t.badge_whatsapp}></span>
          </span>
          <span class="faqE__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span set:html={t.badge_phone}></span>
          </span>
          <span class="faqE__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span set:html={t.badge_news}></span>
          </span>
        </div>
      </aside>

      <!-- Acordeón -->
      <div class="faqE__list">
        {faqs.map((f, i) => (
          <details class="faqERow" name="faq-home" open={i === 0}>
            <summary>
              <span>{f.q}</span>
              <span class="faqERow__sign" aria-hidden="true">
                <svg class="plus" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <div class="faqERow__a" set:html={f.a}></div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faqE {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-elevated, #FFFFFF);
  }

  .faqE__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .faqE__grid { grid-template-columns: 1fr 1.3fr; gap: clamp(3rem, 5vw, 5rem); }
  }

  /* Aside */
  .faqE__aside { min-width: 0; }
  .faqE__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary); margin-bottom: var(--s-4);
  }
  .faqE__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-4);
  }
  .faqE__title em {
    font-family: var(--font-serif); font-style: italic;
    font-weight: 400; color: var(--color-primary);
    letter-spacing: -0.01em;
  }
  .faqE__lead {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 var(--s-6);
  }

  .faqE__badges {
    display: flex; flex-direction: column; gap: var(--s-3);
    margin-top: var(--s-6);
    padding-top: var(--s-5);
    border-top: 1px solid var(--color-border-subtle);
  }
  .faqE__badge {
    display: flex; align-items: flex-start; gap: var(--s-2);
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.45;
    color: var(--color-text-secondary);
  }
  .faqE__badge strong {
    color: var(--color-text-primary); font-weight: 700;
  }
  .faqE__badge svg {
    color: var(--color-primary); flex-shrink: 0;
    background: rgba(233, 133, 111, 0.14);
    border-radius: 50%;
    padding: 4px;
    box-sizing: content-box;
    margin-top: 2px;
  }

  /* Lista acordeón */
  .faqE__list {
    display: flex; flex-direction: column;
    min-width: 0;
  }

  .faqERow {
    border-bottom: 1px solid var(--color-border-subtle);
    transition: border-color 200ms var(--ease-out);
  }
  .faqERow[open] {
    border-color: rgba(233, 133, 111, 0.35);
  }

  .faqERow > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-5) 0;
    font-family: var(--font-display);
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    transition: color 200ms var(--ease-out);
  }
  .faqERow > summary::-webkit-details-marker { display: none; }
  .faqERow > summary:hover { color: var(--color-primary); }

  .faqERow__sign {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    color: var(--color-text-primary);
    flex-shrink: 0;
    transition: transform 300ms cubic-bezier(0.34, 1.2, 0.64, 1), color 200ms;
  }
  .faqERow:hover .faqERow__sign { color: var(--color-primary); }
  .faqERow[open] .faqERow__sign {
    transform: rotate(45deg);
    color: var(--color-primary);
  }

  .faqERow__a {
    padding: 0 0 var(--s-5);
    font-family: var(--font-sans);
    font-size: 0.9375rem; line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 60ch;
  }
  .faqERow__a :global(strong) {
    color: var(--color-text-primary);
    font-weight: 700;
  }
</style>
