---
const stats = [
  { value: '25', suffix: '+', label: 'Años guiando familias' },
  { value: '56K', suffix: '+', label: 'Aventureros felices' },
  { value: '4.5', suffix: '', label: 'Valoración media' },
  { value: '15', suffix: ' km', label: 'Ruta completa' },
];
---

<section class="trust">
  <div class="trust__container">
    <div class="trust__grid">
      {stats.map((s, i) => (
        <>
          <div class="trust__item" data-reveal data-reveal-delay={i + 1}>
            <div class="trust__value">
              <span>{s.value}</span>
              <span class="trust__suffix">{s.suffix}</span>
            </div>
            <div class="trust__label">{s.label}</div>
          </div>
          {i < stats.length - 1 && <div class="trust__divider" aria-hidden="true"></div>}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    padding-block: clamp(3rem, 6vw, 5rem);
    background: var(--color-bg-base);
  }

  .trust__container {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .trust__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-10) var(--s-4);
    align-items: center;
  }

  @media (min-width: 768px) {
    .trust__grid {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
      gap: var(--s-8);
    }
  }

  .trust__item {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    text-align: center;
  }

  .trust__value {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: var(--fw-bold);
    line-height: 1;
    letter-spacing: var(--ls-tighter);
    color: var(--color-text-primary);
    font-feature-settings: 'tnum' 1;
  }

  .trust__suffix {
    font-size: 0.6em;
    color: var(--color-primary);
    margin-left: 2px;
  }

  .trust__label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .trust__divider {
    display: none;
    width: 1px;
    height: 48px;
    background: var(--color-border-default);
  }

  @media (min-width: 768px) {
    .trust__divider { display: block; }
  }
</style>
