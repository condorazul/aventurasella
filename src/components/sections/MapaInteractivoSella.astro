const t = i18n[lang] ?? i18n.es;

// Pueblos con pill label (interactivos: hover resalta)
const pueblos = [
  { id: 'arriondas', name: 'Arriondas',      type: t.type_salida,            km: 0,    x: 55,  y: 168, align: 'top',    important: true },
  { id: 'fuentes',   name: 'Fuentes',        type: t.type_paraje,            km: 4,    x: 230, y: 130, align: 'top' },
  { id: 'margolles', name: 'Margolles',      type: t.type_pueblo,            km: 6.5,  x: 330, y: 300, align: 'bottom' },
  { id: 'torano',    name: 'Toraño',         type: t.type_fin_mini,          km: 7,    x: 420, y: 130, align: 'top',    important: true, finish: 'mini' },
  { id: 'llordon',   name: 'Llordón',        type: t.type_parada,            km: 10,   x: 540, y: 300, align: 'bottom' },
  { id: 'cuevas',    name: 'Cuevas',         type: t.type_pueblo,            km: 12,   x: 640, y: 130, align: 'top' },
  { id: 'launa',     name: 'La Uña',         type: t.type_pasarela,          km: 13,   x: 720, y: 300, align: 'bottom' },
  { id: 'fries',     name: 'Fríes',          type: t.type_final_completo,    km: 14.5, x: 820, y: 168, align: 'top',    important: true, finish: 'completo' },
];

// Dots intermedios con nombre completo para tooltip
const dots = [
  { id: 'raiz',      name: 'La Raíz',                 type: t.type_rapido,      km: 0.2, x: 100, y: 210, kind: 'rapido' },
  { id: 'remolina',  name: 'La Remolina',             type: t.type_rapido,      km: 1,   x: 150, y: 225, kind: 'rapido' },
  { id: 'riverland', name: 'Riverland',               type: t.type_chiringuito, km: 1,   x: 185, y: 220, kind: 'chiringuito' },
  { id: 'oasisprau', name: 'El Oasis · El Prau',      type: t.type_chiringuito, km: 3,   x: 260, y: 200, kind: 'chiringuito' },
  { id: 'pasfuentes',name: 'Pasarela de Fuentes',     type: t.type_pasarela,    km: 4,   x: 295, y: 205, kind: 'pasarela' },
  { id: 'bosqmed',   name: 'El Bosque · La Mediana',  type: t.type_chiringuito, km: 4,   x: 315, y: 210, kind: 'chiringuito' },
  { id: 'pozoarco',  name: 'Pozo del Arco',           type: t.type_playa,       km: 6,   x: 400, y: 225, kind: 'playa' },
  { id: 'toranochi', name: 'Toraño',                  type: t.type_chiringuito, km: 8,   x: 470, y: 215, kind: 'chiringuito' },
  { id: 'pascuevas', name: 'Pasarela de Cuevas',      type: t.type_pasarela,    km: 12,  x: 670, y: 225, kind: 'pasarela' },
  { id: 'paslauna',  name: 'Pasarela de La Uña',      type: t.type_pasarela,    km: 13,  x: 750, y: 220, kind: 'pasarela' },
];

// Cards con target coordinates (cx/cy) para zoom al mapa + tipo para el tooltip
// pointId vincula cada card con su punto SVG (para resaltarlo al clickar)
const cards = [
  { variant: 'start',  km: 0,    name: t.card_arriondas_name,    tag: t.card_tag_inicio,        tipType: t.type_salida,         detail: t.card_arriondas_detail,  icon: 'flag',       cx: 55,  cy: 210, pointId: 'arriondas' },
  { variant: 'normal', km: 1,    name: 'La Remolina',            tag: `${t.card_tag_km} 1`,     tipType: t.type_rapido,         detail: t.card_remolina_detail,   icon: 'wave',       cx: 150, cy: 225, pointId: 'remolina' },
  { variant: 'normal', km: 4,    name: 'Pasarela de Fuentes',    tag: `${t.card_tag_km} 4`,     tipType: t.type_pasarela,       detail: t.card_pasfuentes_detail, icon: 'bridge',     cx: 295, cy: 205, pointId: 'pasfuentes' },
  { variant: 'normal', km: 6,    name: 'Pozo del Arco',          tag: `${t.card_tag_km} 6`,     tipType: t.type_playa,          detail: t.card_pozoarco_detail,   icon: 'drop',       cx: 400, cy: 225, pointId: 'pozoarco' },
  { variant: 'mid',    km: 7,    name: 'Toraño',                 tag: t.card_tag_fin_mini,      tipType: t.type_fin_mini,       detail: t.card_torano_detail,     icon: 'flag-mini',  cx: 420, cy: 172, pointId: 'torano', fullMap: true },
  { variant: 'normal', km: 10,   name: 'Llordón',                tag: `${t.card_tag_km} 10`,    tipType: t.type_parada,         detail: t.card_llordon_detail,    icon: 'coffee',     cx: 540, cy: 258, pointId: 'llordon' },
  { variant: 'end',    km: 14.5, name: 'Fríes',                  tag: t.card_tag_final,         tipType: t.type_final_descenso, detail: t.card_fries_detail,      icon: 'flag-final', cx: 820, cy: 210, pointId: 'fries', fullMap: true },
];

// Chiringuitos (para el panel desplegable al clickar la card)
const chiringuitos = [
  { km: 1, name: 'Riverland' },
  { km: 3, name: 'El Oasis' },
  { km: 3, name: 'El Prau' },
  { km: 4, name: 'El Bosque' },
  { km: 4, name: 'La Mediana' },
  { km: 8, name: 'Toraño' },
];

// Path del río: empieza en Arriondas (~55, 210) y termina justo en Fríes (820, 210)
const riverPath = 'M 55 210 C 140 240, 220 140, 310 205 S 430 180, 500 220 T 650 210 T 780 196 T 820 210';
---

<section class="routeV2" aria-labelledby="routeV2-title">
  <div class="container container--xl">
    <header class="routeV2__header">
      <span class="eyebrow routeV2__eyebrow" data-reveal>{t.eyebrow}</span>
      <h2 id="routeV2-title" class="routeV2__title" data-reveal data-reveal-delay="1">
        {t.title_l1}<br/>
        <span class="serif-italic">{t.title_l2}</span>
      </h2>
      <p class="routeV2__lead body-lg" data-reveal data-reveal-delay="2">
        {t.lead}
      </p>
    </header>

    <div class="routeV2__layout">
      <!-- ============== MAPA ============== -->
      <div class="routeV2__map" data-reveal id="routeV2-map" data-tip-km-prefix={t.tip_km_prefix}>
        <!-- Tooltip único (hover + card click) -->
        <div class="routeV2__tip" id="routeV2-tip" aria-hidden="true">
          <span class="routeV2__tip-type" id="routeV2-tip-type">—</span>
          <span class="routeV2__tip-name" id="routeV2-tip-name">—</span>
          <span class="routeV2__tip-km" id="routeV2-tip-km">—</span>
          <span class="routeV2__tip-detail" id="routeV2-tip-detail"></span>
        </div>

        <svg id="routeV2-svg" viewBox="0 0 900 430" class="routeV2__svg" role="img" aria-label={t.svg_aria}>
          <defs>
            <linearGradient id="river-gradient-v2" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#7dbfda"/>
              <stop offset="100%" stop-color="#5a9dbb"/>
            </linearGradient>
            <pattern id="terrain-dots-v2" width="30" height="30" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="0.8" fill="rgba(138, 133, 120, 0.18)"/>
              <circle cx="15" cy="15" r="0.6" fill="rgba(138, 133, 120, 0.12)"/>
            </pattern>
            <filter id="pin-shadow-v2" x="-50%" y="-50%" width="200%" height="200%">
              <feDropShadow dx="0" dy="2" stdDeviation="2" flood-opacity="0.25"/>
            </filter>
          </defs>

          <rect width="900" height="430" fill="#f5ebd1"/>
          <rect width="900" height="430" fill="url(#terrain-dots-v2)"/>

          <g opacity="0.28">
            <path d="M 0 430 L 60 310 L 110 370 L 160 290 L 220 360 L 260 320 L 280 430 Z" fill="#8a8578"/>
            <path d="M 620 430 L 680 320 L 740 380 L 810 300 L 870 350 L 900 330 L 900 430 Z" fill="#8a8578"/>
          </g>

          <g opacity="0.32" fill="#4a6b4a">
            <circle cx="180" cy="90" r="5"/><circle cx="200" cy="85" r="4"/><circle cx="210" cy="95" r="4.5"/>
            <circle cx="370" cy="80" r="4.5"/><circle cx="385" cy="75" r="4"/>
            <circle cx="520" cy="85" r="5"/><circle cx="540" cy="90" r="4"/>
            <circle cx="170" cy="350" r="4.5"/><circle cx="185" cy="345" r="4"/>
            <circle cx="450" cy="360" r="5"/><circle cx="465" cy="365" r="4"/>
            <circle cx="620" cy="350" r="4.5"/><circle cx="635" cy="360" r="4"/>
          </g>

          <path d={riverPath} stroke="rgba(26, 31, 46, 0.08)" stroke-width="40" fill="none" stroke-linecap="round"/>
          <path d={riverPath} stroke="url(#river-gradient-v2)" stroke-width="32" fill="none" stroke-linecap="round"/>
          <path d={riverPath} stroke="rgba(255, 255, 255, 0.35)" stroke-width="14" fill="none" stroke-linecap="round"/>
          <path d={riverPath} stroke="rgba(255, 255, 255, 0.6)" stroke-width="1.5" stroke-dasharray="6 8" fill="none" stroke-linecap="round"/>

          <!-- Ruta Mini: Arriondas → Toraño (aprox. 48% del recorrido) -->
          <path d={riverPath}
                id="routeV2-route-mini"
                pathLength="100"
                stroke="#3d4f3a" stroke-width="10" fill="none" stroke-linecap="round"
                class="routeV2__route routeV2__route--mini"/>

          <!-- Ruta Completo: Arriondas → Fríes (100%) -->
          <path d={riverPath}
                id="routeV2-route-completo"
                pathLength="100"
                stroke="#e9856f" stroke-width="10" fill="none" stroke-linecap="round"
                class="routeV2__route routeV2__route--completo"/>

          <!-- Dots intermedios INTERACTIVOS -->
          {dots.map(d => (
            <g class={`routeV2__hit routeV2__dot routeV2__dot--${d.kind}`}
               data-id={d.id}
               data-name={d.name} data-type={d.type} data-km={d.km}
               tabindex="0" role="button" aria-label={`${d.name} — ${d.type} — ${t.aria_km} ${d.km}`}>
              <circle cx={d.x} cy={d.y} r="14" fill="transparent"/>{/* hit area amplia */}
              <circle cx={d.x} cy={d.y} r="7" fill="#fbf8f1" stroke="#1a1f2e" stroke-width="1.5" class="routeV2__dot-outer"/>
              <circle cx={d.x} cy={d.y} r="3" class="routeV2__dot-core"/>
            </g>
          ))}

          <!-- Pueblos con pill INTERACTIVOS -->
          {pueblos.map(p => {
            const isFinish = Boolean(p.finish);
            // Pill con "·" y badge para finales
            const badgeTxt = p.finish === 'mini' ? t.badge_fin_mini : p.finish === 'completo' ? t.badge_final : '';
            const pillW = isFinish ? (p.name.length * 8) + (badgeTxt.length * 6.4) + 54 : p.name.length * 8 + 20;
            const pillH = isFinish ? 30 : 26;
            const pinY = p.y + (p.align === 'top' ? 42 : -42);
            const pillY = p.y;
            return (
              <g class={`routeV2__hit routeV2__pueblo ${p.important ? 'is-important' : ''} ${isFinish ? 'is-finish is-finish--' + p.finish : ''}`}
                 data-id={p.id}
                 data-name={p.name} data-type={p.type} data-km={p.km}
                 tabindex="0" role="button" aria-label={`${p.name} — ${p.type} — ${t.aria_km} ${p.km}`}>
                <line x1={p.x} y1={pillY + (p.align === 'top' ? pillH/2 : -pillH/2)} x2={p.x} y2={pinY} stroke="#1a1f2e" stroke-width="1.2" stroke-dasharray="2 3" opacity="0.5"/>

                {/* Halo para finales */}
                {isFinish && (
                  <circle cx={p.x} cy={pinY} r="22" fill="none" stroke="#e9856f" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.7" class="routeV2__halo"/>
                )}

                <rect x={p.x - pillW/2} y={pillY - pillH/2} width={pillW} height={pillH} rx="14" fill={isFinish ? '#e9856f' : '#1a1f2e'} filter="url(#pin-shadow-v2)" class="routeV2__pill"/>

                {isFinish ? (
                  <>
                    <text x={p.x - pillW/2 + 14} y={pillY + 5} class="routeV2__pueblo-text routeV2__pueblo-text--finish">{p.name}</text>
                    <rect x={p.x + pillW/2 - (badgeTxt.length * 6.4) - 14} y={pillY - 8} width={badgeTxt.length * 6.4 + 8} height="16" rx="8" fill="#fbf8f1" opacity="0.92"/>
                    <text x={p.x + pillW/2 - (badgeTxt.length * 6.4 / 2) - 10} y={pillY + 4} text-anchor="middle" class="routeV2__pueblo-badge">{badgeTxt}</text>
                  </>
                ) : (
                  <text x={p.x} y={pillY + 5} text-anchor="middle" class="routeV2__pueblo-text">{p.name}</text>
                )}

                <circle cx={p.x} cy={pinY} r={isFinish ? 14 : (p.important ? 12 : 8)} fill={isFinish ? '#e9856f' : '#e9856f'} stroke="#fbf8f1" stroke-width={isFinish ? 4 : 3} filter="url(#pin-shadow-v2)" class="routeV2__pin"/>
                <circle cx={p.x} cy={pinY} r={isFinish ? 5 : (p.important ? 4 : 3)} fill="#fbf8f1"/>
                {/* Bandera interior para finales */}
                {isFinish && (
                  <path
                    d={`M ${p.x - 3.5} ${pinY - 4} L ${p.x - 3.5} ${pinY + 4} M ${p.x - 3.5} ${pinY - 4} L ${p.x + 3.5} ${pinY - 3} L ${p.x + 1} ${pinY - 1} L ${p.x + 3.5} ${pinY + 1}`}
                    fill="none" stroke="#1a1f2e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"
                  />
                )}
              </g>
            );
          })}

          <text x="40" y="35" class="routeV2__svg-caption">{t.svg_caption}</text>
        </svg>

        <!-- Panel de chiringuitos (visible solo cuando se activa esa card) -->
        <aside class="routeV2__chiriPanel" id="routeV2-chiri-panel" aria-hidden="true">
          <header class="routeV2__chiriPanel-head">
            <span class="routeV2__chiriPanel-tag">{t.chiri_panel_count}</span>
            <button type="button" class="routeV2__chiriPanel-close" id="routeV2-chiri-close" aria-label={t.chiri_panel_close}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </header>
          <ul class="routeV2__chiriPanel-list">
            {chiringuitos.map(c => (
              <li class="routeV2__chiriPanel-item">
                <span class="routeV2__chiriPanel-km">{t.tip_km_prefix} {c.km}</span>
                <span class="routeV2__chiriPanel-name">{c.name}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <!-- Panel lateral (igual que la otra) -->
      <aside class="routeV2__chooser" data-reveal data-reveal-delay="2">
        <span class="routeV2__chooser-eyebrow">{t.chooser_eyebrow}</span>

        <button type="button" class="routeV2__option routeV2__option--mini" id="routeV2-opt-mini" aria-pressed="false">
          <div class="routeV2__option-top">
            <span class="routeV2__option-km">7<span>{t.km_suffix}</span></span>
            <span class="routeV2__option-tag">{t.opt_mini_tag}</span>
          </div>
          <p class="routeV2__option-line">{t.opt_mini_line}</p>
          <p class="routeV2__option-note">{t.opt_mini_note}</p>
        </button>

        <button type="button" class="routeV2__option routeV2__option--completo" id="routeV2-opt-completo" aria-pressed="false">
          <div class="routeV2__option-top">
            <span class="routeV2__option-km">14,5<span>{t.km_suffix}</span></span>
            <span class="routeV2__option-tag">{t.opt_completo_tag}</span>
          </div>
          <p class="routeV2__option-line">{t.opt_completo_line}</p>
          <p class="routeV2__option-note">{t.opt_completo_note}</p>
        </button>

        <ul class="routeV2__features">
          <li>{t.feature_transfer}</li>
          <li>{t.feature_picnic}</li>
          <li>{t.feature_vestuarios}</li>
        </ul>
      </aside>
    </div>

    <!-- Cards inferiores: cada una hace zoom al mapa en su coordenada -->
    <ul class="routeV2__cards">
      {cards.map((c, i) => (
        <li data-reveal data-reveal-delay={(i % 7) + 1}>
          <button type="button"
                  class={`routeV2__card routeV2__card--${c.variant}`}
                  data-cx={c.cx}
                  data-cy={c.cy}
                  data-idx={i}
                  data-tip-type={c.tipType}
                  data-tip-name={c.name}
                  data-tip-km={c.km}
                  data-tip-detail={c.detail}
                  data-point-id={c.pointId}
                  data-full-map={c.fullMap ? 'true' : undefined}
                  aria-pressed="false">
          <div class="routeV2__card-top">
            <div class="routeV2__card-icon" aria-hidden="true">
              {c.icon === 'flag'       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>}
              {c.icon === 'wave'       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2"/><path d="M2 12c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2"/><path d="M2 18c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2"/></svg>}
              {c.icon === 'bridge'     && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18v-6a8 8 0 0 1 16 0v6"/><line x1="2" y1="18" x2="22" y2="18"/><line x1="8" y1="12" x2="8" y2="18"/><line x1="16" y1="12" x2="16" y2="18"/></svg>}
              {c.icon === 'drop'       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>}
              {c.icon === 'flag-mini'  && <svg width="14" height="14" viewBox="0 0 24 24" fill="#e9856f" stroke="#1a1f2e" stroke-width="1.5" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15" stroke-width="2.2" stroke-linecap="round"/></svg>}
              {c.icon === 'coffee'     && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>}
              {c.icon === 'flag-final' && <svg width="14" height="14" viewBox="0 0 24 24" fill="#e9856f" stroke="#1a1f2e" stroke-width="1.5" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><polygon points="12 7 13 9.2 15.4 9.4 13.6 10.9 14.1 13.2 12 12 9.9 13.2 10.4 10.9 8.6 9.4 11 9.2 12 7" fill="#fbf8f1" stroke="none"/></svg>}
            </div>
            <span class="routeV2__card-tag">{c.tag}</span>
          </div>
          <div class="routeV2__card-body">
            <span class="routeV2__card-dash" aria-hidden="true">—</span>
            <h3 class="routeV2__card-name">{c.name}</h3>
            <p class="routeV2__card-detail">{c.detail}</p>
          </div>
          </button>
        </li>
      ))}
    </ul>

    <!-- Card especial "Chiringuitos" (hace pulsar los puntos amarillos + abre panel) -->
    <button type="button" class="routeV2__chiriCard" id="routeV2-chiri-btn" aria-pressed="false" data-reveal data-reveal-type="scale" data-reveal-delay="8">
      <div class="routeV2__chiriCard-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
      </div>
      <div class="routeV2__chiriCard-body">
        <span class="routeV2__chiriCard-count">{t.chiri_card_count}</span>
        <span class="routeV2__chiriCard-note">{t.chiri_card_note}</span>
      </div>
      <div class="routeV2__chiriCard-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
    </button>
  </div>
</section>

<script>
  // PERFORMANCE · diferir setup hasta que el mapa entre en viewport.
  // El componente es below-the-fold en la Home → no necesitamos enganchar
  // listeners durante el LCP. Esto saca el trabajo del critical path y
  // mejora TBT/Speed Index.
  const _mapRoot = document.querySelector<HTMLElement>('.routeV2__map');
  const init = () => {
  const wrap = document.querySelector<HTMLElement>('.routeV2__map');
  const tip = document.getElementById('routeV2-tip') as HTMLElement | null;
  const tipType = document.getElementById('routeV2-tip-type') as HTMLElement | null;
  const tipName = document.getElementById('routeV2-tip-name') as HTMLElement | null;
  const tipKm = document.getElementById('routeV2-tip-km') as HTMLElement | null;

  if (wrap && tip && tipType && tipName && tipKm) {
    const hits = wrap.querySelectorAll<SVGGElement>('.routeV2__hit');
    const kmPrefix = wrap.dataset.tipKmPrefix || 'KM';

    function show(e: Event, el: Element) {
      // Si hay un tooltip "pinned" por click de card, el hover no lo sobrescribe
      if (tip!.classList.contains('is-pinned')) return;
      const name = el.getAttribute('data-name') || '';
      const type = el.getAttribute('data-type') || '';
      const km = el.getAttribute('data-km') || '';
      tipType!.textContent = type;
      tipName!.textContent = name;
      tipKm!.textContent = kmPrefix + ' ' + km;
      tip!.classList.remove('has-detail');
      tip!.classList.add('is-visible');

      // Posicionar tooltip según el evento
      const rect = wrap!.getBoundingClientRect();
      let mx = 0, my = 0;
      if (e instanceof MouseEvent) {
        mx = e.clientX - rect.left;
        my = e.clientY - rect.top;
      } else {
        const bbox = (el as SVGGraphicsElement).getBoundingClientRect();
        mx = bbox.left - rect.left + bbox.width / 2;
        my = bbox.top - rect.top;
      }
      tip!.style.left = Math.min(Math.max(mx, 110), rect.width - 110) + 'px';
      tip!.style.top = Math.max(my - 80, 10) + 'px';
    }

    function hide() {
      // No ocultar si está pinned
      if (tip!.classList.contains('is-pinned')) return;
      tip!.classList.remove('is-visible');
    }

    hits.forEach(h => {
      h.addEventListener('mouseenter', (e) => show(e, h));
      h.addEventListener('mousemove', (e) => show(e, h));
      h.addEventListener('mouseleave', hide);
      h.addEventListener('focus', (e) => show(e, h));
      h.addEventListener('blur', hide);
    });
  }

  // ===================== ZOOM AL MAPA + RUTAS =====================
  const svg = document.getElementById('routeV2-svg') as unknown as SVGSVGElement | null;
  const mapWrap = document.querySelector<HTMLElement>('.routeV2__map');
  const cards = Array.from(document.querySelectorAll<HTMLButtonElement>('.routeV2__card'));
  const optMini = document.getElementById('routeV2-opt-mini') as HTMLButtonElement | null;
  const optCompleto = document.getElementById('routeV2-opt-completo') as HTMLButtonElement | null;
  const routeMini = document.getElementById('routeV2-route-mini') as unknown as SVGPathElement | null;
  const routeCompleto = document.getElementById('routeV2-route-completo') as unknown as SVGPathElement | null;

  const tipDetail = document.getElementById('routeV2-tip-detail');

  // Marca el punto del mapa correspondiente a la card activa (pulsa + destaca)
  function focusPoint(pointId: string) {
    document.querySelectorAll('.routeV2__hit.is-focused')
      .forEach(el => el.classList.remove('is-focused'));
    if (!pointId) return;
    const el = document.querySelector(`.routeV2__hit[data-id="${pointId}"]`);
    el?.classList.add('is-focused');
  }

  // Muestra el tooltip fijado sobre el punto focused, incluyendo el detalle
  function showTipForPoint(card: HTMLButtonElement) {
    if (!tip || !tipType || !tipName || !tipKm || !tipDetail || !mapWrap) return;
    const pointId = card.dataset.pointId;
    const el = pointId ? document.querySelector(`.routeV2__hit[data-id="${pointId}"]`) : null;
    if (!el) return;

    const kmPrefixPin = mapWrap.dataset.tipKmPrefix || 'KM';
    tipType.textContent = card.dataset.tipType || '';
    tipName.textContent = card.dataset.tipName || '';
    tipKm.textContent = kmPrefixPin + ' ' + (card.dataset.tipKm || '');
    tipDetail.textContent = card.dataset.tipDetail || '';
    tip.classList.add('has-detail', 'is-visible', 'is-pinned');

    // Posición: centrado sobre el punto (usa el bbox del hit)
    const rect = mapWrap.getBoundingClientRect();
    const bbox = (el as SVGGraphicsElement).getBoundingClientRect();
    const cx = bbox.left - rect.left + bbox.width / 2;
    const cy = bbox.top - rect.top + bbox.height / 2;
    tip.style.left = Math.min(Math.max(cx, 120), rect.width - 120) + 'px';
    tip.style.top = Math.max(cy - 80, 8) + 'px';
  }

  function hidePinnedTip() {
    if (!tip) return;
    tip.classList.remove('has-detail', 'is-visible', 'is-pinned');
  }

  function resetZoom() {
    if (!svg) return;
    svg.style.transformOrigin = '50% 50%';
    svg.style.transform = 'scale(1)';
    cards.forEach(c => {
      c.classList.remove('is-active');
      c.setAttribute('aria-pressed', 'false');
    });
    hidePinnedTip();
    focusPoint('');
  }

  function doZoomIn(card: HTMLButtonElement) {
    if (!svg) return;
    const cx = Number(card.dataset.cx);
    const cy = Number(card.dataset.cy);
    if (Number.isNaN(cx) || Number.isNaN(cy)) return;

    const fullMap = card.dataset.fullMap === 'true';
    if (fullMap) {
      // Mapa completo: sin zoom, pero resaltamos el punto + tooltip
      svg.style.transformOrigin = '50% 50%';
      svg.style.transform = 'scale(1)';
    } else {
      const originX = (cx / 900) * 100;
      const originY = (cy / 430) * 100;
      svg.style.transformOrigin = `${originX}% ${originY}%`;
      svg.style.transform = 'scale(1.9)';
    }

    cards.forEach(c => {
      const active = c === card;
      c.classList.toggle('is-active', active);
      c.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    // Destacamos el punto del mapa (escala + pulse + color)
    focusPoint(card.dataset.pointId || '');
    // Mostramos el tooltip (con detalle) sobre el punto focused
    // Si es fullMap, menor delay (no hay animación fuerte). Si hay zoom, esperamos 520ms.
    setTimeout(() => showTipForPoint(card), fullMap ? 200 : 520);
  }

  function zoomToCard(card: HTMLButtonElement) {
    const anyActive = cards.some(c => c.classList.contains('is-active'));
    if (anyActive) {
      // Alejamos primero, luego acercamos al nuevo punto
      svg!.style.transform = 'scale(1)';
      setTimeout(() => doZoomIn(card), 380);
    } else {
      doZoomIn(card);
    }
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      if (card.classList.contains('is-active')) {
        resetZoom();
      } else {
        zoomToCard(card);
      }
    });
  });

  // Click fuera del mapa (sobre el fondo de la sección) = reset
  document.querySelector('.routeV2')?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.closest('.routeV2__card') || t.closest('.routeV2__map') || t.closest('.routeV2__option')) return;
    resetZoom();
  });

  // ===================== RUTAS MINI / COMPLETO =====================
  function setRoute(which: 'mini' | 'completo' | 'none') {
    // Si activamos una ruta y hay un zoom activo de card, lo reseteamos antes
    if (which !== 'none') {
      const anyActive = cards.some(c => c.classList.contains('is-active'));
      if (anyActive) resetZoom();
    }
    if (routeMini) routeMini.classList.toggle('is-drawn', which === 'mini');
    if (routeCompleto) routeCompleto.classList.toggle('is-drawn', which === 'completo');
    optMini?.classList.toggle('is-selected', which === 'mini');
    optCompleto?.classList.toggle('is-selected', which === 'completo');
    optMini?.setAttribute('aria-pressed', which === 'mini' ? 'true' : 'false');
    optCompleto?.setAttribute('aria-pressed', which === 'completo' ? 'true' : 'false');
  }

  optMini?.addEventListener('click', () => {
    if (optMini.classList.contains('is-selected')) setRoute('none');
    else setRoute('mini');
  });
  optCompleto?.addEventListener('click', () => {
    if (optCompleto.classList.contains('is-selected')) setRoute('none');
    else setRoute('completo');
  });

  // ===================== CHIRINGUITOS =====================
  const chiriBtn = document.getElementById('routeV2-chiri-btn');
  const chiriPanel = document.getElementById('routeV2-chiri-panel');
  const chiriClose = document.getElementById('routeV2-chiri-close');
  const mapEl = document.getElementById('routeV2-map');

  function toggleChiri(force?: boolean) {
    if (!mapEl || !chiriPanel || !chiriBtn) return;
    const shouldOpen = force === undefined ? !mapEl.classList.contains('is-chiri-active') : force;
    mapEl.classList.toggle('is-chiri-active', shouldOpen);
    chiriPanel.setAttribute('aria-hidden', shouldOpen ? 'false' : 'true');
    chiriBtn.setAttribute('aria-pressed', shouldOpen ? 'true' : 'false');
    chiriBtn.classList.toggle('is-active', shouldOpen);
    // Si abrimos chiringuitos, reseteamos zoom, rutas y tooltip para no saturar
    if (shouldOpen) {
      resetZoom();
      setRoute('none');
      hidePinnedTip();
    }
  }

  chiriBtn?.addEventListener('click', () => toggleChiri());
  chiriClose?.addEventListener('click', () => toggleChiri(false));
  };

  // Defer doble: idle callback + intersection observer.
  // Lighthouse mide TBT durante los primeros segundos · no queremos que el
  // setup del mapa (218 líneas de listeners) ejecute en esa ventana.
  // Solo arrancamos cuando (a) el navegador está idle DESPUÉS de LCP, o
  // (b) el usuario ha hecho scroll cerca del mapa. Lo que ocurra antes.
  const lazyInit = () => {
    let started = false;
    const start = () => { if (!started) { started = true; init(); } };

    if (_mapRoot && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) { io.disconnect(); start(); }
      }, { rootMargin: '100px 0px' });
      io.observe(_mapRoot);
    }

    // Fallback: arranca cuando el navegador esté idle (después de LCP/FCP).
    // timeout 3000ms garantiza arranque aunque el usuario no scrollee.
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 3000 });
    } else {
      setTimeout(start, 1500);
    }
  };

  if (_mapRoot) lazyInit();
</script>

<style>
  .routeV2 { padding-block: var(--section-padding-lg); background: var(--color-bg-base); }
  .routeV2__header { max-width: 820px; margin-bottom: var(--s-10); }
  .routeV2__eyebrow { display: inline-block; color: var(--color-primary); margin-bottom: var(--s-5); }
  .routeV2__title {
    font-family: var(--font-display); font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    font-weight: var(--fw-black); line-height: 0.95; letter-spacing: var(--ls-tightest);
    text-transform: uppercase; color: var(--color-text-primary); margin: 0 0 var(--s-5);
  }
  .routeV2__title .serif-italic { color: var(--color-primary); font-weight: var(--fw-regular); text-transform: none; letter-spacing: -0.01em; }
  .routeV2__lead { color: var(--color-text-secondary); margin: 0; max-width: 60ch; }

  .routeV2__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    margin-bottom: var(--s-10);
  }

  @media (min-width: 960px) {
    .routeV2__layout { grid-template-columns: 2fr 1fr; gap: var(--s-8); }
  }

  /* Map wrapper */
  .routeV2__map {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-3xl);
    padding: clamp(1rem, 2vw, 1.5rem);
    position: relative;
    overflow: hidden;
  }

  .routeV2__svg {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-2xl);
    transform-origin: 50% 50%;
    transform: scale(1);
    transition: transform 500ms cubic-bezier(0.34, 1.2, 0.64, 1),
                transform-origin 0ms;
    will-change: transform;
  }

  /* ========== RUTAS SOBREIMPUESTAS (Mini / Completo) ========== */
  .routeV2__route {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    opacity: 0;
    pointer-events: none;
    transition: stroke-dashoffset 1.4s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 280ms ease-out;
  }

  .routeV2__route.is-drawn {
    opacity: 1;
  }

  /* Mini: solo se dibuja hasta ~48% (Toraño aprox.) */
  .routeV2__route--mini.is-drawn {
    stroke-dasharray: 48 52;
    stroke-dashoffset: 0;
  }

  /* Completo: dibuja el 100% */
  .routeV2__route--completo.is-drawn {
    stroke-dashoffset: 0;
  }

  /* ========== OPTIONS SELECCIONADAS ========== */
  .routeV2__option {
    width: 100%;
    text-align: left;
    cursor: pointer;
    font: inherit;
  }
  .routeV2__option.is-selected {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(233, 133, 111, 0.2), var(--shadow-md);
    background: var(--color-bg-warm);
  }
  .routeV2__option--mini.is-selected {
    border-color: var(--color-sage);
    box-shadow: 0 0 0 3px rgba(61, 79, 58, 0.18), var(--shadow-md);
  }

  /* Tooltip compacto */
  .routeV2__tip {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translate(-50%, 0) scale(0.92);
    background: #1a1f2e;
    color: #fbf8f1;
    padding: 0.375rem 0.625rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 150ms var(--ease-out), transform 150ms var(--ease-out);
    box-shadow: 0 4px 14px rgba(26,31,46,0.25);
    white-space: nowrap;
    text-align: left;
