const t =
  lang === 'en' ? i18n.en :
  lang === 'fr' ? i18n.fr :
  lang === 'pt' ? i18n.pt :
  i18n.es;

const jsonLdGraph: any[] = [
  localBusinessSchema(baseUrl, lang),
  {
    '@type': 'BlogPosting',
    '@id': `${canonicalUrl}#article`,
    headline: post.h1,
    name: post.title,
    description: post.description,
    url: canonicalUrl,
    mainEntityOfPage: canonicalUrl,
    inLanguage:
      lang === 'en' ? 'en-GB' :
      lang === 'fr' ? 'fr-FR' :
      lang === 'pt' ? 'pt-PT' :
      'es-ES',
    image: {
      '@type': 'ImageObject',
      url: imageUrl,
      width: 1920,
      height: 1200,
    },
    author:    { '@id': `${baseUrl}/#business` },
    publisher: { '@id': `${baseUrl}/#business` },
    datePublished: post.datePublished,
    dateModified: post.dateModified,
    keywords: post.keyword,
    articleSection: post.category,
    /* Estimación wordCount basada en readingTime (220 palabras/min, promedio
     * lectura adulta en español/inglés). Señal de profundidad para search. */
    wordCount: post.readingTime * 220,
    /* SpeakableSpecification · Google y Bing usan esto para snippets de voz
     * (Google Assistant, Bing voice). Selecciona el lead + las respuestas FAQ. */
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.ed__lead', '.rrfI__a', '.edFAQ__answer'],
    },
    isPartOf: { '@id': `${baseUrl}${blogBasePath}/#blog` },
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t.breadcrumbHome, item:
          lang === 'en' ? `${baseUrl}/en/` :
          lang === 'fr' ? `${baseUrl}/fr/` :
          lang === 'pt' ? `${baseUrl}/pt/` :
          baseUrl },
      { '@type': 'ListItem', position: 2, name: t.breadcrumbBlog, item: `${baseUrl}${blogBasePath}/` },
      { '@type': 'ListItem', position: 3, name: post.h1,          item: canonicalUrl },
    ],
  },
];

if (faqs.length > 0) {
  jsonLdGraph.push({
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}#faq`,
    /* speakable también en FAQPage para que Google/Bing usen las respuestas
     * en resultados de búsqueda por voz */
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.rrfI__a', '.edFAQ__answer'],
    },
    inLanguage:
      lang === 'en' ? 'en-GB' :
      lang === 'fr' ? 'fr-FR' :
      lang === 'pt' ? 'pt-PT' :
      'es-ES',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.a.replace(/<[^>]+>/g, ''),
      },
    })),
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': jsonLdGraph,
};

// ============== TOC server-side (más fiable que JS · sin caché de navegador) ==
// Capturamos el HTML del slot, extraemos H2s con id y construimos el índice.
const slotHtml = await Astro.slots.render('default');

interface TocItem { id: string; title: string; subtitle: string; }
const tocItems: TocItem[] = [];
const h2Regex = /<h2\b[^>]*?\bid="([^"]+)"[^>]*>([\s\S]*?)<\/h2>/gi;
const stripTags = (s: string) => s.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
let m: RegExpExecArray | null;
while ((m = h2Regex.exec(slotHtml)) !== null) {
  const id = m[1];
  const inner = m[2];
  // Solo H2s con class post__h2 (los del cuerpo editorial · no FAQs ni CTAs)
  const fullMatch = m[0];
  if (!/class="[^"]*\bpost__h2\b/.test(fullMatch)) continue;
  const parts = inner.split(/<br\b[^>]*>/i);
  tocItems.push({
    id,
    title: stripTags(parts[0]),
    subtitle: parts.length > 1 ? stripTags(parts.slice(1).join(' ')) : '',
  });
}
---

<BaseLayout title={post.title} description={post.description} currentPath={currentPath} translationKey="blog" customAlternates={blogAlternates}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="article:published_time" content={post.datePublished} />
    <meta property="article:modified_time"  content={post.dateModified} />
    <meta property="article:author"         content={t.bylineTeam} />
    <meta property="article:section"        content={post.category} />
    <meta property="og:type"                content="article" />
    <meta property="og:title"               content={post.title} />
    <meta property="og:description"         content={post.description} />
    <meta property="og:image"               content={imageUrl} />
    <meta property="og:url"                 content={canonicalUrl} />
    <meta name="twitter:card"               content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- Reading progress bar (top of viewport) -->
  <div class="edProgress" aria-hidden="true">
    <span class="edProgress__fill" id="edProgressFill"></span>
  </div>

  <article class="ed" itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={post.h1} />
    <meta itemprop="datePublished" content={post.datePublished} />
    <meta itemprop="dateModified"  content={post.dateModified} />

    <!-- ============ 1 · HERO ============ -->
    <header class="edH">
      <div class="edH__inner">
        <nav class="edH__crumb" aria-label={t.breadcrumbAria}>
          <a href={
            lang === 'en' ? '/en/' :
            lang === 'fr' ? '/fr/' :
            lang === 'pt' ? '/pt/' :
            '/'
          }>{t.breadcrumbHome}</a>
          <span aria-hidden="true">·</span>
          <a href={t.articleHref}>{t.breadcrumbBlog}</a>
          <span aria-hidden="true">·</span>
          <span aria-current="page">{post.h1}</span>
        </nav>

        <span class="edH__cat">{post.category}</span>

        <h1 class="edH__title" itemprop="name">{post.h1}</h1>

        <p class="edH__lead">{post.excerpt}</p>

        <div class="edH__byline">
          <span class="edH__bylineLeft" itemprop="author" itemscope itemtype="https://schema.org/Organization">
            {t.bylinePrefix} <span class="edH__bylineName" itemprop="name">{t.bylineTeam}</span> · <span class="edH__bylineCity">{t.bylineCity}</span>
          </span>
          <span class="edH__bylineDot" aria-hidden="true">·</span>
          <time class="edH__bylineDate" datetime={post.datePublished} itemprop="datePublished">{formatDate(post.datePublished)}</time>
          <span class="edH__bylineDot" aria-hidden="true">·</span>
          <span class="edH__bylineRead">{post.readingTime} {t.readingTime}</span>
        </div>
      </div>
    </header>

    <!-- ============ 2 · COVER ============ -->
    <div class="edCover">
      <div class="edCover__inner">
        <figure class="edCover__figure" data-img-reveal>
          <Picture
            src={post.image}
            alt={post.imageAlt}
            sizes="(min-width: 1100px) 1080px, 92vw"
            aspectRatio="16 / 9"
            priority="high"
          />
        </figure>
      </div>
    </div>

    <!-- ============ 3 · LAYOUT 2 COLS (article + sidebar) ============ -->
    <div class="edLayout">
      <div class="edLayout__inner">

        <!-- ============ 3a · BODY (slot) ============ -->
        <div class="edBody" itemprop="articleBody">
          <Fragment set:html={slotHtml} />

          {faqs.length > 0 && (
            <section class="edFaq" aria-labelledby="ed-faq-title">
              <span class="edFaq__kicker">{t.faqKicker}</span>
              <h2 id="ed-faq-title" class="edFaq__h2">
                {t.faqTitleA} <span class="serif-italic">{t.faqTitleB}</span>
              </h2>
              <dl class="edFaq__list">
                {faqs.map(f => (
                  <div class="edFaq__item">
                    <dt class="edFaq__q">{f.q}</dt>
                    <dd class="edFaq__a" set:html={f.a} />
                  </div>
                ))}
              </dl>
            </section>
          )}

          <!-- Cluster links (en columna izquierda, sin doble fondo) -->
          <section class="edCluster" aria-labelledby="ed-cluster-title">
            <span class="edCluster__kicker">{t.clusterKicker}</span>
            <h2 id="ed-cluster-title" class="edCluster__h2">
              {t.clusterTitleA}<br/>
              <span class="serif-italic">{t.clusterTitleB}</span>
            </h2>
            <ul class="edCluster__list" role="list">
              {post.relatedPages.map(link => (
                <li>
                  <a href={link.href} class="edCluster__link">
                    <span>{link.label}</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <!-- Firma final del equipo -->
          <aside class="edSign" aria-label={t.signAside}>
            <div class="edSign__inner">
              <span class="edSign__line" aria-hidden="true"></span>
              <p class="edSign__text">
                {t.signA} <strong>{t.signB}</strong><br/>
                {t.signCity} · <time datetime={post.datePublished}>{formatDate(post.datePublished)}</time>
              </p>
            </div>
          </aside>
        </div>

        <!-- ============ 3b · SIDEBAR ============ -->
        <aside class="edSide" aria-label={t.articleSectionAria}>
          <div class="edSide__sticky">

            <!-- Autor card -->
            <section class="edSide__author" aria-labelledby="ed-author-title">
              <span class="edSide__authorMark" aria-hidden="true">A</span>
              <div class="edSide__authorBody">
                <span class="edSide__authorKicker">{t.authorKicker}</span>
                <h2 id="ed-author-title" class="edSide__authorName">
                  {t.authorTeamA}<br/>
                  <span class="serif-italic">{t.authorTeamB}</span>
                </h2>
                <p class="edSide__authorMeta">
                  {t.authorCity}<br/>
                  <time datetime={post.datePublished}>{formatDate(post.datePublished)}</time>
                </p>
              </div>
            </section>

            <!-- TOC (SSR · server-rendered desde los H2 del slot) -->
            {tocItems.length > 0 && (
              <nav class="edSide__toc" id="edToc" aria-label={t.tocAria}>
                <span class="edSide__tocKicker">{t.tocKicker}</span>
                <ol class="edSide__tocList" id="edTocList" role="list">
                  {tocItems.map(item => (
                    <li>
                      <a href={`#${item.id}`} data-toc-link={item.id}>
                        {item.subtitle ? (
                          <>
                            <span class="edSide__tocTitle">{item.title}</span>
                            <span class="edSide__tocSub">{item.subtitle}</span>
                          </>
                        ) : (
                          item.title
                        )}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )}

            <!-- CTA card -->
            <section class="edSide__cta" aria-labelledby="ed-cta-title">
              <span class="edSide__ctaKicker">{t.ctaKicker}</span>
              <h2 id="ed-cta-title" class="edSide__ctaTitle">
                {t.ctaTitleA}<br/>
                <span class="serif-italic">{t.ctaTitleB}</span>
              </h2>
              <ul class="edSide__ctaList" role="list">
                <li>{t.ctaItem1}</li>
                <li>{t.ctaItem2}</li>
                <li>{t.ctaItem3}</li>
              </ul>
