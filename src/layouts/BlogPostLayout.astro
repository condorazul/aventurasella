<script>
  // -------- TOC: solo interactividad (el HTML ya viene SSR) --------
  const tocList = document.getElementById('edTocList');
  const body = document.querySelector('.edBody');
  if (tocList && body) {
    const headings = body.querySelectorAll<HTMLElement>('h2.post__h2[id]');
    const links = tocList.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]');
    const linkMap = new Map<string, HTMLAnchorElement>();
    links.forEach(l => linkMap.set(l.dataset.tocLink || '', l));

    if (headings.length > 0 && links.length > 0) {
      // Active section tracking via IntersectionObserver
      let activeId: string | null = null;
      const setActive = (id: string | null) => {
        if (id === activeId) return;
        activeId = id;
        links.forEach(l => l.classList.remove('is-active'));
        if (id) {
          const a = linkMap.get(id);
          if (a) a.classList.add('is-active');
        }
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter(e => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length > 0) {
            setActive((visible[0].target as HTMLElement).id);
          }
        },
        { rootMargin: '-20% 0px -65% 0px', threshold: 0 }
      );
      headings.forEach(h => observer.observe(h));

      // smooth scroll
      links.forEach(l => {
        l.addEventListener('click', (e) => {
          const href = l.getAttribute('href');
          if (!href || !href.startsWith('#')) return;
          const target = document.getElementById(href.slice(1));
          if (!target) return;
          e.preventDefault();
          window.scrollTo({
            top: target.getBoundingClientRect().top + window.scrollY - 96,
            behavior: 'smooth'
          });
          history.replaceState(null, '', href);
        });
      });
    }
  }

  // -------- Reading progress bar --------
  const progressFill = document.getElementById('edProgressFill');
  const article = document.querySelector('.edBody');
  if (progressFill && article) {
    let ticking = false;
    const update = () => {
      const rect = (article as HTMLElement).getBoundingClientRect();
      const articleTop = rect.top + window.scrollY;
      const articleHeight = rect.height;
      const scrolled = window.scrollY - articleTop + window.innerHeight * 0.5;
      const ratio = Math.max(0, Math.min(1, scrolled / articleHeight));
      (progressFill as HTMLElement).style.transform = `scaleX(${ratio})`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    update();
  }

  // -------- Share buttons (copy link) --------
  const copyBtn = document.querySelector<HTMLButtonElement>('[data-share="copy"]');
  const toast = document.getElementById('edShareToast');
  if (copyBtn && toast) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        toast.classList.add('is-visible');
        setTimeout(() => toast.classList.remove('is-visible'), 1600);
      } catch (e) {
        // Fallback silencioso
      }
    });
  }

  // -------- Slide LTR para imágenes y figuras --------
  const targets = document.querySelectorAll<HTMLElement>('[data-img-reveal], .post__figure');
  if (targets.length > 0 && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });
    targets.forEach(t => io.observe(t));
  }

  // -------- Reveal slide-up + fade para pull quotes --------
  const pulls = document.querySelectorAll<HTMLElement>('.post__pull');
  if (pulls.length > 0 && 'IntersectionObserver' in window) {
    const ioPull = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-revealed');
          ioPull.unobserve(e.target);
        }
      });
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    pulls.forEach(p => ioPull.observe(p));
  }

  // -------- Reveal slide-up + fade para tablas editoriales --------
  const tables = document.querySelectorAll<HTMLElement>('.post__table');
  if (tables.length > 0 && 'IntersectionObserver' in window) {
    const ioTable = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-revealed');
          ioTable.unobserve(e.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
    tables.forEach(t => ioTable.observe(t));
  }
</script>

