---
/**
 * BlogPostLayout · template editorial canónico del blog (validado 2026-04-30).
 *
 * Diseño de blog oficial de aventuraenelsella.es. Aplicar a TODA entrada nueva
 * sin variar el template. Variaciones permitidas solo a nivel contenido (foto cover,
 * foto inline, FAQs, longitud). Ver memoria `feedback_blog_design_system.md`.
 *
 * Anatomía:
 *   - Reading progress bar fixed top (coral gradient)
 *   - Hero: breadcrumb · category eyebrow · H1 + serif italic accent · lead Fraunces · byline
 *   - Cover full-width · slide LTR semi-lento al revelar
 *   - Layout 2 cols (≥1024px): article 1fr + sidebar 320px sticky
 *   - Body: dropcap coral en 1er p · counters automáticos "— 01" en H2s · pull quote sin caja
 *   - FAQ y cluster sin cards · solo hairlines (sin doble fondo)
 *   - Firma editorial centrada del equipo · desde Arriondas
 *   - Sidebar sage subtle: autor + TOC autogenerado + CTA + share (WhatsApp/X/copy)
 *   - Related posts cards limpias · ReservaCTA cierre
 *
 * Mantiene todas las clases `.post__*` heredadas (intro, h2, h3, pull, callout, table, figure).
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import ReservaCTA from '@components/sections/ReservaCTA.astro';
import { BLOG_POSTS, getPostBySlug, getRelatedPosts, formatDateES } from '@data/blog-posts';
import { BLOG_POSTS_EN, getPostBySlugEn, getRelatedPostsEn, formatDateEn } from '@data/blog-posts-en';
import { BLOG_POSTS_FR, getPostBySlugFr, getRelatedPostsFr, formatDateFr } from '@data/blog-posts-fr';
import { BLOG_POSTS_PT, getPostBySlugPt, getRelatedPostsPt, formatDatePt } from '@data/blog-posts-pt';
import { localBusinessSchema } from '@data/business-schema';
import { DEFAULT_LOCALE, type Locale } from '@i18n/ui';
import { getLocaleFromPath } from '@utils/i18n';

interface FAQ { q: string; a: string; }

interface Props {
  slug: string;
  faqs?: FAQ[];
}

const { slug, faqs = [] } = Astro.props;

// Locale detection · same approach as BaseLayout
const lang: Locale = (((Astro as any).currentLocale as Locale) ?? getLocaleFromPath(Astro.url.pathname)) || DEFAULT_LOCALE;

// Load metadata + helpers from the right data file
const post =
  lang === 'en' ? getPostBySlugEn(slug) :
  lang === 'fr' ? getPostBySlugFr(slug) :
  lang === 'pt' ? getPostBySlugPt(slug) :
  getPostBySlug(slug);

if (!post) {
  throw new Error(`BlogPostLayout: no post found for slug "${slug}" (lang="${lang}").`);
}

const related =
  lang === 'en' ? getRelatedPostsEn(slug, 2) :
  lang === 'fr' ? getRelatedPostsFr(slug, 2) :
  lang === 'pt' ? getRelatedPostsPt(slug, 2) :
  getRelatedPosts(slug, 2);
const formatDate =
  lang === 'en' ? formatDateEn :
  lang === 'fr' ? formatDateFr :
  lang === 'pt' ? formatDatePt :
  formatDateES;
const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const blogBasePath =
  lang === 'en' ? '/en/blog' :
  lang === 'fr' ? '/fr/blog' :
  lang === 'pt' ? '/pt/blog' :
  '/blog';
const canonicalUrl = `${baseUrl}${blogBasePath}/${post.slug}/`;
const currentPath = `${blogBasePath}/${post.slug}/`;
const imageUrl = `${baseUrl}/images/optimized/${post.image}-lg.jpg`;

// ============== hreflang específico por post ==============
// Los 4 arrays de blog-posts-{lang}.ts siguen el mismo orden, así que el
// índice del post en su array nos da el equivalente en otros idiomas.
const allLangData: Record<Locale, readonly { slug: string }[]> = {
  es: BLOG_POSTS,
  en: BLOG_POSTS_EN,
  fr: BLOG_POSTS_FR,
  pt: BLOG_POSTS_PT,
};
const currentLangData = allLangData[lang];
const postIdx = currentLangData.findIndex(p => p.slug === slug);

const blogAlternates: Record<Locale, string> = {
  es: '/blog/',
  en: '/en/blog/',
  fr: '/fr/blog/',
  pt: '/pt/blog/',
};
if (postIdx >= 0) {
  for (const l of ['es', 'en', 'fr', 'pt'] as const) {
    const equivalent = allLangData[l]?.[postIdx];
    if (equivalent) {
      const prefix = l === 'es' ? '' : `/${l}`;
      blogAlternates[l] = `${prefix}/blog/${equivalent.slug}/`;
    }
  }
}

