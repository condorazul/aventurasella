  }

  /* ---- Callout sage · simple, sin border-left grueso ---- */
  .edBody :global(.post__callout) {
    padding: clamp(1.25rem, 2.5vw, 1.75rem) clamp(1.5rem, 3vw, 2rem);
    margin-block: clamp(1.75rem, 3.5vw, 2.5rem);
    background: var(--color-sage-subtle, #e8ece6);
    border-radius: clamp(0.875rem, 1.75vw, 1.25rem);
    border-left: 0;
    max-width: 65ch;
  }
  /* Solo el <strong> directo (título) recibe estilo de kicker uppercase */
  .edBody :global(.post__callout > strong) {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-sage, #3d4f3a);
    margin-bottom: 0.5rem;
  }
  /* Los <strong> dentro de párrafos del callout son énfasis inline normales */
  .edBody :global(.post__callout p strong) {
    display: inline;
    font-family: inherit;
    font-size: inherit;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-text-primary);
    margin: 0;
  }
  .edBody :global(.post__callout p) {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    max-width: none;
  }
  .edBody :global(.post__callout p:last-child) {
    margin-bottom: 0;
  }
  /* Listas dentro del callout · estilo limpio, interpunct sage como bullet */
  .edBody :global(.post__callout ul.post__callout__items) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    max-width: none;
  }
  .edBody :global(.post__callout ul.post__callout__items li) {
    position: relative;
    padding-left: 1rem;
    margin: 0;
    font-size: 0.93rem;
    line-height: 1.65;
    color: var(--color-text-primary);
  }
  .edBody :global(.post__callout ul.post__callout__items li::before) {
    content: '·';
    position: absolute;
    left: 0;
    top: -0.05em;
    width: auto;
    height: auto;
    background: transparent;
    color: var(--color-sage, #3d4f3a);
    font-size: 1.4em;
    line-height: 1;
    font-weight: 700;
    border-radius: 0;
  }
  .edBody :global(.post__callout ul.post__callout__items li strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* =========================================================
     Tabla DELUXE editorial · primera col Fraunces italic coral,
     headers tracked, hover con accent vertical, reveal animado
     ========================================================= */
  .edBody :global(.post__table) {
    margin-block: clamp(2.75rem, 5vw, 4rem);
    overflow-x: auto;
    border-radius: 0;
    border: 0;
    background: transparent;
    /* Reveal · slide-up + fade al entrar viewport */
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 900ms var(--ease-out), transform 1100ms var(--ease-out);
    will-change: opacity, transform;
  }
  .edBody :global(.post__table.is-revealed) {
    opacity: 1;
    transform: translateY(0);
  }
  .edBody :global(.post__table table) {
    width: 100%;
    border-collapse: collapse;
    min-width: 480px;
    border-top: 1px solid rgba(26, 31, 46, 0.14);
    border-bottom: 1px solid rgba(26, 31, 46, 0.14);
  }
  /* Headers · microtipografía refinada · tracking amplio · em-dash editorial */
  .edBody :global(.post__table th) {
    padding: 1.6rem 1.4rem 1rem;
    text-align: left;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: transparent;
    border-bottom: 1px solid rgba(233, 133, 111, 0.45);
    vertical-align: bottom;
    white-space: nowrap;
  }
  /* Cells · más respiro vertical · línea de lectura confortable */
  .edBody :global(.post__table td) {
    padding: 1.5rem 1.4rem;
    text-align: left;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-primary);
    border-bottom: 1px solid rgba(26, 31, 46, 0.06);
    vertical-align: top;
    position: relative;
  }
  /* Primera columna · Fraunces italic display, peso ligero, coral */
  .edBody :global(.post__table td:first-child) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1.075rem;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    white-space: nowrap;
    padding-left: 1.6rem;
  }
  .edBody :global(.post__table td:first-child strong) {
    font-family: inherit;
    font-style: italic;
    font-weight: 500;
    color: var(--color-primary);
  }
  .edBody :global(.post__table tr:last-child td) { border-bottom: 0; }
  /* Hover · accent vertical coral 2px que se desliza en la izquierda */
  .edBody :global(.post__table tbody tr) {
    transition: background 280ms var(--ease-out);
  }
  .edBody :global(.post__table tbody tr:hover) {
    background: rgba(233, 133, 111, 0.045);
  }
  .edBody :global(.post__table tbody tr td:first-child::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 1.7rem;
    bottom: 1.7rem;
    width: 2px;
    background: var(--color-primary);
    opacity: 0;
    transform: scaleY(0.4);
    transform-origin: center;
    transition: opacity 280ms var(--ease-out), transform 320ms var(--ease-out);
    pointer-events: none;
    border-radius: 2px;
  }
  .edBody :global(.post__table tbody tr:hover td:first-child::before) {
    opacity: 1;
    transform: scaleY(1);
  }

  /* ---- Concerns list · preguntas-respuesta con numeral grande Fraunces italic ---- */
  .edBody :global(.post__concerns) {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-block: clamp(2rem, 4vw, 2.75rem);
    max-width: none;
    counter-reset: edConcernCount;
  }
  .edBody :global(.post__concern) {
    counter-increment: edConcernCount;
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: clamp(1rem, 2.2vw, 1.6rem);
    padding-block: clamp(1.5rem, 2.8vw, 2rem);
    border-bottom: 1px solid var(--color-border-subtle);
    align-items: start;
    position: relative;
  }
  .edBody :global(.post__concern:first-child) { padding-top: clamp(0.5rem, 1vw, 0.75rem); }
  .edBody :global(.post__concern:last-child) {
    border-bottom: 0;
    padding-bottom: clamp(0.5rem, 1vw, 0.75rem);
  }
  .edBody :global(.post__concern::before) {
    content: counter(edConcernCount, decimal-leading-zero);
    grid-column: 1;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.4rem, 2.4vw, 1.65rem);
    line-height: 1;
    color: var(--color-primary);
    padding-top: 0.15rem;
    letter-spacing: -0.01em;
    opacity: 0.95;
  }
  .edBody :global(.post__concern__body) {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .edBody :global(h3.post__concern__q) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 1.95vw, 1.4rem);
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }
  .edBody :global(.post__concern__body p) {
    font-size: 0.97rem;
    line-height: 1.78;
    color: var(--color-text-primary);
    margin: 0;
    max-width: 60ch;
  }
  .edBody :global(.post__concern__body p strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .edBody :global(.post__concern__body p + p) {
    margin-top: 0.5rem;
  }

  /* ---- Checklist · listas de items con icono circular sage + label + desc ----
     Para guías tipo "qué llevar / qué hace falta / detalles a no olvidar".               */
  .edBody :global(.post__checklist) {
    display: flex;
    flex-direction: column;
    margin-block: clamp(2rem, 4vw, 2.75rem);
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    max-width: none;
  }
  .edBody :global(.post__checklist__item) {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: clamp(0.85rem, 1.75vw, 1.15rem);
    padding-block: clamp(1.1rem, 2vw, 1.4rem);
    border-bottom: 1px solid var(--color-border-subtle);
    align-items: start;
    transition: padding-left 320ms var(--ease-out), background 320ms var(--ease-out);
  }
  .edBody :global(.post__checklist__item:last-child) {
    border-bottom: 0;
  }
  .edBody :global(.post__checklist__item:hover) {
    padding-left: 0.4rem;
    background: rgba(233, 133, 111, 0.035);
  }
  .edBody :global(.post__checklist__icon) {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-sage-subtle, #e8ece6);
    color: var(--color-sage, #3d4f3a);
    border-radius: 50%;
    flex-shrink: 0;
    transition: background 280ms var(--ease-out), color 280ms var(--ease-out), transform 280ms var(--ease-out);
  }
  .edBody :global(.post__checklist__item:hover .post__checklist__icon) {
    background: var(--color-primary);
    color: #fff;
    transform: scale(1.08);
  }
  .edBody :global(.post__checklist__body) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    padding-top: 0.3rem;
    max-width: 60ch;
  }
  .edBody :global(.post__checklist__label) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    color: var(--color-text-primary);
    letter-spacing: -0.005em;
  }
  .edBody :global(.post__checklist__desc) {
    font-size: 0.93rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    display: block;
  }

  /* ---- Zones · stack tipográfico para listas tipo "anillos / niveles / zonas" ----
     Cada item tiene: distancia/label grande Fraunces italic + nombre + descripción.
     Sin cards · solo hairlines · pura tipografía editorial.                            */
  .edBody :global(.post__zones) {
    display: flex;
    flex-direction: column;
    margin-block: clamp(2rem, 4vw, 2.75rem);
    padding-block: 0;
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    max-width: none;
  }
  .edBody :global(.post__zone) {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    padding-block: clamp(1.5rem, 2.8vw, 2rem);
    border-bottom: 1px solid var(--color-border-subtle);
    align-items: baseline;
    transition: padding-left 320ms var(--ease-out), background 320ms var(--ease-out);
  }
  .edBody :global(.post__zone:last-child) {
    border-bottom: 0;
  }
  .edBody :global(.post__zone:hover) {
    padding-left: 0.4rem;
    background: rgba(233, 133, 111, 0.03);
  }
  .edBody :global(.post__zone__distance) {
    grid-column: 1;
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin: 0;
  }
  .edBody :global(.post__zone__num) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.6vw, 1.95rem);
    line-height: 1;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }
  .edBody :global(.post__zone__unit) {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.75;
  }
  .edBody :global(.post__zone__body) {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
  }
  .edBody :global(h3.post__zone__name) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.05rem, 1.7vw, 1.2rem);
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }
  .edBody :global(h3.post__zone__name .serif-italic) {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .edBody :global(p.post__zone__desc) {
    font-size: 0.94rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 52ch;
  }
  .edBody :global(p.post__zone__desc strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }
  /* Modifier --wide · primera col más ancha y num más pequeño (para meses, etiquetas largas) */
  .edBody :global(.post__zones--wide .post__zone) {
    grid-template-columns: 8.5rem 1fr;
  }
  .edBody :global(.post__zones--wide .post__zone__num) {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
  }

  /* Mobile · distancia arriba, body abajo */
  @media (max-width: 600px) {
    .edBody :global(.post__zone),
    .edBody :global(.post__zones--wide .post__zone) {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .edBody :global(.post__zone__distance) {
      gap: 0.4rem;
    }
  }

  /* ---- Timeline · "X hora por hora" con time prefix Fraunces italic ---- */
  .edBody :global(ol.post__timeline) {
    list-style: none;
    margin: clamp(2rem, 4vw, 2.75rem) 0;
    padding: 0;
    max-width: none;
    counter-reset: none;
  }
  .edBody :global(ol.post__timeline li) {
    display: grid;
    grid-template-columns: 5.25rem 1fr;
    gap: clamp(0.85rem, 1.5vw, 1.25rem);
    padding: clamp(1.1rem, 2vw, 1.4rem) 0;
    margin: 0;
    border-bottom: 1px solid var(--color-border-subtle);
    align-items: baseline;
    counter-increment: none;
  }
  .edBody :global(ol.post__timeline li:first-child) {
    padding-top: clamp(0.5rem, 1vw, 0.75rem);
  }
  .edBody :global(ol.post__timeline li:last-child) {
    border-bottom: 0;
    padding-bottom: clamp(0.5rem, 1vw, 0.75rem);
  }
  .edBody :global(ol.post__timeline li::before) {
    content: none !important;
  }
  .edBody :global(ol.post__timeline li time) {
    grid-column: 1;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-primary);
    letter-spacing: -0.005em;
    text-align: right;
    white-space: nowrap;
  }
  .edBody :global(ol.post__timeline li .post__timeline__body) {
    grid-column: 2;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--color-text-primary);
  }
  .edBody :global(ol.post__timeline li .post__timeline__body strong) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.005em;
    margin-right: 0.15rem;
  }
  /* Mobile · time arriba, body abajo */
  @media (max-width: 600px) {
    .edBody :global(ol.post__timeline li) {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .edBody :global(ol.post__timeline li time) {
      text-align: left;
      font-size: 0.95rem;
    }
  }

  /* ---- Essentials grid · 4 cards visuales para listas tipo "lo esencial" ---- */
  .edBody :global(.post__essentials) {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.25rem);
    margin-block: clamp(2rem, 4vw, 2.75rem);
    max-width: none;
  }
  @media (min-width: 720px) {
    .edBody :global(.post__essentials) {
      grid-template-columns: repeat(2, 1fr);
    }
    .edBody :global(.post__essentials--three) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .edBody :global(.post__essential) {
    padding: clamp(1.4rem, 2.5vw, 1.75rem);
    background: transparent;
    border: 1px solid rgba(61, 79, 58, 0.14);
    border-radius: clamp(1rem, 2vw, 1.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 280ms var(--ease-out), transform 280ms var(--ease-out), box-shadow 280ms var(--ease-out);
  }
  .edBody :global(.post__essential:hover) {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 14px 32px -22px rgba(26, 31, 46, 0.18);
  }
  .edBody :global(.post__essential__icon) {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-sage-subtle, #e8ece6);
    color: var(--color-sage, #3d4f3a);
    border-radius: 50%;
    margin-bottom: 0.4rem;
    transition: background 280ms var(--ease-out), color 280ms var(--ease-out);
  }
  .edBody :global(.post__essential:hover .post__essential__icon) {
    background: var(--color-primary);
    color: #fff;
  }
  .edBody :global(h3.post__essential__label) {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .edBody :global(p.post__essential__desc) {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: none;
  }
  .edBody :global(p.post__essential__desc strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .edBody :global(ol.post__essential__options) {
    list-style: none;
    margin: 0.4rem 0 0;
    padding: 0;
    max-width: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    counter-reset: optsCount;
  }
  .edBody :global(ol.post__essential__options li) {
    counter-increment: optsCount;
    position: relative;
    padding-left: 1.75rem;
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--color-text-primary);
    margin: 0;
  }
  .edBody :global(ol.post__essential__options li::before) {
    content: counter(optsCount);
    position: absolute;
    left: 0;
    top: 0.05em;
    width: 19px;
    height: 19px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.65rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
  }
  .edBody :global(ol.post__essential__options li strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* ---- Figuras inline · slide LTR + rounded ---- */
  .edBody :global(.post__figure) {
    margin-block: clamp(2.25rem, 4.5vw, 3.25rem);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    overflow: hidden;
    /* slide LTR initial state */
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 900ms var(--ease-out), transform 1100ms var(--ease-out);
    will-change: opacity, transform;
  }
  .edBody :global(.post__figure.is-revealed) {
    opacity: 1;
    transform: translateX(0);
  }
  .edBody :global(.post__figure .picture) {
    border-radius: clamp(1rem, 2vw, 1.5rem);
  }
  .edBody :global(.post__figure figcaption) {
    margin-top: 0.85rem;
    padding-inline: 0.5rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.5;
  }

  /* =========================================================
     FAQ DELUXE · counters Fraunces italic, Q editorial, A respira
     ========================================================= */
  .edFaq {
    margin-top: clamp(3.5rem, 6vw, 5rem);
    padding-top: clamp(2.25rem, 4.5vw, 3.25rem);
    border-top: 1px solid var(--color-border-subtle);
  }
  .edFaq__kicker {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  .edFaq__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin-bottom: clamp(1.75rem, 3.5vw, 2.5rem);
    text-wrap: balance;
  }
  .edFaq__h2 .serif-italic {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
  }
  .edFaq__list {
    margin: 0;
    display: flex;
    flex-direction: column;
    counter-reset: edFaqCount;
  }
  .edFaq__item {
    counter-increment: edFaqCount;
    padding-block: clamp(1.5rem, 2.8vw, 2.1rem);
    border-bottom: 1px solid var(--color-border-subtle);
    transition: padding-left 320ms var(--ease-out);
  }
  .edFaq__item:first-child { padding-top: clamp(0.5rem, 1vw, 0.75rem); }
  .edFaq__item:last-child { border-bottom: 0; }
  .edFaq__item:hover {
    padding-left: 0.4rem;
  }
  /* Pregunta · counter Fraunces italic coral + texto display ampliado */
  .edFaq__q {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin-bottom: 0.95rem;
    letter-spacing: -0.008em;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.95rem;
    text-wrap: balance;
  }
  .edFaq__q::before {
    content: counter(edFaqCount, decimal-leading-zero);
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-primary);
    letter-spacing: 0.04em;
    opacity: 0.95;
    transition: color 280ms var(--ease-out);
  }
  .edFaq__item:hover .edFaq__q::before {
    color: var(--color-primary-active, #c85c44);
  }
  /* Respuesta · respira más, indentada para alinear con la pregunta */
  .edFaq__a {
    font-size: 0.98rem;
    line-height: 1.85;
    color: var(--color-text-primary);
    max-width: 65ch;
    padding-left: calc(0.85rem + 1.6em);
  }
  .edFaq__a :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(233, 133, 111, 0.45);
    transition: text-decoration-color 240ms var(--ease-out);
  }
  .edFaq__a :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }
  .edFaq__a :global(strong) { font-weight: 600; }
  .edFaq__a :global(p) { margin-bottom: 0.6rem; }
  .edFaq__a :global(p:last-child) { margin-bottom: 0; }
  /* En mobile · indentación más conservadora para no perder ancho de lectura */
  @media (max-width: 600px) {
    .edFaq__a { padding-left: 1.6rem; }
  }

  /* =========================================================
     Cluster links DELUXE · counter Fraunces italic, label ampliado,
     hover con coral wash sutil + arrow translate
     ========================================================= */
  .edCluster {
    margin-top: clamp(3.5rem, 6vw, 5rem);
    padding-top: clamp(2.25rem, 4.5vw, 3.25rem);
    border-top: 1px solid var(--color-border-subtle);
  }
  .edCluster__kicker {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  .edCluster__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin-bottom: clamp(1.75rem, 3.5vw, 2.25rem);
    text-wrap: balance;
  }
  .edCluster__h2 .serif-italic {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
  }
  .edCluster__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    counter-reset: edClusterCount;
  }
  .edCluster__list li {
    counter-increment: edClusterCount;
    padding: 0;
    margin: 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .edCluster__list li:last-child { border-bottom: 0; }
  /* Cluster ya tiene counter "01 —" como marca · ocultar el bullet global ul */
  .edCluster__list li::before {
    content: none;
    background: transparent;
    box-shadow: none;
  }
  .edCluster__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.3rem 0.5rem 1.3rem 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.5vw, 1.175rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 280ms var(--ease-out);
    position: relative;
  }
  /* Counter Fraunces italic coral antes del label */
  .edCluster__link::before {
    content: counter(edClusterCount, decimal-leading-zero) '  —';
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-primary);
    opacity: 0.95;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: color 280ms var(--ease-out), transform 280ms var(--ease-out);
  }
  .edCluster__link span {
    flex: 1;
    min-width: 0;
  }
  .edCluster__link svg {
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform 320ms var(--ease-out), opacity 280ms var(--ease-out);
    opacity: 0.6;
  }
  .edCluster__link:hover {
    color: var(--color-primary);
  }
  .edCluster__link:hover::before {
    color: var(--color-primary-active, #c85c44);
    transform: translateX(2px);
  }
  .edCluster__link:hover svg {
    transform: translateX(8px);
    opacity: 1;
  }

  /* =========================================================
     Firma final del equipo · cierre editorial
     ========================================================= */
  .edSign {
    margin-top: clamp(3rem, 5vw, 4rem);
  }
  .edSign__inner {
    text-align: center;
    max-width: 520px;
    margin-inline: auto;
  }
  .edSign__line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--color-primary);
    margin: 0 auto 1.25rem;
    opacity: 0.7;
  }
  .edSign__text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: none;
  }
  .edSign__text strong {
    font-style: normal;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.005em;
  }
  .edSign__text time {
    color: var(--color-primary);
  }

  /* =========================================================
     3b · SIDEBAR (sticky)
     ========================================================= */
  .edSide {
    /* en mobile aparece debajo del body por orden DOM */
  }
  .edSide__sticky {
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 3vw, 2.5rem);
  }
  @media (min-width: 1024px) {
    .edSide__sticky {
      position: sticky;
      top: 96px;
      max-height: calc(100vh - 120px);
      overflow-y: auto;
      padding-right: 0.5rem;
      /* sutil scrollbar custom */
      scrollbar-width: thin;
      scrollbar-color: var(--color-border-subtle) transparent;
    }
    .edSide__sticky::-webkit-scrollbar { width: 4px; }
    .edSide__sticky::-webkit-scrollbar-thumb {
      background: var(--color-border-subtle);
      border-radius: 4px;
    }
  }

  /* ---- Autor card · sin caja, microtipografía ---- */
  .edSide__author {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding-bottom: clamp(1.5rem, 2.8vw, 2rem);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .edSide__authorMark {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: -0.02em;
  }
  .edSide__authorBody {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .edSide__authorKicker {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .edSide__authorName {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .edSide__authorName .serif-italic {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .edSide__authorMeta {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---- TOC ---- */
  .edSide__toc {
    padding-bottom: clamp(1.5rem, 2.8vw, 2rem);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .edSide__tocKicker {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .edSide__tocList {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: edTocCount;
  }
  .edSide__tocList li {
    counter-increment: edTocCount;
    margin-bottom: 0.85rem;
    padding-left: 2rem;
    position: relative;
  }
  .edSide__tocList li::before {
    content: counter(edTocCount, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.1em;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-text-muted);
    transition: color 240ms var(--ease-out);
  }
  .edSide__tocList a {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.45;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    text-underline-offset: 3px;
    transition: color 240ms var(--ease-out);
  }
  .edSide__tocList a:hover {
    color: var(--color-primary);
  }
  .edSide__tocList a.is-active {
    color: var(--color-primary);
    font-weight: 600;
  }
  .edSide__tocList li:has(a.is-active)::before {
    color: var(--color-primary);
  }
  /* Cuando un H2 tiene <br/>, el TOC parte el item en título + subtítulo */
  .edSide__tocTitle {
    display: block;
  }
  .edSide__tocSub {
    display: block;
    margin-top: 2px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0;
  }

  /* ---- CTA card · sin caja, hairlines arriba/abajo ---- */
  .edSide__cta {
    padding-block: clamp(1.5rem, 2.8vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .edSide__ctaKicker {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .edSide__ctaTitle {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    font-weight: 900;
    line-height: 1.18;
    letter-spacing: -0.012em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .edSide__ctaTitle .serif-italic {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .edSide__ctaList {
    list-style: none;
    margin: 0.25rem 0 0.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .edSide__ctaList li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
  }
  .edSide__ctaList li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 7px;
    height: 1px;
    background: var(--color-primary);
  }
  .edSide__ctaBtn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1.1rem 0.85rem 1.25rem;
    background: var(--color-text-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 999px;
    margin-top: 0.5rem;
    transition: background 240ms var(--ease-out), transform 240ms var(--ease-out);
  }
  .edSide__ctaBtn:hover {
    background: var(--color-primary);
    transform: translateY(-1px);
  }
  .edSide__ctaIcon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    transition: transform 240ms var(--ease-out);
  }
  .edSide__ctaBtn:hover .edSide__ctaIcon {
    transform: translateX(2px);
  }
  .edSide__ctaLink {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    align-self: flex-start;
    transition: border-color 240ms var(--ease-out);
  }
  .edSide__ctaLink:hover {
    border-bottom-color: var(--color-primary);
  }

  /* =========================================================
     4 · RELATED POSTS · cards limpias sin doble fondo
     ========================================================= */
  .edRelated {
    padding-block: clamp(3.5rem, 6vw, 5.5rem);
    border-top: 1px solid var(--color-border-subtle);
  }
  .edRelated__inner {
    max-width: 1180px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }
  .edRelated__kicker {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  .edRelated__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    text-wrap: balance;
  }
  .edRelated__h2 .serif-italic {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
  }
  .edRelated__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* Related cards no necesitan bullet · son cards visuales */
  .edRelated__grid li {
    padding-left: 0;
  }
  .edRelated__grid li::before {
    content: none;
    background: transparent;
    box-shadow: none;
  }
  @media (min-width: 720px) {
    .edRelated__grid { grid-template-columns: repeat(2, 1fr); }
  }
  .edRelated__card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    transition: transform 360ms var(--ease-out), filter 360ms var(--ease-out);
  }
  .edRelated__card:hover {
    transform: translateY(-3px);
  }
  .edRelated__media {
    position: relative;
    overflow: hidden;
    border-radius: clamp(1rem, 2vw, 1.5rem);
    box-shadow: 0 12px 28px -22px rgba(26, 31, 46, 0.14);
    transition: box-shadow 360ms var(--ease-out);
  }
  .edRelated__card:hover .edRelated__media {
    box-shadow: 0 24px 52px -28px rgba(26, 31, 46, 0.22);
  }
  .edRelated__media :global(.picture) {
    border-radius: clamp(1rem, 2vw, 1.5rem);
  }
  .edRelated__media :global(img) {
    transition: transform 900ms var(--ease-out);
  }
  .edRelated__card:hover .edRelated__media :global(img) {
    transform: scale(1.05);
  }
  .edRelated__body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  /* Meta line · cat coral + interpunct · tiempo lectura */
  .edRelated__metaTop {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.1rem;
  }
  .edRelated__cat {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .edRelated__metaSep {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }
  .edRelated__time {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .edRelated__title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.4vw, 1.65rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
    transition: color 280ms var(--ease-out);
  }
  .edRelated__card:hover .edRelated__title {
    color: var(--color-primary);
  }
  .edRelated__excerpt {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 52ch;
  }
  .edRelated__more {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--color-primary);
    margin-top: 0.4rem;
    transition: gap 320ms var(--ease-out);
  }
  .edRelated__more svg {
    flex-shrink: 0;
    transition: transform 320ms var(--ease-out);
  }
  .edRelated__card:hover .edRelated__more {
    gap: 0.65rem;
  }
  .edRelated__card:hover .edRelated__more svg {
    transform: translateX(4px);
  }

  /* =========================================================
     Reading progress bar (top fixed)
     ========================================================= */
  .edProgress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    z-index: 90;
    pointer-events: none;
  }
  .edProgress__fill {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-active, #c85c44) 100%);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 120ms linear;
    will-change: transform;
  }

  /* =========================================================
     Editorial dropcap · primer párrafo después del intro
     ========================================================= */
  .edBody :global(.post__intro + p)::first-letter {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3.75rem, 7vw, 5rem);
    line-height: 0.85;
    color: var(--color-primary);
    float: left;
    padding: 0.5rem 0.65rem 0 0;
    margin-bottom: -0.35rem;
  }

  /* =========================================================
     Section numbers · "— 01" antes de cada H2 (counter)
     ========================================================= */
  .edBody {
    counter-reset: edSection;
  }
  .edBody :global(.post__h2) {
    counter-increment: edSection;
  }
  .edBody :global(.post__h2)::before {
    content: '— ' counter(edSection, decimal-leading-zero);
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
    opacity: 0.95;
  }

  /* =========================================================
     SIDEBAR · sage subtle panel · denota separación
     ========================================================= */
  @media (min-width: 1024px) {
    .edSide__sticky {
      background: var(--color-sage-subtle, #e8ece6);
      padding: clamp(1.75rem, 2.4vw, 2.25rem) clamp(1.5rem, 2.2vw, 2rem);
      border-radius: clamp(1rem, 2vw, 1.5rem);
      gap: clamp(1.5rem, 2.5vw, 2rem);
      max-height: calc(100vh - 120px);
    }
  }

  /* En mobile · sigue sin bg para evitar caja flotante mid-page */
  @media (max-width: 1023px) {
    .edSide {
      background: var(--color-sage-subtle, #e8ece6);
      border-radius: clamp(1rem, 2vw, 1.5rem);
      padding: clamp(1.75rem, 4vw, 2.25rem);
    }
  }

  /* Refinar bordes interiores · ahora todo está dentro de un panel sage */
  .edSide__author,
  .edSide__toc,
  .edSide__cta {
    border-bottom-color: rgba(61, 79, 58, 0.15);
  }
  .edSide__author { padding-top: 0; }

  /* Ajustar colores en panel sage para mejor contraste */
  .edSide__authorKicker,
  .edSide__tocKicker {
    color: rgba(61, 79, 58, 0.7);
  }
  .edSide__tocList li::before {
    color: rgba(61, 79, 58, 0.65);
  }
  .edSide__tocList a {
    color: var(--color-text-primary);
    opacity: 0.8;
  }
  .edSide__tocList a:hover { opacity: 1; }
  .edSide__authorMeta {
    color: rgba(26, 31, 46, 0.6);
  }
  .edSide__ctaList li {
    color: var(--color-text-primary);
    opacity: 0.85;
  }

  /* Compartir · trío de iconos al final del sidebar */
  .edSide__share {
    padding-top: clamp(1.25rem, 2.4vw, 1.6rem);
    border-top: 1px solid rgba(61, 79, 58, 0.15);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .edSide__shareKicker {
    font-size: 0.65rem;
