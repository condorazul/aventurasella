---
/**
 * /reservar/ · Página oficial de reserva del descenso del Sella
 * -----------------------------------------------------------------
 * Cierre del embudo · CTA #1 desde toda la web. Diseño minimalista
 * Premium inspirado en bicisendadeloso.es/reservas/ — adaptado a
 * nuestros colores (cream/sage/coral/navy), tipografías (Fraunces +
 * Inter) y fotografía propia. Sección #booking-widget reservada
 * para el motor externo (sustituir el contenido del div cuando el
 * cliente entregue el código).
 *
 * SEO: meta optimizado · Schema.org completo · ranking #1
 * "reservar descenso del sella".
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const title = 'Reservar descenso del Sella · Cambio y cancelación flexible · Desde 30€';
const description = 'Reserva online tu descenso del Sella en canoa desde Arriondas. Sin pagar ahora, cambio o cancelación flexible antes del día, confirmación inmediata por WhatsApp y email. 4,5★ con 147 reseñas reales.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/reservar/`;

// Tarifas reales (canónicas) · 40€ adulto · 30€ niño · mascotas gratis
// El servicio "Reserva Premium" ya está incluido SIN COSTE EXTRA: mismo precio,
// con todo (taquillas, vestuarios, picnic asturiano, transfer, parking). Por eso
// NO existe una tarifa "Premium" superior · son los mismos 40/30 €.
const tarifas = [
  {
    img: 'reservar-tarifa-adultos',
    imgAlt: 'Grupo de adultos descendiendo el Sella en canoa desde Arriondas · tarifa adulto del descenso',
    badge: 'Más reservado',
    title: 'Adultos',
    age: 'Desde 13 años',
    price: '40',
    note: 'Canoa, pala, chaleco, picnic asturiano y transfer · todo incluido',
  },
  {
    img: 'precios-ninos',
    imgAlt: 'Niños remando en canoa por el Sella · tarifa infantil del descenso',
    badge: 'Niños',
    title: 'Niños',
    age: 'Hasta 12 años',
    price: '30',
    note: 'Edad mínima 5 años · 1,15 m de altura',
  },
  {
    img: 'con-perro-cta',
    imgAlt: 'Perro con chaleco salvavidas en canoa · descenso del Sella con mascotas gratis',
    badge: 'Mascotas · gratis',
    title: 'Con perro',
    age: 'Hasta 25 kg',
    price: '0',
    note: 'Chaleco canino incluido hasta agotar existencias',
  },
];

// Pasos del proceso (tipo "4 pasos" bicisenda)
const pasos = [
  {
    num: '01',
    title: 'Reserva tu día',
    text: 'Elige fecha, ruta y nº de personas en el calendario. <strong>No pagas nada ahora</strong>: bloqueamos tu plaza al instante.',
  },
  {
    num: '02',
    title: 'Llega a Arriondas',
    text: 'Te esperamos en C/ Juan Carlos I, 18. Parking privado vigilado, vestuarios, duchas calientes y taquillas con llave.',
  },
  {
    num: '03',
    title: 'Sales en canoa',
    text: 'Mini clase con monitor titulado, pala, chaleco, bidón estanco y picnic asturiano. Horario abierto Premium 10:30–12:30.',
  },
  {
    num: '04',
    title: 'Te recogemos al final',
    text: 'Transfer de regreso desde Toraño (ruta mini) o Fríes (ruta completa). Vuelta cómoda, sin coche extra, sin esperas.',
  },
];

// FAQ específicas del proceso de reserva
const faqs = [
  {
    q: '¿Tengo que pagar ahora para reservar?',
    a: 'No. Puedes <strong>reservar sin pagar nada</strong>. Bloqueamos tu plaza y eliges entre pagar online por adelantado (tarjeta o transferencia) o el día de la actividad al recoger la canoa (tarjeta, Bizum, efectivo o transferencia inmediata).',
  },
  {
    q: '¿Cuál es la política de cancelación?',
    a: 'Puedes <strong>cambiar o cancelar tu reserva en cualquier momento antes del día de la actividad</strong>, sin coste. Si pagaste con <strong>tarjeta por adelantado</strong>, para tramitar el reembolso necesitamos que nos avises con un mínimo de <strong>24 h de antelación</strong>. Avísanos por WhatsApp o email y te ayudamos a mover la fecha o devolverte el importe. Si reprogramamos nosotras por tiempo o condiciones del río, cambio sin coste o devolución íntegra.',
  },
  {
    q: '¿Cuándo recibo la confirmación?',
    a: 'En el momento, automáticamente por email. Te llega: fecha confirmada, ruta elegida, horario abierto Premium (llegada flexible 10:30–12:30), instrucciones de llegada y un WhatsApp directo por si surge algo.',
  },
  {
    q: '¿Con cuánta antelación debo reservar?',
    a: 'En temporada baja, el día anterior suele ser suficiente. En <strong>julio-agosto, fines de semana y festivos</strong> recomendamos 3-7 días de antelación. El calendario muestra en tiempo real qué días tienen plazas.',
  },
  {
    q: '¿Qué pasa si llueve el día de mi reserva?',
    a: 'En el Sella se reman muchos días con cielo cubierto sin problema · es parte del encanto verde de Asturias. Si hay <strong>aviso meteorológico o crecida del río</strong>, reprogramamos sin coste o devolvemos íntegro. Decidimos siempre del lado de la seguridad.',
  },
  {
    q: '¿Grupos y descuentos por volumen?',
    a: 'A partir de <strong>15 personas</strong> valoramos condiciones especiales (franja horaria dedicada, picnic asturiano, factura empresa). Escríbenos a <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a> con fecha, número de personas y edades · te pasamos presupuesto cerrado.',
  },
];

// Resources cards ("Mira antes de decidir")
const resources = [
  { img: 'reservar-resource-precios',   imgAlt: 'Canoa naranja preparada en la orilla del Sella · tarifas detalladas del descenso', title: 'Tarifas detalladas', text: 'Precios por edad, qué incluyen y comparativa por ruta.',         href: getLocalePath('precios', 'es'),        cta: 'Ver precios' },
  { img: 'reservar-resource-recorrido', imgAlt: 'Vista del río Sella en Asturias · recorrido y mapa del descenso',                  title: 'Recorrido y mapa',   text: 'Ruta mini (7 km · 2-3 h) o completa (14,5 km · 4-5 h).',           href: getLocalePath('recorrido_mapa', 'es'), cta: 'Ver recorrido' },
  { img: 'reservar-resource-premium',   imgAlt: 'Familias y adultos remando en el Sella · Reserva Premium todo incluido',           title: 'Reserva Premium',    text: 'Taquillas, picnic asturiano y horario abierto 10:30–12:30.',     href: getLocalePath('reserva_premium', 'es'), cta: 'Ver Premium' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, 'es'),
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'es-ES',
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#business` },
      mainEntityOfPage: canonicalUrl,
      datePublished: '2026-05-14',
      dateModified: '2026-05-14',
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Reserva del descenso del Sella en canoa',
      description: 'Servicio de reserva online del descenso turístico del Sella desde Arriondas (Asturias). Cambio o cancelación flexible antes del día (24 h si pagaste con tarjeta). Sin pagar ahora.',
      provider: { '@id': `${baseUrl}/#business` },
      serviceType: 'Canoe rental and guided river descent',
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturias, España' },
      offers: [
        { '@type': 'Offer', name: 'Niños hasta 12 años', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
        { '@type': 'Offer', name: 'Adultos',              price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',   item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Reservar', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/reservar/" translationKey="reservar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preload" as="image" href="/images/optimized/hero-canoa-lago-lg.avif" type="image/avif" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>

  <!-- ============== HERO COVER ============== -->
  <section class="rsvH" aria-labelledby="rsvH-title">
    <div class="rsvH__media" aria-hidden="true">
      <Picture src="hero-canoa-lago" alt="Canoa en el río Sella al atardecer · descenso del Sella desde Arriondas" priority="high" sizes="100vw" aspectRatio="16 / 10" />
      <div class="rsvH__overlay"></div>
    </div>

    <div class="rsvH__inner">
      <nav class="rsvH__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Reservar</span>
      </nav>

      <span class="rsvH__eyebrow">
        <span class="rsvH__eyebrow-dot" aria-hidden="true"></span>
        Reserva en 2 minutos · sin pagar ahora
      </span>

      <h1 id="rsvH-title" class="rsvH__title">
        Reserva tu<br/>
        <span class="serif-italic">descenso del Sella</span>
      </h1>

      <p class="rsvH__lead">
        Elige día, ruta y personas. La canoa, el equipo, el picnic, el transfer y todo lo demás · ya viene incluido. <strong>Sin pagar nada ahora</strong>: pagas online o el día que recojas la canoa en Arriondas.
      </p>

      <div class="rsvH__ctas">
        <a class="rsvH__cta rsvH__cta--primary" href="#booking-widget">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Ir al calendario</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="https://wa.me/34681093673?text=Hola%2C%20me%20gustar%C3%ADa%20reservar%20el%20descenso%20del%20Sella" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.87 11.87 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.56 4.18 1.62 6L0 24l6.18-1.6A11.9 11.9 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="tel:+34681093673" aria-label="Llamar al +34 681 09 36 73">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          <span>+34 681 09 36 73</span>
        </a>
      </div>

      <ul class="rsvH__trust" role="list">
        <li><span class="rsvH__trustNum">4,5★</span><span class="rsvH__trustLabel">147 reseñas reales</span></li>
        <li><span class="rsvH__trustNum">Flexible</span><span class="rsvH__trustLabel">cambio antes del día</span></li>
        <li><span class="rsvH__trustNum">25 años</span><span class="rsvH__trustLabel">en Arriondas</span></li>
        <li><span class="rsvH__trustNum">0 €</span><span class="rsvH__trustLabel">por reservar</span></li>
      </ul>
    </div>
  </section>

  <!-- ============== BOOKING WIDGET ============== -->
  <section class="rsvB" aria-labelledby="rsvB-title">
    <div class="rsvB__inner">
      <header class="rsvB__header">
        <span class="rsvB__eyebrow">— Calendario en vivo</span>
        <h2 id="rsvB-title" class="rsvB__title">
          Elige tu día<br/>
          <span class="serif-italic">en menos de 2 minutos</span>
        </h2>
        <p class="rsvB__lead">
          Disponibilidad en tiempo real · días con plazas en verde · sin sorpresas. <strong>Confirmación al instante por WhatsApp y email</strong> · rápido, fácil y sin formularios eternos.
        </p>
      </header>

      <!--
        ╔════════════════════════════════════════════════════════════════════════╗
        ║  ESPACIO RESERVADO PARA EL MOTOR DE RESERVAS                          ║
        ║                                                                        ║
        ║  Sustituir el siguiente bloque #booking-widget por el código (iframe, ║
        ║  script o embed) que entregue el proveedor del motor de reservas.     ║
        ║  El contenedor tiene altura mínima y borde elegante para que mientras ║
        ║  no haya código se vea profesional · cuando llegue el código,         ║
        ║  reemplazar el contenido interno del div manteniendo el contenedor.   ║
        ╚════════════════════════════════════════════════════════════════════════╝
      -->
      <div id="booking-widget" class="rsvB__slot" aria-live="polite">
        <div class="rsvB__placeholder">
          <span class="rsvB__placeholderIcon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <p class="rsvB__placeholderTitle">Calendario de reservas</p>
          <p class="rsvB__placeholderText">
            Estamos cargando el calendario en tiempo real. Si no aparece en unos segundos, escríbenos por <a href="https://wa.me/34681093673" target="_blank" rel="noopener noreferrer">WhatsApp</a> o al <a href="tel:+34681093673">+34 681 09 36 73</a> · te reservamos al momento.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 3 COL · TRUST (Pago · Cancelación · Confirmación) ============== -->
  <section class="rsvT" aria-labelledby="rsvT-title">
    <div class="rsvT__inner">
      <header class="rsvT__header">
        <span class="rsvT__eyebrow">— Reservar con tranquilidad</span>
        <h2 id="rsvT-title" class="rsvT__title">
          Sin pagar ahora,<br/>
          <span class="serif-italic">sin letra pequeña.</span>
        </h2>
      </header>

      <div class="rsvT__grid">
        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-pago" alt="Orilla del río Sella en Arriondas · pago flexible para reservar el descenso" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag">Pago flexible</span>
            <h3 class="rsvT__cardTitle">Pagas online o al llegar</h3>
            <ul class="rsvT__cardList">
              <li>Tarjeta online al reservar</li>
              <li>El día de la actividad: tarjeta, Bizum, efectivo o transferencia</li>
              <li>Sin fianza · sin extras escondidos</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-cambios" alt="Grupo de chicas remando juntas en el descenso del Sella · cambio o cancelación flexible" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--sage">Cambios y cancelaciones flexibles</span>
            <h3 class="rsvT__cardTitle">Cambia o cancela antes del día · sin coste</h3>
            <ul class="rsvT__cardList">
              <li>Cambia o cancela en cualquier momento antes del día de la actividad</li>
              <li>Si pagaste con tarjeta, el reembolso requiere 24 h de antelación</li>
              <li>Si llueve fuerte o sube el río, reprogramamos o devolvemos</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-equipo" alt="Equipo de Aventura en el Sella en Arriondas · personas reales que te atienden" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--coral">Confirmación humana</span>
            <h3 class="rsvT__cardTitle">Personas reales, no bots</h3>
            <ul class="rsvT__cardList">
              <li>Te confirmamos por email + WhatsApp</li>
              <li>Atendemos de 9:30 a 19:00 todos los días en temporada</li>
              <li>25 años recibiendo aventureros en Arriondas</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== TARIFAS · PRODUCT CARDS ============== -->
  <section class="rsvP" aria-labelledby="rsvP-title">
    <div class="rsvP__inner">
      <header class="rsvP__header">
        <span class="rsvP__eyebrow">— Tarifas habituales</span>
        <h2 id="rsvP-title" class="rsvP__title">
          Precio por persona y día,<br/>
          <span class="serif-italic">todo incluido.</span>
        </h2>
        <p class="rsvP__lead">
          Mismo precio para la ruta mini (7 km · 2-3 h) y la ruta completa (14,5 km · 4-5 h). <strong>Reserva Premium incluida sin coste extra</strong> · mascotas siempre gratis.
        </p>
      </header>

      <p class="rsvP__premiumBadge">
        <span class="rsvP__premiumStar" aria-hidden="true">✦</span>
        <span><strong>Reserva Premium · Todo incluido</strong> en cualquier tarifa · taquillas, vestuarios, duchas calientes, picnic asturiano, transfer y parking privado vigilado</span>
      </p>

      <div class="rsvP__grid">
        {tarifas.map(t => (
          <article class="rsvP__card">
            <div class="rsvP__cardMedia">
              <Picture src={t.img} alt={t.imgAlt} sizes="(min-width: 960px) 25vw, 50vw" aspectRatio="4 / 5" />
              <span class="rsvP__cardBadge">{t.badge}</span>
            </div>
            <div class="rsvP__cardBody">
              <h3 class="rsvP__cardTitle">{t.title}</h3>
              <p class="rsvP__cardAge">{t.age}</p>
              <p class="rsvP__cardPrice">
                {t.price === '0' ? (
                  <span class="rsvP__cardFree">Gratis</span>
                ) : (
                  <>
                    <span class="rsvP__cardCurrency">€</span>
                    <span class="rsvP__cardAmount">{t.price}</span>
                    <span class="rsvP__cardUnit">/día</span>
                  </>
                )}
              </p>
              <p class="rsvP__cardNote">{t.note}</p>
              <a class="rsvP__cardLink" href={t.href ?? '#booking-widget'}>
                Reservar
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="rsvP__foot">
        ¿Buscas tarifa familiar, grupo escolar o despedida? <a href={getLocalePath('precios', 'es')}>Ver todas las tarifas al detalle</a>.
      </p>
    </div>
  </section>

  <!-- ============== 4 PASOS ============== -->
  <section class="rsvS" aria-labelledby="rsvS-title">
    <div class="rsvS__inner">
      <header class="rsvS__header">
        <span class="rsvS__eyebrow">— Cómo funciona</span>
        <h2 id="rsvS-title" class="rsvS__title">
          Reservar tu descenso<br/>
          <span class="serif-italic">en 4 pasos.</span>
        </h2>
        <div class="rsvS__times">
          <div><strong>Horario abierto</strong><span>Llegada flexible 10:30 – 12:30</span></div>
          <div><strong>Recogidas</strong><span>De 13:00 a 18:00 desde Toraño / Fríes</span></div>
        </div>
      </header>

      <ol class="rsvS__list" role="list">
        {pasos.map(p => (
          <li class="rsvS__step">
            <span class="rsvS__stepNum">{p.num}</span>
            <h3 class="rsvS__stepTitle">{p.title}</h3>
            <p class="rsvS__stepText" set:html={p.text}></p>
          </li>
        ))}
      </ol>

      <p class="rsvS__foot">
        <a href={getLocalePath('cuanto_dura', 'es')}>Ver cómo funciona el descenso en detalle</a> · tiempos reales por ruta y franja del día.
      </p>
    </div>
  </section>

  <!-- ============== OTRAS FORMAS DE RESERVAR ============== -->
  <section class="rsvO" aria-labelledby="rsvO-title">
    <div class="rsvO__inner">
      <header class="rsvO__header">
        <span class="rsvO__eyebrow">— ¿Prefieres hablar con alguien?</span>
        <h2 id="rsvO-title" class="rsvO__title">
          Otras formas<br/>
          <span class="serif-italic">de reservar.</span>
        </h2>
        <p class="rsvO__lead">
          Reserva siempre con antelación · te confirmamos al momento en horario de atención. Persona real del equipo, nunca un bot.
        </p>
      </header>

      <div class="rsvO__row" role="list">
        <a class="rsvO__item" href="https://wa.me/34681093673?text=Hola%2C%20me%20gustar%C3%ADa%20reservar%20el%20descenso%20del%20Sella" target="_blank" rel="noopener noreferrer" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
