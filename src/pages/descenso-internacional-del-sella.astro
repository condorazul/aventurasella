---
import BaseLayout from '@layouts/BaseLayout.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';

const title = 'Descenso Internacional del Sella 2026 · Fecha y guía';
const description = 'Descenso Internacional del Sella 2026: fecha, recorrido, horarios, palmarés y cómo vivirlo. Reserva tu canoa turística el mismo día del evento.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/descenso-internacional-del-sella/`;

// ============== Datos estructurados ==============
const datosClave = [
  { label: 'Nombre oficial',    valueLines: ['Descenso Internacional', 'del Sella'], sub: '“Les Piragües”' },
  { label: 'Fundado',           valueLines: ['1930'],                                 sub: 'casi un siglo de historia' },
  { label: 'Recorrido',         valueLines: ['20 km'],                                sub: 'Arriondas → Ribadesella' },
  { label: 'Participantes',     valueLines: ['+1.200'],                               sub: 'élite + amateurs' },
  { label: 'Espectadores',      valueLines: ['~200.000'],                             sub: 'a orillas del río' },
  { label: 'Reconocimiento',    valueLines: ['F. I. Turístico', 'Internacional'],     sub: 'declarada en 1981' },
];

const fechas2026 = [
  { day: 'Jueves 6 ago',               hour: 'Todo el día',      title: 'Llegada de las peñas',           text: 'Concentración en Arriondas. Empieza el ambiente festivo.' },
  { day: 'Viernes 7 ago',              hour: 'Todo el día',      title: 'Verbena oficial',                 text: 'Fiestas populares, encendido de fogatas y música en Arriondas.' },
  { day: 'Sábado 8 ago',               hour: '11:30 h',          title: 'Salida oficial',                  text: 'Arranca la competición desde el Puente de los Piragüistas.',  highlight: true },
  { day: 'Sábado 8 ago',               hour: '12:00 h',          title: 'Salida turística · nosotros',     text: 'Única salida del día tras la élite. Reserva especial con cupo limitado.',  highlight: true },
  { day: 'Sábado 8 ago',               hour: '14:30–17:00 h',    title: 'Llegada a Ribadesella',           text: 'Festival de meta y entrega de trofeos junto al mar.' },
  { day: 'Domingo 9 ago',              hour: 'Mañana',           title: 'Entrega de premios',              text: 'Ceremonia oficial y Misa del Piragüista. Cierre del fin de semana.' },
];

const recorrido = [
  { km: '0 km',    place: 'Arriondas',            note: 'Salida oficial · Puente de los Piragüistas',  us: false },
  { km: '3 km',    place: 'Puente de Santianes',  note: 'Primer punto de cronometraje',                us: false },
  { km: '7 km',    place: 'Puente de Toraño',     note: 'Final de nuestra ruta Mini Sella',            us: true  },
  { km: '14,5 km', place: 'Fríes',                note: 'Final de nuestro descenso Completo',          us: true  },
  { km: '17 km',   place: 'Llovio',               note: 'Últimos rápidos del trazado',                 us: false },
  { km: '20 km',   place: 'Ribadesella',          note: 'Meta · orilla del mar Cantábrico',            us: false },
];

const palmares = [
  { year: '2025', winners: 'Rodrigo Germade / Diego Romero', flag: 'ESP' },
  { year: '2024', winners: 'Javier Reja / Adrián Sieiro',     flag: 'ESP' },
  { year: '2023', winners: 'Walter Bouzán / Manuel Vargas',   flag: 'ESP' },
  { year: '2022', winners: 'Walter Bouzán / Manuel Vargas',   flag: 'ESP' },
  { year: '2021', winners: 'Íñigo Peña / Pedro Vázquez',       flag: 'ESP' },
];

const faqs = [
  { q: '¿Cuándo es el Descenso Internacional del Sella 2026?',
    a: 'La edición 2026 se celebra el <strong>sábado 8 de agosto</strong>. La salida oficial de la élite está fijada para las <strong>11:30 h</strong> en Arriondas y la llegada a Ribadesella es entre las 14:30 y las 17:00 h. Nuestra salida turística es a las <strong>12:00 h</strong>, justo después de los profesionales.' },
  { q: '¿Puedo bajar el Sella el mismo día del Descenso Internacional?',
    a: 'Sí — pero con reserva especial. Ofrecemos una <strong>única salida turística a las 12:00 h</strong>, justo después de la salida de la élite profesional. El río se abre al tráfico turístico tras el paso del pelotón. <strong>Precio único de 35 €</strong> por persona (sin picnic incluido, porque la logística ese día es distinta). Pago anticipado online. Reserva hasta <strong>2 días antes</strong> del evento — las plazas se agotan con semanas de antelación.' },
  { q: '¿Por qué el check-in ese día es tan temprano?',
    a: 'El <strong>tráfico de entrada a Arriondas se cierra a las 10:00 h</strong> — las calles se peatonalizan y no se permite el paso de vehículos al pueblo. Por eso pedimos que llegues a Arriondas <strong>antes de las 9:30 h</strong> para hacer el check-in y dejar el coche en nuestro parking privado. Si llegas tarde, no podrás acceder y perderías la actividad.' },
  { q: '¿Puedo llevar a mi perro el día del Descenso Internacional?',
    a: '<strong>No lo recomendamos</strong>. Aunque las mascotas son bienvenidas <a href="/">el resto del año</a>, ese día hay una afluencia extraordinaria (~200.000 espectadores), mucho ruido, fuegos artificiales, tráfico y tensión. Los perros se asustan mucho y la experiencia no será placentera para ellos ni para ti. Mejor reserva cualquier otro día de la temporada.' },
  { q: '¿Cuánto cuesta participar en el Descenso Internacional como atleta?',
    a: 'La inscripción como deportista federado ronda los <strong>35–45 €</strong> según categoría. Requiere licencia de piragüismo vigente y acreditación federativa. No se admiten canoas turísticas en la prueba oficial.' },
  { q: '¿Dónde puedo ver el Descenso Internacional gratis?',
    a: 'Toda la ribera del Sella es de acceso libre. Los mejores puntos son <strong>Arriondas</strong> (salida), el <strong>Puente de Llovio</strong> (últimos rápidos espectaculares) y la llegada en <strong>Ribadesella</strong>.' },
  { q: '¿Cuál es el palmarés del Descenso Internacional del Sella?',
    a: 'Puedes consultar el listado completo de ganadores desde 1930 en la web oficial de la <a href="https://www.rfep.es" target="_blank" rel="nofollow noopener external">Federación Española de Piragüismo</a> o en <a href="https://es.wikipedia.org/wiki/Descenso_Internacional_del_Sella" target="_blank" rel="noopener external">Wikipedia</a>. Aquí arriba tienes la tabla de ediciones recientes, que actualizamos cada septiembre.' },
  { q: '¿Hay alojamiento disponible el fin de semana del Descenso Internacional?',
    a: 'Difícil. Reserva con <strong>meses de antelación</strong> en Arriondas, Cangas de Onís, Ribadesella o Llanes. La ocupación esa semana supera el 95 % en todo el entorno.' },
  { q: '¿Se puede asistir con niños?',
    a: 'Sí, es un <strong>evento familiar por excelencia</strong>. El ambiente es festivo y la organización prepara zonas de orilla seguras. Cuidado con el sol: recomendamos sombrero y crema alta.' },
  { q: '¿Qué más se puede hacer ese fin de semana en Asturias?',
    a: 'Visitar los <strong>Lagos de Covadonga</strong>, bajar el <a href="/">Sella turísticamente</a> los días previos, hacer una ruta en bici por la Senda del Oso, conocer Ribadesella y la cueva de Tito Bustillo, o probar la sidra y la gastronomía asturiana en los chigres locales.' },
];

// ============== Schema.org JSON-LD ==============
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descenso Internacional del Sella 2026 · Fecha, recorrido y guía completa',
      description,
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/og/og-internacional-es.jpg`, width: 1200, height: 630 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-11',
      articleSection: 'Eventos · Descenso Internacional del Sella',
      keywords: [
        'Descenso Internacional del Sella',
        'Descenso del Sella 2026',
        'Les Piragües',
        'Fiesta del Sella',
        'piragüismo Asturias',
        'Arriondas Ribadesella canoa',
      ],
      about: 'Competición internacional de piragüismo en el río Sella, Asturias',
    },
    {
      '@type': 'Event',
      '@id': `${canonicalUrl}#event-2026`,
      name: 'Descenso Internacional del Sella 2026 · Les Piragües',
      alternateName: 'Les Piragües',
      description: 'Competición de piragüismo de 20 km por el río Sella, declarada Fiesta de Interés Turístico Internacional. Atrae a más de 1.200 piragüistas y 200.000 espectadores.',
      startDate: '2026-08-08T11:30:00+02:00',
      endDate:   '2026-08-08T17:00:00+02:00',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      inLanguage: 'es-ES',
      isAccessibleForFree: true,
      audience: { '@type': 'Audience', audienceType: 'General public · piragüismo · turismo deportivo' },
      maximumAttendeeCapacity: 200000,
      location: {
        '@type': 'Place',
        name: 'Río Sella · Arriondas — Ribadesella',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Puente de los Piragüistas',
          addressLocality: 'Arriondas',
          addressRegion: 'Asturias',
          postalCode: '33540',
          addressCountry: 'ES',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      },
      organizer: {
        '@type': 'Organization',
        name: 'Federación Española de Piragüismo',
        url: 'https://www.rfep.es',
      },
      image: `${baseUrl}/images/og/og-internacional-es.jpg`,
      url: canonicalUrl,
      offers: {
        '@type': 'Offer',
        name: 'Salida turística del Descenso Internacional · 12:00 h',
        description: 'Única salida turística del día tras el paso de la élite profesional. Cupo limitado.',
        price: '35',
        priceCurrency: 'EUR',
        availability: 'https://schema.org/LimitedAvailability',
        validFrom: '2026-01-15T00:00:00+02:00',
        url: `${baseUrl}/reservar/?dia=2026-08-08`,
      },
      subEvent: [
        { '@type': 'Event', name: 'Llegada de las peñas',     startDate: '2026-08-06', endDate: '2026-08-06', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Verbena oficial',          startDate: '2026-08-07', endDate: '2026-08-07', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Salida turística (12:00)', startDate: '2026-08-08T12:00:00+02:00', endDate: '2026-08-08T17:00:00+02:00', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Entrega de premios y Misa del Piragüista', startDate: '2026-08-09', endDate: '2026-08-09', eventStatus: 'https://schema.org/EventScheduled' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'El Descenso del Sella Asturias · Aventura en el Sella · Alquiler de Canoas',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acceso por Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        'https://share.google/huLLaIz31FiYohuTV',
        'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html',
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',                          item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Descenso Internacional del Sella', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/og/og-internacional-es.jpg"
  currentPath="/descenso-internacional-del-sella/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="dih" aria-labelledby="dih-title">

    <div class="dih__inner">
      <nav class="dih__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Descenso Internacional del Sella</span>
      </nav>

      <span class="dih__eyebrow">
        <span class="dih__eyebrow-dot" aria-hidden="true"></span>
        1930 · Fiesta de Interés Turístico Internacional
      </span>

      <h1 id="dih-title" class="dih__title">
        Descenso Internacional<br/>
        <span class="serif-italic">del Sella</span>
      </h1>

      <p class="dih__lead">
        Una de las <strong>competiciones de piragüismo más emblemáticas del mundo</strong>
        y la prueba deportiva más antigua de Asturias. Cada año, en un sábado de agosto,
        miles de atletas bajan los <strong>20 km</strong> que separan Arriondas de Ribadesella,
        acompañados por más de <strong>200.000 espectadores</strong> a orillas del río Sella.
      </p>

      <div class="dih__event">
        <div class="dih__event-col">
          <span class="dih__event-label">Edición 2026</span>
          <span class="dih__event-value">Sábado 8 de agosto</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Salida oficial</span>
          <span class="dih__event-value">11:30 h · Arriondas</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Meta</span>
          <span class="dih__event-value">14:30–17:00 h · Ribadesella</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== QUÉ ES + DATOS CLAVE ============== -->
  <section class="dis">
    <div class="container container--xl">
      <header class="dis__header">
        <span class="dis__eyebrow">— Qué es</span>
        <h2 class="dis__title">La fiesta de las piraguas <span class="serif-italic">más antigua de España</span></h2>
        <p class="dis__lead">
          Nacido en <strong>1930</strong> de la mano de Dionisio de la Huerta, el
          Descenso Internacional del Sella es la <strong>competición de piragüismo
          en aguas tranquilas más longeva</strong> del piragüismo español. Atrae
          cada año a los mejores kayakistas y canoístas del mundo — desde campeones
          olímpicos hasta deportistas amateurs — junto a una multitud que convierte
          las orillas en un festival continuo de 20 km.
        </p>
      </header>

      <div class="dis__grid">
        {datosClave.map((d, i) => (
          <div class="disData" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="disData__label">{d.label}</span>
            <span class="disData__value">
              {d.valueLines.map((line, idx) => (
                <>
                  {idx > 0 && <br/>}
                  {line}
                </>
              ))}
            </span>
            <span class="disData__sub">{d.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== FECHA 2026 ============== -->
  <section class="dif">
    <div class="container container--lg">
      <header class="dif__header">
        <span class="dif__eyebrow">— Fechas 2026</span>
        <h2 class="dif__title">
          Cuatro días de fiesta.<br/>
          <span class="serif-italic">Un sábado inolvidable.</span>
        </h2>
        <p class="dif__lead">
          Las actividades paralelas empiezan el jueves previo con la llegada de las
          peñas a Arriondas y culminan el sábado con la <strong>salida oficial de la
          competición a las 11:30 h</strong>.
        </p>
      </header>

      <ol class="dif__timeline">
        {fechas2026.map((f, i) => (
          <li class:list={['difStep', f.highlight && 'difStep--top']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <div class="difStep__date">
              <span class="difStep__day">{f.day}</span>
              <span class="difStep__hour">{f.hour}</span>
            </div>
            <div class="difStep__bullet" aria-hidden="true"></div>
            <div class="difStep__body">
              <h3 class="difStep__title">{f.title}</h3>
              <p class="difStep__text">{f.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="dif__note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>La fecha oficial depende del calendario de la Federación Española de Piragüismo. Confirmamos cada enero la edición del año en curso.</span>
      </p>
    </div>
  </section>

  <!-- ============== RECORRIDO 20 KM ============== -->
  <section class="dir">
    <div class="container container--xl">
      <header class="dir__header">
        <span class="dir__eyebrow">— Recorrido</span>
        <h2 class="dir__title">20 kilómetros entre <span class="serif-italic">Arriondas y Ribadesella</span></h2>
        <p class="dir__lead">
          El trazado del Descenso Internacional del Sella reproduce el mismo río que
          recorres tú en tu <a href="/" class="dir__link">descenso turístico</a> — pero
          en versión competitiva y multitudinaria.
        </p>
      </header>

      <ol class="dir__track">
        {recorrido.map((r, i) => (
          <li class:list={['dirPoint', r.us && 'dirPoint--us']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="dirPoint__km">{r.km}</span>
            <span class="dirPoint__dot" aria-hidden="true"></span>
            <div class="dirPoint__body">
              <span class="dirPoint__place">{r.place}</span>
              <span class="dirPoint__note">{r.note}</span>
              {r.us && <span class="dirPoint__tag">Nuestro</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== CÓMO VERLO ============== -->
  <section class="div">
    <div class="container container--xl">
      <header class="div__header">
        <span class="div__eyebrow">— Guía práctica</span>
        <h2 class="div__title">Cómo ver el Descenso Internacional <span class="serif-italic">sin líos</span></h2>
        <p class="div__lead">
          Los <strong>mejores puntos</strong> para ver el Descenso Internacional del Sella
          son <strong>Arriondas</strong> (salida), el <strong>Puente de Llovio</strong>
          (últimos rápidos espectaculares) y la llegada en <strong>Ribadesella</strong>.
        </p>
      </header>

      <div class="div__grid">
        <article class="divCard" data-reveal data-reveal-delay="1">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>
            Aparcamiento recomendado
          </h3>
          <ul class="divCard__list">
            <li><strong>Arriondas</strong> · parkings habilitados por el ayuntamiento desde el jueves. Llegar antes de las <strong>10:00 h el sábado</strong>.</li>
            <li><strong>Toraño / Fríes</strong> · parking más tranquilo si no te importa ver parte intermedia. Buena opción para familias con niños.</li>
            <li><strong>Ribadesella</strong> · atasco severo desde las 11 h. Alternativa: aparcar en <strong>Llovio</strong> y subir caminando.</li>
          </ul>
        </article>

        <article class="divCard" data-reveal data-reveal-delay="2">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
            Qué llevar
          </h3>
          <ul class="divCard__list">
            <li><strong>Ropa cómoda</strong> y <strong>crema solar</strong> (muchas horas al sol de agosto).</li>
            <li><strong>Agua y picnic</strong> si no quieres hacer cola en los bares.</li>
            <li><strong>Cámara con buen zoom</strong> — el río está a 10–20 m de la orilla en algunos tramos.</li>
            <li>Prepárate para <strong>calor</strong> y <strong>muchísima gente</strong>. Es uno de los grandes eventos del verano asturiano.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== PALMARÉS ============== -->
  <section class="dip">
    <div class="container container--lg">
      <header class="dip__header">
        <span class="dip__eyebrow">— Palmarés reciente</span>
        <h2 class="dip__title">Ganadores del Descenso del Sella <span class="serif-italic">K2 senior absoluto</span></h2>
        <p class="dip__lead">
          Ediciones recientes de la categoría estrella del Descenso Internacional
          del Sella. Actualizamos la tabla cada septiembre tras la ceremonia oficial.
        </p>
      </header>

