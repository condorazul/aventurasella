---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';

const title = 'Opiniones del descenso del Sella · 4,5★ en Google y TripAdvisor';
const description = '147 opiniones reales del descenso del Sella — 4,5★ en Google, 4,8★ en TripAdvisor. Lee qué dicen familias, parejas y amigos tras bajar el río con Aventura en el Sella.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/opiniones/`;

// Números agregados oficiales (snapshot 2026-04-13 · reference_reviews.md)
const aggregate = {
  global: { rating: '4,5', total: 147, rating_num: 4.5 },
  google: { rating: '4,5', total: 127, url: 'https://share.google/huLLaIz31FiYohuTV', label: 'Google' },
  trip:   { rating: '4,8', total:  20, url: 'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html', label: 'TripAdvisor' },
};

// Testimonios reales aprobados (reference_reviews.md 2026-04-13)
const testimonios = [
  {
    initial: 'A',
    name: 'Anaïs Suárez Blanco',
    source: 'Google',
    date: 'octubre 2025',
    context: 'Experiencia',
    rating: 5,
    text: 'Buen servicio, trabajadores atentos y muy simpáticos. La experiencia genial, me ha encantado.',
    sourceUrl: aggregate.google.url,
  },
  {
    initial: 'N',
    name: 'Nacho A.',
    source: 'TripAdvisor',
    date: 'agosto 2025',
    context: 'Parejas',
    rating: 5,
    text: 'Todo puntual y muy amables. Una experiencia para probar una vez en la vida, recomendada para jóvenes y mayores.',
    sourceUrl: aggregate.trip.url,
  },
  {
    initial: 'C',
    name: 'Carlos S.',
    source: 'TripAdvisor',
    date: 'mayo 2025',
    context: 'Amigos',
    rating: 5,
    text: 'Merece la pena. Tienes vestuarios y puedes ducharte tras la actividad. Te dan instrucciones divertidas, un bidón donde meter muchas cosas y el resto te lo da el río.',
    sourceUrl: aggregate.trip.url,
  },
];

// Perfiles de visitante recurrentes en las reseñas · palabras que aparecen repetidamente
const perfiles = [
  { tag: 'Familias',  nota: 'Con niños desde 5 años',            words: ['niños atentos', 'seguridad', 'instrucciones claras', 'mascotas bienvenidas'] },
  { tag: 'Parejas',   nota: 'Una vez en la vida',                 words: ['romántico', 'atardecer', 'tranquilidad', 'fotos'] },
  { tag: 'Amigos',    nota: 'Grupo · día completo',               words: ['ambiente', 'chiringuitos', 'divertido', 'duchas'] },
  { tag: 'Jubilados', nota: 'Ritmo tranquilo',                    words: ['para mayores', 'seguro', 'paisaje', 'trato cercano'] },
];

const faqs = [
  { q: '¿Dónde puedo leer todas las opiniones del descenso del Sella?',
    a: 'Tenemos <strong>147 reseñas reales</strong> repartidas entre <strong><a href="' + aggregate.google.url + '" target="_blank" rel="noopener">Google</a></strong> (127 reseñas · 4,5 estrellas) y <strong><a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a></strong> (20 reseñas · 4,8 estrellas). En esta página destacamos las más representativas, pero todas están públicas en sus plataformas.' },
  { q: '¿Son todas las opiniones reales y verificadas?',
    a: 'Sí. <strong>No compramos ni fabricamos reseñas</strong>. Cada una viene de un cliente que hizo el descenso del Sella con nosotros y dejó su opinión voluntariamente en Google o TripAdvisor. Eso significa que verás de todo: 5 estrellas mayoritarias, alguna 4 y, muy de vez en cuando, alguna crítica que respondemos públicamente.' },
  { q: '¿Cómo dejo mi opinión tras hacer el descenso?',
    a: 'Lo más fácil: tras la actividad te mandamos un mensaje con el enlace directo de Google. También puedes dejarla en <a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a> buscando "Aventura en el Sella · Arriondas". <strong>Nos ayuda enormemente</strong> — es lo que hace que otros confíen en nosotros.' },
  { q: '¿Cómo respondéis a las opiniones negativas?',
    a: 'Con honestidad y en público. Contestamos <strong>todas</strong> las reseñas críticas desde el panel de Google Business, reconociendo lo que no hicimos bien y explicando qué hemos cambiado. Es la única forma de mejorar y de que futuros clientes vean cómo gestionamos los problemas reales.' },
  { q: '¿Por qué la media de Google es 4,5 y la de TripAdvisor 4,8?',
    a: 'Porque son plataformas con perfiles de usuarios distintos. Google recibe más volumen y más diversidad de expectativas; TripAdvisor suele usarlo el viajero que planifica con cuidado y valora más detalles del servicio. <strong>La media combinada es 4,5★ sobre 147 reseñas</strong> — el número que usamos en toda la web.' },
  { q: '¿Cuántos años lleváis recibiendo opiniones?',
    a: 'Aventura en el Sella acumula <strong>reseñas desde hace varios años</strong> de clientes de temporadas distintas. Ese volumen y consistencia es lo que nos diferencia de nuevos operadores sin historial — <a href="/experiencia/">descubre más sobre nuestra historia</a>.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Opiniones reales del descenso del Sella · 4,5★ · 147 reseñas verificadas',
      description: '147 opiniones reales sobre el descenso del Sella con Aventura en el Sella. 4,5 estrellas en Google y 4,8 en TripAdvisor.',
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-11',
      articleSection: 'Opiniones · Reseñas verificadas',
      keywords: ['opiniones descenso del Sella', 'reseñas descenso del Sella', 'Aventura en el Sella opiniones', 'descenso del Sella reviews', 'canoas Sella Arriondas opiniones'],
      about: 'Opiniones, reseñas y testimonios reales del descenso del Sella en canoa desde Arriondas',
      mentions: [
        { '@type': 'Thing', name: 'Google reviews', url: aggregate.google.url },
        { '@type': 'Thing', name: 'TripAdvisor', url: aggregate.trip.url },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'El Descenso del Sella Asturias · Aventura en el Sella · Alquiler de Canoas',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acceso por Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: aggregate.global.rating_num,
        reviewCount: aggregate.global.total,
        bestRating: 5,
        worstRating: 1,
      },
      review: testimonios.map(t => ({
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5, worstRating: 1 },
        author: { '@type': 'Person', name: t.name },
        datePublished: t.date,
        reviewBody: t.text,
        publisher: { '@type': 'Organization', name: t.source },
      })),
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        aggregate.google.url,
        aggregate.trip.url,
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',    item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Opiniones', item: canonicalUrl },
      ],
    },
  ],
};

// Helper estrellas
const starSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/opiniones/" translationKey="opiniones">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · big stars + media aggregate ============== -->
  <section class="opH" aria-labelledby="opH-title">
    <span class="opH__watermark" aria-hidden="true">4,5</span>

    <div class="opH__inner">
      <nav class="opH__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Opiniones</span>
      </nav>

      <span class="opH__eyebrow">— Opiniones reales y verificadas</span>

      <h1 id="opH-title" class="opH__title">
        El Sella<br/>
        <span class="serif-italic">en sus propias palabras.</span>
      </h1>

      <div class="opH__badge" aria-hidden="true">
        <span class="opH__badgeStars" set:html={Array(5).fill(starSvg).join('')}></span>
        <span class="opH__badgeRating">4,5</span>
        <span class="opH__badgeSep"></span>
        <span class="opH__badgeCount">147 reseñas verificadas</span>
      </div>

      <p class="opH__lead">
        Durante años nos bastó el <strong>boca a boca de Asturias</strong>. Desde hace poco pedimos activamente que dejes tu opinión — y por eso el volumen es modesto. Pero cada una de las <strong>147 reseñas</strong> es <strong>real, pública y verificable</strong> en Google y TripAdvisor.
      </p>

      <div class="opH__ctas">
        <a href={aggregate.google.url} class="opH__cta opH__cta--primary" target="_blank" rel="noopener noreferrer">Ver en Google<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
        <a href={aggregate.trip.url} class="opH__cta opH__cta--ghost" target="_blank" rel="noopener noreferrer">Ver en TripAdvisor<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · BREAKDOWN · Google + TripAdvisor + Combinado ============== -->
  <section class="opB" aria-labelledby="opB-title">
    <div class="container container--xl">
      <header class="opB__header" data-reveal>
        <span class="opB__eyebrow">— El dato en bruto</span>
        <h2 id="opB-title" class="opB__title">
          Dos plataformas<br/><span class="serif-italic">y una sola media.</span>
        </h2>
        <p class="opB__lead">
          Transparencia total: estos son los números tal cual están hoy en las fichas públicas.
        </p>
      </header>

      <div class="opB__grid">
        <article class="opB__card" data-reveal>
          <span class="opB__cardLabel">Google</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.google.rating}</strong>
          <span class="opB__cardCount">{aggregate.google.total} reseñas</span>
          <a href={aggregate.google.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Ver en Google
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--trip" data-reveal data-reveal-delay="1">
          <span class="opB__cardLabel">TripAdvisor</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.trip.rating}</strong>
          <span class="opB__cardCount">{aggregate.trip.total} reseñas</span>
          <a href={aggregate.trip.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Ver en TripAdvisor
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--total" data-reveal data-reveal-delay="2">
          <span class="opB__cardLabel">Media combinada</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.global.rating}</strong>
          <span class="opB__cardCount">{aggregate.global.total} reseñas totales</span>
          <span class="opB__cardNota">Ponderada entre ambas plataformas</span>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== 3 · TESTIMONIOS DESTACADOS · feature cards ============== -->
  <section class="opT" aria-labelledby="opT-title">
    <div class="container container--xl">
      <header class="opT__header" data-reveal>
        <span class="opT__eyebrow">— Qué dicen tras bajar el Sella</span>
        <h2 id="opT-title" class="opT__title">
          Tres reseñas<br/><span class="serif-italic">que resumen lo que hacemos.</span>
        </h2>
      </header>

      <div class="opT__grid">
        {testimonios.map((t, i) => (
          <article class="opT__card" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="opT__head">
              <span class="opT__avatar" aria-hidden="true">{t.initial}</span>
              <div class="opT__meta">
                <strong class="opT__name">{t.name}</strong>
                <span class="opT__src">{t.source} · {t.date}</span>
              </div>
              <span class="opT__tag">{t.context}</span>
            </div>
            <div class="opT__stars" aria-hidden="true" set:html={Array(t.rating).fill(starSvg).join('')}></div>
            <blockquote class="opT__quote">
              <span class="opT__mark" aria-hidden="true">“</span>
              {t.text}
            </blockquote>
            <a href={t.sourceUrl} class="opT__link" target="_blank" rel="noopener noreferrer">
              Ver en {t.source}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 4 · PERFILES · quién nos recomienda ============== -->
  <section class="opP" aria-labelledby="opP-title">
    <div class="container container--xl">
      <header class="opP__intro" data-reveal>
        <span class="opP__eyebrow">— Por perfil de visitante</span>
        <h2 id="opP-title" class="opP__title">
          Cuatro formas<br/><span class="serif-italic">de bajar el Sella.</span>
        </h2>
        <p class="opP__lead">
          Leyendo las 147 reseñas aparecen patrones claros: el perfil de quien viene y las palabras que más se repiten.
        </p>
      </header>

      <div class="opP__panel">
        <ol class="opP__grid">
          {perfiles.map(p => (
            <li class="opP__cell">
              <div class="opP__cellBody">
                <h3 class="opP__cellName">{p.tag}</h3>
                <span class="opP__cellNota">{p.nota}</span>
                <ul class="opP__words">
                  {p.words.map(w => <li class="opP__word">“{w}”</li>)}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ============== 5 · BANNER oscuro · ¿Listo para hacer el descenso? ============== -->
  <section class="opR" aria-label="Llamada a la acción · reservar descenso">
    <div class="container container--xl">
      <div class="opR__inner" data-reveal>
        <div class="opR__text">
          <span class="opR__eyebrow">— Aventura en el Sella</span>
          <h2 class="opR__title">Ya sabes lo que piensan <span class="serif-italic">los que lo probaron.</span></h2>
        </div>
        <a href="/reservar/" class="opR__cta">
          <span>Reservar mi descenso</span>
          <span class="opR__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 6 · INTERLINKING sage dark ============== -->
  <section class="opX">
    <div class="container container--xl">
      <header class="opX__header" data-reveal>
        <span class="opX__eyebrow">— Antes de venir</span>
        <h2 class="opX__title">Prepara<br/><span class="serif-italic">tu descenso del Sella.</span></h2>
      </header>

      <nav class="opX__list" aria-label="Páginas relacionadas">
        <a href="/precios/" class="opX__item">
          <span class="opX__num">01</span>
          <h3 class="opX__t">Precios del descenso</h3>
          <p class="opX__p">30€ niños · 40€ adultos · mascotas gratis. Todo incluido.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href="/con-ninos/" class="opX__item">
          <span class="opX__num">02</span>
          <h3 class="opX__t">Con niños</h3>
          <p class="opX__p">Desde 5 años · 1,15 m. Seguridad y ritmo familiar.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href="/con-perro/" class="opX__item">
          <span class="opX__num">03</span>
          <h3 class="opX__t">Con perro</h3>
          <p class="opX__p">Mascotas gratis. Chaleco canino incluido.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href="/recorrido-y-mapa/" class="opX__item">
          <span class="opX__num">04</span>
          <h3 class="opX__t">Recorrido y mapa</h3>
          <p class="opX__p">14,5 km · mapa interactivo · 8 hitos del camino.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
      </nav>
    </div>
  </section>

  <!-- ============== 7 · FAQ sage sidebar (reuse canónico) ============== -->
  <section class="opF">
    <div class="container container--xl">
      <div class="opF__grid">
        <aside class="opF__aside" data-reveal>
          <span class="opF__eyebrow">— Preguntas frecuentes</span>
          <h2 class="opF__title">Sobre las<br/><span class="serif-italic">opiniones.</span></h2>
          <p class="opF__lead">
            Cómo gestionamos las reseñas, cómo dejar la tuya y qué hay detrás del 4,5★.
            Si falta algo, <a href="/contacto/">escríbenos</a>.
          </p>
        </aside>
        <div class="opF__list" data-reveal data-reveal-delay="2">
          {faqs.map((f, i) => (
            <details class="opFI" name="op-faq" open={i === 0}>
              <summary class="opFI__q">
                {f.q}
                <svg class="opFI__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="opFI__a" set:html={f.a} />
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 8 · CTA FINAL dark photo ============== -->
  <section class="opCta" aria-labelledby="opCta-title">
    <div class="opCta__bg" aria-hidden="true">
      <Picture src="opiniones-cta" alt="" sizes="100vw" bare />
    </div>
    <div class="opCta__inner">
      <span class="opCta__eyebrow">— Sé parte de la siguiente reseña</span>
      <h2 id="opCta-title" class="opCta__title">
        Del río<br/>
        <span class="serif-italic">a tu propia historia.</span>
      </h2>
      <p class="opCta__lead">
        Baja el Sella con nosotros y decide tú qué contar. Reserva sin pagar ahora — <strong>paga con tarjeta o el día que recojas la canoa</strong>.
      </p>
      <div class="opCta__ctas">
        <a href="/reservar/" class="opCta__primary">
          Reservar mi descenso
