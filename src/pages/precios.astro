---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const title = 'Precios del descenso del Sella · Desde 30 € todo incluido';
const description = 'Precios del descenso del Sella: 30 € niños · 40 € adultos. Todo incluido (canoa, picnic, transfer, parking). Mascotas gratis. Reserva sin pagar ahora.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/precios/`;

// Todo incluido · ordenado por relevancia para quien busca precios
const incluido = [
  { icon: 'canoe',    title: 'Canoas K1, K2 y K3',           sub: 'Insumergibles, con remo y bidón estanco' },
  { icon: 'shield',   title: 'Chaleco salvavidas',           sub: 'Homologado, adaptado por talla' },
  { icon: 'wetsuit',  title: 'Neopreno',                     sub: 'Excepto del 15/06 al 28/09' },
  { icon: 'teacher',  title: 'Mini clase + monitores',       sub: 'Titulados y campeones del Sella' },
  { icon: 'picnic',   title: 'Picnic asturiano',             sub: 'Empanada de bonito, bollín preñao y agua' },
  { icon: 'bus',      title: 'Transfer de regreso',          sub: 'Desde Toraño o Fríes' },
  { icon: 'shower',   title: 'Vestuarios con ducha',         sub: 'Taquillas con llave incluidas' },
  { icon: 'parking',  title: 'Parking privado',              sub: '300 plazas · vigilado · autocaravanas' },
  { icon: 'paw',      title: 'Mascotas gratis',              sub: 'Toda la familia en canoa' },
  { icon: 'ticket',   title: 'Seguros obligatorios',         sub: 'Cobertura completa incluida' },
  { icon: 'ramp',     title: 'Rampa de embarque',            sub: 'Opcional y gratuita · o embarcas a pie de río' },
  { icon: 'heart',    title: 'Un trato cercano',             sub: 'Sin colas, sin robots, sin extras' },
];

const rutas = [
  {
    name: 'Mini Sella',   km: '7 km',   dur: '2 – 3 h',   desc: 'Ruta corta de Arriondas a Toraño. Ideal si vais con peques, queréis hacer muchas paradas o preferís una bajada tranquila.', tone: 'sage',
  },
  {
    name: 'Completo',     km: '14,5 km', dur: '4 – 5 h',  desc: 'Ruta clásica de Arriondas a Fríes. Más kilómetros, más paisaje, más paradas para bañarse. La experiencia más redonda.', tone: 'coral',
  },
];

const faqs = [
  { q: '¿Cuánto cuesta bajar el Sella?',
    a: 'Bajar el Sella en canoa con nosotros cuesta <strong>40 € por adulto</strong> (desde 13 años) y <strong>30 € por niño</strong> (de 5 a 12 años). El precio es <strong>todo incluido</strong>: canoa insumergible, chaleco, pala doble, neopreno en fechas frías, bidón estanco, mini clase con monitor titulado, picnic asturiano (empanada de bonito, bollín preñao y agua), transfer de regreso, <strong>parking privado vigilado (300 plazas · también para autocaravanas)</strong>, vestuarios con duchas, taquillas con llave y seguros. <strong>Mascotas gratis</strong>. El único día con tarifa distinta es el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional del Sella</a> — 35 € con condiciones especiales.' },
  { q: '¿El precio es por persona o por canoa?',
    a: 'El precio es <strong>por persona</strong>, no por canoa. Si sois dos adultos compartiendo una K2, pagáis <strong>40 € cada uno</strong>. Si vais tres personas en una K3, también por cabeza — compartir canoa no cambia la tarifa individual.' },
  { q: '¿Cuesta lo mismo la ruta Mini y la Completa?',
    a: 'Sí — <strong>una sola reserva, un solo precio</strong>. Eliges ruta en el agua, no al reservar. Puedes salir pensando en hacer la Completa y quedarte en Toraño (km 7) si te apetece, o empezar pensando en la Mini y seguir hasta Fríes. No cambia ni el precio ni lo que incluye.' },
  { q: '¿Hay descuento para grupos?',
    a: 'Para grupos de <strong>10 o más personas</strong> aplicamos condiciones especiales. Escríbenos por <a href="https://wa.me/34681093673?text=Hola,%20somos%20un%20grupo%20de...">WhatsApp</a> o <a href="mailto:info@aventuraenelsella.es">email</a> con el número de personas y la fecha aproximada, y te preparamos propuesta personalizada.' },
  { q: '¿Cómo se paga? ¿Hay que pagar por adelantado?',
    a: 'Reserva <strong>sin pagar ahora</strong>. Eliges lo que te sea más cómodo: <strong>pago con tarjeta por adelantado</strong> o <strong>pago el día al recoger la canoa</strong>. La única excepción es <a href="/descenso-internacional-del-sella/">el sábado del Descenso Internacional</a>, en el que solo se reserva con pago anticipado.' },
  { q: '¿Puedo cambiar la fecha o cancelar?',
    a: 'Puedes <strong>cambiar o cancelar en cualquier momento antes del día de la actividad</strong>, sin coste. Si pagaste con <strong>tarjeta por adelantado</strong>, para tramitar el reembolso necesitamos que nos avises con un mínimo de <strong>24 h de antelación</strong>. Avísanos por WhatsApp o email y movemos la fecha o devolvemos el importe.' },
  { q: '¿Tengo que elegir hora de salida?',
    a: 'No. Tu reserva es <strong>Premium · horario abierto</strong>: llega a nuestras instalaciones de Arriondas <strong>cuando te venga bien entre las 10:30 y las 12:30</strong>, sin elegir hora concreta. Es una de las <strong>ventajas Premium</strong>. La única excepción es el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional</a> (salida única a las 12:00) y los días con condiciones del río que requieran entrada con monitor (te avisamos con antelación). La Confederación Hidrográfica marca permanencia en el río hasta las 18:00.' },
  { q: '¿A partir de qué edad pueden bajar los niños?',
    a: 'Los menores pueden bajar a partir de <strong>5 años cumplidos y 1,15 m de altura mínima</strong>. Es un <strong>requisito estricto de seguridad</strong>, no solo por el chaleco — también por la naturaleza del río (corriente, profundidad variable, tramos con rápidos) y por exigencia de las compañías de seguros. <strong>No se admiten menores que no lleguen al mínimo</strong>, ni aunque vayan acompañados de un adulto o sepan nadar.' },
  { q: '¿Qué pasa el día del Descenso Internacional?',
    a: 'El sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional del Sella</a> se aplica un precio único de <strong>35 € por persona</strong>, con condiciones propias: salida única a las 12:00 h, pago anticipado obligatorio, sin picnic incluido y plazas muy limitadas. Todo explicado en su página.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, 'es'),
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'es-ES',
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#business` },
      mainEntityOfPage: canonicalUrl,
    },
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descenso del Sella en canoa · Todo incluido',
      description: 'Descenso turístico en canoa por el río Sella desde Arriondas. Todo incluido: canoa, equipo, mini clase con monitores titulados, transfer de regreso, picnic asturiano, vestuarios y parking. Mascotas gratis.',
      inLanguage: 'es-ES',
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      image: `${baseUrl}/images/optimized/includes-b.jpg`,
      offers: [
        { '@type': 'Offer', name: 'Niños (hasta 12 años)', price: '30.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/reservar/` },
        { '@type': 'Offer', name: 'Adulto',                price: '40.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/reservar/` },
        { '@type': 'Offer', name: 'Día del Descenso Internacional', price: '35.00', priceCurrency: 'EUR', availability: 'https://schema.org/LimitedAvailability', url: `${baseUrl}/descenso-internacional-del-sella/` },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5', reviewCount: '147', bestRating: '5', worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',  item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Precios', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/precios/" translationKey="precios">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="prh" aria-labelledby="prh-title">

    <div class="prh__inner">
      <nav class="prh__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Precios</span>
      </nav>

      <div class="prh__grid">
        <div class="prh__main">
          <span class="prh__eyebrow">
            <span class="prh__eyebrow-dot" aria-hidden="true"></span>
            Desde 30 € · Temporada 2026
          </span>

          <h1 id="prh-title" class="prh__title">
            Precios del<br/>
            <span class="serif-italic">descenso del Sella</span>
          </h1>

          <p class="prh__lead">
            <strong>Un solo precio, todo incluido</strong>. Eliges ruta en el agua, no en
            la web. El coste depende solo de la edad — no de los kilómetros ni de si te
            quedas en Toraño o llegas a Fríes.
          </p>

          <div class="prh__stats">
            <span class="prh__statsKicker">
              <span class="prh__statsKickerMark" aria-hidden="true"></span>
              Tarifa única · todo incluido
            </span>
            <div class="prh__statsRow">
              <div class="prh__stat">
                <strong>30<small>€</small></strong>
                <span>Niños · 5–12</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>40<small>€</small></strong>
                <span>Adultos</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>Gratis</strong>
                <span>Mascotas</span>
              </div>
            </div>
          </div>
        </div>

        <aside class="prh__contact" aria-label="Reservar o contactar">
          <span class="prh__contactKicker">— Reserva tu plaza</span>
          <ul class="prh__contactList" role="list">
            <li>
              <a href="/reservar/" class="prh__contactPill prh__contactPill--primary">
                <strong>Reservar ahora</strong>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </li>
            <li>
              <a href="tel:+34681093673" class="prh__contactPill" aria-label="Llamar al 681 09 36 73">
                <strong>Llámanos</strong>
                <small>681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Hola%2C%20me%20gustar%C3%ADa%20m%C3%A1s%20info%20de%20precios" target="_blank" rel="noopener noreferrer" class="prh__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Respuesta en minutos</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== PRECIO CARDS ============== -->
  <section class="prp">
    <div class="container container--xl">
      <header class="prp__header" data-reveal>
        <span class="prp__eyebrow">— Tarifas</span>
        <h2 class="prp__title">
          Precio por persona,<br/>
          <span class="serif-italic">todo incluido</span>
        </h2>
        <p class="prp__lead">
          Sin extras. Sin coste por llegar hasta Fríes. Sin añadir el neopreno, el transfer o el picnic.<br/>
          <strong>El precio que ves es el precio final.</strong>
        </p>
      </header>

      <div class="prp__grid">
        <!-- CARD 1: NIÑOS -->
        <article class="prpCard prpCard--sage" data-reveal data-reveal-delay="1">
          <div class="prpCard__media">
            <Picture src="precios-ninos" alt="Niños disfrutando del descenso del Sella en canoa" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarifa infantil</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">30&nbsp;€ <span>/ niño</span></p>
              <p class="prpCard__mediaSub">5-12 años · Canoa compartida</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Plaza infantil</h3>
              <span class="prpCard__rating" aria-label="Valoración media 4.9 sobre 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">5-12</span><span class="prpCard__stat-lbl">Años</span></li>
              <li><span class="prpCard__stat-val">K2/K3</span><span class="prpCard__stat-lbl">Canoa</span></li>
              <li><span class="prpCard__stat-val">Sí</span><span class="prpCard__stat-lbl">Accesorios</span></li>
              <li><span class="prpCard__stat-val">Sí</span><span class="prpCard__stat-lbl">Picnic</span></li>
            </ul>
            <p class="prpCard__desc">
              La opción más accesible para familias · los peques bajan compartiendo canoa con un adulto, con <strong>misma cobertura completa que la tarifa adulto</strong>.
            </p>
            <ul class="prpCard__list">
              <li>Edad mínima <strong>5 años y 1,15 m</strong> · sin excepciones</li>
              <li>Canoa compartida con un adulto responsable</li>
              <li>Equipo infantil, picnic y servicios incluidos · <a href="#pri-title">ver detalle abajo</a></li>
            </ul>
            <a href="/reservar/" class="prpCard__cta prpCard__cta--primary">
              Reservar plaza de niño
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 2: ADULTOS -->
        <article class="prpCard prpCard--coral" data-reveal data-reveal-delay="2">
          <div class="prpCard__media">
            <Picture src="precios-adultos" alt="Grupo de amigas en el descenso del Sella en canoa" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarifa adulto</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">40&nbsp;€ <span>/ adulto</span></p>
              <p class="prpCard__mediaSub">Desde 13 años · Todo incluido</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Plaza adulto</h3>
              <span class="prpCard__rating" aria-label="Valoración media 4.9 sobre 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">13+</span><span class="prpCard__stat-lbl">Años</span></li>
              <li><span class="prpCard__stat-val">K1/K2/K3</span><span class="prpCard__stat-lbl">Canoa</span></li>
              <li><span class="prpCard__stat-val">Sí</span><span class="prpCard__stat-lbl">Accesorios</span></li>
              <li><span class="prpCard__stat-val">Sí</span><span class="prpCard__stat-lbl">Picnic</span></li>
            </ul>
            <p class="prpCard__desc">
              La tarifa estándar · eliges <strong>K1 solo, K2 en pareja o K3 con amigos</strong> — el precio es por persona igual.
            </p>
            <ul class="prpCard__list">
              <li>A partir de <strong>13 años</strong></li>
              <li>Canoa individual, doble o triple <strong>(K1/K2/K3)</strong></li>
              <li>Eliges ruta en el agua (Mini o Completo) sin coste extra · <a href="#pri-title">ver detalle abajo</a></li>
            </ul>
            <a href="/reservar/" class="prpCard__cta prpCard__cta--primary">
              Reservar plaza de adulto
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 3: CTA IMAGEN -->
        <article class="prpCardCTA" data-reveal data-reveal-delay="3">
          <div class="prpCardCTA__media">
            <video
              class="prpCardCTA__video"
              muted loop playsinline
              preload="none"
              poster="/videos/rio-sella-loop-poster.jpg"
              aria-hidden="true"
              data-src="/videos/rio-sella-loop.mp4"
            ></video>
          </div>
          <div class="prpCardCTA__inner">
            <div class="prpCardCTA__bottom">
              <span class="prpCardCTA__kicker">Aventura en el Sella &nbsp;·&nbsp; Alquiler de Canoas</span>
              <h3 class="prpCardCTA__title">
                Haz tu reserva<br/>con nosotros
              </h3>
              <a href="/reservar/" class="prpCardCTA__btn">
                <span>Reservar ahora</span>
                <span class="prpCardCTA__btnIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
          </div>
        </article>
      </div>

      <p class="prp__note" data-reveal>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Mascotas gratis cualquier día — <strong>excepto el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional</a></strong>, por la afluencia y el ruido del evento.</span>
      </p>
    </div>
  </section>

  <!-- ============== TODO INCLUIDO ============== -->
  <section class="pri" id="pri-title">
    <div class="container container--xl">
      <header class="pri__header" data-reveal>
        <span class="pri__eyebrow">— Todo incluido significa todo</span>
        <h2 class="pri__title">
          El día de tu descenso,<br/>
          <span class="serif-italic">ya lo tienes todo</span>
        </h2>
        <p class="pri__lead">
          Mira todo lo que incluye tu <strong>reserva Premium</strong> — tu día
          resuelto al detalle. Llegas, te recibimos, te equipamos, bajas el río
          y te traemos de vuelta. <strong>Tú solo tienes que despreocuparte y
          disfrutar</strong>.
        </p>
      </header>

      <ul class="priD">
        {incluido.map((it, i) => (
          <li class="priDItem" data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="priDItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="priDItem__body">
              <h3 class="priDItem__title">
                <span class="priDItem__icon" aria-hidden="true">
                  {it.icon === 'canoe'   && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 14c3-4 7-6 10-6s7 2 10 6"/><path d="M2 14c3 4 7 6 10 6s7-2 10-6"/></svg>}
                  {it.icon === 'shield'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {it.icon === 'wetsuit' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8l1 4-2 3v10a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V10L7 7z"/></svg>}
                  {it.icon === 'teacher' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>}
                  {it.icon === 'picnic'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h18l-1 5H4z"/><path d="M5 13l1 8M19 13l-1 8"/></svg>}
                  {it.icon === 'bus'     && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/></svg>}
                  {it.icon === 'shower'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6M8 9h8"/><path d="M6 12c0 5 2 9 6 9s6-4 6-9z"/></svg>}
