  .prf__title .serif-italic {
    color: var(--color-primary); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .prp__lead,
  .pri__lead,
  .prr__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .prp__lead strong,
  .pri__lead strong,
  .prr__lead strong {
    color: var(--color-text-primary); font-weight: 700;
  }

  /* ============== PRECIO CARDS ============== */
  .prp { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .prp__header {
    max-width: 720px; margin: 0 auto clamp(2.5rem, 5vw, 4rem); text-align: center;
  }
  .prp__grid {
    display: grid; grid-template-columns: 1fr; gap: var(--s-5);
    max-width: 1280px; margin: 0 auto;
  }
  @media (min-width: 720px)  { .prp__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .prp__grid { grid-template-columns: repeat(3, 1fr); } }

  /* --- TARJETA PRECIO (niños / adultos) --- */
  .prpCard {
    background: var(--color-bg-elevated, #FFFFFF);
    border: 1px solid var(--color-border-subtle);
    border-radius: clamp(1.25rem, 2vw, 1.75rem);
    display: flex; flex-direction: column;
    transition: transform 320ms cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 320ms cubic-bezier(0.34, 1.2, 0.64, 1),
                border-color 320ms ease;
    position: relative;
    overflow: hidden;
  }
  .prpCard:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 60px rgba(26, 31, 46, 0.1), 0 8px 18px rgba(26, 31, 46, 0.06);
  }
  .prpCard--sage:hover  { border-color: rgba(61, 79, 58, 0.4); }
  .prpCard--coral:hover { border-color: rgba(233, 133, 111, 0.5); }

  /* Media (imagen + overlay) */
  .prpCard__media {
    position: relative; overflow: hidden;
    border-radius: clamp(1rem, 1.8vw, 1.5rem);
    margin: 1rem 1rem 0;
    aspect-ratio: 4 / 3;
    isolation: isolate;
  }
  .prpCard__media :global(picture),
  .prpCard__media :global(img) {
    display: block; width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .prpCard:hover .prpCard__media :global(img) { transform: scale(1.04); }
  .prpCard__media::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.68) 0%, rgba(0,0,0,0.25) 40%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }
  .prpCard__mediaTag {
    position: absolute; top: 0.875rem; left: 0.875rem; z-index: 2;
    display: inline-flex; align-items: center;
    padding: 5px 11px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.4px; text-transform: uppercase;
  }
  .prpCard--sage  .prpCard__mediaTag { color: var(--color-sage, #3D4F3A); }
  .prpCard--coral .prpCard__mediaTag { color: var(--color-primary); }

  .prpCard__mediaContent {
    position: absolute; left: 1.125rem; right: 1.125rem; bottom: 1rem; z-index: 2;
    color: #fff;
  }
  .prpCard__mediaTitle {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.25rem);
    font-weight: 900; line-height: 1; letter-spacing: -0.02em;
    margin: 0 0 0.375rem;
    color: #fff;
    display: inline-flex; align-items: baseline; gap: 0.375rem;
  }
  .prpCard__mediaTitle span {
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 600;
    letter-spacing: 0.2px; opacity: 0.92; text-transform: none;
  }
  .prpCard__mediaSub {
    margin: 0;
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.4;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: 0.2px;
  }

  /* Cuerpo blanco */
  .prpCard__body {
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex; flex-direction: column;
    flex: 1;
  }

  .prpCard__head {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--s-3);
    margin-bottom: var(--s-5);
  }
  .prpCard__name {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1.9vw, 1.3125rem);
    font-weight: 800; line-height: 1.15; letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .prpCard__rating {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }
  .prpCard__rating svg {
    color: #E8B339;
  }

  /* Stats (4 chips) */
  .prpCard__stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    list-style: none; padding: 0;
    margin: 0 0 var(--s-5);
    background: var(--color-bg-warm, #F5F1E8);
    border-radius: 0.875rem;
    overflow: hidden;
  }
  .prpCard__stats li {
    display: flex; flex-direction: column; align-items: center;
    gap: 4px;
    padding: 0.9375rem 0.5rem;
    text-align: center;
    border-right: 1px solid rgba(26, 31, 46, 0.08);
    min-width: 0;
  }
  .prpCard__stats li:last-child { border-right: none; }
  .prpCard__stat-val {
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.15;
    max-width: 100%;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .prpCard__stat-lbl {
    font-family: var(--font-sans); font-size: 0.5625rem; font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 1.3px; text-transform: uppercase;
  }

  /* Descripción + lista */
  .prpCard__desc {
    margin: 0 0 var(--s-5);
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .prpCard__list {
    list-style: none; padding: 0;
    display: flex; flex-direction: column; gap: 0.8125rem;
    margin: 0 0 var(--s-6);
    flex: 1;
  }
  .prpCard__list li {
    position: relative;
    padding-left: 1.125rem;
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
  }
  .prpCard__list li::before {
    content: "";
    position: absolute; left: 0; top: 0.625rem;
    width: 6px; height: 6px;
    border-radius: 50%;
  }
  .prpCard--sage  .prpCard__list li::before { background: var(--color-sage, #3D4F3A); }
  .prpCard--coral .prpCard__list li::before { background: var(--color-primary); }
  .prpCard__list strong { color: var(--color-text-primary); font-weight: 700; }

  /* CTA negro full-width */
  .prpCard__cta {
    display: inline-flex; align-items: center; justify-content: center;
    gap: var(--s-2);
    width: 100%;
    padding: 1.0625rem 1.25rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #fff;
    border: 1.5px solid var(--color-text-primary, #1A1F2E);
    border-radius: 0.875rem;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.8px;
    transition: all 240ms cubic-bezier(0.34, 1.2, 0.64, 1);
    margin-top: auto;
  }
  .prpCard__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(26, 31, 46, 0.22);
  }
  .prpCard__cta--primary {
    background: var(--color-primary); color: #fff;
    border-color: var(--color-primary);
    box-shadow: 0 8px 20px rgba(233, 133, 111, 0.3);
  }
  .prpCard__cta--primary:hover {
    background: var(--color-primary-hover, #D66F59);
    border-color: var(--color-primary-hover, #D66F59);
    box-shadow: 0 12px 28px rgba(233, 133, 111, 0.5);
  }
  .prpCard__cta svg { transition: transform 200ms; }
  .prpCard__cta:hover svg { transform: translateX(3px); }

  /* --- TARJETA CTA IMAGEN (3ª) --- */
  .prpCardCTA {
    position: relative; overflow: hidden;
    border-radius: clamp(1.25rem, 2vw, 1.75rem);
    min-height: 380px;
    display: flex;
    isolation: isolate;
    transition: transform 320ms cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 320ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .prpCardCTA:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 60px rgba(26, 31, 46, 0.18), 0 8px 18px rgba(26, 31, 46, 0.08);
  }
  .prpCardCTA__media {
    position: absolute; inset: 0; z-index: 0;
  }
  .prpCardCTA__media :global(picture),
  .prpCardCTA__media :global(img),
  .prpCardCTA__video {
    display: block; width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 700ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .prpCardCTA:hover .prpCardCTA__media :global(img),
  .prpCardCTA:hover .prpCardCTA__video { transform: scale(1.04); }

  .prpCardCTA__media::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.15) 45%, rgba(0,0,0,0.75) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .prpCardCTA__inner {
    position: relative; z-index: 2;
    flex: 1;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    display: flex; flex-direction: column; justify-content: flex-end;
    color: #fff;
  }
  .prpCardCTA__bottom {
    display: flex; flex-direction: column; gap: 1.5rem;
  }
  .prpCardCTA__kicker {
    font-family: var(--font-serif);
    font-size: clamp(0.75rem, 1.1vw, 0.9375rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.1px;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: -0.5rem;
    white-space: nowrap;
  }
  .prpCardCTA__title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 2.8vw, 2.125rem);
    font-weight: 900; line-height: 1.08; letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }
  .prpCardCTA__btn {
    display: inline-flex; align-items: center; justify-content: space-between;
    gap: 0.75rem;
    align-self: flex-start;
    padding: 0.375rem 0.375rem 0.375rem 1.25rem;
    background: #fff;
    color: var(--color-text-primary, #1A1F2E);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700;
    letter-spacing: 0.2px;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }
  .prpCardCTA__btn:hover {
    transform: translateX(4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
  }
  .prpCardCTA__btnIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--color-text-primary, #1A1F2E);
    color: #fff;
    transition: transform 220ms ease;
  }
  .prpCardCTA__btn:hover .prpCardCTA__btnIcon { transform: rotate(-15deg); }

  /* Responsive: en tablet (2 cols) la CTA ocupa las 2 cols */
  @media (min-width: 720px) and (max-width: 1023.98px) {
    .prpCardCTA { grid-column: 1 / -1; min-height: 280px; }
  }
  @media (max-width: 719.98px) {
    .prpCardCTA { min-height: 320px; }
  }

  .prp__note {
    max-width: 760px; margin: clamp(2rem, 4vw, 3rem) auto 0;
    display: flex; align-items: flex-start; gap: var(--s-2);
    padding: var(--s-3) var(--s-4);
    background: rgba(61, 79, 58, 0.06);
    border-left: 2px solid var(--color-sage, #3D4F3A);
    border-radius: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.55;
    color: var(--color-text-secondary);
  }
  .prp__note svg { color: var(--color-sage, #3D4F3A); flex-shrink: 0; margin-top: 3px; }
  .prp__note a {
    color: var(--color-primary); font-weight: 600;
    border-bottom: 1px dashed var(--color-primary);
  }
  .prp__note strong { color: var(--color-text-primary); font-weight: 700; }

  /* ============== TODO INCLUIDO ============== */
  .pri { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .pri__header { max-width: 720px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  /* ============== RUTAS ============== */
  .prr { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .prr__header { max-width: 720px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  /* ============== PRI · Numerada editorial 3 cols + iconos + animaciones ============== */
  .priD {
    list-style: none; padding: 0; margin: 0 auto;
    max-width: 1100px;
    display: grid; grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 640px)  { .priD { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px)  { .priD { grid-template-columns: repeat(3, 1fr); } }

  .priDItem {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--s-4);
    padding: clamp(1.75rem, 3vw, 2.25rem) clamp(1rem, 2vw, 1.75rem);
    border-bottom: 1px solid var(--color-border-subtle);
    border-left: 3px solid transparent;
    align-items: start;
    transition: all 320ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .priDItem:hover {
    border-left-color: var(--color-primary);
    background: rgba(233, 133, 111, 0.03);
    transform: translateX(4px);
  }

  @media (min-width: 640px) {
    .priDItem { border-right: 1px solid var(--color-border-subtle); }
    .priDItem:nth-child(2n) { border-right: 0; }
  }
  @media (min-width: 960px) {
    .priDItem:nth-child(2n) { border-right: 1px solid var(--color-border-subtle); }
    .priDItem:nth-child(3n) { border-right: 0; }
    .priDItem:nth-last-child(-n+3) { border-bottom: 0; }
  }

  .priDItem__num {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: rgba(233, 133, 111, 0.18);
    min-width: 40px;
    transition: all 320ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .priDItem:hover .priDItem__num {
    color: rgba(233, 133, 111, 0.45);
    transform: scale(1.12);
  }

  .priDItem__body { min-width: 0; }
  .priDItem__title {
    display: flex; align-items: center; gap: var(--s-2);
    font-family: var(--font-display); font-size: 1rem; font-weight: 800;
    line-height: 1.3; letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-2);
  }
  .priDItem__icon {
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--color-primary);
    opacity: 0.7;
    flex-shrink: 0;
    transition: all 260ms var(--ease-out);
  }
  .priDItem:hover .priDItem__icon {
    opacity: 1;
    transform: scale(1.15) rotate(-6deg);
  }
  .priDItem__sub {
    font-family: var(--font-sans); font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* --- Acento sage para "Todo incluido" (sobrescribe el coral compartido) --- */
  .pri__eyebrow { color: var(--color-sage, #3D4F3A); }
  .pri__title .serif-italic { color: var(--color-sage, #3D4F3A); }
  .priDItem__num { color: rgba(61, 79, 58, 0.18); }
  .priDItem:hover .priDItem__num { color: rgba(61, 79, 58, 0.45); }
  .priDItem__icon { color: var(--color-sage, #3D4F3A); }


  /* ============== RUTAS · Variante C · Comparativa con línea central ============== */
  .prrC {
    max-width: 1000px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    padding-block: var(--s-6);
  }
  @media (min-width: 720px) {
    .prrC { grid-template-columns: 1fr auto 1fr; gap: clamp(2rem, 3.5vw, 3rem); }
  }

  .prrC__col {
    display: flex; flex-direction: column;
    text-align: center;
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
  }
  .prrC__km {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 900; line-height: 0.85;
    letter-spacing: -0.04em;
    margin-bottom: var(--s-2);
  }
  .prrC__km--sage  { color: var(--color-sage, #3D4F3A); }
  .prrC__km--coral { color: var(--color-primary); }
  .prrC__dur {
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--s-4);
  }
  .prrC__name {
    font-family: var(--font-display); font-size: clamp(1.25rem, 2vw, 1.625rem);
    font-weight: 800; line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-4);
  }
  .prrC__sep {
    width: 40px; height: 2px;
    background: var(--color-border-subtle);
    margin: 0 auto var(--s-4);
  }
  .prrC__desc {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 38ch;
    margin-inline: auto;
  }

  .prrC__divider {
    display: none;
    width: 1px;
    background: var(--color-border-subtle);
    position: relative;
    align-self: stretch;
  }
  @media (min-width: 720px) { .prrC__divider { display: block; } }
  .prrC__vs {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-bg-base);
    padding: var(--s-2) var(--s-3);
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ============== DÍA ESPECIAL · Sage banner ============== */
  .prdC {
    padding-block: clamp(4.5rem, 9vw, 7rem);
    background: var(--color-sage, #3D4F3A);
    color: var(--color-text-on-dark, #FBF8F1);
    text-align: center;
  }
  .prdC__head { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); }
  .prdC__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    margin-bottom: var(--s-4);
  }
  .prdC__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900; line-height: 0.98;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-on-dark);
    margin: 0 0 var(--s-4);
  }
  .prdC__title .serif-italic {
    color: var(--color-primary); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
  }
  .prdC__text {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    color: rgba(251, 248, 241, 0.82);
    margin: 0;
    max-width: 52ch; margin-inline: auto;
  }

  .prdC__stats {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: var(--s-4);
    max-width: 960px; margin: 0 auto clamp(2rem, 4vw, 3rem);
    padding: var(--s-5) 0;
    border-top: 1px solid rgba(251, 248, 241, 0.14);
    border-bottom: 1px solid rgba(251, 248, 241, 0.14);
  }
  @media (min-width: 640px) { .prdC__stats { grid-template-columns: repeat(4, 1fr); } }
  .prdC__stat { display: flex; flex-direction: column; gap: 4px; }
  .prdC__stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 900; line-height: 1;
    color: var(--color-primary);
    letter-spacing: -0.015em;
  }
  .prdC__stat-label {
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 700;
    letter-spacing: 1.4px; text-transform: uppercase;
    color: rgba(251, 248, 241, 0.6);
  }

  .prdC__cta {
