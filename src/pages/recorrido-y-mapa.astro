    font-family: var(--font-display); font-weight: 900;
    font-size: 1.25rem; letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-right: 0.5rem;
  }
  .rrs__counterTotal {
    font-family: var(--font-sans); font-size: 0.8125rem;
    color: var(--color-text-muted); font-weight: 700;
  }
  .rrs__navBtn {
    width: 42px; height: 42px; border-radius: 50%;
    background: transparent;
    border: 1px solid var(--color-text-primary);
    color: var(--color-text-primary);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 200ms, transform 200ms, color 200ms;
  }
  .rrs__navBtn:hover:not(:disabled) { transform: translateY(-2px); }
  .rrs__navBtn.is-dark {
    background: var(--color-text-primary); color: var(--color-bg-warm, #F6F1E3);
  }
  .rrs__navBtn:disabled { opacity: 0.4; cursor: not-allowed; }

  .rrs__track {
    display: flex; gap: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 1300px; margin: 0 auto;
    overflow-x: auto; overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .rrs__track::-webkit-scrollbar { display: none; }

  .rrsItem {
    flex: 0 0 min(920px, 92vw);
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
    align-items: center;
  }
  @media (max-width: 820px) {
    .rrsItem { grid-template-columns: 1fr; }
  }
  .rrsItem__num {
    position: absolute;
    top: -1.25rem; right: 1rem;
    font-family: var(--font-serif); font-style: italic;
    font-size: clamp(4rem, 7vw, 6rem);
    font-weight: 400; line-height: 1;
    color: rgba(26, 31, 46, 0.08);
    pointer-events: none;
    z-index: 0;
  }
  .rrsItem__media {
    position: relative;
