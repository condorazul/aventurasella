    letter-spacing: -0.02em;
    color: #FFFFFF;
    margin: 0;
  }
  .rrb__title .serif-italic {
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    letter-spacing: -0.005em;
    color: var(--color-primary-soft, #F5C5B5);
  }
  .rrb__cta {
    display: inline-flex; align-items: center; gap: 0.625rem;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    background: #FFFFFF;
    color: var(--color-text-primary, #1A1F2E);
    border-radius: var(--radius-pill, 999px);
    font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 700;
    letter-spacing: -0.005em;
    text-decoration: none;
    transition: transform 300ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 300ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
    white-space: nowrap;
    justify-self: end;
  }
  @media (max-width: 720px) { .rrb__cta { justify-self: start; } }
  .rrb__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px -12px rgba(0, 0, 0, 0.45);
  }
  .rrb__ctaIcon {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--color-text-primary, #1A1F2E);
    color: #FFFFFF;
    display: inline-flex; align-items: center; justify-content: center;
    transition: transform 300ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .rrb__cta:hover .rrb__ctaIcon { transform: rotate(-8deg) translateX(2px); }

  /* ============== 3.5 · TRAMO POR TRAMO · timeline editorial ============== */
  .rrt {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-base, #FBF8F1);
    position: relative;
  }
  .rrt::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26, 31, 46, 0.1), transparent);
  }
  .rrt__header { max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center; }
  .rrt__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }
  .rrt__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary); margin: 0 0 1.25rem;
  }
  .rrt__title .serif-italic {
    color: var(--color-sage, #3D4F3A);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    letter-spacing: -0.01em; text-transform: none;
  }
  .rrt__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.75;
    color: var(--color-text-secondary); margin: 0;
  }
  .rrt__lead strong { color: var(--color-text-primary); font-weight: 700; }
  .rrt__lead a { color: var(--color-sage, #3D4F3A); border-bottom: 1px solid rgba(61, 79, 58, 0.4); }

  /* Timeline centrado · spine con fill por scroll + cards alternas + iconos limpios */
  .rrt__track {
    position: relative;
    max-width: 1040px;
    margin: 0 auto;
    padding-block: 1rem;
  }

  /* Spine vertical centrado (desktop) · 26 px (mobile) · 4 px grosor */
  .rrt__spine {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 4px;
    transform: translateX(-2px);
    pointer-events: none;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .rrt__spine { left: 26px; transform: translateX(-2px); }
  }
  .rrt__spineBg {
    position: absolute; inset: 0;
    background: rgba(61, 79, 58, 0.16);
    border-radius: 4px;
  }
  .rrt__spineFg {
    position: absolute; inset: 0;
    background: linear-gradient(180deg,
      var(--color-sage, #3D4F3A) 0%,
      var(--color-sage, #3D4F3A) 50%,
      var(--color-primary, #E9856F) 100%);
    border-radius: 4px;
    transform-origin: top;
    transform: scaleY(var(--rrt-progress, 0));
    transition: transform 120ms linear;
    box-shadow: 0 0 16px rgba(233, 133, 111, 0.22);
  }
  @media (prefers-reduced-motion: reduce) {
    .rrt__spineFg { transition: none; transform: scaleY(1); }
  }

  .rrt__timeline {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    position: relative;
    z-index: 1;
  }

  .rrtItem {
    display: grid;
    grid-template-columns: 1fr 96px 1fr;
    column-gap: clamp(1rem, 3vw, 2.5rem);
    align-items: start;
    position: relative;
  }

  /* Pane · texto directo sobre el fondo claro de la sección, sin recuadro */
  .rrtItem__pane {
    padding: 0.25rem 0;
    min-width: 0;
    transition: transform 420ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .rrtItem:hover .rrtItem__pane {
    transform: translateY(-2px);
  }

  /* Alternancia: item impar → card a la izquierda, axis centro, col 3 vacía */
  .rrtItem:nth-child(odd) .rrtItem__pane {
    grid-column: 1;
    text-align: right;
  }
  .rrtItem:nth-child(even) .rrtItem__pane {
    grid-column: 3;
    text-align: left;
  }

  /* Axis con nodo circular · icono de alto contraste */
  .rrtItem__axis {
    grid-column: 2;
    justify-self: center;
    display: flex; align-items: flex-start; justify-content: center;
    padding-top: 1.25rem;
    position: relative;
    z-index: 2;
  }
  .rrtItem__node {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--color-sage, #3D4F3A);
    color: var(--color-bg-base, #FBF8F1);
    display: flex; align-items: center; justify-content: center;
    box-shadow:
      0 0 0 6px var(--color-bg-base, #FBF8F1),
      0 12px 28px -10px rgba(26, 31, 46, 0.3);
    transition: transform 420ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 320ms ease;
  }
  .rrtItem:hover .rrtItem__node { transform: scale(1.08); }
  .rrtItem__icon { display: block; flex-shrink: 0; }

  /* Meta · km + separador + tag en una línea */
  .rrtItem__meta {
    display: inline-flex; align-items: center; gap: 0.625rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
  }
  .rrtItem:nth-child(odd) .rrtItem__pane > .rrtItem__meta {
    flex-direction: row-reverse;
  }
  .rrtItem__km {
    color: var(--color-sage, #3D4F3A);
  }
  .rrtItem.is-highlight .rrtItem__km {
    color: var(--color-primary, #E9856F);
  }
  .rrtItem__sep {
    width: 4px; height: 4px; border-radius: 50%;
    background: rgba(26, 31, 46, 0.25);
    flex-shrink: 0;
  }
  .rrtItem__tag {
    color: var(--color-text-muted, #8A8578);
    font-weight: 700;
  }

  .rrtItem__name {
    font-family: var(--font-display);
    font-size: clamp(1.1875rem, 2.1vw, 1.5rem);
    font-weight: 900; line-height: 1.2;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary, #1A1F2E);
    margin: 0 0 0.875rem;
  }
  .rrtItem__text {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #4A5267);
    margin: 0;
  }
  .rrtItem__text strong { color: var(--color-text-primary, #1A1F2E); font-weight: 700; }
  .rrtItem__text a {
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(61, 79, 58, 0.4);
    transition: color 220ms, border-color 220ms;
  }
  .rrtItem__text a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  @media (prefers-reduced-motion: reduce) {
    .rrtItem__pane, .rrtItem__node { transition: none; }
    .rrtItem:hover .rrtItem__pane { transform: none; }
    .rrtItem:hover .rrtItem__node { transform: none; }
  }

  /* Mobile · single-column left-aligned (spine a la izquierda) */
  @media (max-width: 768px) {
    .rrt__timeline { gap: 2rem; }
    .rrtItem,
    .rrtItem:nth-child(odd),
    .rrtItem:nth-child(even) {
      grid-template-columns: 52px 1fr;
      column-gap: 1rem;
    }
    .rrtItem__axis,
    .rrtItem:nth-child(odd) .rrtItem__axis,
    .rrtItem:nth-child(even) .rrtItem__axis {
      grid-column: 1;
      justify-self: start;
      padding-top: 0.5rem;
    }
    .rrtItem__pane,
    .rrtItem:nth-child(odd) .rrtItem__pane,
    .rrtItem:nth-child(even) .rrtItem__pane {
      grid-column: 2;
      text-align: left;
    }
    .rrtItem:nth-child(odd) .rrtItem__pane > .rrtItem__meta {
      flex-direction: row;
    }
    .rrtItem__node { width: 44px; height: 44px; }
    .rrtItem__icon { width: 19px; height: 19px; }
  }

  /* ============== 4 · CHIRINGUITOS · intro arriba + panel 6 celdas iguales ============== */
  .rrc {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-sand, #F1E9D4);
  }

  .rrc__intro {
    max-width: 760px;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }
  .rrc__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: clamp(1rem, 2vw, 1.25rem);
  }
  .rrc__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 900; line-height: 1.02;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 clamp(1rem, 2vw, 1.25rem);
  }
  .rrc__title .serif-italic {
    color: var(--color-sage, #3D4F3A);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    letter-spacing: -0.01em; text-transform: none;
  }
  .rrc__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .rrc__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Panel abierto · hairlines directas sobre el fondo sand, sin card blanca */
  .rrc__panel {
    max-width: 1200px; margin: 0 auto;
  }
  .rrc__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid rgba(26, 31, 46, 0.14);
    border-bottom: 1px solid rgba(26, 31, 46, 0.14);
  }
  @media (min-width: 560px) { .rrc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .rrc__grid { grid-template-columns: repeat(3, 1fr); } }

  .rrc__cell {
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    min-height: 168px;
    border-right: 1px solid rgba(26, 31, 46, 0.14);
    border-bottom: 1px solid rgba(26, 31, 46, 0.14);
    transition: background 300ms ease;
  }
  /* Desktop 3-col · última columna sin border-right + última fila sin border-bottom */
  @media (min-width: 960px) {
    .rrc__cell:nth-child(3n) { border-right: none; }
    .rrc__cell:nth-last-child(-n+3) { border-bottom: none; }
  }
  /* Tablet 2-col */
  @media (min-width: 560px) and (max-width: 959.98px) {
    .rrc__cell:nth-child(2n) { border-right: none; }
    .rrc__cell:nth-last-child(-n+2) { border-bottom: none; }
  }
  /* Mobile 1-col · sin border-right nunca, último sin border-bottom */
  @media (max-width: 559.98px) {
    .rrc__cell { border-right: none; }
    .rrc__cell:last-child { border-bottom: none; }
  }
  .rrc__cell:hover {
    background: rgba(255, 255, 255, 0.35);
  }

  .rrc__cellBody {
    display: flex; flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .rrc__cellName {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.2vw, 1.875rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #1A1F2E);
