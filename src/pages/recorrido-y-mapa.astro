  .rrh__cta--link svg { transition: transform 200ms; }
  .rrh__cta--link:hover svg { transform: translateX(3px); }

  /* ============== 3 · HITOS · feature spread editorial (Variante C elegida) ============== */
  .rrs {
    padding-block: clamp(4rem, 7vw, 5.5rem);
    background: var(--color-bg-warm, #F6F1E3);
    overflow: hidden;
  }
  .rrs__header {
    display: flex; align-items: flex-end; justify-content: space-between;
