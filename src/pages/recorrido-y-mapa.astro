    color: var(--color-sage); margin: 0;
  }
  .rrsItem__text {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.8;
    color: var(--color-text-secondary); margin: 0;
    max-width: 440px;
  }
  .rrsItem__text strong { color: var(--color-text-primary); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .rrs__navBtn { transition: none; }
    .rrs__navBtn:hover:not(:disabled) { transform: none; }
  }

  /* ============== 3.25 · BANNER oscuro · ¿Listo para hacer el descenso? ============== */
  .rrb {
    padding-block: clamp(2.25rem, 4vw, 3rem);
    background: var(--color-bg-dark, #1A1F2E);
    color: var(--color-text-on-dark, #F4F0E8);
  }
  .rrb__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }
  @media (max-width: 720px) {
    .rrb__inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .rrb__text { min-width: 0; }
  .rrb__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary, #E9856F);
