  }
  @media (min-width: 560px)  { .rpI__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px)  { .rpI__grid { grid-template-columns: repeat(4, 1fr); } }

  .rpI__cell {
    position: relative;
    padding: clamp(1.5rem, 2.75vw, 2rem);
    display: flex; align-items: flex-start; gap: 0.875rem;
    border-right: 1px solid rgba(26, 31, 46, 0.14);
    border-bottom: 1px solid rgba(26, 31, 46, 0.14);
