---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const title = 'Reserva Premium · descenso del Sella todo incluido';
const description = 'Descenso del Sella Premium · 40€ adulto · 30€ niño · mascotas gratis. Todo incluido + picnic asturiano (empanada de bonito, bollín preñao) de regalo.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/reserva-premium/`;

// Items de "Qué incluye" · grid editorial 4×4 (13 items, picnic full-width última fila)
const includesPremium = [
  { icon: 'parking',   name: 'Parking privado',           nota: 'Vigilado y gratuito · 300 plazas · también para autocaravanas · junto a base',  highlight: false },
  { icon: 'canoa',     name: 'Canoa insumergible',        nota: 'Sistema insumergible · 1 a 3 plazas · homologada · mantenimiento diario',      highlight: false },
  { icon: 'chaleco',   name: 'Chaleco homologado',        nota: 'Obligatorio CHC · talla adulto e infantil · ajuste verificado',                highlight: false },
  { icon: 'pala',      name: 'Pala doble',                nota: 'De doble hoja en aluminio · una por persona · ligera y ergonómica',             highlight: false },
  { icon: 'neopreno',  name: 'Traje de neopreno',         nota: 'En fechas frías establecidas · protección térmica contra el agua fría',         highlight: false },
  { icon: 'bidon',     name: 'Bidón estanco',             nota: 'Tus cosas secas todo el descenso · móvil · cartera · ropa',                    highlight: false },
  { icon: 'rampa',     name: 'Rampa de embarque',         nota: 'Opcional y gratuita · embarca por la rampa o directamente a pie de río',      highlight: false },
  { icon: 'monitor',   name: 'Monitor titulado',          nota: 'Brief de seguridad · mini clase de remo · equipo asturiano',                   highlight: false },
  { icon: 'transfer',  name: 'Transfer de vuelta',        nota: 'Te recogemos en Toraño (Mini) o Fríes (Completo) y vuelta a base',             highlight: false },
  { icon: 'duchas',    name: 'Vestuarios con duchas',     nota: 'Cambio cómodo antes y después · agua caliente al terminar',                    highlight: false },
  { icon: 'taquilla',  name: 'Taquillas con llave',       nota: 'Tus cosas seguras · lo que otros cobran aparte, incluido en el precio',       highlight: false },
  { icon: 'seguro',    name: 'Seguros obligatorios',      nota: 'Responsabilidad civil y accidentes · incluidos sin coste añadido',              highlight: false },
  { icon: 'picnic',    name: 'Picnic asturiano',          nota: 'Empanada de bonito · bollín preñao · botella de agua 500 ml · dentro del bidón', highlight: true  },
];

// Precio actual (confirmado 2026-04-10 · project_premium_strategy.md)
const tarifas = [
  { label: 'Adulto',          from: 13, to: 99, price: '40', unit: '€' },
  { label: 'Niño',            from: 5,  to: 12, price: '30', unit: '€' },
  { label: 'Mascotas',        from: 0,  to: 0,  price: 'gratis', unit: '' },
];

// Testimonios reales (reference_reviews.md)
const testimonios = [
  { initial: 'N', name: 'Nacho A.',    source: 'TripAdvisor', date: 'agosto 2025', context: 'Parejas', rating: 5,
    text: 'Todo puntual y muy amables. Una experiencia para probar una vez en la vida, recomendada para jóvenes y mayores.' },
  { initial: 'C', name: 'Carlos S.',   source: 'TripAdvisor', date: 'mayo 2025',   context: 'Amigos',  rating: 5,
    text: 'Merece la pena. Tienes vestuarios y puedes ducharte tras la actividad. Te dan instrucciones divertidas, un bidón donde meter muchas cosas y el resto te lo da el río.' },
  { initial: 'A', name: 'Anaïs Suárez', source: 'Google',    date: 'octubre 2025', context: 'Experiencia', rating: 5,
    text: 'Buen servicio, trabajadores atentos y muy simpáticos. La experiencia genial, me ha encantado.' },
];

const faqs = [
  { q: '¿Qué incluye exactamente la reserva Premium del descenso del Sella?',
    a: 'Todo lo necesario para bajar el Sella sin preocuparte por nada: <strong>parking privado vigilado (300 plazas · también para autocaravanas), canoa insumergible (1-3 plazas), chaleco homologado, pala doble, traje de neopreno en fechas frías, bidón estanco, rampa de embarque opcional (o embarcas a pie de río), monitor titulado, transfer de vuelta, vestuarios con duchas calientes, taquillas con llave (que otras empresas cobran aparte), seguros obligatorios y el <em>picnic asturiano como regalo</em></strong>. Son 13 cosas, todas en el precio. No hay extras ocultos.' },
  { q: '¿Cuánto cuesta el descenso Premium?',
    a: '<strong>40 € por adulto</strong> (de 13 años en adelante) y <strong>30 € por niño</strong> (de 5 a 12 años). Las <strong>mascotas son gratis</strong>. El precio es el mismo para la Mini Sella (7 km) y el Descenso Completo (14,5 km) — no hay sorpresas.' },
  { q: '¿En qué se diferencia Premium del descenso básico de otros operadores?',
    a: 'Competidores del valle del Sella suelen ofrecer entre 15 y 35 € sin picnic, con canoa y chaleco nada más. Nuestra <strong>reserva Premium cuesta un poco más pero incluye: parking privado vigilado, rampa de embarque propia (opcional y gratuita, si prefieres embarcas a pie de río), canoa con sistema insumergible, traje de neopreno en fechas frías, picnic asturiano, transfer, vestuarios con duchas calientes, <em>taquillas con llave</em> y seguros — todo cosas que otros operadores cobran aparte o no ofrecen</strong>. Es la versión sin sorpresas.' },
  { q: '¿Qué lleva el picnic asturiano?',
    a: 'Cocina asturiana tradicional: una <strong>empanada de bonito</strong>, un <strong>bollín preñao</strong> (chorizo envuelto en pan) y una <strong>botella de agua de 500 ml</strong>. Todo dentro del bidón estanco para que llegue seco y fresco. Puedes disfrutarlo donde quieras del recorrido — en una playa fluvial, en una orilla o tras el último rápido. <em>El picnic es fijo y el mismo para todos los clientes — no tenemos opción vegana ni vegetariana. Si tienes una alergia concreta (gluten, frutos secos...), avísanos al reservar para confirmarte los ingredientes.</em>' },
  { q: '¿Tengo que elegir una hora de salida?',
    a: 'No. Tu reserva es <strong>Premium · horario abierto</strong>: llega a nuestras instalaciones de Arriondas <strong>cuando te venga bien entre las 10:30 y las 12:30</strong>, sin elegir hora concreta. Es una de las <strong>ventajas Premium</strong> · te equipamos al llegar y sales al río según estés listo. <strong>Excepciones</strong>: el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional</a> sí tiene salida única en hora concreta · y si por temporal o condiciones del río necesitamos una hora específica o salida con monitor, te avisamos con antelación. La Confederación Hidrográfica marca permanencia en el río hasta las 18:00.' },
  { q: '¿Tengo que pagar ahora al reservar?',
    a: 'No. Puedes pagar <strong>con tarjeta al reservar o el día que recojas la canoa</strong>. Lo que tú prefieras.' },
  { q: '¿Puedo reservar el mismo día?',
    a: 'Sí — <strong>siempre que el calendario de reserva muestre disponibilidad</strong> para ese día. Nuestra recomendación sincera es <strong>reservar con antelación</strong>, sobre todo en temporada alta (julio-agosto) y fines de semana, cuando las plazas se agotan rápido. El <a href="/reservar/">calendario online</a> te muestra en tiempo real los días libres. Reservar cuesta 2 minutos y <strong>no tienes que pagar nada en ese momento</strong>.' },
  { q: '¿Se puede cancelar la reserva Premium?',
    a: 'Sí. Puedes <strong>cambiar o cancelar tu reserva en cualquier momento antes del día de la actividad</strong>, sin coste. Si pagaste con <strong>tarjeta por adelantado</strong>, para tramitar el reembolso necesitamos que nos avises con un mínimo de <strong>24 h de antelación</strong>. Si el tiempo no acompaña o la Confederación Hidrográfica cierra el río, reprogramamos o devolvemos el importe íntegro.' },
  { q: '¿Hay alguna opción superior a Premium?',
    a: 'No hay más categorías. <strong>Todas nuestras reservas son Premium</strong> — es nuestra forma estándar de hacer las cosas: todo incluido, picnic de regalo, sin planes engañosos con "niveles" distintos. Lo que ves es lo que hay.' },
  { q: '¿Puedo regalar un descenso Premium?',
    a: 'Sí, funciona muy bien como <strong>regalo de cumpleaños, aniversario o experiencia</strong>. Reservas la fecha y emitimos una tarjeta regalo con el nombre de quien lo recibe. <a href="/contacto/">Escríbenos</a> y lo preparamos.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Reserva Premium del descenso del Sella — Todo Incluido + Picnic Asturiano',
      description: 'Reserva Premium del descenso del Sella: 40€ adulto, 30€ niño, mascotas gratis, picnic asturiano incluido. Todo en el precio.',
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-04-22',
      about: 'Descenso del Sella Premium todo incluido con picnic asturiano desde Arriondas',
    },
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descenso del Sella · Reserva Premium',
      description: 'Descenso del Sella en canoa con todo incluido y picnic asturiano de regalo (empanada de bonito, bollín preñao y agua). Desde Arriondas, 14,5 km (Completo) o 7 km (Mini Sella).',
      image: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      aggregateRating: { '@type': 'AggregateRating', ratingValue: 4.5, reviewCount: 147, bestRating: 5, worstRating: 1 },
      offers: [
        { '@type': 'Offer', name: 'Adulto',  price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/reservar/` },
        { '@type': 'Offer', name: 'Niño',    price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/reservar/` },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',          item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Reserva Premium', item: canonicalUrl },
      ],
    },
  ],
};

// Iconos mínimos stroke-based para "Qué incluye"
const iconPaths = {
  parking:  '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M10 8v8M10 8h3.5a2.5 2.5 0 0 1 0 5H10"/>',
  canoa:    '<path d="M3 14c3 3 7 4 9 4s6-1 9-4"/><path d="M5 14l2-8h10l2 8"/><line x1="12" y1="6" x2="12" y2="14"/>',
  chaleco:  '<path d="M7 4h10v4l-2 2v10H9V10L7 8z"/><line x1="9" y1="14" x2="15" y2="14"/>',
  neopreno: '<path d="M8 4l-2 2v4l2 1v11h8V11l2-1V6l-2-2zM10 4v2h4V4"/>',
  pala:     '<line x1="5.5" y1="12" x2="18.5" y2="12"/><ellipse cx="3" cy="12" rx="2.5" ry="4.5"/><ellipse cx="21" cy="12" rx="2.5" ry="4.5"/>',
  rampa:    '<line x1="3" y1="20" x2="21" y2="20"/><path d="M5 20V13h14v7"/><path d="M3 10c3 2 6 2 9 0s6-2 9 0"/>',
  bidon:    '<path d="M8 4h8v3H8zM7 7h10v14H7zM7 12h10M7 17h10"/>',
  transfer: '<rect x="3" y="8" width="18" height="10" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/><line x1="3" y1="12" x2="21" y2="12"/>',
  duchas:   '<circle cx="7" cy="5" r="2"/><path d="M5 7v3h4V7M3 10h8M5 10v4M7 10v6M9 10v4"/>',
  taquilla: '<rect x="5" y="11" width="14" height="10" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/>',
  monitor:  '<circle cx="12" cy="8" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>',
  seguro:   '<path d="M12 3L5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  picnic:   '<path d="M4 11h16l-2 10H6z"/><path d="M8 11V6a4 4 0 0 1 8 0v5"/><line x1="10" y1="15" x2="10" y2="18"/><line x1="14" y1="15" x2="14" y2="18"/>',
};

const starSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/reserva-premium/" translationKey="reserva_premium">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · premium editorial con badge picnic ============== -->
  <section class="rpH" aria-labelledby="rpH-title">
    <span class="rpH__watermark" aria-hidden="true">Premium</span>

    <div class="rpH__inner">
      <nav class="rpH__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Reserva Premium</span>
      </nav>

      <div class="rpH__grid">
        <div class="rpH__main">
          <span class="rpH__eyebrow">— Para tu día perfecto en el Sella</span>

          <h1 id="rpH-title" class="rpH__title">
            Todo el Sella.<br/>
            <span class="serif-italic">Sin pensar en nada.</span>
          </h1>

          <div class="rpH__deluxe" aria-hidden="true">
            <span class="rpH__deluxeMark"></span>
            <span class="rpH__deluxeWord">Premium</span>
            <span class="rpH__deluxeMark"></span>
          </div>

          <p class="rpH__lead">
            El descenso del Sella con <strong>todo incluido</strong> — canoa, chaleco, pala, bidón, transfer, duchas calientes y <strong>picnic asturiano de regalo</strong>. Una sola tarifa honesta, sin extras, sin sorpresas.
          </p>

          <div class="rpH__stats">
            <span class="rpH__statsKicker">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Todo incluido · sin extras
            </span>
            <div class="rpH__statsRow">
              <div class="rpH__stat">
                <strong>40<small>€</small></strong>
                <span>Adulto</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>30<small>€</small></strong>
                <span>Niño · 5–12</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>Gratis</strong>
                <span>Mascotas</span>
              </div>
            </div>
          </div>

          <div class="rpH__ctas">
            <a href="/reservar/" class="rpH__cta rpH__cta--primary">
              Reservar ahora
              <span class="rpH__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
            <a href="#rpH-incluye" class="rpH__cta rpH__cta--ghost">
              Ver qué incluye
            </a>
          </div>
        </div>

        <aside class="rpH__contact" aria-labelledby="rpH-contact-kicker">
          <span class="rpH__contactKicker" id="rpH-contact-kicker">— ¿Hablamos?</span>
          <ul class="rpH__contactList" role="list">
            <li>
              <a href="tel:+34681093673" class="rpH__contactPill rpH__contactPill--primary" aria-label="Llamar al 681 09 36 73">
                <strong>Llámanos</strong>
                <small>681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Hola%2C%20tengo%20una%20pregunta%20sobre%20la%20Reserva%20Premium" target="_blank" rel="noopener noreferrer" class="rpH__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Respuesta en minutos</small>
              </a>
            </li>
            <li>
              <a href="mailto:reservas@aventuraenelsella.es" class="rpH__contactPill" aria-label="Email">
                <strong>Email</strong>
                <small>Reservas y dudas</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== 2 · ¿QUÉ ES PREMIUM? · definición honesta ============== -->
  <section class="rpQ" aria-labelledby="rpQ-title">
    <div class="container container--xl">
      <div class="rpQ__grid">
        <header class="rpQ__head" data-reveal>
          <span class="rpQ__eyebrow">— Qué es Premium en esta casa</span>
          <h2 id="rpQ-title" class="rpQ__title">
            No es más caro.<br/>
            <span class="serif-italic">Es todo incluido.</span>
          </h2>
        </header>
        <div class="rpQ__body" data-reveal data-reveal-delay="1">
          <p class="rpQ__lead">
            "Premium" aquí no significa pomposo ni pijo. Significa <strong>una sola tarifa honesta</strong> con absolutamente todo lo que necesitas en la canoa — y un <strong>picnic asturiano esperándote</strong> dentro del bidón estanco.
          </p>
          <p class="rpQ__lead">
            Los operadores del valle del Sella cobran entre 15 y 35 € por la canoa básica. Nuestra tarifa de <strong>40 € por adulto</strong> es apenas unos euros más, pero incluye lo que otros te venden como extras o no ofrecen: <strong>parking privado vigilado</strong>, canoa insumergible, <strong>rampa de embarque propia</strong> (opcional y gratuita), traje de neopreno en fechas frías, bidón, transfer, vestuarios con duchas calientes, <strong>taquillas con llave</strong>, seguros y el <strong>picnic asturiano</strong>. <em>Sin sorpresas al final del día.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 3 · QUÉ INCLUYE · grid editorial 4×2 con picnic destacado ============== -->
  <section class="rpI" id="rpH-incluye" aria-labelledby="rpI-title">
    <div class="container container--xl">
      <header class="rpI__header" data-reveal>
        <span class="rpI__eyebrow">— 13 cosas incluidas</span>
        <h2 id="rpI-title" class="rpI__title">
          Lo que entra<br/>
          <span class="serif-italic">en la reserva Premium.</span>
        </h2>
        <p class="rpI__lead">
          Todo lo de la lista va en el precio. Nada se cobra aparte. <strong>Nada.</strong>
        </p>
      </header>

      <ol class="rpI__grid">
        {includesPremium.map((item, i) => (
          <li class={`rpI__cell${item.highlight ? ' is-highlight' : ''}`}>
            <span class="rpI__cellNum" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rpI__cellBody">
              <span class="rpI__cellIcon" aria-hidden="true">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[item.icon]} />
              </span>
              <h3 class="rpI__cellName">{item.name}</h3>
              <p class="rpI__cellNota">{item.nota}</p>
              {item.highlight && <span class="rpI__cellBadge">REGALO</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 4 · BANNER NAVY · CTA justo tras los 13 incluidos ============== -->
  <section class="rpB" aria-label="Llamada a la acción · reservar Premium">
    <div class="container container--xl">
      <div class="rpB__inner" data-reveal>
        <div class="rpB__text">
          <span class="rpB__eyebrow">— Aventura en el Sella</span>
          <h2 class="rpB__title">¿Listo para el río <span class="serif-italic">y el picnic?</span></h2>
        </div>
        <a href="/reservar/" class="rpB__cta">
          <span>Reservar ahora</span>
          <span class="rpB__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 5 · PICNIC ASTURIANO · feature spread dedicado ============== -->
  <section class="rpP" aria-labelledby="rpP-title">
    <div class="container container--xl">
      <div class="rpP__split">
        <div class="rpP__media" data-reveal data-reveal-type="slide-right">
          <Picture src="fiesta-sella" alt="Ambiente y picnic asturiano en el descenso del Sella · Reserva Premium con todo incluido" sizes="(min-width: 960px) 45vw, 100vw" bare />
          <span class="rpP__mediaTag">Incluido · Regalo</span>
        </div>
        <div class="rpP__body" data-reveal data-reveal-delay="1">
          <span class="rpP__eyebrow">— El diferencial</span>
          <h2 id="rpP-title" class="rpP__title">
            Picnic asturiano<br/>
            <span class="serif-italic">dentro del bidón.</span>
          </h2>
          <p class="rpP__lead">
            Cocina asturiana pura: una <strong>empanada de bonito</strong>, un <strong>bollín preñao</strong> (chorizo envuelto en pan) y una <strong>botella de agua de 500 ml</strong>. Simple, honesto, sabroso — dentro del bidón estanco para que llegue seco y fresco.
          </p>
          <ul class="rpP__list">
            <li><span class="rpP__listDot" aria-hidden="true"></span>Cómelo en una <strong>playa fluvial</strong> — el Pozo del Arco es el favorito del equipo.</li>
            <li><span class="rpP__listDot" aria-hidden="true"></span>O paras en uno de los <strong>6 chiringuitos</strong> y lo abres allí con calma.</li>
