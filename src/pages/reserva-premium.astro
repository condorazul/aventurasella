  }
  .rpI__cell:hover { background: rgba(255, 255, 255, 0.4); }
  .rpI__cell.is-highlight {
    background: rgba(233, 133, 111, 0.08);
  }
  .rpI__cell.is-highlight:hover { background: rgba(233, 133, 111, 0.14); }

  /* Desktop 4-col · picnic full-width última fila */
  @media (min-width: 960px) {
    .rpI__cell:nth-child(4n) { border-right: none; }
    .rpI__cell.is-highlight {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: none;
      min-height: auto;
      padding: clamp(1.125rem, 2vw, 1.5rem) clamp(1.5rem, 2.75vw, 2rem);
