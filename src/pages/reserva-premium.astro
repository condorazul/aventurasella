<style>
  /* ==================== 1 · HERO ==================== */
  .rpH {
    position: relative;
    background:
      radial-gradient(ellipse 70% 55% at 90% 0%, rgba(233, 133, 111, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 45% at 10% 100%, rgba(61, 79, 58, 0.08) 0%, transparent 60%),
      linear-gradient(180deg, #F9F5EA 0%, #F0E9D3 100%);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    overflow: hidden; isolation: isolate;
  }
  .rpH__watermark {
    position: absolute;
    top: 10%; right: -2%;
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    font-size: clamp(10rem, 22vw, 22rem);
    line-height: 0.85;
    color: rgba(26, 31, 46, 0.04);
    pointer-events: none; user-select: none;
    z-index: 0;
  }
  .rpH__inner {
    max-width: 1280px; margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1rem, 3vw, 2rem) 0;
    position: relative; z-index: 1;
  }
  /* Grid 2 cols · contenido + contacto a la derecha · respira */
  .rpH__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 1080px) {
    .rpH__grid {
      grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.75fr);
      gap: clamp(3rem, 6vw, 6rem);
      align-items: end;
    }
  }
  .rpH__main { min-width: 0; }

  /* Bloque contacto · sin fondo · pills sueltas estilo image-47 */
  .rpH__contact {
    background: transparent;
    padding: 0;
    border: 0;
    box-shadow: none;
    align-self: end;
  }
  .rpH__contactKicker {
    display: block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.875rem;
  }
  .rpH__contactList {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.625rem;
  }

  /* Pills tipo image-47 · titulo izq + tag uppercase derecha · sin iconos */
  .rpH__contactPill {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: var(--radius-pill, 999px);
    text-decoration: none;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: background 220ms ease, border-color 220ms ease, transform 220ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .rpH__contactPill:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(61, 79, 58, 0.3);
    transform: translateY(-1px);
  }
  .rpH__contactPill strong {
    font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 700;
    letter-spacing: 0.2px;
    color: var(--color-text-primary);
  }
  .rpH__contactPill small {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    color: var(--color-text-muted);
    text-align: right;
    white-space: nowrap;
  }

  /* Pill primaria · Llamar destacada */
  .rpH__contactPill--primary {
    background: var(--color-text-primary, #1A1F2E);
    border-color: var(--color-text-primary, #1A1F2E);
  }
  .rpH__contactPill--primary:hover {
    background: var(--color-primary, #E9856F);
    border-color: var(--color-primary, #E9856F);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -10px rgba(233, 133, 111, 0.5);
  }
  .rpH__contactPill--primary strong { color: #fff; }
  .rpH__contactPill--primary small { color: rgba(251, 248, 241, 0.65); }

  @media (prefers-reduced-motion: reduce) {
    .rpH__contactPill,
    .rpH__contactPill:hover { transition: none; transform: none; }
  }
  .rpH__breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }
  .rpH__breadcrumb a { color: var(--color-text-primary); }
  .rpH__breadcrumb a:hover { color: var(--color-primary); }
  .rpH__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }
  .rpH__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.035em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .rpH__title .serif-italic {
    color: var(--color-sage, #3D4F3A);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    letter-spacing: -0.01em; text-transform: none;
  }

  /* Sello deluxe · "Premium" entre H1 y lead — feel editorial */
  .rpH__deluxe {
    display: inline-flex; align-items: center;
    gap: clamp(0.875rem, 1.75vw, 1.25rem);
    margin: 0 0 clamp(1.5rem, 2.75vw, 2rem);
    padding: clamp(0.625rem, 1.25vw, 0.875rem) 0;
  }
  .rpH__deluxeMark {
    display: inline-block;
    width: clamp(2.5rem, 6vw, 4.5rem);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-primary, #E9856F) 30%,
      var(--color-primary, #E9856F) 70%,
      transparent 100%
    );
  }
  .rpH__deluxeWord {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.4vw, 1.875rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--color-primary, #E9856F);
    line-height: 1;
    position: relative;
  }
  .rpH__deluxeWord::before,
  .rpH__deluxeWord::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--color-primary, #E9856F);
    opacity: 0.55;
    transform: translateY(-50%);
  }
  .rpH__deluxeWord::before { left: -0.875rem; }
  .rpH__deluxeWord::after  { right: -0.875rem; }

  .rpH__lead {
    font-family: var(--font-sans); font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.7; color: var(--color-text-secondary);
    max-width: 620px;
    margin: 0 0 clamp(1.75rem, 3vw, 2.25rem);
  }
  .rpH__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Bloque editorial · sin pill · feel Premium con eyebrow + cifras grandes */
  .rpH__stats {
    display: flex; flex-direction: column;
    gap: clamp(0.625rem, 1.25vw, 0.875rem);
    margin-bottom: clamp(2.25rem, 3.75vw, 3rem);
    align-items: flex-start;
    background: transparent;
    padding: 0;
    border: 0;
    box-shadow: none;
  }
  .rpH__statsKicker {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.375rem 0.75rem 0.375rem 0.625rem;
    background: rgba(233, 133, 111, 0.1);
    border-radius: var(--radius-pill, 999px);
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--color-primary);
  }
  .rpH__statsKicker svg { color: var(--color-primary); flex-shrink: 0; }

  .rpH__statsRow {
    display: inline-flex; flex-wrap: wrap; align-items: flex-end;
    gap: clamp(1.25rem, 2.75vw, 2.25rem);
  }
  .rpH__stat {
    display: flex; flex-direction: column; gap: 0.25rem;
    min-width: 0;
  }
  .rpH__stat strong {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 3.2vw, 2.5rem);
    font-weight: 900; line-height: 0.9; letter-spacing: -0.03em;
    color: var(--color-text-primary);
    display: flex; align-items: baseline; gap: 2px;
  }
  .rpH__stat strong small {
    font-family: var(--font-serif);
