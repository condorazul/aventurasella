    .rpI__cell.is-highlight .rpI__cellBadge { margin-top: 0; margin-left: auto; }
  }
  /* Tablet 2-col · picnic spans 2 cols en última fila */
  @media (min-width: 560px) and (max-width: 959.98px) {
    .rpI__cell:nth-child(2n) { border-right: none; }
    .rpI__cell.is-highlight {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: none;
    }
  }
  @media (max-width: 559.98px) {
