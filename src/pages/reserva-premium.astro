  .rpP__media {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-2xl, 2rem);
    overflow: hidden;
    box-shadow: 0 24px 56px -20px rgba(26, 31, 46, 0.2);
    /* Slide-from-left entrance (override del data-reveal global) */
    transform: translateX(-120px);
    opacity: 0;
    transition:
      transform 1100ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 1100ms ease-out,
      box-shadow 380ms ease;
  }
  .rpP__media.is-visible {
    transform: translateX(0);
    opacity: 1;
  }
  .rpP__media:hover {
    box-shadow: 0 32px 72px -22px rgba(26, 31, 46, 0.28);
  }
  .rpP__media :global(picture),
  .rpP__media :global(img) {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 1200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .rpP__media:hover :global(img) {
    transform: scale(1.04);
  }
  /* Reflejo glass diagonal en hover */
  .rpP__media::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.0) 40%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(255, 255, 255, 0.0) 60%,
      transparent 70%
    );
    transform: translateX(-110%);
    pointer-events: none;
    z-index: 2;
  }
  .rpP__media:hover::after {
    animation: rpPglass 1100ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes rpPglass {
    0%   { transform: translateX(-110%); }
    100% { transform: translateX(110%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rpP__media,
    .rpP__media :global(img),
    .rpP__media::after { transition: none !important; animation: none !important; }
    .rpP__media:hover :global(img) { transform: none; }
  }
