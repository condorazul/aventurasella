---
/**
 * /pt/reservar/ · Página oficial de reserva · Português (tu)
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const title = 'Reservar descida do Sella · Desde 30€ · Sem pagar agora';
const description = 'Reserva online a tua descida do Sella em canoa desde Arriondas. Sem pagar agora, alteração ou cancelamento flexível antes do dia, confirmação imediata por WhatsApp e email. 4,5★ · 147 opiniões reais.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/reservar/`;

const tarifas = [
  {
    img: 'reservar-tarifa-adultos',
    imgAlt: 'Grupo de adultos a descer o Sella de canoa desde Arriondas · tarifa adulto da descida',
    badge: 'Mais reservado',
    title: 'Adultos',
    age: 'A partir dos 13 anos',
    price: '40',
    note: 'Canoa, remo, colete, piquenique asturiano e transfer · tudo incluído',
  },
  {
    img: 'precios-ninos',
    imgAlt: 'Crianças a remar no Sella · tarifa infantil da descida',
    badge: 'Crianças',
    title: 'Crianças',
    age: 'Até aos 12 anos',
    price: '30',
    note: 'Idade mínima 5 anos · 1,15 m de altura',
  },
  {
    img: 'con-perro-cta',
    imgAlt: 'Cão com colete salva-vidas em canoa · descida do Sella com animais grátis',
    badge: 'Animais · grátis',
    title: 'Com cão',
    age: 'Até 25 kg',
    price: '0',
    note: 'Colete canino incluído até esgotar stock',
  },
];

const pasos = [
  { num: '01', title: 'Reserva o teu dia',         text: 'Escolhe data, percurso e número de pessoas no calendário. <strong>Sem pagar nada agora</strong>: bloqueamos o teu lugar de imediato.' },
  { num: '02', title: 'Chega a Arriondas',          text: 'Esperamos-te na C/ Juan Carlos I, 18. Estacionamento privado vigiado, balneários, duches quentes e cacifos com chave.' },
  { num: '03', title: 'Sais de canoa',              text: 'Mini aula com monitor titulado, remo, colete, bidão estanque e piquenique asturiano. Horário Premium aberto 10:30 – 12:30.' },
  { num: '04', title: 'Vamos buscar-te',            text: 'Transfer de regresso desde Toraño (percurso mini) ou Fríes (percurso completo). Regresso confortável · sem carro extra, sem esperas.' },
];

const faqs = [
  {
    q: 'Tenho de pagar agora para reservar?',
    a: 'Não. Podes <strong>reservar sem pagar nada agora</strong>. Bloqueamos o teu lugar e escolhes entre pagar online antecipadamente (cartão ou transferência) ou no próprio dia ao levantar a canoa (cartão, Bizum, dinheiro ou transferência instantânea).',
  },
  {
    q: 'Qual é a política de cancelamento?',
    a: 'Podes <strong>alterar ou cancelar a tua reserva a qualquer momento antes do dia da atividade</strong>, sem custo. Se pagaste com <strong>cartão antecipadamente</strong>, para tramitar o reembolso precisamos que nos avises com pelo menos <strong>24 h de antecedência</strong>. Avisa-nos por WhatsApp ou email e ajudamos-te a mudar a data ou devolver o valor. Se nós reprogramarmos por mau tempo ou condições do rio, alteração sem custo ou reembolso integral.',
  },
  {
    q: 'Quando recebo a confirmação?',
    a: 'No momento, automaticamente por email. Recebes: data confirmada, percurso escolhido, horário Premium aberto (chegada flexível 10:30 – 12:30), instruções de chegada e um WhatsApp direto para o que precisares.',
  },
  {
    q: 'Com quanta antecedência devo reservar?',
    a: 'Em época baixa, o dia anterior costuma ser suficiente. Em <strong>julho-agosto, fins de semana e feriados</strong> recomendamos 3-7 dias de antecedência. O calendário mostra em tempo real os dias com lugares disponíveis.',
  },
  {
    q: 'E se chover no dia da minha reserva?',
    a: 'No Sella reme-se em muitos dias com céu encoberto sem problema · faz parte do encanto verde das Astúrias. Se houver <strong>aviso meteorológico ou cheia do rio</strong>, reagendamos sem custo ou devolvemos o valor integral. Decidimos sempre do lado da segurança.',
  },
  {
    q: 'Há desconto para grupos?',
    a: 'A partir de <strong>15 pessoas</strong> avaliamos condições especiais (horário dedicado, piquenique asturiano, fatura empresa). Escreve-nos para <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a> com data, número de pessoas e idades · enviamos-te um orçamento fechado.',
  },
];

const resources = [
  { img: 'reservar-resource-precios',   imgAlt: 'Canoa laranja na margem do Sella · tarifas detalhadas da descida',           title: 'Tarifas detalhadas', text: 'Preços por idade, o que incluem e comparativo por percurso.',     href: getLocalePath('precios', 'pt'),        cta: 'Ver preços' },
  { img: 'reservar-resource-recorrido', imgAlt: 'Vista do rio Sella nas Astúrias · percurso e mapa da descida',                title: 'Percurso e mapa',    text: 'Percurso mini (7 km · 2-3 h) ou completo (14,5 km · 4-5 h).',       href: getLocalePath('recorrido_mapa', 'pt'), cta: 'Ver percurso' },
  { img: 'reservar-resource-premium',   imgAlt: 'Famílias e adultos a remar no Sella · Reserva Premium tudo incluído',         title: 'Reserva Premium',    text: 'Cacifos, piquenique asturiano e horário aberto 10:30 – 12:30.',   href: getLocalePath('reserva_premium', 'pt'), cta: 'Ver Premium' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, 'pt'),
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'pt-PT',
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#business` },
      mainEntityOfPage: canonicalUrl,
      datePublished: '2026-05-14',
      dateModified: '2026-05-14',
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Reserva online da descida do Sella em canoa',
      description: 'Serviço de reserva online da descida turística do Sella desde Arriondas (Astúrias). Alteração ou cancelamento flexível antes do dia (24 h se pagaste com cartão). Sem pagar agora.',
      provider: { '@id': `${baseUrl}/#business` },
      serviceType: 'Canoe rental and guided river descent',
      areaServed: { '@type': 'Place', name: 'Arriondas, Astúrias, Espanha' },
      offers: [
        { '@type': 'Offer', name: 'Crianças até aos 12 anos', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
        { '@type': 'Offer', name: 'Adultos',                  price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',   item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Reservar', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/pt/reservar/" translationKey="reservar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preload" as="image" href="/images/optimized/hero-canoa-lago-lg.avif" type="image/avif" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>

  <section class="rsvH" aria-labelledby="rsvH-title">
    <div class="rsvH__media" aria-hidden="true">
      <Picture src="hero-canoa-lago" alt="Canoa no rio Sella ao pôr do sol · descida do Sella desde Arriondas" priority="high" sizes="100vw" aspectRatio="16 / 10" />
      <div class="rsvH__overlay"></div>
    </div>

    <div class="rsvH__inner">
      <nav class="rsvH__breadcrumb" aria-label="Migalhas">
        <a href="/pt/">Início</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Reservar</span>
      </nav>

      <span class="rsvH__eyebrow">
        <span class="rsvH__eyebrow-dot" aria-hidden="true"></span>
        Reserva em 2 minutos · sem pagar agora
      </span>

      <h1 id="rsvH-title" class="rsvH__title">
        Reserva a tua<br/>
        <span class="serif-italic">descida do Sella</span>
      </h1>

      <p class="rsvH__lead">
        Escolhe dia, percurso e número de pessoas. A canoa, o equipamento, o piquenique, o transfer e tudo o resto · já vem incluído. <strong>Sem pagar nada agora</strong> · pagas online ou no dia em que recolhes a canoa em Arriondas.
      </p>

      <div class="rsvH__ctas">
        <a class="rsvH__cta rsvH__cta--primary" href="#booking-widget">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Ir ao calendário</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="https://wa.me/34681093673?text=Ol%C3%A1%2C%20gostaria%20de%20reservar%20a%20descida%20do%20Sella" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.87 11.87 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.56 4.18 1.62 6L0 24l6.18-1.6A11.9 11.9 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="tel:+34681093673" aria-label="Ligar para +34 681 09 36 73">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          <span>+34 681 09 36 73</span>
        </a>
      </div>

      <ul class="rsvH__trust" role="list">
        <li><span class="rsvH__trustNum">4,5★</span><span class="rsvH__trustLabel">147 opiniões reais</span></li>
        <li><span class="rsvH__trustNum">Flexível</span><span class="rsvH__trustLabel">alteração antes do dia</span></li>
        <li><span class="rsvH__trustNum">25 anos</span><span class="rsvH__trustLabel">em Arriondas</span></li>
        <li><span class="rsvH__trustNum">0 €</span><span class="rsvH__trustLabel">para reservar</span></li>
      </ul>
    </div>
  </section>

  <section class="rsvB" aria-labelledby="rsvB-title">
    <div class="rsvB__inner">
      <header class="rsvB__header">
        <span class="rsvB__eyebrow">— Calendário em direto</span>
        <h2 id="rsvB-title" class="rsvB__title">
          Escolhe o teu dia<br/>
          <span class="serif-italic">em menos de 2 minutos</span>
        </h2>
        <p class="rsvB__lead">
          Disponibilidade em tempo real · dias com lugares a verde · sem surpresas. <strong>Confirmação imediata por WhatsApp e email</strong> · rápido, fácil e sem formulários intermináveis.
        </p>
      </header>

      <div id="booking-widget" class="rsvB__slot" aria-live="polite">
        <div class="rsvB__placeholder">
          <span class="rsvB__placeholderIcon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <p class="rsvB__placeholderTitle">Calendário de reservas</p>
          <p class="rsvB__placeholderText">
            Estamos a carregar o calendário em tempo real. Se não aparecer em alguns segundos, escreve-nos por <a href="https://wa.me/34681093673" target="_blank" rel="noopener noreferrer">WhatsApp</a> ou liga para <a href="tel:+34681093673">+34 681 09 36 73</a> · reservamos-te de imediato.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rsvT" aria-labelledby="rsvT-title">
    <div class="rsvT__inner">
      <header class="rsvT__header">
        <span class="rsvT__eyebrow">— Reservar com tranquilidade</span>
        <h2 id="rsvT-title" class="rsvT__title">
          Sem pagar agora,<br/>
          <span class="serif-italic">sem letras pequenas.</span>
        </h2>
      </header>

      <div class="rsvT__grid">
        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-pago" alt="Margem do rio Sella em Arriondas · pagamento flexível para reservar a descida" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag">Pagamento flexível</span>
            <h3 class="rsvT__cardTitle">Pagas online ou à chegada</h3>
            <ul class="rsvT__cardList">
              <li>Cartão online ao reservar</li>
              <li>Ou no dia: cartão, Bizum, dinheiro ou transferência</li>
              <li>Sem sinal · sem extras escondidos</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-cambios" alt="Grupo de raparigas a remar juntas na descida do Sella · alteração ou cancelamento flexível" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--sage">Alterações e cancelamentos flexíveis</span>
            <h3 class="rsvT__cardTitle">Altera ou cancela antes do dia · sem custo</h3>
            <ul class="rsvT__cardList">
              <li>Altera ou cancela a qualquer momento antes do dia da atividade</li>
              <li>Se pagaste com cartão, o reembolso requer 24 h de antecedência</li>
              <li>Se chover forte ou o rio subir, reagendamos ou devolvemos</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-equipo" alt="Equipa da Aventura en el Sella em Arriondas · pessoas reais que te atendem" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--coral">Confirmação humana</span>
            <h3 class="rsvT__cardTitle">Pessoas reais, não bots</h3>
            <ul class="rsvT__cardList">
              <li>Confirmamos por email + WhatsApp</li>
              <li>Atendemos das 9:30 às 19:00 todos os dias em época</li>
              <li>25 anos a receber aventureiros em Arriondas</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="rsvP" aria-labelledby="rsvP-title">
    <div class="rsvP__inner">
      <header class="rsvP__header">
        <span class="rsvP__eyebrow">— Tarifas habituais</span>
        <h2 id="rsvP-title" class="rsvP__title">
          Preço por pessoa e dia,<br/>
          <span class="serif-italic">tudo incluído.</span>
        </h2>
        <p class="rsvP__lead">
          Mesmo preço para o percurso mini (7 km · 2-3 h) e o percurso completo (14,5 km · 4-5 h). <strong>Reserva Premium incluída sem custo extra</strong> · animais sempre grátis.
        </p>
      </header>

      <p class="rsvP__premiumBadge">
        <span class="rsvP__premiumStar" aria-hidden="true">✦</span>
        <span><strong>Reserva Premium · Tudo incluído</strong> em qualquer tarifa · cacifos, balneários, duches quentes, piquenique asturiano, transfer e estacionamento privado vigiado</span>
      </p>

      <div class="rsvP__grid">
        {tarifas.map(t => (
          <article class="rsvP__card">
            <div class="rsvP__cardMedia">
              <Picture src={t.img} alt={t.imgAlt} sizes="(min-width: 960px) 25vw, 50vw" aspectRatio="4 / 5" />
              <span class="rsvP__cardBadge">{t.badge}</span>
            </div>
            <div class="rsvP__cardBody">
              <h3 class="rsvP__cardTitle">{t.title}</h3>
              <p class="rsvP__cardAge">{t.age}</p>
              <p class="rsvP__cardPrice">
                {t.price === '0' ? (
                  <span class="rsvP__cardFree">Grátis</span>
                ) : (
                  <>
                    <span class="rsvP__cardCurrency">€</span>
                    <span class="rsvP__cardAmount">{t.price}</span>
                    <span class="rsvP__cardUnit">/dia</span>
                  </>
                )}
              </p>
              <p class="rsvP__cardNote">{t.note}</p>
              <a class="rsvP__cardLink" href="#booking-widget">
                Reservar
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="rsvP__foot">
        Procuras tarifa família, grupo escolar ou despedida? <a href={getLocalePath('precios', 'pt')}>Ver todas as tarifas em detalhe</a>.
      </p>
    </div>
  </section>

  <section class="rsvS" aria-labelledby="rsvS-title">
    <div class="rsvS__inner">
      <header class="rsvS__header">
        <span class="rsvS__eyebrow">— Como funciona</span>
        <h2 id="rsvS-title" class="rsvS__title">
          Reservar a tua descida<br/>
          <span class="serif-italic">em 4 passos.</span>
        </h2>
        <div class="rsvS__times">
          <div><strong>Horário aberto</strong><span>Chegada flexível 10:30 – 12:30</span></div>
          <div><strong>Recolhas</strong><span>Das 13:00 às 18:00 desde Toraño / Fríes</span></div>
        </div>
      </header>

      <ol class="rsvS__list" role="list">
        {pasos.map(p => (
          <li class="rsvS__step">
            <span class="rsvS__stepNum">{p.num}</span>
            <h3 class="rsvS__stepTitle">{p.title}</h3>
            <p class="rsvS__stepText" set:html={p.text}></p>
          </li>
        ))}
      </ol>

      <p class="rsvS__foot">
        <a href={getLocalePath('cuanto_dura', 'pt')}>Ver como funciona a descida em detalhe</a> · tempos reais por percurso e franja do dia.
      </p>
    </div>
  </section>

  <section class="rsvO" aria-labelledby="rsvO-title">
    <div class="rsvO__inner">
      <header class="rsvO__header">
        <span class="rsvO__eyebrow">— Preferes falar com alguém?</span>
        <h2 id="rsvO-title" class="rsvO__title">
          Outras formas<br/>
          <span class="serif-italic">de reservar.</span>
        </h2>
        <p class="rsvO__lead">
          Reserva sempre com antecedência · confirmamos no momento em horário de atendimento. Pessoa real da equipa, nunca um bot.
        </p>
      </header>

      <div class="rsvO__row" role="list">
        <a class="rsvO__item" href="https://wa.me/34681093673?text=Ol%C3%A1%2C%20gostaria%20de%20reservar%20a%20descida%20do%20Sella" target="_blank" rel="noopener noreferrer" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
          </span>
          <span class="rsvO__itemTag">Resposta imediata</span>
          <h3 class="rsvO__itemTitle">WhatsApp</h3>
          <p class="rsvO__itemText">Respondemos em minutos em horário de atendimento. Sem formulários, sem esperas.</p>
          <span class="rsvO__itemValue">Abrir chat</span>
          <span class="rsvO__itemCta" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a class="rsvO__item" href="tel:+34681093673" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <span class="rsvO__itemTag">9:30 – 19:00 em época</span>
