  .prcta__primary { display: inline-flex; align-items: center; gap: var(--s-2); padding: 1.125rem 2rem; background: var(--color-primary); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; box-shadow: 0 10px 28px rgba(233, 133, 111, 0.38); transition: all 240ms cubic-bezier(0.34, 1.2, 0.64, 1); }
  .prcta__primary:hover { background: var(--color-primary-hover, #D66F59); transform: translateY(-3px); box-shadow: 0 16px 32px rgba(233, 133, 111, 0.5); }
  .prcta__primary svg { transition: transform 200ms; }
  .prcta__primary:hover svg { transform: translateX(3px); }
</style>

<script>
  (function () {
    const videos = document.querySelectorAll<HTMLVideoElement>('.prpCardCTA__video');
    if (!videos.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    function load(video: HTMLVideoElement) {
      if (video.dataset.loaded === '1') return;
      const src = video.dataset.src;
      if (!src) return;
      const source = document.createElement('source');
      source.src = src;
      source.type = 'video/mp4';
      video.appendChild(source);
      video.load();
      video.dataset.loaded = '1';
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const v = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              load(v);
              v.play().catch(() => {});
            } else {
              v.pause();
            }
          });
        },
        { rootMargin: '200px 0px', threshold: 0 }
      );
      videos.forEach((v) => io.observe(v));
    } else {
      videos.forEach((v) => {
        load(v);
        v.play().catch(() => {});
      });
    }
  })();
</script>
