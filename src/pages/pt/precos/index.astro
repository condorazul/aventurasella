---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Preços da descida do Sella · A partir de 30 € tudo incluído';
const description = 'Preços da descida do Sella: 30 € crianças · 40 € adultos. Tudo incluído (canoa, piquenique, transfer, estacionamento). Animais grátis. Reserve sem pagar agora.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/precos/`;

const incluido = [
  { icon: 'canoe',    title: 'Canoas K1, K2 e K3',             sub: 'Insubmersíveis, com remo e bidão estanque' },
  { icon: 'shield',   title: 'Colete salva-vidas',             sub: 'Homologado, ajustado ao tamanho' },
  { icon: 'wetsuit',  title: 'Fato de neoprene',               sub: 'Exceto de 15/06 a 28/09' },
  { icon: 'teacher',  title: 'Mini aula + monitores',          sub: 'Titulados e campeões do Sella' },
  { icon: 'picnic',   title: 'Piquenique asturiano',           sub: 'Empada de bonito, bolinho asturiano e água' },
  { icon: 'bus',      title: 'Transfer de regresso',           sub: 'Desde Toraño ou Fríes' },
  { icon: 'shower',   title: 'Balneários com duches',          sub: 'Cacifos com chave incluídos' },
  { icon: 'parking',  title: 'Estacionamento privado',         sub: '300 lugares · vigiado · autocaravanas' },
  { icon: 'paw',      title: 'Animais grátis',                 sub: 'Toda a família na canoa' },
  { icon: 'ticket',   title: 'Seguros obrigatórios',           sub: 'Cobertura completa incluída' },
  { icon: 'ramp',     title: 'Rampa de embarque',              sub: 'Opcional e gratuita · ou embarque à beira do rio' },
  { icon: 'heart',    title: 'Um atendimento próximo',         sub: 'Sem filas, sem robôs, sem extras' },
];

const rutas = [
  {
    name: 'Mini Sella',   km: '7 km',   dur: '2 – 3 h',   desc: 'Percurso curto de Arriondas a Toraño. Ideal se vão com pequenos, querem fazer muitas paragens ou preferem uma descida tranquila.', tone: 'sage',
  },
  {
    name: 'Percurso completo', km: '14,5 km', dur: '4 – 5 h',  desc: 'Percurso clássico de Arriondas a Fríes. Mais quilómetros, mais paisagem, mais paragens para se banhar. A experiência mais completa.', tone: 'coral',
  },
];

const faqs = [
  { q: 'Quanto custa descer o Sella?',
    a: `Descer o Sella de canoa connosco custa <strong>40 € por adulto</strong> (a partir dos 13 anos) e <strong>30 € por criança</strong> (dos 5 aos 12 anos). O preço é <strong>tudo incluído</strong>: canoa insubmersível, colete, remo duplo, neoprene em datas frias, bidão estanque, mini aula com monitor titulado, piquenique asturiano (empada de bonito, bolinho asturiano e água), transfer de regresso, <strong>estacionamento privado vigiado (300 lugares · também para autocaravanas)</strong>, balneários com duches, cacifos com chave e seguros. <strong>Animais grátis</strong>. O único dia com tarifa diferente é o sábado da <a href="${getLocalePath('descenso_internacional', 'pt')}">Descida Internacional do Sella</a> — 35 € com condições especiais.` },
  { q: 'O preço é por pessoa ou por canoa?',
    a: 'O preço é <strong>por pessoa</strong>, não por canoa. Se forem dois adultos a partilhar uma K2, pagam <strong>40 € cada um</strong>. Se forem três pessoas numa K3, também por cabeça — partilhar canoa não muda a tarifa individual.' },
  { q: 'O percurso Mini custa o mesmo que o Completo?',
    a: 'Sim — <strong>uma só reserva, um só preço</strong>. Escolhem o percurso na água, não na reserva. Podem partir a pensar em fazer o Completo e ficar em Toraño (km 7) se vos apetecer, ou começar a pensar no Mini e seguir até Fríes. Não muda nem o preço nem o que inclui.' },
  { q: 'Há desconto para grupos?',
    a: 'Para grupos de <strong>10 ou mais pessoas</strong> aplicamos condições especiais. Escrevam-nos por <a href="https://wa.me/34681093673?text=Ola,%20somos%20um%20grupo%20de...">WhatsApp</a> ou <a href="mailto:info@aventuraenelsella.es">email</a> com o número de pessoas e a data aproximada, e preparamos uma proposta personalizada.' },
  { q: 'Como se paga? É preciso pagar adiantado?',
    a: `Reserve <strong>sem pagar agora</strong>. Escolha o que for mais cómodo: <strong>pagamento com cartão adiantado</strong> ou <strong>pagamento no dia ao levantar a canoa</strong>. A única exceção é <a href="${getLocalePath('descenso_internacional', 'pt')}">o sábado da Descida Internacional</a>, em que só se reserva com pagamento antecipado.` },
  { q: 'Posso mudar a data ou cancelar?',
    a: 'Pode <strong>mudar ou cancelar em qualquer momento antes do dia da atividade</strong>, sem custos. Se pagou com <strong>cartão adiantado</strong>, para tramitar o reembolso precisamos que nos avise com um mínimo de <strong>24 h de antecedência</strong>. Avise-nos por WhatsApp ou email e mudamos a data ou devolvemos o valor.' },
  { q: 'Tenho de escolher hora de partida?',
    a: `Não. A sua reserva é <strong>Premium · horário aberto</strong>: chegue às nossas instalações em Arriondas <strong>quando for melhor para si entre as 10:30 e as 12:30</strong>, sem escolher hora concreta. É uma das <strong>vantagens Premium</strong>. A única exceção é o sábado da <a href="${getLocalePath('descenso_internacional', 'pt')}">Descida Internacional</a> (partida única às 12:00) e os dias com condições do rio que requeiram entrada com monitor (avisamos com antecedência). A Confederación Hidrográfica determina a permanência no rio até às 18:00.` },
  { q: 'A partir de que idade as crianças podem descer?',
    a: 'Os menores podem descer a partir dos <strong>5 anos completos e 1,15 m de altura mínima</strong>. É um <strong>requisito estrito de segurança</strong>, não só pelo colete — também pela natureza do rio (corrente, profundidade variável, troços com rápidos) e por exigência das companhias de seguros. <strong>Não se admitem menores que não alcancem o mínimo</strong>, mesmo que vão acompanhados por um adulto ou saibam nadar.' },
  { q: 'O que acontece no dia da Descida Internacional?',
    a: `O sábado da <a href="${getLocalePath('descenso_internacional', 'pt')}">Descida Internacional do Sella</a> aplica-se um preço único de <strong>35 € por pessoa</strong>, com condições próprias: partida única às 12:00 h, pagamento antecipado obrigatório, sem piquenique incluído e lugares muito limitados. Tudo explicado na sua página.` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descida do Sella em canoa · Tudo incluído',
      description: 'Descida turística em canoa pelo rio Sella desde Arriondas. Tudo incluído: canoa, equipamento, mini aula com monitores titulados, transfer de regresso, piquenique asturiano, balneários e estacionamento. Animais grátis.',
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      image: `${baseUrl}/images/optimized/includes-b.jpg`,
      offers: [
        { '@type': 'Offer', name: 'Crianças (até 12 anos)', price: '30.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/pt/reservar/` },
        { '@type': 'Offer', name: 'Adulto',                 price: '40.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/pt/reservar/` },
        { '@type': 'Offer', name: 'Dia da Descida Internacional', price: '35.00', priceCurrency: 'EUR', availability: 'https://schema.org/LimitedAvailability', url: `${baseUrl}/pt/descida-internacional-do-sella/` },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5', reviewCount: '147', bestRating: '5', worstRating: '1',
      },
      inLanguage: 'pt-PT',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'pt-PT',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Preços', item: canonicalUrl },
      ],
    },
    {
      '@type': 'WebPage',
      '@id': canonicalUrl,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'pt-PT',
      keywords: 'preços descida do sella, canoa sella, descida sella canoa preço, aluguer canoa arriondas',
      dateModified: '2026-05-12',
      isPartOf: { '@id': `${baseUrl}/#website` },
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/pt/precos/" translationKey="precios">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="prh" aria-labelledby="prh-title">

    <div class="prh__inner">
      <nav class="prh__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', 'pt')}>Início</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Preços</span>
      </nav>

      <div class="prh__grid">
        <div class="prh__main">
          <span class="prh__eyebrow">
            <span class="prh__eyebrow-dot" aria-hidden="true"></span>
            A partir de 30 € · Temporada 2026
          </span>

          <h1 id="prh-title" class="prh__title">
            Preços da<br/>
            <span class="serif-italic">descida do Sella</span>
          </h1>

          <p class="prh__lead">
            <strong>Um só preço, tudo incluído</strong>. Escolhe o percurso na
            água, não no website. O custo depende apenas da idade — não dos
            quilómetros nem de ficares em Toraño ou chegares a Fríes.
          </p>

          <div class="prh__stats">
            <span class="prh__statsKicker">
              <span class="prh__statsKickerMark" aria-hidden="true"></span>
              Tarifa única · tudo incluído
            </span>
            <div class="prh__statsRow">
              <div class="prh__stat">
                <strong>30<small>€</small></strong>
                <span>Crianças · 5–12</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>40<small>€</small></strong>
                <span>Adultos</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>Grátis</strong>
                <span>Animais</span>
              </div>
            </div>
          </div>
        </div>

        <aside class="prh__contact" aria-label="Reservar ou contactar">
          <span class="prh__contactKicker">— Reserve o seu lugar</span>
          <ul class="prh__contactList" role="list">
            <li>
              <a href={getLocalePath('reservar', 'pt')} class="prh__contactPill prh__contactPill--primary">
                <strong>Reservar agora</strong>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </li>
            <li>
              <a href="tel:+34681093673" class="prh__contactPill" aria-label="Ligar para o 681 09 36 73">
                <strong>Liga-nos</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Ola%2C%20gostaria%20de%20mais%20info%20sobre%20pre%C3%A7os" target="_blank" rel="noopener noreferrer" class="prh__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Resposta em minutos</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== CARTÕES DE PREÇOS ============== -->
  <section class="prp">
    <div class="container container--xl">
      <header class="prp__header" data-reveal>
        <span class="prp__eyebrow">— Tarifas</span>
        <h2 class="prp__title">
          Preço por pessoa,<br/>
          <span class="serif-italic">tudo incluído</span>
        </h2>
        <p class="prp__lead">
          Sem extras. Sem custo por chegar até Fríes. Sem adicionar o neoprene, o transfer ou o piquenique.<br/>
          <strong>O preço que vês é o preço final.</strong>
        </p>
      </header>

      <div class="prp__grid">
        <!-- CARD 1: CRIANÇAS -->
        <article class="prpCard prpCard--sage" data-reveal data-reveal-delay="1">
          <div class="prpCard__media">
            <Picture src="precios-ninos" alt="Crianças a desfrutar da descida do Sella em canoa" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarifa infantil</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">30&nbsp;€ <span>/ criança</span></p>
              <p class="prpCard__mediaSub">5-12 anos · Canoa partilhada</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Lugar infantil</h3>
              <span class="prpCard__rating" aria-label="Avaliação média 4.9 em 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">5-12</span><span class="prpCard__stat-lbl">Anos</span></li>
              <li><span class="prpCard__stat-val">K2/K3</span><span class="prpCard__stat-lbl">Canoa</span></li>
              <li><span class="prpCard__stat-val">Sim</span><span class="prpCard__stat-lbl">Equipamento</span></li>
              <li><span class="prpCard__stat-val">Sim</span><span class="prpCard__stat-lbl">Piquenique</span></li>
            </ul>
            <p class="prpCard__desc">
              A opção mais acessível para famílias · os pequenos descem partilhando canoa com um adulto, com <strong>a mesma cobertura completa da tarifa adulto</strong>.
            </p>
            <ul class="prpCard__list">
              <li>Idade mínima <strong>5 anos e 1,15 m</strong> · sem exceções</li>
              <li>Canoa partilhada com um adulto responsável</li>
              <li>Equipamento infantil, piquenique e serviços incluídos · <a href="#pri-title">ver detalhe abaixo</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'pt')} class="prpCard__cta prpCard__cta--primary">
              Reservar lugar de criança
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 2: ADULTOS -->
        <article class="prpCard prpCard--coral" data-reveal data-reveal-delay="2">
          <div class="prpCard__media">
            <Picture src="precios-adultos" alt="Grupo de amigas na descida do Sella em canoa" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarifa adulto</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">40&nbsp;€ <span>/ adulto</span></p>
              <p class="prpCard__mediaSub">A partir dos 13 anos · Tudo incluído</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Lugar adulto</h3>
              <span class="prpCard__rating" aria-label="Avaliação média 4.9 em 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">13+</span><span class="prpCard__stat-lbl">Anos</span></li>
              <li><span class="prpCard__stat-val">K1/K2/K3</span><span class="prpCard__stat-lbl">Canoa</span></li>
              <li><span class="prpCard__stat-val">Sim</span><span class="prpCard__stat-lbl">Equipamento</span></li>
              <li><span class="prpCard__stat-val">Sim</span><span class="prpCard__stat-lbl">Piquenique</span></li>
            </ul>
            <p class="prpCard__desc">
              A tarifa standard · escolhe <strong>K1 a solo, K2 a dois ou K3 com amigos</strong> — o preço por pessoa é igual.
            </p>
            <ul class="prpCard__list">
              <li>A partir dos <strong>13 anos</strong></li>
              <li>Canoa individual, dupla ou tripla <strong>(K1/K2/K3)</strong></li>
              <li>Escolhes o percurso na água (Mini ou Completo) sem custo extra · <a href="#pri-title">ver detalhe abaixo</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'pt')} class="prpCard__cta prpCard__cta--primary">
              Reservar lugar de adulto
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 3: CTA IMAGEM -->
        <article class="prpCardCTA" data-reveal data-reveal-delay="3">
          <div class="prpCardCTA__media">
            <video
              class="prpCardCTA__video"
              muted loop playsinline
              preload="none"
              poster="/videos/rio-sella-loop-poster.jpg"
              aria-hidden="true"
              data-src="/videos/rio-sella-loop.mp4"
            ></video>
          </div>
          <div class="prpCardCTA__inner">
            <div class="prpCardCTA__bottom">
              <span class="prpCardCTA__kicker">Aventura en el Sella &nbsp;·&nbsp; Aluguer de canoas</span>
              <h3 class="prpCardCTA__title">
                Faz a tua reserva<br/>connosco
              </h3>
              <a href={getLocalePath('reservar', 'pt')} class="prpCardCTA__btn">
                <span>Reservar agora</span>
                <span class="prpCardCTA__btnIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
          </div>
        </article>
      </div>

      <p class="prp__note" data-reveal>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Animais grátis qualquer dia — <strong>exceto no sábado da <a href={getLocalePath('descenso_internacional', 'pt')}>Descida Internacional</a></strong>, pela afluência e ruído do evento.</span>
      </p>
    </div>
  </section>

  <!-- ============== TUDO INCLUÍDO ============== -->
  <section class="pri" id="pri-title">
    <div class="container container--xl">
      <header class="pri__header" data-reveal>
        <span class="pri__eyebrow">— Tudo incluído significa tudo</span>
        <h2 class="pri__title">
          No dia da tua descida,<br/>
          <span class="serif-italic">já tens tudo</span>
        </h2>
        <p class="pri__lead">
          Vê tudo o que inclui a tua <strong>reserva Premium</strong> — o teu dia
          resolvido ao detalhe. Chegas, recebemos-te, equipamos-te, desces o rio
          e trazemos-te de volta. <strong>Só tens de te despreocupar e
          desfrutar</strong>.
        </p>
      </header>

      <ul class="priD">
        {incluido.map((it, i) => (
          <li class="priDItem" data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="priDItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="priDItem__body">
              <h3 class="priDItem__title">
                <span class="priDItem__icon" aria-hidden="true">
                  {it.icon === 'canoe'   && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 14c3-4 7-6 10-6s7 2 10 6"/><path d="M2 14c3 4 7 6 10 6s7-2 10-6"/></svg>}
                  {it.icon === 'shield'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {it.icon === 'wetsuit' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8l1 4-2 3v10a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V10L7 7z"/></svg>}
                  {it.icon === 'teacher' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>}
                  {it.icon === 'picnic'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h18l-1 5H4z"/><path d="M5 13l1 8M19 13l-1 8"/></svg>}
                  {it.icon === 'bus'     && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/></svg>}
                  {it.icon === 'shower'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6M8 9h8"/><path d="M6 12c0 5 2 9 6 9s6-4 6-9z"/></svg>}
                  {it.icon === 'parking' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>}
                  {it.icon === 'paw'     && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>}
                  {it.icon === 'ticket'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v3a2 2 0 0 1 0 4v3a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-3a2 2 0 0 1 0-4V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"/></svg>}
                  {it.icon === 'ramp'    && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21L21 3"/><path d="M3 21h18"/></svg>}
