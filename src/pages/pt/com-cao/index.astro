---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Descida do Sella com cão · Aventura com o seu animal';
const description = 'Descida do Sella com cão: animais grátis, colete salva-vidas canino incluído (até esgotar), monitores dog-friendly. Reserve sem pagar agora.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/com-cao/`;
const ogImage = '/images/optimized/con-perro-cta-lg.jpg';

const jornada = [
  { num: '01', title: 'Chegada com o seu cão',     text: 'Recebemo-vos em Arriondas. <strong>Estacionamento privado gratuito</strong> para evitar stress à chegada. Explicamos o plano do dia e esclarecemos dúvidas sobre a atividade com o vosso animal.' },
  { num: '02', title: 'Avaliação prévia',          text: 'Vemos como está o cão — <strong>tranquilo, nervoso, tamanho, confiança com a água</strong> — e ajustamos a canoa mais adequada para que o dia seja confortável para ambos.' },
  { num: '03', title: 'Briefing com monitor',      text: '<strong>Monitores com experiência dog-friendly</strong> explicam como colocar o cão na canoa, o que fazer se se mexer e as normas básicas. <strong>Tudo claro antes de entrar na água</strong>.' },
  { num: '04', title: 'Embarque tranquilo',        text: 'Saída da nossa rampa privada de 35 m até ao rio. O cão desce <strong>solto dentro da canoa</strong>, nunca atado — é o mais seguro se houver movimento ou virada.' },
  { num: '05', title: 'Paragens quando precisar',  text: 'Existem praias fluviais tranquilas para <strong>parar, beber água, esticar patas</strong> e deixar o cão respirar. Sem pressa, <strong>ao ritmo que o vosso animal pede</strong>.' },
  { num: '06', title: 'Regresso e balneários',     text: '<strong>O nosso transfer</strong> leva-vos de volta. Balneários com duches quentes para si e zona exterior com água para secar o cão. Dia completo resolvido.' },
];

const llevar = [
  { icon: 'leash',    t: 'Trela + arnês',                   s: 'Obrigatório em terra (embarque, acessos, balneários). Arnês confortável melhor que coleira' },
  { icon: 'bowl',     t: 'Água e bebedouro dobrável',       s: 'Essencial se fizer calor. Paramos as vezes necessárias para o hidratar' },
  { icon: 'towel',    t: 'Toalha extra para o cão',         s: 'Melhor separada da sua · no fim do percurso ele sai encharcado e agradece-se não partilhar' },
  { icon: 'bag',      t: 'Sacos higiénicos',                s: 'Respeitar o rio e as suas margens. Tudo o que desce sobe connosco' },
  { icon: 'human',    t: 'O seu equipamento pessoal',       s: 'Roupa confortável que se molhe, calçado seguro, toalha e muda. Como qualquer descida' },
];

const beneficios = [
  { t: 'Animais 100% grátis',             s: 'O seu cão não paga. Vem consigo na canoa sem custo extra — exceto no sábado da Descida Internacional.' },
  { t: 'Monitores dog-friendly',          s: 'Com experiência real a descer o Sella com animais. No briefing prévio ensinam o que olhar antes de entrar na água e como agir se o cão ficar inquieto durante a descida.' },
  { t: 'Plano tranquilo e adaptável',     s: 'O Sella turístico tem leito calmo — corrente tranquila, paragens a pedido, sem white-water nem exigência desportiva.' },
  { t: 'Indicações claras antes de partir', s: 'Briefing específico sobre como colocar o cão, o que fazer se se mexer e como manter a canoa equilibrada com ele a bordo.' },
  { t: 'Balneários + estacionamento privado', s: 'Duches quentes para si + zona exterior com água para enxaguar o cão ao terminar. Estacionamento vigiado todo o dia.' },
  { t: 'Um cão por canoa',                s: 'Para garantir espaço, equilíbrio e conforto. Se vier com mais do que um, ajudamos a coordenar as embarcações.' },
  { t: 'Sem pagar agora',                 s: 'Reserve sem adiantar dinheiro. Pague com cartão antes ou no dia ao recolher a canoa — como preferir.' },
  { t: 'Mudar ou cancelar',               s: 'Alterações e cancelamentos flexíveis antes do dia. Se pagou com cartão, reembolso avisando com 24 h.' },
];

const faqs = [
  { q: 'Quanto custa descer o Sella com cão?',
    a: `O cão <strong>não paga</strong> — os animais vêm grátis na canoa. Pessoas: <strong>40 € por adulto</strong> (a partir dos 13 anos) e <strong>30 € por criança</strong> (5-12 anos, <strong>idade mínima 5 anos completos e 1,15 m de altura</strong>). A única exceção é o sábado da <a href="${getLocalePath('descenso_internacional', 'pt')}">Descida Internacional do Sella</a>, que pelo ruído do evento não admite animais. Pode <a href="${getLocalePath('precios', 'pt')}">ver o detalhe completo dos preços</a>.` },
  { q: 'Pode-se fazer a descida do Sella com cão?',
    a: 'Sim, é uma das atividades dog-friendly mais populares do rio. A única coisa que pedimos é <strong>bom senso com o cão</strong>: avaliar se tolera água, se fica tranquilo durante um bocado, e se obedece a ordens básicas. Se for um cão sociável e equilibrado, a experiência costuma correr muito bem.' },
  { q: 'O meu cão pode subir no transfer de regresso?',
    a: 'Sim, sem problema. <strong>O seu animal poderá subir no nosso transfer de regresso</strong> ao terminar o trajeto que escolheu (Mini Sella ou Completo). Sobe consigo na carrinha junto com o resto do grupo, tal como a canoa — <strong>sem custo adicional</strong>.' },
  { q: 'O meu cão tem de usar colete salva-vidas?',
    a: `Não é obrigatório, mas <strong>é recomendável se o seu cão não nadar bem ou for de tamanho pequeno/médio</strong>. <strong>O colete salva-vidas canino é por nossa conta</strong> sem custo extra · temos vários tamanhos na loja <em>até esgotar</em>. Por isso <a href="${getLocalePath('reservar', 'pt')}">reservar com antecedência é chave</a> · no verão voam. Se vem com cão e quer garantir, avise-nos ao reservar e guardamos o colete em seu nome.` },
  { q: 'Pode ir atado à canoa?',
    a: '<strong>Não, nunca.</strong> Se houver virada, uma trela amarrada é um risco sério tanto para o cão como para as pessoas. Dentro da canoa <strong>vai solto</strong>. Fora da água (embarque, acessos, balneários) sim deve ir com trela.' },
  { q: 'Quantos cães podem ir por canoa?',
    a: 'Por segurança e equilíbrio, <strong>o habitual é um cão por canoa</strong>. Se vierem com mais do que um, distribuímo-los entre as canoas do grupo. Para casos especiais (cão pequeno + cão pequeno tranquilos) podemos avaliar à chegada.' },
  { q: 'Podem ir cães grandes?',
    a: 'Sim, desde que seja um cão <strong>tranquilo, habituado a sair e que tolere a água</strong>. Os cães grandes ocupam mais espaço e afetam mais o equilíbrio, por isso avaliamo-lo antes do embarque. Um cão grande tranquilo costuma ir muito melhor que um cão pequeno muito nervoso.' },
  { q: 'É preciso que o meu cão saiba nadar?',
    a: 'Não é imprescindível, mas ajuda saber antes. Se o seu cão <strong>não tem experiência na água</strong> ou não transmite segurança a nadar, <strong>é melhor ir com colete canino</strong> · damos-lho até esgotar. O Sella turístico tem corrente tranquila, mas o colete dá um plus real.' },
  { q: 'O que faço se o meu cão se stressar ou não quiser continuar?',
    a: 'Paramos. Há <strong>praias fluviais tranquilas</strong> onde o cão pode descer, esticar patas, beber água e respirar. Se se stressar muito, podemos procurar uma saída antecipada pela margem e coordenar o regresso. <strong>Ninguém desce contra a vontade do seu cão</strong>.' },
  { q: 'É melhor a rota Mini ou Completa com cão?',
    a: 'Para cães pouco habituados ou de idade avançada, recomendamos a <strong>Mini Sella</strong> (Arriondas → Toraño, 7 km, 2-3 h) — ritmo tranquilo e menos tempo na água. Para cães ativos e em forma, a <strong>Completa</strong> (Arriondas → Fríes, 14,5 km, 4-5 h) é perfeitamente viável com paragens.' },
  { q: 'É preciso reservar com antecedência?',
    a: 'Sim, <strong>especialmente em época alta</strong>. Reserve sem pagar agora: confirma a vaga, paga com cartão antes ou no dia ao recolher a canoa. Se cancelar antes do dia, sem custo; se pagou com cartão, reembolso avisando com 24 h.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descida do Sella com cão: guia completo para desfrutar com o seu animal',
      description: 'Guia para descer o Sella com cão: normas, colete salva-vidas canino incluído (até esgotar), como colocar o cão na canoa, o que levar e porque é o plano dog-friendly estrela das Astúrias.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/con-perro-cta-lg.jpg`,
        width: 1920,
        height: 1080,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-19',
      dateModified:  '2026-05-12',
      articleSection: 'Animais',
      keywords: ['descida do sella com cão', 'descida do sella animais grátis', 'canoa com cão sella', 'colete canino sella', 'dog-friendly arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Descida do Sella com cão · atividade dog-friendly nas Astúrias' },
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Descida do Sella com cão',
      description: 'Atividade de descida do Sella em canoa dog-friendly. Animais grátis. Colete salva-vidas canino incluído sem custo extra (até esgotar). Monitores com experiência canina, briefing específico, normas claras. Tudo incluído: canoa, colete humano homologado, colete canino, transfer, estacionamento e balneários com zona exterior para secar o cão.',
      serviceType: 'Descida do Sella dog-friendly',
      category: 'Turismo ativo · Animais',
      url: canonicalUrl,
      provider: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      areaServed: { '@type': 'Place', name: 'Arriondas, Astúrias' },
      audience: { '@type': 'Audience', audienceType: 'Famílias e donos com animais' },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'EUR',
        lowPrice: '0.00',
        highPrice: '40.00',
        offerCount: 3,
        availability: 'https://schema.org/InStock',
        url: `${baseUrl}/pt/reservar/`,
        offers: [
          { '@type': 'Offer', name: 'Animal',             price: '0.00',  priceCurrency: 'EUR', url: `${baseUrl}/pt/reservar/`, description: 'Grátis · todos os animais viajam sem custo' },
          { '@type': 'Offer', name: 'Criança (5-12 anos)', price: '30.00', priceCurrency: 'EUR', url: `${baseUrl}/pt/reservar/` },
          { '@type': 'Offer', name: 'Adulto (13+ anos)',   price: '40.00', priceCurrency: 'EUR', url: `${baseUrl}/pt/reservar/` },
        ],
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',     item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Com cão',    item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/pt/com-cao/" translationKey="con_perro">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="cnh cnh--cream" aria-labelledby="cnh-title">

    <div class="cnh__inner">
      <nav class="cnh__breadcrumb" aria-label="Breadcrumb">
        <a href="/pt/">Início</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Com cão</span>
      </nav>

      <span class="cnh__eyebrow">
        <span class="cnh__eyebrow-dot" aria-hidden="true"></span>
        Dog-friendly · Temporada 2026
      </span>

      <h1 id="cnh-title" class="cnh__title">
        Descida do Sella<br/>
        <span class="serif-italic">com <span class="cnh__underlined">cão<svg class="cnh__swoosh" width="200" height="18" viewBox="0 0 200 18" fill="none" aria-hidden="true"><path d="M3 14C30 6 74 4 118 8c27 2.5 54 6 78 4" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/></svg></span></span>
      </h1>

      <p class="cnh__lead">
        <strong>Aventura com o seu animal nas Astúrias</strong>. Um dia dog-friendly pensado
        ao detalhe — com normas claras antes de partir, monitores com experiência canina
        e um rio tranquilo para desfrutar juntos. <strong>O cão vem grátis</strong>.
      </p>

      <div class="cnh__stats">
        <div class="cnh__stat">
          <span class="cnh__stat-value">Grátis</span>
          <span class="cnh__stat-label">O seu cão não paga</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">40 €</span>
          <span class="cnh__stat-label">Por pessoa · tudo incluído</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">4.5 ⭐</span>
          <span class="cnh__stat-label">147 avaliações</span>
        </div>
      </div>

      <div class="cnh__ctas">
        <a href={getLocalePath('reservar', 'pt')} class="cnh__cta cnh__cta--primary">
          Reservar com o meu cão
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+34681093673" class="cnh__cta cnh__cta--phone" aria-label="Ligar para 681 093 673">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Ligar</span>
        </a>
        <a href={getLocalePath('precios', 'pt')} class="cnh__cta cnh__cta--ghost">
          Ver preços e modalidades
        </a>
      </div>
    </div>
  </section>

  <!-- ============== INTRO ============== -->
  <section class="cni">
    <div class="container container--xl">
      <div class="cni__grid">
        <div class="cni__media" data-reveal>
          <div class="cni__mediaMain">
            <Picture src="con-perro-intro-1" alt="Cão a bordo de uma canoa na descida do Sella" sizes="(min-width: 960px) 44vw, 90vw" aspectRatio="1 / 1" bare />
          </div>
          <div class="cni__mediaSmall" aria-hidden="true">
            <Picture src="con-perro-intro-2" alt="Cão a desfrutar do rio Sella com a sua família" sizes="220px" aspectRatio="1 / 1" bare />
          </div>
          <a class="cni__contact" href="https://wa.me/34681093673?text=Olá,%20tenho%20uma%20dúvida%20sobre%20descer%20o%20Sella%20com%20o%20meu%20cão" target="_blank" rel="noopener noreferrer">
            <span class="cni__contactIcon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-1-.5-2-.8-2.9-1.9-.7-.6-1.2-1.4-1.6-2.1-.2-.3 0-.5.1-.7.1-.2.3-.4.5-.6.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5-.2 0-.4 0-.6 0-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6 0 1.6 1.1 3.1 1.3 3.3.2.2 2.3 3.6 5.7 5 3.4 1.4 3.4.9 4 .9.6-.1 1.8-.8 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3z"/></svg>
            </span>
            <div class="cni__contactBody">
              <strong>Dúvidas com o seu cão?</strong>
              <span>WhatsApp · respondemos rápido</span>
            </div>
          </a>
        </div>

        <div class="cni__content" data-reveal data-reveal-delay="2">
          <span class="cni__eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            A pergunta de sempre
          </span>
          <h2 class="cni__title">
            Pode-se descer<br/>
            o Sella <span class="serif-italic">com cão?</span>
          </h2>
          <p class="cni__lead">
            <strong>Sim, e os animais vêm totalmente grátis.</strong> O Sella é um dos
            planos dog-friendly estrela das Astúrias — rio tranquilo, paragens quando o
            cão pede, e uma equipa que sabe o que olhar antes de entrar na água.
          </p>

          <ul class="cni__features">
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Animais 100% grátis</h3>
                <p class="cni__featureText">O seu cão não paga. Vem consigo na canoa <strong>sem custo extra</strong>. A única exceção é o sábado da Descida Internacional.</p>
              </div>
            </li>
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Monitores dog-friendly</h3>
                <p class="cni__featureText">Com experiência real a descer o Sella com animais. <strong>Sabem o que olhar antes de entrar na água</strong> e como preparar o dia para ambos.</p>
              </div>
            </li>
          </ul>

          <a href={getLocalePath('reservar', 'pt')} class="cni__cta">
            Reservar com o meu cão
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== JORNADA · 6 passos ============== -->
  <section class="cnj">
    <div class="container container--xl">
      <header class="cnj__header" data-reveal>
        <span class="cnj__eyebrow">— Como é o dia com o seu cão</span>
        <h2 class="cnj__title">
          Um dia no Sella,<br/>
          <span class="serif-italic">passo a passo</span>
        </h2>
        <p class="cnj__lead">
          Saber como decorre o dia ajuda a decidir-se. Assim preparamos a
          experiência para que <strong>você e o seu cão estejam confortáveis e seguros</strong> de princípio
          ao fim — sem pressas, sem surpresas.
        </p>
      </header>

      <ol class="cnjT">
        {jornada.map((j, i) => (
          <li class={`cnjT__step ${i % 2 === 0 ? 'cnjT__step--left' : 'cnjT__step--right'}`} data-reveal>
            <span class="cnjT__node" aria-hidden="true">{j.num}</span>
            <div class="cnjT__body">
              <h3 class="cnjT__title">{j.title}</h3>
              <p class="cnjT__text" set:html={j.text} />
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- ============== SEGURANÇA ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Segurança e confiança</span>
        <h2 class="cns__title">
          O que olhar com o seu cão,<br/>
          <span class="serif-italic">e como o resolvemos</span>
        </h2>
        <p class="cns__lead">
          A primeira pergunta é sempre <strong>"é seguro para o meu cão?"</strong> — e é
          lógica. A resposta curta é sim, quando é feito com bom senso, normas
          claras e uma avaliação honesta de como é o seu animal.
        </p>
      </header>

      <ol class="cns__grid">
        <li class="cns__item" data-reveal data-reveal-delay="1">
          <span class="cns__num" aria-hidden="true">01</span>
          <h3 class="cns__itemTitle">Animais 100% grátis</h3>
          <p class="cns__itemText">O seu cão não paga. Vem consigo na canoa <strong>sem custo extra</strong>, com normas dog-friendly explicadas antes de partir.</p>
