  }
  .met__stat strong small {
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .met__stat span:last-child {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .met__desc {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .met__desc strong { color: var(--color-text-primary); font-weight: 700; }

  .met__features {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;
    width: 100%;
  }
  @media (min-width: 500px) { .met__features { grid-template-columns: repeat(3, 1fr); } }
  .met__features li {
    padding: 0.55rem 0.9rem;
    background: rgba(61, 79, 58, 0.06);
    border: 1px solid rgba(61, 79, 58, 0.15);
    border-radius: 8px;
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.2px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
    transition: background 200ms ease, border-color 200ms ease, transform 200ms ease;
  }
  .met__features li:hover {
    background: rgba(61, 79, 58, 0.12);
    border-color: rgba(61, 79, 58, 0.3);
    transform: translateY(-2px);
  }
  .met__panel.is-active .met__features li { animation: metFeatureIn 500ms cubic-bezier(0.22, 1, 0.36, 1) both; }
  .met__panel.is-active .met__features li:nth-child(1) { animation-delay: 180ms; }
  .met__panel.is-active .met__features li:nth-child(2) { animation-delay: 240ms; }
  .met__panel.is-active .met__features li:nth-child(3) { animation-delay: 300ms; }
  .met__panel.is-active .met__features li:nth-child(4) { animation-delay: 360ms; }
  .met__panel.is-active .met__features li:nth-child(5) { animation-delay: 420ms; }
  .met__panel.is-active .met__features li:nth-child(6) { animation-delay: 480ms; }
  @keyframes metFeatureIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .met__cta {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #FBF8F1;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    margin-top: 0.5rem;
    transition: all 240ms cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 10px 24px rgba(26, 31, 46, 0.2);
  }
  .met__cta:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(26, 31, 46, 0.32); }
  .met__ctaIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: #FBF8F1; color: var(--color-text-primary, #1A1F2E);
    transition: transform 240ms ease;
  }
  .met__cta:hover .met__ctaIcon { transform: rotate(-12deg) translateX(2px); }

  .met__photo {
    position: relative;
    min-height: 360px;
    overflow: hidden;
    border-radius: clamp(0.5rem, 1.5vw, 1rem);
    isolation: isolate;
    /* Slide entry: empieza desplazada y oculta */
    transform: translateX(-80px);
    opacity: 0;
    transition:
      transform 1100ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 900ms ease-out,
      box-shadow 380ms ease;
  }
  /* Cuando el panel está activo, la foto entra desde la izquierda */
  .met__panel.is-active .met__photo {
    transform: translateX(0);
    opacity: 1;
  }
  .met__photo:hover {
    box-shadow: 0 24px 56px -22px rgba(26, 31, 46, 0.28);
  }
  .met__photo :global(picture),
  .met__photo :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    position: absolute; inset: 0;
    transition: transform 1400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .met__photo:hover :global(img) { transform: scale(1.05); }
  /* Reflejo glass diagonal en hover · estilo deluxe premium */
  .met__photo::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0) 40%,
      rgba(255, 255, 255, 0.4) 50%,
      rgba(255, 255, 255, 0) 60%,
      transparent 70%
    );
    transform: translateX(-110%);
    pointer-events: none;
    z-index: 2;
  }
  .met__photo:hover::after {
    animation: metGlass 1100ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes metGlass {
    0%   { transform: translateX(-110%); }
    100% { transform: translateX(110%); }
  }
  .met__badges {
    position: absolute;
    top: clamp(1rem, 2vw, 1.5rem);
    left: clamp(1rem, 2vw, 1.5rem);
    display: flex; flex-direction: column; gap: 0.5rem;
    z-index: 1;
  }
  .met__badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    background: rgba(26, 31, 46, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #FBF8F1;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.4px; text-transform: uppercase;
    transition: background 200ms ease, transform 200ms ease;
  }
  .met__badge:hover { background: var(--color-primary); transform: translateX(3px); }
  .met__panel.is-active .met__badge { animation: metBadgeIn 500ms cubic-bezier(0.22, 1, 0.36, 1) both; }
  .met__panel.is-active .met__badge:nth-child(1) { animation-delay: 240ms; }
  .met__panel.is-active .met__badge:nth-child(2) { animation-delay: 340ms; }
  .met__panel.is-active .met__badge:nth-child(3) { animation-delay: 440ms; }
  @keyframes metBadgeIn {
    from { opacity: 0; transform: translateX(-14px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @media (max-width: 899.98px) { .met__photo { min-height: 280px; aspect-ratio: 4 / 3; } }
  @media (prefers-reduced-motion: reduce) {
    .met__panel.is-active { animation: none; }
    .met__cta:hover { transform: none; }
    .met__photo,
    .met__photo :global(img),
    .met__photo::after { transition: none !important; animation: none !important; }
    .met__photo:hover :global(img) { transform: none; }
    .met__photo:hover { box-shadow: none; }
  }

  /* ============== 4 · CTA intermedio sage dark (REUSE) ============== */
  .mem {
    padding-block: clamp(4rem, 8vw, 6rem);
    background:
      radial-gradient(ellipse 70% 55% at 15% 20%, rgba(244, 181, 163, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 55% 50% at 100% 100%, rgba(251, 248, 241, 0.06) 0%, transparent 60%),
      linear-gradient(180deg, #3D4F3A 0%, #2C3B2A 100%);
    color: #FBF8F1;
    position: relative;
    isolation: isolate;
  }
  .mem::before {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background-image:
      linear-gradient(rgba(251, 248, 241, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(251, 248, 241, 0.035) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 75%);
  }
  .mem__wrap { max-width: 780px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .mem__quote {
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    font-size: clamp(1.25rem, 2.4vw, 1.75rem); line-height: 1.45;
    color: #FBF8F1;
    margin: 0 0 clamp(2.25rem, 4vw, 2.75rem);
    letter-spacing: -0.005em;
  }
  .mem__quote em { color: var(--color-primary-soft, #F4B5A3); font-style: italic; }
  .mem__quote strong { font-style: normal; font-weight: 700; color: #FBF8F1; }
  .mem__rule { display: flex; align-items: center; gap: 1rem; }
  .mem__ruleLine { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(251, 248, 241, 0.3), transparent); }
  .mem__pill {
    display: inline-flex; align-items: center; gap: 0.625rem;
    padding: 0.9rem 1.6rem 0.9rem 1.35rem;
    background: #FBF8F1; color: var(--color-sage, #3D4F3A);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 800;
    letter-spacing: 1.2px; text-transform: uppercase;
    flex-shrink: 0;
    transition: all 260ms cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
  }
  .mem__pill:hover { transform: translateY(-3px); background: var(--color-primary-soft, #F4B5A3); box-shadow: 0 16px 36px rgba(0, 0, 0, 0.42); }
  .mem__pillDot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-primary);
    animation: memPillPulse 2s ease-in-out infinite;
  }
  @keyframes memPillPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(233, 133, 111, 0.6); }
    50%      { box-shadow: 0 0 0 6px rgba(233, 133, 111, 0); }
  }
  .mem__pill svg { transition: transform 220ms; }
  .mem__pill:hover svg { transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) { .mem__pillDot { animation: none; } }

  /* ============== 5 · BARRAS AFLUENCIA 12 MESES ============== */
  .mea {
    padding-block: clamp(4rem, 8vw, 6rem);
    background:
      radial-gradient(ellipse 60% 50% at 90% 10%, rgba(233, 133, 111, 0.08) 0%, transparent 60%),
      var(--color-bg-base);
  }
  .mea__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .mea__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1.5rem;
  }
  .mea__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }
  .mea__title .serif-italic { color: var(--color-primary); font-family: var(--font-serif); font-weight: 400; font-style: italic; letter-spacing: -0.01em; text-transform: none; }
  .mea__lead { font-family: var(--font-sans); font-size: 1rem; line-height: 1.7; color: var(--color-text-secondary); margin: 0; }
  .mea__lead strong { color: var(--color-text-primary); font-weight: 700; }

  .mea__chart {
    max-width: 1100px; margin: 0 auto;
  }

  /* ===== 12 Photo-cards encima de las barras (flip 180° Y al hover + shine horizontal) ===== */
  .mea__cards {
    list-style: none; padding: 0; margin: 0 0 clamp(1.5rem, 3vw, 2rem);
    display: grid; grid-template-columns: repeat(12, 1fr);
    gap: 0.375rem;
    perspective: 1200px;
  }
  .mea__card {
    aspect-ratio: 1 / 1;
    min-width: 0;
    position: relative;
  }
  .mea__cardInner {
    position: relative;
    width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .mea__card:hover .mea__cardInner,
  .mea__card:focus-within .mea__cardInner {
    transform: rotateY(180deg);
  }
  .mea__cardFront,
  .mea__cardBack {
    position: absolute; inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(26, 31, 46, 0.08);
  }
  /* Front · foto + month label */
  .mea__cardFront {
    display: flex; flex-direction: column; justify-content: flex-end;
    background: #1A1F2E;
  }
  .mea__cardPhoto {
    position: absolute; inset: 0;
    overflow: hidden;
  }
  .mea__cardPhoto :global(picture),
  .mea__cardPhoto :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    filter: saturate(1.05) contrast(1.02);
    transition: transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mea__card:hover .mea__cardPhoto :global(img),
  .mea__card:hover .mea__cardPhoto :global(picture) { transform: scale(1.08); }

  /* Shine horizontal · reflejo que pasa de izq a dcha continuo + al hover se acelera */
  .mea__cardShine {
    position: absolute;
    top: 0; left: -60%;
    width: 40%; height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 100%
    );
    transform: skewX(-18deg);
    animation: meaShineLoop 4.6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes meaShineLoop {
    0%, 18%   { left: -60%; }
    52%, 100% { left: 120%; }
  }
  .mea__card:hover .mea__cardShine {
    animation: meaShineHover 850ms ease-in-out;
    animation-iteration-count: 1;
  }
  @keyframes meaShineHover {
    0%   { left: -60%; }
    100% { left: 120%; }
  }

  /* Front gradient overlay on bottom for readability */
  .mea__cardFront::after {
    content: "";
    position: absolute; bottom: 0; left: 0; right: 0; height: 55%;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.78) 100%);
    pointer-events: none;
  }
  .mea__cardM {
    position: relative; z-index: 1;
    padding: 0.5rem 0.375rem;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.3px; text-transform: uppercase;
    color: #FBF8F1;
    text-align: center;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  /* Back · info textual (rotado 180Y para que salga leíble) */
  .mea__cardBack {
    transform: rotateY(180deg);
    background: linear-gradient(160deg, var(--color-sage, #3D4F3A) 0%, #2C3B2A 100%);
    color: #FBF8F1;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.25rem;
    padding: 0.5rem 0.25rem;
    text-align: center;
  }
  .mea__cardFull {
    font-family: var(--font-display); font-size: clamp(0.625rem, 1.4vw, 0.8125rem);
    font-weight: 900; letter-spacing: 0.4px; text-transform: uppercase;
    line-height: 1;
  }
  .mea__cardTemp {
    font-family: var(--font-serif); font-style: italic;
    font-size: clamp(0.875rem, 1.8vw, 1.125rem); font-weight: 400;
    color: var(--color-primary-soft, #F4B5A3);
    line-height: 1;
    margin-top: 0.25rem;
  }
  .mea__cardNota {
    font-family: var(--font-sans); font-size: 0.5625rem; font-weight: 600;
    line-height: 1.25;
    color: rgba(251, 248, 241, 0.78);
    letter-spacing: 0.2px;
    padding: 0 0.25rem;
  }

  /* Mobile responsive · 4 cols en móvil pequeño, 6 en medio, 12 en desktop */
  @media (max-width: 640px) {
    .mea__cards { grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
  }
  @media (min-width: 640.01px) and (max-width: 900px) {
    .mea__cards { grid-template-columns: repeat(6, 1fr); gap: 0.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mea__cardInner { transition: none; }
    .mea__cardShine { animation: none; opacity: 0; }
    .mea__card:hover .mea__cardShine { animation: none; }
    .mea__card:hover .mea__cardPhoto :global(img) { transform: none; }
  }

  .mea__bars {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(12, 1fr);
    gap: 0.375rem;
    align-items: end;
    min-height: 220px;
  }
  .mea__bar {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.375rem;
    min-width: 0;
  }
  .mea__barTrack {
    width: 100%;
    height: 160px;
    background: linear-gradient(180deg, rgba(26, 31, 46, 0.03), rgba(26, 31, 46, 0.06));
    border-radius: 6px;
    display: flex; flex-direction: column; justify-content: flex-end;
    overflow: hidden;
    position: relative;
    transition: box-shadow 260ms ease, background 260ms ease;
  }
  .mea__bar:hover .mea__barTrack {
    background: linear-gradient(180deg, rgba(26, 31, 46, 0.05), rgba(26, 31, 46, 0.1));
    box-shadow: inset 0 0 0 1px rgba(233, 133, 111, 0.4);
  }
  .mea__barFill {
    position: relative;
    width: 100%;
    height: 0;
    background: linear-gradient(180deg, var(--color-primary-soft, #F4B5A3), var(--color-primary));
    border-radius: 6px 6px 4px 4px;
    transition: height 1500ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: height;
    overflow: hidden;
  }
  /* Shine sweep al hover · diagonal desde arriba a abajo · se dispara siempre */
  .mea__barFill::after {
    content: "";
    position: absolute;
    top: -30%; left: -50%;
    width: 60%; height: 160%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.1) 45%,
      rgba(255, 255, 255, 0.65) 50%,
      rgba(255, 255, 255, 0.1) 55%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-100%) skewX(-8deg);
    pointer-events: none;
    opacity: 0;
  }
  .mea__bar:hover .mea__barFill::after {
    animation: meaShine 900ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes meaShine {
    0%   { transform: translateX(-100%) skewX(-8deg); opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateX(300%) skewX(-8deg); opacity: 0; }
  }
  /* Agosto pico · color sage oscuro para destacarlo */
  .mea__bar[data-level="100"] .mea__barFill { background: linear-gradient(180deg, #4A5E47, var(--color-sage, #3D4F3A)); }
  .mea__bar[data-level="100"]:hover .mea__barTrack { box-shadow: inset 0 0 0 1px rgba(61, 79, 58, 0.5); }
  /* Low months: subtle coral */
  .mea__bar[data-level="0"] .mea__barFill { background: rgba(26, 31, 46, 0.08); }
  .mea__bar[data-level="0"]:hover .mea__barFill::after { animation: none; }

  /* Animación width → height al entrar viewport */
  .mea__chart.is-visible .mea__barFill { height: var(--p); }
  .mea__chart.is-visible .mea__bar:nth-child(1)  .mea__barFill { transition-delay: 50ms; }
  .mea__chart.is-visible .mea__bar:nth-child(2)  .mea__barFill { transition-delay: 100ms; }
  .mea__chart.is-visible .mea__bar:nth-child(3)  .mea__barFill { transition-delay: 150ms; }
  .mea__chart.is-visible .mea__bar:nth-child(4)  .mea__barFill { transition-delay: 200ms; }
  .mea__chart.is-visible .mea__bar:nth-child(5)  .mea__barFill { transition-delay: 250ms; }
  .mea__chart.is-visible .mea__bar:nth-child(6)  .mea__barFill { transition-delay: 300ms; }
  .mea__chart.is-visible .mea__bar:nth-child(7)  .mea__barFill { transition-delay: 350ms; }
  .mea__chart.is-visible .mea__bar:nth-child(8)  .mea__barFill { transition-delay: 400ms; }
  .mea__chart.is-visible .mea__bar:nth-child(9)  .mea__barFill { transition-delay: 450ms; }
  .mea__chart.is-visible .mea__bar:nth-child(10) .mea__barFill { transition-delay: 500ms; }
  .mea__chart.is-visible .mea__bar:nth-child(11) .mea__barFill { transition-delay: 550ms; }
  .mea__chart.is-visible .mea__bar:nth-child(12) .mea__barFill { transition-delay: 600ms; }

  .mea__barM {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.3px; text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .mea__barV {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .mea__foot {
    text-align: center; max-width: 560px; margin: 1.75rem auto 0;
    font-family: var(--font-sans); font-size: 0.875rem; line-height: 1.6;
    color: var(--color-text-secondary);
  }
  .mea__foot strong { color: var(--color-text-primary); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .mea__barFill { transition: none; height: var(--p); }
    .mea__bar:hover .mea__barFill::after { animation: none; }
  }

  /* ============== 6 · CONSEJOS · editorial carrusel (Variante B sage · 1 línea slide) ============== */
  .meq {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: #FBF8F1;
    position: relative;
    overflow: hidden;
  }
  .meq::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26, 31, 46, 0.12), transparent);
  }

  /* Header · title left + nav (counter + arrows) right */
  .meq__header {
    display: flex; flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2rem);
    align-items: flex-start; justify-content: space-between;
    max-width: 1300px; margin: 0 auto;
  }
  @media (min-width: 720px) {
    .meq__header { flex-direction: row; align-items: flex-end; gap: 2rem; }
  }
  .meq__headerMain { min-width: 0; }
  .meq__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: clamp(0.75rem, 1.5vw, 1rem);
  }
  .meq__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    margin: 0;
  }

  /* Navegación · contador + flechas modernas */
  .meq__nav {
    display: inline-flex; align-items: center; gap: 0.875rem;
    flex-shrink: 0;
  }
  .meq__counter {
    display: inline-flex; align-items: baseline; gap: 0.25rem;
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-right: 0.5rem;
    letter-spacing: 0.3px;
  }
  .meq__counterCurrent {
    font-family: var(--font-display); font-style: normal;
    font-size: 1.25rem; font-weight: 900;
    color: var(--color-sage, #3D4F3A);
    letter-spacing: -0.02em;
    min-width: 1.5ch;
    display: inline-block;
    transition: color 240ms ease;
  }
  .meq__counterSep { opacity: 0.4; padding: 0 0.125rem; }
  .meq__counterTotal { font-family: var(--font-serif); font-size: 0.9375rem; }

  .meq__navBtn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px;
    padding: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--color-sage, #3D4F3A);
    border: 1.5px solid var(--color-sage, #3D4F3A);
    cursor: pointer;
    transition: all 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .meq__navBtn:hover:not(:disabled) {
    background: var(--color-sage, #3D4F3A);
    color: #FBF8F1;
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(61, 79, 58, 0.28);
  }
  .meq__navBtn:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(61, 79, 58, 0.2);
  }
  .meq__navBtn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    border-color: rgba(61, 79, 58, 0.3);
  }
  .meq__navBtn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
  .meq__navIcon { transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1); }
  .meq__navBtn[data-meq-nav="prev"]:hover:not(:disabled) .meq__navIcon { transform: translateX(-3px); }
  .meq__navBtn[data-meq-nav="next"]:hover:not(:disabled) .meq__navIcon { transform: translateX(3px); }

  /* Divider hairline */
  .meq__divider {
    border: 0; height: 1px;
    background: rgba(26, 31, 46, 0.14);
    max-width: 1300px;
    margin: clamp(1.5rem, 3vw, 2rem) auto clamp(2rem, 4vw, 3rem);
  }

  /* Track · scroll horizontal con snap · padding generoso para no cortar el scale de la card activa */
  .meq__track {
    max-width: 1300px;
    margin: 0 auto;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 2rem clamp(0.75rem, 2vw, 1.25rem) 2.5rem;
    margin-left: calc(clamp(0.75rem, 2vw, 1.25rem) * -1);
    margin-right: calc(clamp(0.75rem, 2vw, 1.25rem) * -1);
  }
  .meq__track::-webkit-scrollbar { display: none; }
  .meq__track:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 4px; border-radius: 1rem; }

  /* Lista horizontal · todas las cards en una línea */
  .meqL {
    list-style: none; padding: 0; margin: 0;
    display: flex;
    gap: 1rem;
    align-items: stretch;
  }

  /* Cards editoriales · número gigante watermark + body abajo · ancho fijo para snap */
  .meqItem {
    position: relative;
    flex: 0 0 clamp(260px, 30vw, 320px);
    padding: clamp(1.75rem, 3vw, 2.25rem) clamp(1.5rem, 2.5vw, 1.75rem);
    background: #F3EFE4;
    color: var(--color-text-primary);
    border-radius: 1.25rem;
    display: flex; flex-direction: column;
    gap: clamp(1rem, 2vw, 1.5rem);
    min-height: 240px;
    scroll-snap-align: start;
    transform-origin: center;
    transform: scale(1);
    transition: transform 460ms cubic-bezier(0.22, 1, 0.36, 1),
                background 360ms ease,
                color 360ms ease;
    will-change: transform, background;
  }

  .meqItem__num {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5vw, 3.75rem);
    font-weight: 900; line-height: 0.9;
    letter-spacing: -0.03em;
    color: rgba(26, 31, 46, 0.14);
    user-select: none; pointer-events: none;
    transition: color 360ms ease;
  }

  .meqItem__body {
    display: flex; flex-direction: column; gap: 0.5rem;
    margin-top: auto;
  }
  .meqItem__t {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    font-weight: 900; line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0;
    transition: color 360ms ease;
  }
  .meqItem__s {
    font-family: var(--font-sans); font-size: 0.875rem; line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
    transition: color 360ms ease;
  }
  .meqItem__s strong { color: var(--color-text-primary); font-weight: 700; transition: color 360ms ease; }
  .meqItem__s a { color: var(--color-sage, #3D4F3A); border-bottom: 1px solid rgba(61, 79, 58, 0.4); transition: color 360ms ease, border-color 360ms ease; }

  /* Card ACTIVA · sage profundo + scale sutil · sin sombra rara */
  .meqItem.is-active {
    background: linear-gradient(160deg, #3D4F3A 0%, #2C3B2A 100%);
    color: #FBF8F1;
    transform: scale(1.04);
    z-index: 2;
  }
  .meqItem.is-active .meqItem__num { color: rgba(251, 248, 241, 0.20); }
  .meqItem.is-active .meqItem__t { color: #FBF8F1; }
  .meqItem.is-active .meqItem__s { color: rgba(251, 248, 241, 0.88); }
  .meqItem.is-active .meqItem__s strong { color: #FBF8F1; }
  .meqItem.is-active .meqItem__s a { color: var(--color-primary-soft, #F4B5A3); border-bottom-color: rgba(244, 181, 163, 0.5); }

  /* Progress bar · línea fina que se llena según el scroll del track */
  .meq__progress {
    max-width: 1300px; margin: 0 auto;
    height: 2px;
    background: rgba(26, 31, 46, 0.08);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }
  .meq__progressBar {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--color-sage, #3D4F3A), var(--color-primary));
    border-radius: 999px;
    transition: width 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Foot link */
  .meq__foot {
    text-align: center;
    margin: clamp(2rem, 4vw, 2.75rem) auto 0;
  }
  .meq__footLink {
    display: inline-flex; align-items: center; gap: 0.625rem;
    font-family: var(--font-sans); font-size: 0.875rem; font-weight: 800;
    letter-spacing: 0.3px;
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-primary);
    padding-bottom: 4px;
    transition: color 220ms, border-color 220ms;
  }
  .meq__footLink:hover { color: var(--color-primary); border-bottom-color: var(--color-text-primary); }
  .meq__footLink svg { color: var(--color-primary); transition: transform 220ms; }
  .meq__footLink:hover svg { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .meqItem { transition: background 200ms ease, color 200ms ease; }
    .meqItem.is-active { transform: none; }
    .meq__navBtn { transition: background 200ms, color 200ms; }
    .meq__navBtn:hover:not(:disabled) { transform: none; }
    .meq__navIcon { transition: none; }
    .meq__track { scroll-behavior: auto; }
    .meq__progressBar { transition: none; }
    .meq__footLink:hover svg { transform: none; }
  }

  /* ============== 7 · INTERLINKING + PANEL RESERVA (REUSE cdx · sage dark) ============== */
  .mex {
    padding-block: clamp(4rem, 8vw, 6rem);
    background:
      radial-gradient(ellipse 60% 50% at 10% 100%, rgba(244, 181, 163, 0.12) 0%, transparent 65%),
      linear-gradient(180deg, #3D4F3A 0%, #2C3B2A 100%);
    color: #FBF8F1;
    overflow: hidden;
    position: relative;
    isolation: isolate;
  }
  .mex::before {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background-image:
      linear-gradient(rgba(251, 248, 241, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(251, 248, 241, 0.03) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 50% 40%, black 10%, transparent 80%);
    pointer-events: none;
  }
  .mex__header { max-width: 900px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .mex__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    margin-bottom: 1rem;
  }
  .mex__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.02em; text-transform: uppercase;
    color: #FBF8F1;
    margin: 0 0 1.25rem;
  }
  .mex__title .serif-italic { color: var(--color-primary-soft, #F4B5A3); font-family: var(--font-serif); font-style: italic; font-weight: 400; text-transform: none; letter-spacing: -0.01em; }
  .mex__lead { font-family: var(--font-sans); font-size: 1rem; line-height: 1.7; color: rgba(251, 248, 241, 0.78); margin: 0; }
  .mex__lead strong { color: #FBF8F1; font-weight: 700; }

  .mex__grid {
    display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3rem);
    max-width: 1200px; margin: 0 auto; align-items: stretch;
  }
  @media (min-width: 900px) { .mex__grid { grid-template-columns: 1fr 1.05fr; gap: clamp(2.5rem, 4vw, 3.5rem); } }

  .mex__reserva { position: relative; border-radius: 1.25rem; overflow: hidden; box-shadow: 0 24px 56px rgba(0, 0, 0, 0.4); align-self: stretch; min-height: 100%; }
  .mex__reservaBg { position: absolute; inset: 0; overflow: hidden; }
  .mex__reservaBg :global(picture), .mex__reservaBg :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    transform-origin: 50% 60%;
    animation: mexKen 24s ease-in-out infinite alternate;
  }
  @keyframes mexKen { 0% { transform: scale(1.02); } 100% { transform: scale(1.12) translate(-1%, 1%); } }
  .mex__reservaScrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 20, 30, 0.65) 0%, rgba(15, 20, 30, 0.55) 35%, rgba(15, 20, 30, 0.9) 100%),
      radial-gradient(ellipse 60% 45% at 15% 80%, rgba(61, 79, 58, 0.4) 0%, transparent 70%);
  }
  .mex__reservaInner {
    position: relative; height: 100%;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex; flex-direction: column; gap: clamp(1rem, 2vw, 1.25rem);
    justify-content: flex-start;
  }
  .mex__reservaKicker {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.875rem 0.4rem 0.625rem;
    background: rgba(251, 248, 241, 0.1);
    border: 1px solid rgba(251, 248, 241, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    align-self: flex-start;
  }
  .mex__reservaDot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--color-primary);
    animation: mexResPulse 2.2s ease-in-out infinite;
  }
  @keyframes mexResPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(233, 133, 111, 0.5); }
    50%      { box-shadow: 0 0 0 6px rgba(233, 133, 111, 0); }
  }
  .mex__reservaT {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.125rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: #FBF8F1;
    margin: 0;
  }
  .mex__reservaT .serif-italic { color: var(--color-primary-soft, #F4B5A3); font-family: var(--font-serif); font-style: italic; font-weight: 400; text-transform: none; letter-spacing: -0.01em; }
  .mex__reservaS { font-family: var(--font-sans); font-size: 0.875rem; line-height: 1.65; color: rgba(251, 248, 241, 0.8); margin: 0 0 0.25rem; }
  .mex__reservaS strong { color: #FBF8F1; font-weight: 700; }

  .mex__channels { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; margin-top: auto; }
  .mex__ch {
    display: grid; grid-template-columns: auto 1fr auto; gap: 0.875rem;
    align-items: center;
    padding: 0.875rem 1rem;
    background: rgba(251, 248, 241, 0.08);
    border: 1px solid rgba(251, 248, 241, 0.14);
    border-radius: 0.75rem;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: all 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mex__ch:hover { background: rgba(251, 248, 241, 0.14); border-color: rgba(244, 181, 163, 0.5); transform: translateX(3px); }
  .mex__chIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(251, 248, 241, 0.12);
    color: var(--color-primary-soft, #F4B5A3);
    transition: background 260ms ease, color 260ms ease;
    flex-shrink: 0;
  }
  .mex__ch--wa .mex__chIcon { color: #25D366; }
  .mex__ch:hover .mex__chIcon { background: var(--color-primary); color: #FBF8F1; }
  .mex__ch--wa:hover .mex__chIcon { background: #25D366; color: #FBF8F1; }
  .mex__chBody { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .mex__chLabel { font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 800; color: #FBF8F1; letter-spacing: 0.3px; }
  .mex__chValue { font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 600; color: rgba(251, 248, 241, 0.65); letter-spacing: 0.3px; }
  .mex__chArrow {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    color: rgba(251, 248, 241, 0.5);
    transition: transform 260ms ease, color 260ms ease;
    flex-shrink: 0;
  }
  .mex__ch:hover .mex__chArrow { color: var(--color-primary-soft, #F4B5A3); transform: translateX(4px); }

  .mex__list { display: flex; flex-direction: column; gap: 0.75rem; }
  .mex__item {
    background: rgba(251, 248, 241, 0.05);
    border: 1px solid rgba(251, 248, 241, 0.12);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: background 300ms ease, border-color 300ms ease;
  }
  .mex__item[open] { background: rgba(251, 248, 241, 0.09); border-color: rgba(244, 181, 163, 0.4); }
  .mex__item:hover:not([open]) { background: rgba(251, 248, 241, 0.07); border-color: rgba(251, 248, 241, 0.2); }
  .mex__sum {
    list-style: none;
    display: grid; grid-template-columns: 1fr auto; gap: 1rem;
    align-items: center;
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    position: relative;
    transition: padding 300ms ease;
  }
  .mex__sum::-webkit-details-marker { display: none; }
  .mex__item[open] .mex__sum { padding-bottom: 0.625rem; }
  .mex__eyerow { display: flex; align-items: center; gap: 0.75rem; grid-row: 1; grid-column: 1; margin-bottom: 0.375rem; }
  .mex__num { font-family: var(--font-serif); font-style: italic; font-size: 0.875rem; color: var(--color-primary-soft, #F4B5A3); letter-spacing: 0.02em; }
  .mex__smallE { font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: rgba(251, 248, 241, 0.55); }
  .mex__t { font-family: var(--font-display); font-size: clamp(1.0625rem, 1.6vw, 1.25rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.005em; color: #FBF8F1; margin: 0; grid-row: 2; grid-column: 1; }
  .mex__chev {
    grid-row: 1 / span 2; grid-column: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    background: var(--color-primary);
    color: #FBF8F1;
    border-radius: 50%;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1), background-color 300ms ease;
    flex-shrink: 0;
  }
  .mex__item[open] .mex__chev { transform: rotate(90deg); background: var(--color-primary-soft, #F4B5A3); color: var(--color-text-primary, #1A1F2E); }
  .mex__item:hover .mex__chev { transform: translateX(3px); }
  .mex__item[open]:hover .mex__chev { transform: rotate(90deg) translateX(0); }
  .mex__body {
    padding: 0 1.25rem 1.25rem;
    animation: mexBodyIn 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes mexBodyIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
  .mex__body p { font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65; color: rgba(251, 248, 241, 0.8); margin: 0.375rem 0 1rem; }
  .mex__body p strong { color: #FBF8F1; font-weight: 700; }
  .mex__link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--color-primary-soft, #F4B5A3);
    border-bottom: 1px solid rgba(244, 181, 163, 0.4);
    padding-bottom: 2px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .mex__link:hover { color: #FBF8F1; border-color: #FBF8F1; }
  .mex__link svg { transition: transform 200ms ease; }
  .mex__link:hover svg { transform: translateX(3px); }

  @media (prefers-reduced-motion: reduce) {
    .mex__body { animation: none; }
    .mex__reservaBg :global(img), .mex__reservaBg :global(picture), .mex__reservaDot { animation: none; }
    .mex__ch:hover, .mex__ch:hover .mex__chArrow { transform: none; }
    .mex__chev { transition: background-color 200ms ease; }
    .mex__item[open] .mex__chev { transform: rotate(90deg); }
    .mex__item:hover .mex__chev { transform: none; }
    .mex__item[open]:hover .mex__chev { transform: rotate(90deg); }
  }

  /* ============== 6.5 · Banda CONTACTO editorial (image 34) ============== */
  .meb {
