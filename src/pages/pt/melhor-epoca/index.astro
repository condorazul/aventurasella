---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const lang = 'pt';
const title = 'Melhor época para fazer a descida do Sella · mês a mês';
const description = 'A melhor época para fazer a descida do Sella: mês a mês, clima, caudal, afluência e conselhos. Reserva sem pagar agora · animais grátis.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/melhor-epoca/`;

// Calendário 12 meses · classificação de idealidade (0=fora de época · 1=início/fim · 2=bom · 3=muito bom · 4=ideal)
const meses = [
  { n: 'Jan', full: 'Janeiro',   rating: 0, label: 'Fora de época',              tone: 'off'   },
  { n: 'Fev', full: 'Fevereiro', rating: 0, label: 'Fora de época',              tone: 'off'   },
  { n: 'Mar', full: 'Março',     rating: 0, label: 'Fora de época',              tone: 'off'   },
  { n: 'Abr', full: 'Abril',     rating: 2, label: 'Início de época',            tone: 'soft'  },
  { n: 'Mai', full: 'Maio',      rating: 3, label: 'Muito boa — pouca gente',    tone: 'mid'   },
  { n: 'Jun', full: 'Junho',     rating: 4, label: 'Ideal — caudal + clima',     tone: 'high'  },
  { n: 'Jul', full: 'Julho',     rating: 3, label: 'Popular — bom clima',        tone: 'warm'  },
  { n: 'Ago', full: 'Agosto',    rating: 2, label: 'Afluência máxima — reserva já', tone: 'coral' },
  { n: 'Set', full: 'Setembro',  rating: 4, label: 'Ideal — calma + clima',      tone: 'high'  },
  { n: 'Out', full: 'Outubro',   rating: 2, label: 'Fim de época · paisagem outonal', tone: 'ocre' },
  { n: 'Nov', full: 'Novembro',  rating: 0, label: 'Fora de época',              tone: 'off'   },
  { n: 'Dez', full: 'Dezembro',  rating: 0, label: 'Fora de época',              tone: 'off'   },
];

// 4 estações para os tabs
const estaciones = [
  {
    id: 'primavera',
    tab: 'Primavera',
    meses: 'Abr – Jun',
    eyebrow: 'Primavera',
    route: 'Caudal vivo, verde cantábrico',
    stats: [
      { v: '14–18', u: '°C',    l: 'água' },
      { v: 'Alto',  u: '',      l: 'caudal' },
      { v: 'Baixa', u: '',      l: 'afluência' },
    ],
    desc: 'A melhor época para fazer a descida do Sella se procuras <strong>tranquilidade e paisagem verde</strong>. O caudal é mais ativo pelo degelo e as chuvas de primavera, o rio está no seu melhor momento e há muito pouca gente. Temperatura da água mais fresca — <strong>recomendado ir com neoprene</strong>, disponível ao recolher.',
    features: ['Caudal ativo', 'Pouca afluência', 'Verde intenso', 'Neoprene recomendado', 'Dias longos', 'Ar limpo'],
    photo: 'sella-primavera',
    badges: ['Verde', 'Tranquila', 'Caudal alto'],
  },
  {
    id: 'verano',
    tab: 'Verão',
    meses: 'Jun – Ago',
    eyebrow: 'Verão',
    route: 'Sol, ambiente e água quente',
    popular: true,
    ribbon: 'O favorito · mais animado',
    stats: [
      { v: '18–22', u: '°C',    l: 'água' },
      { v: 'Médio', u: '',      l: 'caudal' },
      { v: 'Alta',  u: '',      l: 'afluência' },
    ],
    desc: 'A descida do Sella <strong>no verão</strong> é a opção mais popular do ano. Bom clima, água quente para banhar-se e ambiente animado nas praias fluviais. <strong>Agosto</strong> concentra a época no seu auge — jornadas com mais luz, mais vida no rio e o melhor ambiente. <a href="/pt/reservar/">Consulta o calendário de reserva</a>: verás que dias estão ativos e quais não. Com 5-7 dias de antecedência costuma ser suficiente, quanto antes melhor.',
    features: ['Água quente', 'Clima estável', 'Ambiente animado', 'Reservar antecedência', 'Piqueniques na margem', 'Família e amigos'],
    photo: 'sella-verano',
    badges: ['Soalheira', 'Familiar', 'Água quente'],
  },
  {
    id: 'otono',
    tab: 'Outono',
    meses: 'Set – Out',
    eyebrow: 'Outono',
    route: 'O segredo mais bem guardado do Sella',
    stats: [
      { v: '16–20', u: '°C',    l: 'água' },
      { v: 'Médio', u: '',      l: 'caudal' },
      { v: 'Baixa', u: '',      l: 'afluência' },
    ],
    desc: '<strong>Setembro</strong> costuma ser o melhor mês do ano: clima ainda quente, menos gente e o rio com bom caudal. Outubro traz <strong>paisagem outonal</strong> entre os tons ocres da floresta. Um plano íntimo, sem pressas — para quem procura <strong>o Sella mais tranquilo</strong>.',
    features: ['Equilíbrio perfeito', 'Pouca gente', 'Paisagem outonal', 'Clima suave', 'Luz dourada', 'Fotos espetaculares'],
    photo: 'sella-otono',
    badges: ['Tranquila', 'Paisagem ocre', 'Luz dourada'],
  },
  {
    id: 'invierno',
    tab: 'Inverno',
    meses: 'Nov – Mar',
    eyebrow: 'Inverno',
    route: 'Fora de época · a consultar',
    stats: [
      { v: '8–14',  u: '°C',     l: 'água' },
      { v: 'Muito alto', u: '',  l: 'caudal' },
      { v: '—',     u: '',       l: 'fechado' },
    ],
    desc: 'A <strong>época regular da descida do Sella é de abril a outubro</strong>. Fora desses meses, a atividade não está operacional de forma regular pelo caudal elevado, as temperaturas da água e as condições variáveis. Se tens uma data concreta em mente, <strong>escreve-nos</strong> e vemos.',
    features: ['Fora de época', 'Caudal muito alto', 'Água fria', 'Condições variáveis', 'Consultar disponibilidade', 'Planifica para a primavera'],
    photo: 'sella-invierno',
    badges: ['Consultar', 'Fora de época'],
  },
];

// Afluência por mês · % relativo ao pico (agosto = 100) + foto sazonal + info flip
const afluencia = [
  { m: 'Jan', full: 'Janeiro',   p: 0,   photo: 'sella-enero',       temp: '—',      nota: 'Fora de época' },
  { m: 'Fev', full: 'Fevereiro', p: 0,   photo: 'sella-febrero',     temp: '—',      nota: 'Fora de época' },
  { m: 'Mar', full: 'Março',     p: 0,   photo: 'sella-marzo',       temp: '—',      nota: 'Fora de época' },
  { m: 'Abr', full: 'Abril',     p: 18,  photo: 'sella-abril',       temp: '14 °C',  nota: 'Início época · verde' },
  { m: 'Mai', full: 'Maio',      p: 35,  photo: 'sella-mayo',        temp: '16 °C',  nota: 'Primavera · caudal vivo' },
  { m: 'Jun', full: 'Junho',     p: 60,  photo: 'sella-junio',       temp: '18 °C',  nota: 'Ideal · pouca gente' },
  { m: 'Jul', full: 'Julho',     p: 85,  photo: 'sella-julio',       temp: '20 °C',  nota: 'Popular · bom clima' },
  { m: 'Ago', full: 'Agosto',    p: 100, photo: 'sella-agosto',      temp: '22 °C',  nota: 'O mais animado' },
  { m: 'Set', full: 'Setembro',  p: 40,  photo: 'sella-septiembre',  temp: '20 °C',  nota: 'Segredo · melhor equilíbrio' },
  { m: 'Out', full: 'Outubro',   p: 22,  photo: 'sella-octubre',     temp: '16 °C',  nota: 'Outono · paisagem dourada' },
  { m: 'Nov', full: 'Novembro',  p: 0,   photo: 'sella-noviembre',   temp: '—',      nota: 'Fora de época' },
  { m: 'Dez', full: 'Dezembro',  p: 0,   photo: 'sella-diciembre',   temp: '—',      nota: 'Fora de época' },
];

// Conselhos sazonais (6)
const consejos = [
  { t: 'Agosto · reserva com antecedência',         s: 'É o mês com <strong>mais procura do ano</strong>. Em época alta, com <strong>5-7 dias</strong> costuma ser suficiente — quanto antes, melhor. No <a href="/pt/reservar/">calendário de reserva</a> verás que dias estão disponíveis (ativos) e quais não.' },
  { t: 'Setembro · o segredo',                      s: 'Clima quente, pouca gente e o rio tranquilo. O <strong>melhor equilíbrio do ano</strong> se podes escolher data.' },
  { t: 'Primavera · leva neoprene',                 s: 'A água está fresca (14–18 °C). O neoprene mantém a temperatura corporal e torna a experiência muito mais confortável.' },
  { t: 'Fins de semana · ou meio de semana',        s: 'Em julho e agosto os sábados saturam. <strong>Terça, quarta ou quinta</strong> oferecem o mesmo rio com metade da afluência.' },
  { t: 'Consulta o boletim do dia',                 s: 'Caudal, temperatura e vento influenciam o ritmo da descida. Nós avisamos-te se houver mudanças na tarde anterior.' },
  { t: 'Horário aberto · 10:30–12:30',              s: 'Reserva <strong>Premium · horário aberto</strong>: chegam às nossas instalações de Arriondas quando vos der jeito <strong>entre as 10:30 e as 12:30</strong>, sem escolher hora concreta. Por normativa da <strong>Confederación Hidrográfica del Cantábrico</strong>, a permanência no rio é <strong>até às 18:00 h</strong>.' },
];

// FAQ (8 perguntas adaptadas à época)
const faqs = [
  { q: 'Qual é a melhor época para fazer a descida do Sella?',
    a: 'As melhores épocas são <strong>junho e setembro</strong>: bom clima, caudal estável e afluência baixa-média. Julho e agosto têm o melhor clima mas também a maior procura. Maio e outubro são ideais para quem procura tranquilidade total, assumindo que a água está mais fresca.' },
  { q: 'Pode-se fazer a descida do Sella no verão?',
    a: 'Sim, a descida do Sella <strong>no verão</strong> (junho-agosto) é a opção mais popular. Bom clima, água quente e ambiente animado. Agosto concentra a maior afluência do ano — com <strong>5-7 dias de antecedência</strong> costuma ser suficiente (quanto antes, melhor). No <a href="/pt/reservar/">calendário de reserva</a> verás que dias estão ativos.' },
  { q: 'E na primavera? Vale a pena?',
    a: 'A primavera é <strong>excelente se procuras tranquilidade</strong>: caudal mais ativo pelo degelo, paisagem verde e muito pouca gente. A temperatura da água é mais fresca (14–18 °C), pelo que recomendamos ir com neoprene — damos-to ao recolher.' },
  { q: 'Pode-se fazer a descida no inverno?',
    a: 'A <strong>época regular é de abril a outubro</strong>. Fora desses meses a atividade não está operacional de forma habitual pelo caudal elevado e a temperatura da água. Se queres uma data concreta fora de época, escreve-nos e avaliamos.' },
  { q: 'Quando há menos gente no Sella?',
    a: 'Os meses de <strong>maio, setembro e outubro</strong> são os mais tranquilos. Se preferes ir em plena época evitando saturação, escolhe <strong>dias de semana</strong> (terça a quinta) e horários de saída tempranos.' },
  { q: 'A descida depende do caudal do rio?',
    a: 'Influencia o ritmo e o tempo. Com <strong>caudal alto</strong> (primavera, outono após chuvas), o rio desce mais rápido e a corrente empurra. Com caudal baixo (fim do verão seco), o ritmo é mais pausado. Só se suspende por <strong>cheias extremas</strong> ou tempestade — nesses casos oferecemos mudança de data sem custo.' },
  { q: 'Que temperatura tem a água no Sella?',
    a: 'Varia segundo a época: <strong>14–18 °C na primavera</strong>, <strong>18–22 °C no verão</strong>, <strong>16–20 °C no outono</strong>. O neoprene está disponível na recolha para as épocas mais frescas.' },
  { q: 'Até quando posso reservar?',
    a: 'Recomendamos reservar <strong>com pelo menos 48 h de antecedência</strong>. Em época alta (julho e agosto) com <strong>5-7 dias costuma ser suficiente</strong> — quanto antes, melhor. No <a href="/pt/reservar/">calendário de reserva</a> verás que dias estão ativos e quais não. As reservas de última hora gerimos por <strong>WhatsApp ou telefone</strong> segundo disponibilidade.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Melhor época para fazer a descida do Sella · mês a mês',
      description: 'Guia completo sobre quando fazer a descida do Sella: clima, caudal, afluência e recomendações mês a mês e por estação.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
        width: 1920,
        height: 1280,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified: '2026-05-12',
      about: 'Melhor época para fazer a descida do Sella em canoa, mês a mês',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'pt-PT',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',       item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Melhor época', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/pt/melhor-epoca/" translationKey="mejor_epoca">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Warm editorial con watermark 4 estaciones ============== -->
  <section class="meh" aria-labelledby="meh-title">

    <div class="meh__shapes" aria-hidden="true">
      <span class="meh__shape meh__shape--1"></span>
      <span class="meh__shape meh__shape--2"></span>
      <span class="meh__shape meh__shape--3"></span>
    </div>

    <!-- Marca d'água decorativa atrás · "4 ESTAÇÕES" em serif itálico muito grande, quase invisível -->
    <span class="meh__watermark" aria-hidden="true">4&nbsp;estações</span>

    <div class="meh__inner">
      <nav class="meh__breadcrumb" aria-label="Breadcrumb">
        <a href="/pt/">Início</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Melhor época</span>
      </nav>

      <span class="meh__eyebrow">— Melhor época · temporada 2026</span>

      <h1 id="meh-title" class="meh__title">
        Quando fazer<br/>
        a <span class="serif-italic">descida do Sella</span>?
      </h1>

      <p class="meh__lead">
        Há um momento perfeito para cada plano. Clima, caudal, afluência e temperatura
        da água mudam muito de um mês para outro no Sella — aqui tens o
        <strong>guia mês a mês desde Arriondas</strong> para escolher o melhor dia do ano
        para a tua descida.
      </p>

      <div class="meh__ctas">
        <a href="#meh-calendar" class="meh__cta meh__cta--primary">Ver calendário</a>
        <a href="/pt/reservar/" class="meh__cta meh__cta--link">
          Reservar agora
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · CALENDARIO 12 MESES (NEW PATTERN) ============== -->
  <section id="meh-calendar" class="mec" aria-labelledby="mec-title">
    <div class="container container--xl">
      <header class="mec__header" data-reveal>
        <span class="mec__eyebrow">— Mês a mês</span>
        <h2 id="mec-title" class="mec__title">
          O <span class="serif-italic">melhor mês</span><br/>
          para descer o Sella.
        </h2>
        <p class="mec__lead">
          Cada mês do ano tem o seu caráter no rio. Passa o rato sobre cada mês para ver
          a sua <strong>idealidade</strong>, clima e afluência habitual.
        </p>
      </header>

      <ol class="mec__grid" aria-label="Calendário anual da descida do Sella">
        {meses.map((m, i) => (
          <li class={`mec__m mec__m--${m.tone}`} data-reveal data-reveal-delay={(i % 4) + 1} data-rating={m.rating}>
            <span class="mec__mN">{m.n}</span>
            <span class="mec__mDots" aria-hidden="true">
              {Array.from({ length: 4 }).map((_, idx) => (
                <span class={`mec__mDot ${idx < m.rating ? 'is-on' : ''}`}></span>
              ))}
            </span>
            <span class="mec__mL">{m.label}</span>
          </li>
        ))}
      </ol>

      <div class="mec__legend" data-reveal data-reveal-delay="2">
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--high"></span>Ideal</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--mid"></span>Muito boa</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--warm"></span>Popular</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--coral"></span>Afluência máxima</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--off"></span>Fora de época</span>
      </div>
    </div>
  </section>

  <!-- ============== 3 · TABS · 4 ESTACIONES (REUSE) ============== -->
  <section class="met" aria-labelledby="met-title">
    <div class="container container--xl">
      <header class="met__head" data-reveal>
        <div class="met__headL">
          <span class="met__kicker">— Por estação</span>
          <h2 id="met-title" class="met__title">
            Cada estação,<br/>
            <span class="serif-italic">o seu momento.</span>
          </h2>
        </div>
        <div class="met__tabs" role="tablist" aria-label="Escolher estação do ano">
          {estaciones.map((e, i) => (
            <button
              type="button"
              role="tab"
              id={`met-tab-${e.id}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`met-panel-${e.id}`}
              class={`met__tab${i === 0 ? ' is-active' : ''}`}
              data-tab={e.id}
              tabindex={i === 0 ? 0 : -1}
            >
              {e.tab}
              <span class="met__tabMeses" aria-hidden="true">· {e.meses}</span>
            </button>
          ))}
        </div>
      </header>

      <div class="met__card" data-reveal data-reveal-delay="1">
        {estaciones.map((e, i) => (
          <div
            class={`met__panel${i === 0 ? ' is-active' : ''}${e.popular ? ' met__panel--popular' : ''}`}
            id={`met-panel-${e.id}`}
            role="tabpanel"
            aria-labelledby={`met-tab-${e.id}`}
            data-panel={e.id}
            hidden={i !== 0}
          >
            {e.popular && (
              <span class="met__ribbon" aria-label="Favorito do público">
                <span class="met__ribbonDot" aria-hidden="true"></span>
                <svg class="met__ribbonIcon" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {e.ribbon}
              </span>
            )}
            <div class="met__content">
              <span class={`met__eyebrow met__eyebrow--${e.id}`}>{e.eyebrow}</span>
              <h3 class="met__route">{e.route}</h3>
              <div class="met__stats">
                {e.stats.map(s => (
                  <div class="met__stat">
                    <strong>{s.v}<small>{s.u}</small></strong>
                    <span>{s.l}</span>
                  </div>
                ))}
              </div>
              <p class="met__desc" set:html={e.desc} />
              <ul class="met__features">
                {e.features.map(f => <li>{f}</li>)}
              </ul>
              <a href="/pt/reservar/" class="met__cta">
                Reservar no {e.tab.toLowerCase()}
                <span class="met__ctaIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
            <div class="met__photo">
              <Picture src={e.photo} alt={`Descida do Sella no ${e.tab.toLowerCase()}`} sizes="(min-width: 960px) 45vw, 100vw" bare />
              <div class="met__badges" aria-hidden="true">
                {e.badges.map(b => (
                  <span class="met__badge">{b}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 4 · CTA intermedio Sage Dark (REUSE) ============== -->
  <section class="mem">
    <div class="container container--md">
      <div class="mem__wrap" data-reveal>
        <p class="mem__quote">
          A <em>reserva prévia é obrigatória</em> todo o ano. Tranquila:
          <strong>pagamento flexível — com cartão agora ou no dia em que recolheres a tua canoa.</strong>
        </p>
        <div class="mem__rule">
          <span class="mem__ruleLine" aria-hidden="true"></span>
          <a href="/pt/reservar/" class="mem__pill">
            <span class="mem__pillDot" aria-hidden="true"></span>
            <span>Reservar o meu lugar</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <span class="mem__ruleLine" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 5 · BARRAS AFLUENCIA 12 MESES (REUSE) ============== -->
  <section class="mea">
    <div class="container container--xl">
      <header class="mea__header" data-reveal>
        <span class="mea__eyebrow">— Afluência mensal</span>
        <h2 class="mea__title">
          Quanta gente<br/>
          <span class="serif-italic">desce cada mês.</span>
        </h2>
        <p class="mea__lead">
