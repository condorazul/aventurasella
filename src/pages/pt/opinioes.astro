---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Opiniões da descida do Sella · 4,5★ no Google e TripAdvisor';
const description = '147 opiniões reais da descida do Sella — 4,5★ no Google, 4,8★ no TripAdvisor. Lê o que dizem famílias, casais e amigos depois de descer o rio com Aventura en el Sella.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/opinioes/`;

// Números agregados oficiais (snapshot 2026-04-13 · reference_reviews.md)
const aggregate = {
  global: { rating: '4,5', total: 147, rating_num: 4.5 },
  google: { rating: '4,5', total: 127, url: 'https://share.google/huLLaIz31FiYohuTV', label: 'Google' },
  trip:   { rating: '4,8', total:  20, url: 'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html', label: 'TripAdvisor' },
};

// Testemunhos reais aprovados (reference_reviews.md 2026-04-13)
const testimonios = [
  {
    initial: 'A',
    name: 'Anaïs Suárez Blanco',
    source: 'Google',
    date: 'outubro 2025',
    context: 'Experiência',
    rating: 5,
    text: 'Bom serviço, equipa atenta e muito simpática. A experiência foi genial, adorei.',
    sourceUrl: aggregate.google.url,
  },
  {
    initial: 'N',
    name: 'Nacho A.',
    source: 'TripAdvisor',
    date: 'agosto 2025',
    context: 'Casais',
    rating: 5,
    text: 'Tudo pontual e muito amáveis. Uma experiência para fazer uma vez na vida, recomendada para jovens e mais velhos.',
    sourceUrl: aggregate.trip.url,
  },
  {
    initial: 'C',
    name: 'Carlos S.',
    source: 'TripAdvisor',
    date: 'maio 2025',
    context: 'Amigos',
    rating: 5,
    text: 'Vale mesmo a pena. Tens balneários e podes tomar duche depois da atividade. Dão-te instruções divertidas, um bidão para meter muitas coisas e o resto é o rio que te dá.',
    sourceUrl: aggregate.trip.url,
  },
];

// Perfis de visitante recorrentes nas avaliações · palavras que aparecem repetidamente
const perfiles = [
  { tag: 'Famílias',   nota: 'Com crianças a partir dos 5 anos', words: ['atentos com as crianças', 'segurança', 'instruções claras', 'animais bem-vindos'] },
  { tag: 'Casais',     nota: 'Uma vez na vida',                  words: ['romântico', 'pôr do sol', 'tranquilidade', 'fotos'] },
  { tag: 'Amigos',     nota: 'Grupo · dia completo',             words: ['ambiente', 'bares à beira-rio', 'divertido', 'duches'] },
  { tag: 'Reformados', nota: 'Ritmo tranquilo',                  words: ['para seniores', 'seguro', 'paisagem', 'trato próximo'] },
];

const faqs = [
  { q: 'Onde posso ler todas as opiniões da descida do Sella?',
    a: 'Temos <strong>147 avaliações reais</strong> repartidas entre <strong><a href="' + aggregate.google.url + '" target="_blank" rel="noopener">Google</a></strong> (127 avaliações · 4,5 estrelas) e <strong><a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a></strong> (20 avaliações · 4,8 estrelas). Nesta página destacamos as mais representativas, mas todas estão públicas nas suas plataformas.' },
  { q: 'Todas as avaliações são reais e verificadas?',
    a: 'Sim. <strong>Não compramos nem fabricamos avaliações</strong>. Cada uma vem de um cliente que fez a descida do Sella connosco e deixou a sua opinião voluntariamente no Google ou no TripAdvisor. Isso significa que verás de tudo: 5 estrelas na maioria, alguma 4 e, muito de vez em quando, alguma crítica a que respondemos publicamente.' },
  { q: 'Como deixo a minha opinião depois de fazer a descida?',
    a: 'O mais fácil: depois da atividade, enviamos-te uma mensagem com o link direto do Google. Também a podes deixar no <a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a> a procurar por "Aventura en el Sella · Arriondas". <strong>Ajuda-nos imenso</strong> — é o que faz com que outros confiem em nós.' },
  { q: 'Como respondem às avaliações negativas?',
    a: 'Com honestidade e em público. Respondemos a <strong>todas</strong> as avaliações críticas a partir do painel do Google Business, reconhecendo o que não fizemos bem e explicando o que mudámos. É a única forma de melhorar e de os futuros clientes verem como lidamos com problemas reais.' },
  { q: 'Porque é que a média do Google é 4,5 e a do TripAdvisor 4,8?',
    a: 'Porque são plataformas com perfis de utilizadores diferentes. O Google recebe mais volume e mais diversidade de expectativas; o TripAdvisor costuma ser usado pelo viajante que planeia com cuidado e valoriza mais os detalhes do serviço. <strong>A média combinada é de 4,5★ em 147 avaliações</strong> — o número que usamos em todo o site.' },
  { q: 'Há quantos anos recebem avaliações?',
    a: 'A Aventura en el Sella acumula <strong>avaliações há vários anos</strong> de clientes de temporadas diferentes. Esse volume e consistência é o que nos diferencia de novos operadores sem histórico — <a href="' + getLocalePath('quienes_somos', lang) + '">descobre mais sobre a nossa história</a>.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Opiniões reais da descida do Sella · 4,5★ · 147 avaliações verificadas',
      description: '147 opiniões reais sobre a descida do Sella com Aventura en el Sella. 4,5 estrelas no Google e 4,8 no TripAdvisor.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Opiniões · Avaliações verificadas',
      keywords: ['opiniões descida do Sella', 'avaliações descida do Sella', 'Aventura en el Sella opiniões', 'descida do Sella reviews', 'canoas Sella Arriondas opiniões'],
      about: 'Opiniões, avaliações e testemunhos reais da descida do Sella em canoa desde Arriondas',
      mentions: [
        { '@type': 'Thing', name: 'Avaliações Google', url: aggregate.google.url },
        { '@type': 'Thing', name: 'TripAdvisor', url: aggregate.trip.url },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'A Descida do Sella Astúrias · Aventura en el Sella · Aluguer de Canoas',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acceso por Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: aggregate.global.rating_num,
        reviewCount: aggregate.global.total,
        bestRating: 5,
        worstRating: 1,
      },
      review: testimonios.map(t => ({
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5, worstRating: 1 },
        author: { '@type': 'Person', name: t.name },
        datePublished: t.date,
        reviewBody: t.text,
        publisher: { '@type': 'Organization', name: t.source },
      })),
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        aggregate.google.url,
        aggregate.trip.url,
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',   item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Opiniões', item: canonicalUrl },
      ],
    },
  ],
};

const starSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/pt/opinioes/" translationKey="opiniones">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="opH" aria-labelledby="opH-title">
    <span class="opH__watermark" aria-hidden="true">4,5</span>

    <div class="opH__inner">
      <nav class="opH__breadcrumb" aria-label="Breadcrumb">
        <a href="/pt/">Início</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Opiniões</span>
      </nav>

      <span class="opH__eyebrow">— Opiniões reais e verificadas</span>

      <h1 id="opH-title" class="opH__title">
        O Sella<br/>
        <span class="serif-italic">nas suas próprias palavras.</span>
      </h1>

      <div class="opH__badge" aria-hidden="true">
        <span class="opH__badgeStars" set:html={Array(5).fill(starSvg).join('')}></span>
        <span class="opH__badgeRating">4,5</span>
        <span class="opH__badgeSep"></span>
        <span class="opH__badgeCount">147 avaliações verificadas</span>
      </div>

      <p class="opH__lead">
        Durante anos bastou-nos o <strong>passa-palavra das Astúrias</strong>. Há pouco tempo começámos a pedir ativamente que deixes a tua opinião — e por isso o volume é modesto. Mas cada uma das <strong>147 avaliações</strong> é <strong>real, pública e verificável</strong> no Google e no TripAdvisor.
      </p>

      <div class="opH__ctas">
        <a href={aggregate.google.url} class="opH__cta opH__cta--primary" target="_blank" rel="noopener noreferrer">Ver no Google<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
        <a href={aggregate.trip.url} class="opH__cta opH__cta--ghost" target="_blank" rel="noopener noreferrer">Ver no TripAdvisor<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
      </div>
    </div>
  </section>

  <section class="opB" aria-labelledby="opB-title">
    <div class="container container--xl">
      <header class="opB__header" data-reveal>
        <span class="opB__eyebrow">— O dado em bruto</span>
        <h2 id="opB-title" class="opB__title">
          Duas plataformas<br/><span class="serif-italic">e uma só média.</span>
        </h2>
        <p class="opB__lead">
          Transparência total: estes são os números tal como estão hoje nas fichas públicas.
        </p>
      </header>

      <div class="opB__grid">
        <article class="opB__card" data-reveal>
          <span class="opB__cardLabel">Google</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.google.rating}</strong>
          <span class="opB__cardCount">{aggregate.google.total} avaliações</span>
          <a href={aggregate.google.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Ver no Google
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--trip" data-reveal data-reveal-delay="1">
          <span class="opB__cardLabel">TripAdvisor</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.trip.rating}</strong>
          <span class="opB__cardCount">{aggregate.trip.total} avaliações</span>
          <a href={aggregate.trip.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Ver no TripAdvisor
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--total" data-reveal data-reveal-delay="2">
          <span class="opB__cardLabel">Média combinada</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.global.rating}</strong>
          <span class="opB__cardCount">{aggregate.global.total} avaliações totais</span>
          <span class="opB__cardNota">Ponderada entre ambas as plataformas</span>
        </article>
      </div>
    </div>
  </section>

  <section class="opT" aria-labelledby="opT-title">
    <div class="container container--xl">
      <header class="opT__header" data-reveal>
        <span class="opT__eyebrow">— O que dizem depois de descer o Sella</span>
        <h2 id="opT-title" class="opT__title">
          Três avaliações<br/><span class="serif-italic">que resumem o que fazemos.</span>
        </h2>
      </header>

      <div class="opT__grid">
        {testimonios.map((t, i) => (
          <article class="opT__card" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="opT__head">
              <span class="opT__avatar" aria-hidden="true">{t.initial}</span>
              <div class="opT__meta">
                <strong class="opT__name">{t.name}</strong>
                <span class="opT__src">{t.source} · {t.date}</span>
              </div>
              <span class="opT__tag">{t.context}</span>
            </div>
            <div class="opT__stars" aria-hidden="true" set:html={Array(t.rating).fill(starSvg).join('')}></div>
            <blockquote class="opT__quote">
              <span class="opT__mark" aria-hidden="true">“</span>
              {t.text}
            </blockquote>
            <a href={t.sourceUrl} class="opT__link" target="_blank" rel="noopener noreferrer">
              Ver no {t.source}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="opP" aria-labelledby="opP-title">
    <div class="container container--xl">
      <header class="opP__intro" data-reveal>
        <span class="opP__eyebrow">— Por perfil de visitante</span>
        <h2 id="opP-title" class="opP__title">
          Quatro formas<br/><span class="serif-italic">de descer o Sella.</span>
        </h2>
        <p class="opP__lead">
          Ao ler as 147 avaliações aparecem padrões claros: o perfil de quem vem e as palavras que mais se repetem.
        </p>
      </header>

      <div class="opP__panel">
        <ol class="opP__grid">
          {perfiles.map(p => (
            <li class="opP__cell">
              <div class="opP__cellBody">
                <h3 class="opP__cellName">{p.tag}</h3>
                <span class="opP__cellNota">{p.nota}</span>
                <ul class="opP__words">
                  {p.words.map(w => <li class="opP__word">“{w}”</li>)}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="opR" aria-label="Chamada à ação · reservar descida">
    <div class="container container--xl">
      <div class="opR__inner" data-reveal>
        <div class="opR__text">
          <span class="opR__eyebrow">— Aventura en el Sella</span>
          <h2 class="opR__title">Já sabes o que pensam <span class="serif-italic">os que experimentaram.</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="opR__cta">
          <span>Reservar a minha descida</span>
          <span class="opR__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="opX">
    <div class="container container--xl">
      <header class="opX__header" data-reveal>
        <span class="opX__eyebrow">— Antes de vir</span>
        <h2 class="opX__title">Prepara<br/><span class="serif-italic">a tua descida do Sella.</span></h2>
      </header>

      <nav class="opX__list" aria-label="Páginas relacionadas">
        <a href={getLocalePath('precios', lang)} class="opX__item">
          <span class="opX__num">01</span>
          <h3 class="opX__t">Preços da descida</h3>
          <p class="opX__p">30 € crianças · 40 € adultos · animais grátis. Tudo incluído.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_ninos', lang)} class="opX__item">
          <span class="opX__num">02</span>
          <h3 class="opX__t">Com crianças</h3>
          <p class="opX__p">A partir dos 5 anos · 1,15 m. Segurança e ritmo familiar.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_perro', lang)} class="opX__item">
          <span class="opX__num">03</span>
          <h3 class="opX__t">Com cão</h3>
          <p class="opX__p">Animais grátis. Colete canino incluído.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('recorrido_mapa', lang)} class="opX__item">
          <span class="opX__num">04</span>
          <h3 class="opX__t">Percurso e mapa</h3>
          <p class="opX__p">14,5 km · mapa interativo · 8 marcos no caminho.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
      </nav>
    </div>
  </section>

  <section class="opF">
    <div class="container container--xl">
      <div class="opF__grid">
        <aside class="opF__aside" data-reveal>
          <span class="opF__eyebrow">— Perguntas frequentes</span>
          <h2 class="opF__title">Sobre as<br/><span class="serif-italic">opiniões.</span></h2>
          <p class="opF__lead">
            Como gerimos as avaliações, como deixar a tua e o que há por trás do 4,5★.
            Se faltar alguma coisa, <a href={getLocalePath('contacto', lang)}>escreve-nos</a>.
          </p>
        </aside>
        <div class="opF__list" data-reveal data-reveal-delay="2">
          {faqs.map((f, i) => (
            <details class="opFI" name="op-faq" open={i === 0}>
              <summary class="opFI__q">
                {f.q}
                <svg class="opFI__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="opFI__a" set:html={f.a} />
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="opCta" aria-labelledby="opCta-title">
    <div class="opCta__bg" aria-hidden="true">
      <Picture src="opiniones-cta" alt="" sizes="100vw" bare />
    </div>
    <div class="opCta__inner">
      <span class="opCta__eyebrow">— Faz parte da próxima avaliação</span>
      <h2 id="opCta-title" class="opCta__title">
        Do rio<br/>
        <span class="serif-italic">à tua própria história.</span>
      </h2>
      <p class="opCta__lead">
        Desce o Sella connosco e decide o que contar. Reserva sem pagar agora — <strong>paga com cartão ou no dia em que recolhes a canoa</strong>.
      </p>
      <div class="opCta__ctas">
        <a href={getLocalePath('reservar', lang)} class="opCta__primary">
          Reservar a minha descida
