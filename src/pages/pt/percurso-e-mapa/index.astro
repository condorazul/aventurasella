---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import MapaInteractivoSella from '@components/sections/MapaInteractivoSella.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Descida do Sella · Percurso e mapa · Arriondas → Fríes';
const description = 'Mapa interativo e percurso da descida do Sella: 14,5 km desde Arriondas até Fríes. Quiosques ribeirinhos, rápidos, passadiços e praias fluviais do caminho.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/percurso-e-mapa/`;

// Pontos editoriais do percurso
const hitos = [
  { km: 0,    tag: 'SAÍDA',           name: 'Arriondas',            kind: 'Ponto de partida',           photo: 'arriondas-inicio',  alt: 'Arriondas · ponto de partida da descida do Sella',           text: 'Onde tudo começa. Check-in nos nossos escritórios, equipamento, picnic asturiano e mini-aula antes de entrar na água. Capital turística do concelho de Parres.' },
  { km: 1,    tag: 'RÁPIDO',          name: 'La Remolina',          kind: 'Primeiro rabião',            photo: 'remolina-rapido',   alt: 'La Remolina · primeiro rabião da descida do Sella',          text: 'O primeiro rápido suave do caminho — classe I moderada. Só precisas de remar com calma: o rio guia-te.' },
  { km: 3,    tag: 'QUIOSQUE',        name: 'El Oasis · El Prau',   kind: 'Duas paragens míticas',      photo: 'chiringuito-prao',  alt: 'Quiosque El Prau junto ao rio Sella',                        text: 'Os primeiros quiosques ribeirinhos onde as pessoas param para beber algo ou refrescar-se. Ambiente animado na época alta.' },
  { km: 4,    tag: 'PASSADIÇO',       name: 'Pasarela de Fuentes',  kind: 'Pesqueiro de salmão',        photo: 'pasarela-fuentes',  alt: 'Pasarela de Fuentes sobre o Sella no pesqueiro de salmão',   text: 'Atravessas o pesqueiro histórico de salmão de Los Llaos. Aldeias asturianas nas margens, azinheiras e faias. Um dos troços mais bonitos.' },
  { km: 6,    tag: 'PRAIA',           name: 'Pozo del Arco',        kind: 'Praia fluvial',              photo: 'pozo-del-arco',     alt: 'Pozo del Arco · praia fluvial do rio Sella',                 text: 'Águas tranquilas e praia fluvial. Paragem ideal para tomar banho — sobretudo em julho e agosto quando a água está mais quente.' },
  { km: 7,    tag: 'FIM MINI',        name: 'Toraño',               kind: 'Fim do Mini Sella',          photo: 'torano-mini-fin',   alt: 'Toraño · final da rota Mini Sella',                          text: 'Ponto de recolha de quem escolhe o <strong>Mini Sella</strong>. Quem continua até Fríes atravessa a parte mais aberta do vale.' },
  { km: 10,   tag: 'PARAGEM',         name: 'Llordón',              kind: 'Meio dia',                   photo: 'llordon-parada',    alt: 'Llordón · paragem de meio percurso na descida do Sella',     text: 'Paragem habitual para comer o picnic com calma ou refrescar-se antes do troço final. Pôr-do-sol espetacular.' },
  { km: 14.5, tag: 'FINAL',           name: 'Fríes',                kind: 'Final do Percurso completo', photo: 'frias-final',       alt: 'Fríes · final do Percurso completo da descida do Sella',     text: 'Fim da <strong>Descida completa</strong>. O nosso transfer recolhe-vos e leva-vos de volta a Arriondas. Vestiários com duches quentes esperam-vos.' },
];

// 15 troços detalhados do percurso
const tramos = [
  { km: 0,    type: 'Saída',                   name: 'Arriondas · Puente de las Piraguas', highlight: true,
    photo: 'arriondas-inicio', alt: 'Arriondas · ponto de partida da descida do Sella',
    text: 'Ponto de partida da descida. Sais a partir da nossa <strong>rampa de mais de 35 m</strong> ou diretamente da margem, junto à mítica <strong>Puente de las Piraguas</strong> (Ponte dos Piragüistas) — a mesma ponte onde cada agosto se dá a partida oficial da <a href="/pt/descida-internacional-do-sella/">Descida Internacional</a>.' },
  { km: 0.2,  type: 'Rápido',                  name: 'La Raíz',
    text: 'O primeiro rápido do dia. A corrente acelera e o rio estreita-se. <strong>Classe I moderada</strong> — passa-se sem problema, a canoa ganha alguma velocidade e dá-te a primeira emoção.' },
  { km: 1,    type: 'Rabião',                  name: 'La Remolina',
    text: 'Segundo rabião com águas em forma de <strong>V</strong>. O importante é manter-se centrado entre as duas correntes que convergem — um empurrão divertido.' },
  { km: 2,    type: 'Pesqueiro de salmão',     name: 'El Ricao',
    text: 'Troço mais estreito com <strong>águas tranquilas serpenteantes</strong>. Pesqueiro histórico de salmão — encontrarás pescadores nas margens durante a época do salmão.' },
  { km: 4,    type: 'Passadiço · aldeia',      name: 'Pasarela de Fuentes · Los Llaos',   highlight: true,
    photo: 'pasarela-fuentes', alt: 'Pasarela de Fuentes sobre o rio Sella em Triongo',
    text: 'Passas por baixo do <strong>passadiço da freguesia de Triongo</strong> (Cangas de Onís). Segundo pesqueiro de salmão e um dos troços mais bonitos do rio — aldeias asturianas nas margens, azinheiras e faias.' },
  { km: 5,    type: 'Troço rochoso',           name: 'Triongo',
    text: 'Troço cheio de <strong>pequenos rápidos</strong> e pedras. Na margem direita resta um quebra-mar destruído que faz parte da paisagem fluvial histórica.' },
  { km: 6,    type: 'Praia fluvial',           name: 'Pozo del Arco',                      highlight: true,
    photo: 'pozo-del-arco', alt: 'Pozo del Arco · praia fluvial na descida do Sella',
    text: 'Uma das zonas favoritas do percurso. <strong>Águas tranquilas e profundas</strong>, praia fluvial ideal para tomar banho — paragem imprescindível em julho e agosto quando a água está mais quente.' },
  { km: 6.5,  type: 'Rabião · fronteira',      name: 'El Picu La Vieya',
    text: 'Marca a <strong>fronteira entre Cangas de Onís e Ribadesella</strong>, em Margolles. Pequeno rabião na margem direita que recorda que o rio continua vivo.' },
  { km: 7,    type: 'Fim Mini Sella',          name: 'Puente de Toraño',                   highlight: true,
    photo: 'torano-mini-fin', alt: 'Puente de Toraño · final da rota Mini Sella',
    text: '<strong>Fim do Mini Sella</strong>. Após cerca de <strong>2 horas de remada</strong>, águas tranquilas e dois quiosques na margem. O nosso transfer recolhe a partir das <strong>14h30</strong> quem escolhe a rota curta.' },
  { km: 8,    type: 'Rápido espetacular',      name: 'Rabión del Diablu',
    text: 'Troço <strong>espetacular e muito rochoso</strong>. Um dos momentos mais emocionantes da Descida completa — classe I intensa, sempre seguro com colete homologado e a mini-aula prévia.' },
  { km: 9,    type: 'Troço reto',              name: 'La Requexada',
    text: 'O troço <strong>reto mais longo</strong> do percurso, com águas muito profundas. Tempo perfeito para remar com ritmo, desfrutar do vale aberto e conversar sem sobressaltos.' },
  { km: 10,   type: 'Paragem',                 name: 'Llordón',
    text: 'Paragem habitual para <strong>comer o picnic</strong> ou refrescar-se antes do troço final. Margens amplas e pôr-do-sol espetacular se desceres no outono.' },
  { km: 12,   type: 'Passadiço',               name: 'Pasarela de Cuevas',
    text: 'Aldeia de Ribadesella famosa pela sua <strong>gruta natural</strong>. O passadiço sobre o rio é acesso pedonal e de pescadores — troço muito fotogénico.' },
  { km: 13,   type: 'Passadiço',               name: 'Pasarela de La Uña',
    text: 'O <strong>último passadiço</strong> do percurso. A partir daqui o rio acalma, aparecem mais <strong>praias fluviais</strong> e o vale abre-se suavemente até ao mar.' },
  { km: 14.5, type: 'Final',                   name: 'Fríes · Llovio',                     highlight: true,
    photo: 'frias-final', alt: 'Fríes · final do Percurso completo da descida do Sella',
    text: '<strong>Final da Descida completa</strong>. Entre 3 h 30 e 4 h 30 desde Arriondas segundo o ritmo. O nosso transfer recolhe-te e leva-te de volta aos escritórios, onde te esperam <strong>vestiários com duches quentes</strong>.' },
];

const iconFor = (type) => {
  const t = type.toLowerCase();
  if (t.includes('fim mini'))    return 'flag-mini';
  if (t.includes('saída'))       return 'flag-start';
  if (t.includes('final'))       return 'flag-finish';
  if (t.includes('rápido') || t.includes('rabião')) return 'wave';
  if (t.includes('pesqueiro'))   return 'fish';
  if (t.includes('passadiço'))   return 'bridge';
  if (t.includes('rochoso'))     return 'mountain';
  if (t.includes('praia'))       return 'beach';
  if (t.includes('reto'))        return 'arrow';
  if (t.includes('paragem'))     return 'coffee';
  return 'dot';
};

const iconPaths = {
  'flag-start':  '<path d="M6 21V4m0 0h12l-3 4 3 4H6"/>',
  'flag-finish': '<path d="M6 21V4m0 0h12l-3 4 3 4H6m0-4h12"/>',
  'flag-mini':   '<path d="M6 21V5m0 0h11l-2 3 2 3H6"/>',
  'wave':        '<path d="M3 10c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/><path d="M3 16c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'fish':        '<path d="M3 12c3-3 7-5 11-5 3 0 6 2 7 5-1 3-4 5-7 5-4 0-8-2-11-5z"/><circle cx="15.5" cy="10.5" r="0.9" fill="currentColor" stroke="none"/>',
  'bridge':      '<path d="M3 19V13a9 9 0 0 1 18 0v6M3 19h18M9 19v-3M15 19v-3"/>',
  'mountain':    '<path d="M3 20l5-9 4 6 3-4 6 7z"/>',
  'beach':       '<circle cx="12" cy="8" r="3"/><path d="M3 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'arrow':       '<line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 6 20 12 14 18"/>',
  'coffee':      '<path d="M4 10h12v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-6zm12 2h2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-2"/><line x1="8" y1="3" x2="8" y2="6"/><line x1="12" y1="3" x2="12" y2="6"/>',
  'parasol':     '<path d="M3 11a9 9 0 0 1 18 0z"/><line x1="12" y1="11" x2="12" y2="20"/><path d="M10 20a2 2 0 0 0 4 0"/>',
  'dot':         '<circle cx="12" cy="12" r="3"/>',
};

// 6 quiosques ribeirinhos reais
const chiringuitos = [
  { km: 1, name: 'Riverland',  nota: 'Início do percurso',              icon: 'flag-start' },
  { km: 3, name: 'El Oasis',   nota: 'Primeiro terço · margem',         icon: 'coffee'     },
  { km: 3, name: 'El Prau',    nota: 'Primeiro terço · praia',          icon: 'parasol'    },
  { km: 4, name: 'El Bosque',  nota: 'Meio · após o passadiço',         icon: 'bridge'     },
  { km: 4, name: 'La Mediana', nota: 'Meio · outra margem',             icon: 'wave'       },
  { km: 8, name: 'Toraño',     nota: 'Fim do Mini Sella',               icon: 'flag-finish'},
];

// FAQ específica do percurso
const faqs = [
  { q: 'Quantos quilómetros tem a descida do Sella?',
    a: 'A <strong>Descida completa</strong> tem <strong>14,5 km</strong> desde Arriondas até Fríes. O <strong>Mini Sella</strong>, opção curta, são <strong>7 km</strong> entre Arriondas e Toraño. Ambos partilham o mesmo troço inicial.' },
  { q: 'Onde começa e onde termina a descida do Sella?',
    a: 'A descida <strong>começa em Arriondas</strong> (Astúrias), nos nossos escritórios. O Percurso completo <strong>termina em Fríes</strong> após 14,5 km. O Mini Sella termina antes, em <strong>Toraño</strong> (km 7). Em ambos os casos o nosso transfer recolhe-te e leva-te de volta ao ponto de partida.' },
  { q: 'Quais são os quiosques do percurso?',
    a: 'Na descida há <strong>6 quiosques ribeirinhos</strong> ao longo do caminho: <strong>Riverland</strong> (km 1), <strong>El Oasis</strong> e <strong>El Prau</strong> (km 3), <strong>El Bosque</strong> e <strong>La Mediana</strong> (km 4) e <strong>Toraño</strong> (km 8, fim do Mini Sella). Podes parar para descansar, tomar algo ou simplesmente desfrutar do ambiente.' },
  { q: 'Há praias fluviais onde tomar banho?',
    a: 'Sim. A mais conhecida é o <strong>Pozo del Arco</strong> (km 6), com águas tranquilas perfeitas para banho. Além disso há várias <strong>margens e praias informais</strong> ao longo do percurso — sobretudo após Pasarela de Fuentes e antes de Llordón.' },
  { q: 'Que rápidos ou troços difíceis há?',
    a: 'O Sella no seu troço turístico é <strong>fluvial suave</strong> — não é white-water. Tem algum rabião <strong>classe I moderada</strong> como <strong>La Raíz</strong> (km 0,2) e <strong>La Remolina</strong> (km 1). Com a mini-aula prévia e colete homologado fazem-se com total segurança.' },
  { q: 'Pode parar-se em qualquer ponto do percurso?',
    a: 'Sim, <strong>vocês marcam o ritmo</strong>. Param onde quiserem: em praias fluviais, em quiosques ou simplesmente na margem para esticar. A única coisa a cumprir é a <strong>permanência máxima até às 18:00</strong> por normativa da Confederação Hidrográfica do Cantábrico.' },
  { q: 'Que diferença há entre Mini Sella e Percurso completo?',
    a: 'Ambos partilham os primeiros 7 km (Arriondas → Toraño). O <strong>Mini Sella</strong> termina aí — ideal com crianças pequenas ou para meio dia. A <strong>Descida completa</strong> continua mais 7,5 km até Fríes, somando paisagem aberta, o passadiço de Cuevas, o de La Uña e o fecho do vale. <a href="/pt/quanto-tempo-dura/">Mais detalhe de tempos aqui</a>.' },
  { q: 'O que vamos ver no caminho?',
    a: 'Aldeias asturianas (Fuentes, Margolles, Toraño, Cuevas), <strong>floresta cantábrica</strong> com azinheiras e faias, <strong>6 quiosques</strong> nas margens, o <strong>pesqueiro de salmão</strong> de Los Llaos, <strong>praias fluviais</strong>, rápidos suaves e vários passadiços históricos. O plano mais panorâmico das Astúrias.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Percurso e mapa da descida do Sella · Arriondas a Fríes',
      description: 'Guia completo do percurso da descida do Sella: 14,5 km com mapa interativo, quiosques, rápidos, passadiços e praias fluviais.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-21',
      dateModified: '2026-05-12',
      about: 'Percurso e mapa da descida do Sella em canoa, 14,5 km entre Arriondas e Fríes',
      keywords: 'descida do Sella, percurso e mapa, Arriondas, Fríes, Mini Sella, quiosques, rápidos, passadiços, praias fluviais, Astúrias',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'pt-PT',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',           item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Percurso e mapa',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/pt/percurso-e-mapa/" translationKey="recorrido_mapa">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO ============== -->
  <section class="rrh" aria-labelledby="rrh-title">

    <div class="rrh__shapes" aria-hidden="true">
      <span class="rrh__shape rrh__shape--1"></span>
      <span class="rrh__shape rrh__shape--2"></span>
    </div>
    <span class="rrh__watermark" aria-hidden="true">Sella</span>

    <div class="rrh__inner">
      <nav class="rrh__breadcrumb" aria-label="Migalhas de pão">
        <a href={getLocalePath('home', lang)}>Início</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Percurso e mapa</span>
      </nav>

      <span class="rrh__eyebrow">— Percurso da descida</span>

      <h1 id="rrh-title" class="rrh__title">
        O mapa do<br/>
        <span class="serif-italic">Sella.</span>
      </h1>

      <p class="rrh__lead">
        A descida do Sella em canoa percorre <strong>14,5 km entre Arriondas e Fríes</strong>,
        atravessando aldeias asturianas, rápidos suaves, passadiços históricos, praias fluviais
        e <strong>6 quiosques ribeirinhos</strong>. Aqui tens o mapa interativo com todos os pontos
        do caminho.
      </p>

      <ul class="rrh__stats" aria-label="Números do percurso">
        <li class="rrh__stat">
          <strong>14,5<small>km</small></strong>
          <span>percurso completo</span>
        </li>
        <li class="rrh__stat">
          <strong>7<small>km</small></strong>
          <span>Mini Sella</span>
        </li>
        <li class="rrh__stat">
          <strong>6</strong>
          <span>quiosques</span>
        </li>
      </ul>

      <div class="rrh__ctas">
        <a href="#rrh-mapa" class="rrh__cta rrh__cta--primary">Ver mapa interativo</a>
        <a href={getLocalePath('reservar', lang)} class="rrh__cta rrh__cta--link">
          Reservar descida
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · MAPA INTERATIVO ============== -->
  <div id="rrh-mapa">
    <MapaInteractivoSella />
  </div>

  <!-- ============== 3 · PONTOS DO CAMINHO ============== -->
  <section class="rrs" aria-labelledby="rrs-title">
    <div class="container container--xl">
      <header class="rrs__header" data-reveal>
        <div class="rrs__headerMain">
          <span class="rrs__eyebrow">— Pontos do caminho</span>
          <h2 id="rrs-title" class="rrs__title">8 paragens<br/><span class="serif-italic">canónicas.</span></h2>
        </div>
        <div class="rrs__nav" role="group" aria-label="Navegação pontos">
          <span class="rrs__counter" aria-live="polite">
            <span class="rrs__counterCurrent" data-rrs-current>01</span>
            <small class="rrs__counterTotal">/{String(hitos.length).padStart(2, '0')}</small>
          </span>
          <button type="button" class="rrs__navBtn" data-rrs-nav="prev" aria-label="Ponto anterior">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="rrs__navBtn is-dark" data-rrs-nav="next" aria-label="Ponto seguinte">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </header>

      <div class="rrs__track" data-rrs-track data-drag-scroll role="region" aria-label="Pontos do percurso">
        {hitos.map((h, i) => (
          <article class="rrsItem" data-rrs-item={i}>
            <span class="rrsItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rrsItem__media">
              <Picture src={h.photo} alt={h.alt} sizes="(min-width: 960px) 52vw, 90vw" bare />
            </div>
            <div class="rrsItem__body">
              <span class="rrsItem__tag">KM {h.km === Math.floor(h.km) ? h.km : h.km.toFixed(1).replace('.', ',')} · {h.tag}</span>
              <h3 class="rrsItem__name">{h.name}</h3>
              <p class="rrsItem__kind">{h.kind}</p>
              <p class="rrsItem__text" set:html={h.text} />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 3.25 · BANNER escuro ============== -->
  <section class="rrb" aria-label="Chamada à ação · reservar descida">
    <div class="container container--xl">
      <div class="rrb__inner" data-reveal>
        <div class="rrb__text">
          <span class="rrb__eyebrow">— Aventura en el Sella</span>
          <h2 class="rrb__title">Pronto para <span class="serif-italic">fazer a descida?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rrb__cta">
          <span>Reservar agora</span>
          <span class="rrb__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 3.5 · TROÇO POR TROÇO ============== -->
  <section class="rrt" aria-labelledby="rrt-title">
    <div class="container container--xl">
      <header class="rrt__header" data-reveal>
        <span class="rrt__eyebrow">— Passo a passo</span>
        <h2 id="rrt-title" class="rrt__title">
          Troço por troço<br/>
          <span class="serif-italic">do Sella.</span>
        </h2>
        <p class="rrt__lead">
          A descida do Sella em canoa nasceu em <strong>1929</strong>, quando três asturianos
          — Manés Fernández, Dionisio de la Huerta e Benigno Morán — desceram pela primeira vez entre
          Coya e Arriondas. Hoje, o <strong>percurso turístico entre Arriondas e Fríes</strong>
          mantém cada um dos acidentes históricos do rio: rápidos suaves, passadiços,
          praias fluviais e troços inesquecíveis. Este é o guia completo, lugar por lugar.
