---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Reserva Premium · descida do Sella tudo incluído';
const description = 'Descida do Sella Premium · 40 € adulto · 30 € criança · animais grátis. Tudo incluído + piquenique asturiano (empada de bonito, bolinho asturiano) de oferta.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/reserva-premium/`;

// Itens "O que está incluído" · grelha editorial 4×4 (13 itens, piquenique full-width última linha)
const includesPremium = [
  { icon: 'parking',   name: 'Estacionamento privado',         nota: 'Vigiado e gratuito · 300 lugares · também para autocaravanas · junto à base', highlight: false },
  { icon: 'canoa',     name: 'Canoa insubmersível',            nota: 'Sistema insubmersível · 1 a 3 lugares · homologada · manutenção diária',       highlight: false },
  { icon: 'chaleco',   name: 'Colete homologado',              nota: 'CHC obrigatório · tamanho adulto e infantil · ajuste verificado',              highlight: false },
  { icon: 'pala',      name: 'Pagaia dupla',                    nota: 'Pá dupla em alumínio · uma por pessoa · leve e ergonómica',                    highlight: false },
  { icon: 'neopreno',  name: 'Fato de neoprene',                nota: 'Em datas frias estabelecidas · proteção térmica contra a água fria',           highlight: false },
  { icon: 'bidon',     name: 'Bidão estanque',                  nota: 'As tuas coisas secas toda a descida · telemóvel · carteira · roupa',           highlight: false },
  { icon: 'rampa',     name: 'Rampa de embarque',               nota: 'Opcional e gratuita · embarca pela rampa ou diretamente pela margem',          highlight: false },
  { icon: 'monitor',   name: 'Monitor qualificado',             nota: 'Briefing de segurança · mini-aula de remo · equipa asturiana',                 highlight: false },
  { icon: 'transfer',  name: 'Transfer de regresso',            nota: 'Vamos buscar-te a Toraño (Mini) ou Fríes (Completo) e voltar à base',          highlight: false },
  { icon: 'duchas',    name: 'Balneários com duches',           nota: 'Muda-te à vontade antes e depois · água quente ao terminar',                    highlight: false },
  { icon: 'taquilla',  name: 'Cacifos com chave',               nota: 'As tuas coisas seguras · o que outros cobram à parte, incluído no preço',     highlight: false },
  { icon: 'seguro',    name: 'Seguros obrigatórios',            nota: 'Responsabilidade civil e acidentes · incluídos sem custo extra',                highlight: false },
  { icon: 'picnic',    name: 'Piquenique asturiano',            nota: 'Empada de bonito · bolinho asturiano · garrafa de água 500 ml · dentro do bidão', highlight: true  },
];

// Preço atual (confirmado 2026-04-10 · project_premium_strategy.md)
const tarifas = [
  { label: 'Adulto',   from: 13, to: 99, price: '40', unit: '€' },
  { label: 'Criança',  from: 5,  to: 12, price: '30', unit: '€' },
  { label: 'Animais',  from: 0,  to: 0,  price: 'Grátis', unit: '' },
];

// Testemunhos reais (reference_reviews.md)
const testimonios = [
  { initial: 'N', name: 'Nacho A.',    source: 'TripAdvisor', date: 'agosto 2025',  context: 'Casais', rating: 5,
    text: 'Tudo pontual e muito amáveis. Uma experiência para fazer uma vez na vida, recomendada para jovens e mais velhos.' },
  { initial: 'C', name: 'Carlos S.',   source: 'TripAdvisor', date: 'maio 2025',     context: 'Amigos', rating: 5,
    text: 'Vale mesmo a pena. Tens balneários e podes tomar duche depois da atividade. Dão-te instruções divertidas, um bidão para meter muitas coisas e o resto é o rio que te dá.' },
  { initial: 'A', name: 'Anaïs Suárez', source: 'Google',    date: 'outubro 2025', context: 'Experiência', rating: 5,
    text: 'Bom serviço, equipa atenta e muito simpática. A experiência foi genial, adorei.' },
];

const faqs = [
  { q: 'O que inclui exatamente a reserva Premium da descida do Sella?',
    a: 'Tudo o que precisas para descer o Sella sem preocupações: <strong>estacionamento privado vigiado (300 lugares · também para autocaravanas), canoa insubmersível (1-3 lugares), colete homologado, pagaia dupla, fato de neoprene em datas frias, bidão estanque, rampa de embarque opcional (ou embarcas pela margem), monitor qualificado, transfer de regresso, balneários com duches quentes, cacifos com chave (que outras empresas cobram à parte), seguros obrigatórios e o <em>piquenique asturiano de oferta</em></strong>. São 13 coisas, todas no preço. Sem extras escondidos.' },
  { q: 'Quanto custa a descida Premium?',
    a: '<strong>40 € por adulto</strong> (a partir dos 13 anos) e <strong>30 € por criança</strong> (dos 5 aos 12 anos). Os <strong>animais são grátis</strong>. O preço é o mesmo para a Mini Sella (7 km) e a Descida Completa (14,5 km) — sem surpresas.' },
  { q: 'Em que se diferencia a Premium da descida básica de outros operadores?',
    a: 'Os concorrentes do vale do Sella costumam oferecer entre 15 e 35 € sem piquenique, só com a canoa e o colete. A nossa <strong>reserva Premium custa um pouco mais mas inclui: estacionamento privado vigiado, rampa de embarque própria (opcional e gratuita, se preferires embarcas pela margem), canoa com sistema insubmersível, fato de neoprene em datas frias, piquenique asturiano, transfer, balneários com duches quentes, <em>cacifos com chave</em> e seguros — tudo coisas que outros operadores cobram à parte ou não oferecem</strong>. É a versão sem surpresas.' },
  { q: 'O que leva o piquenique asturiano?',
    a: 'Cozinha asturiana tradicional: uma <strong>empada de bonito</strong>, um <strong>bolinho asturiano</strong> (chouriço envolvido em pão) e uma <strong>garrafa de água de 500 ml</strong>. Tudo dentro do bidão estanque para chegar seco e fresco. Podes desfrutar onde quiseres do percurso — numa praia fluvial, numa margem ou depois do último rápido. <em>O piquenique é fixo e o mesmo para todos os clientes — não temos opção vegana nem vegetariana. Se tens uma alergia concreta (glúten, frutos secos...), avisa-nos na reserva para te confirmarmos os ingredientes.</em>' },
  { q: 'Tenho de escolher uma hora de saída?',
    a: 'Não. A tua reserva é <strong>Premium · horário aberto</strong>: chega às nossas instalações de Arriondas <strong>quando te der jeito entre as 10:30 e as 12:30</strong>, sem escolher hora concreta. É uma das <strong>vantagens Premium</strong> · equipamos-te à chegada e sais para o rio assim que estiveres pronto. <strong>Exceções</strong>: o sábado da <a href="' + getLocalePath('descenso_internacional', lang) + '">Descida Internacional</a> tem saída única em hora concreta · e se por temporal ou condições do rio precisarmos de uma hora específica ou saída com monitor, avisamos com antecedência. A Confederação Hidrográfica impõe permanência no rio até às 18:00.' },
  { q: 'Tenho de pagar agora na reserva?',
    a: 'Não. Podes pagar <strong>com cartão na reserva ou no dia em que recolhes a canoa</strong>. O que preferires.' },
  { q: 'Posso reservar no próprio dia?',
    a: 'Sim — <strong>desde que o calendário de reserva mostre disponibilidade</strong> para esse dia. A nossa recomendação sincera é <strong>reservar com antecedência</strong>, sobretudo na época alta (julho-agosto) e fins de semana, quando os lugares se esgotam depressa. O <a href="' + getLocalePath('reservar', lang) + '">calendário online</a> mostra-te em tempo real os dias livres. Reservar demora 2 minutos e <strong>não tens de pagar nada nesse momento</strong>.' },
  { q: 'Pode-se cancelar a reserva Premium?',
    a: 'Sim. Podes cancelar ou mudar a data até 48 horas antes sem custo. Se o tempo não acompanhar ou a Confederação Hidrográfica fechar o rio, reagendamos ou devolvemos o valor integral.' },
  { q: 'Existe alguma opção superior à Premium?',
    a: 'Não há mais categorias. <strong>Todas as nossas reservas são Premium</strong> — é a nossa forma padrão de fazer as coisas: tudo incluído, piquenique de oferta, sem planos enganosos com "níveis" diferentes. O que vês é o que há.' },
  { q: 'Posso oferecer uma descida Premium?',
    a: 'Sim, funciona muito bem como <strong>presente de aniversário, casamento ou experiência</strong>. Reservas a data e emitimos um cartão presente com o nome de quem o recebe. <a href="' + getLocalePath('contacto', lang) + '">Escreve-nos</a> e tratamos disso.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Reserva Premium da descida do Sella — Tudo Incluído + Piquenique Asturiano',
      description: 'Reserva Premium da descida do Sella: 40 € adulto, 30 € criança, animais grátis, piquenique asturiano incluído. Tudo no preço.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      about: 'Descida do Sella Premium tudo incluído com piquenique asturiano desde Arriondas',
    },
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descida do Sella · Reserva Premium',
      description: 'Descida do Sella em canoa com tudo incluído e piquenique asturiano de oferta (empada de bonito, bolinho asturiano e água). Desde Arriondas, 14,5 km (Completo) ou 7 km (Mini Sella).',
      image: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      aggregateRating: { '@type': 'AggregateRating', ratingValue: 4.5, reviewCount: 147, bestRating: 5, worstRating: 1 },
      offers: [
        { '@type': 'Offer', name: 'Adulto',  price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/pt/reservar/` },
        { '@type': 'Offer', name: 'Criança', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/pt/reservar/` },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',          item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Reserva Premium', item: canonicalUrl },
      ],
    },
  ],
};

const iconPaths = {
  parking:  '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M10 8v8M10 8h3.5a2.5 2.5 0 0 1 0 5H10"/>',
  canoa:    '<path d="M3 14c3 3 7 4 9 4s6-1 9-4"/><path d="M5 14l2-8h10l2 8"/><line x1="12" y1="6" x2="12" y2="14"/>',
  chaleco:  '<path d="M7 4h10v4l-2 2v10H9V10L7 8z"/><line x1="9" y1="14" x2="15" y2="14"/>',
  neopreno: '<path d="M8 4l-2 2v4l2 1v11h8V11l2-1V6l-2-2zM10 4v2h4V4"/>',
  pala:     '<line x1="5.5" y1="12" x2="18.5" y2="12"/><ellipse cx="3" cy="12" rx="2.5" ry="4.5"/><ellipse cx="21" cy="12" rx="2.5" ry="4.5"/>',
  rampa:    '<line x1="3" y1="20" x2="21" y2="20"/><path d="M5 20V13h14v7"/><path d="M3 10c3 2 6 2 9 0s6-2 9 0"/>',
  bidon:    '<path d="M8 4h8v3H8zM7 7h10v14H7zM7 12h10M7 17h10"/>',
  transfer: '<rect x="3" y="8" width="18" height="10" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/><line x1="3" y1="12" x2="21" y2="12"/>',
  duchas:   '<circle cx="7" cy="5" r="2"/><path d="M5 7v3h4V7M3 10h8M5 10v4M7 10v6M9 10v4"/>',
  taquilla: '<rect x="5" y="11" width="14" height="10" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/>',
  monitor:  '<circle cx="12" cy="8" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>',
  seguro:   '<path d="M12 3L5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  picnic:   '<path d="M4 11h16l-2 10H6z"/><path d="M8 11V6a4 4 0 0 1 8 0v5"/><line x1="10" y1="15" x2="10" y2="18"/><line x1="14" y1="15" x2="14" y2="18"/>',
};

const starSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/pt/reserva-premium/" translationKey="reserva_premium">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="rpH" aria-labelledby="rpH-title">
    <span class="rpH__watermark" aria-hidden="true">Premium</span>

    <div class="rpH__inner">
      <nav class="rpH__breadcrumb" aria-label="Breadcrumb">
        <a href="/pt/">Início</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Reserva Premium</span>
      </nav>

      <div class="rpH__grid">
        <div class="rpH__main">
          <span class="rpH__eyebrow">— Para o teu dia perfeito no Sella</span>

          <h1 id="rpH-title" class="rpH__title">
            Todo o Sella.<br/>
            <span class="serif-italic">Sem pensar em nada.</span>
          </h1>

          <div class="rpH__deluxe" aria-hidden="true">
            <span class="rpH__deluxeMark"></span>
            <span class="rpH__deluxeWord">Premium</span>
            <span class="rpH__deluxeMark"></span>
          </div>

          <p class="rpH__lead">
            A descida do Sella com <strong>tudo incluído</strong> — canoa, colete, pagaia, bidão, transfer, duches quentes e <strong>piquenique asturiano de oferta</strong>. Uma só tarifa honesta, sem extras, sem surpresas.
          </p>

          <div class="rpH__stats">
            <span class="rpH__statsKicker">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Tudo incluído · sem extras
            </span>
            <div class="rpH__statsRow">
              <div class="rpH__stat">
                <strong>40<small>€</small></strong>
                <span>Adulto</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>30<small>€</small></strong>
                <span>Criança · 5–12</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>Grátis</strong>
                <span>Animais</span>
              </div>
            </div>
          </div>

          <div class="rpH__ctas">
            <a href={getLocalePath('reservar', lang)} class="rpH__cta rpH__cta--primary">
              Reservar agora
              <span class="rpH__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
            <a href="#rpH-incluye" class="rpH__cta rpH__cta--ghost">
              Ver o que está incluído
            </a>
          </div>
        </div>

        <aside class="rpH__contact" aria-labelledby="rpH-contact-kicker">
          <span class="rpH__contactKicker" id="rpH-contact-kicker">— Falamos?</span>
          <ul class="rpH__contactList" role="list">
            <li>
              <a href="tel:+34681093673" class="rpH__contactPill rpH__contactPill--primary" aria-label="Ligar para 681 09 36 73">
                <strong>Liga-nos</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Ol%C3%A1%2C%20tenho%20uma%20pergunta%20sobre%20a%20Reserva%20Premium" target="_blank" rel="noopener noreferrer" class="rpH__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Resposta em minutos</small>
              </a>
            </li>
            <li>
              <a href="mailto:reservas@aventuraenelsella.es" class="rpH__contactPill" aria-label="Email">
                <strong>Email</strong>
                <small>Reservas e dúvidas</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="rpQ" aria-labelledby="rpQ-title">
    <div class="container container--xl">
      <div class="rpQ__grid">
        <header class="rpQ__head" data-reveal>
          <span class="rpQ__eyebrow">— Premium aqui em casa</span>
          <h2 id="rpQ-title" class="rpQ__title">
            Não é mais caro.<br/>
            <span class="serif-italic">É tudo incluído.</span>
          </h2>
        </header>
        <div class="rpQ__body" data-reveal data-reveal-delay="1">
          <p class="rpQ__lead">
            "Premium" aqui não significa pomposo nem fino. Significa <strong>uma só tarifa honesta</strong> com absolutamente tudo o que precisas na canoa — e um <strong>piquenique asturiano à tua espera</strong> dentro do bidão estanque.
          </p>
          <p class="rpQ__lead">
            Os operadores do vale do Sella cobram entre 15 e 35 € pela canoa básica. A nossa tarifa de <strong>40 € por adulto</strong> é apenas alguns euros mais, mas inclui o que outros te vendem como extras ou nem oferecem: <strong>estacionamento privado vigiado</strong>, canoa insubmersível, <strong>rampa de embarque própria</strong> (opcional e gratuita), fato de neoprene em datas frias, bidão, transfer, balneários com duches quentes, <strong>cacifos com chave</strong>, seguros e o <strong>piquenique asturiano</strong>. <em>Sem surpresas no fim do dia.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rpI" id="rpH-incluye" aria-labelledby="rpI-title">
    <div class="container container--xl">
      <header class="rpI__header" data-reveal>
        <span class="rpI__eyebrow">— 13 coisas incluídas</span>
        <h2 id="rpI-title" class="rpI__title">
          O que entra<br/>
          <span class="serif-italic">na reserva Premium.</span>
        </h2>
        <p class="rpI__lead">
          Tudo o que está na lista vai no preço. Nada é cobrado à parte. <strong>Nada.</strong>
        </p>
      </header>

      <ol class="rpI__grid">
        {includesPremium.map((item, i) => (
          <li class={`rpI__cell${item.highlight ? ' is-highlight' : ''}`}>
            <span class="rpI__cellNum" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rpI__cellBody">
              <span class="rpI__cellIcon" aria-hidden="true">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[item.icon]} />
              </span>
              <h3 class="rpI__cellName">{item.name}</h3>
              <p class="rpI__cellNota">{item.nota}</p>
              {item.highlight && <span class="rpI__cellBadge">OFERTA</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="rpB" aria-label="Chamada à ação · reservar Premium">
    <div class="container container--xl">
      <div class="rpB__inner" data-reveal>
        <div class="rpB__text">
          <span class="rpB__eyebrow">— Aventura en el Sella</span>
          <h2 class="rpB__title">Pronto para o rio <span class="serif-italic">e o piquenique?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rpB__cta">
          <span>Reservar agora</span>
          <span class="rpB__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="rpP" aria-labelledby="rpP-title">
    <div class="container container--xl">
      <div class="rpP__split">
        <div class="rpP__media" data-reveal data-reveal-type="slide-right">
          <Picture src="fiesta-sella" alt="Ambiente e piquenique asturiano na descida do Sella · Reserva Premium tudo incluído" sizes="(min-width: 960px) 45vw, 100vw" bare />
          <span class="rpP__mediaTag">Incluído · Oferta</span>
        </div>
        <div class="rpP__body" data-reveal data-reveal-delay="1">
          <span class="rpP__eyebrow">— O diferencial</span>
          <h2 id="rpP-title" class="rpP__title">
            Piquenique asturiano<br/>
            <span class="serif-italic">dentro do bidão.</span>
          </h2>
          <p class="rpP__lead">
            Cozinha asturiana pura: uma <strong>empada de bonito</strong>, um <strong>bolinho asturiano</strong> (chouriço envolvido em pão) e uma <strong>garrafa de água de 500 ml</strong>. Simples, honesto, saboroso — dentro do bidão estanque para chegar seco e fresco.
          </p>
          <ul class="rpP__list">
            <li><span class="rpP__listDot" aria-hidden="true"></span>Come-o numa <strong>praia fluvial</strong> — o Pozo del Arco é o favorito da equipa.</li>
            <li><span class="rpP__listDot" aria-hidden="true"></span>Ou pára num dos <strong>6 bares à beira-rio</strong> e abre-o aí com calma.</li>
