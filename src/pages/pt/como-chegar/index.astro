---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Como chegar a Arriondas · A 50 m das estações de autocarros e comboios';
const description = 'Como chegar a Arriondas para a descida do Sella: a 50 m das estações de autocarros e comboios. Carro (A-8, A-64), autocarro ALSA ou comboio Renfe. Parking 300 lugares + autocaravanas.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/como-chegar/`;
const ogImage = '/images/optimized/como-llegar-cta-lg.jpg';

// Cidades de origem mais relevantes · distâncias por estrada (rotas recomendadas)
// lat/lng: necessárias no `data=` do Google Maps para calcular rota com FTID destino.
const ciudades = [
  { c: 'Oviedo',    lat: 43.36029, lng: -5.84476, km: 52,  tiempo: '50 min',     ruta: 'A-64 + N-634',      destacado: true  },
  { c: 'Gijón',     lat: 43.53573, lng: -5.66152, km: 75,  tiempo: '55 min',     ruta: 'A-8 + AS-114',       destacado: true  },
  { c: 'Santander', lat: 43.46472, lng: -3.80444, km: 160, tiempo: '1 h 55 min', ruta: 'A-8',                destacado: false },
  { c: 'Bilbao',    lat: 43.26271, lng: -2.92528, km: 255, tiempo: '2 h 45 min', ruta: 'A-8',                destacado: false },
  { c: 'Madrid',    lat: 40.41678, lng: -3.70379, km: 440, tiempo: '4 h 30 min', ruta: 'A-6 + A-66 + A-64',  destacado: false },
];

// 3 meios de transporte em tabs
const medios = [
  {
    id: 'coche',
    tab: 'De carro',
    eyebrow: 'De carro',
    route: 'A opção mais flexível',
    stats: [
      { v: '52',  u: 'km',  l: 'desde Oviedo' },
      { v: '75',  u: 'km',  l: 'desde Gijón' },
      { v: 'A-8', u: '',    l: 'autoestrada' },
    ],
    desc: 'A forma mais cómoda de chegar a Arriondas é <strong>de carro pela A-8</strong> (autoestrada do Cantábrico) desde Santander, Bilbao ou Gijón, ou pela <strong>A-64 + N-634</strong> desde Oviedo. Os acessos estão bem sinalizados, a última parte é por estrada secundária (AS-114 ou N-634) que atravessa belas aldeias asturianas. Junto aos nossos escritórios temos <strong>parking privado e vigiado com 300 lugares — também para autocaravanas</strong>, gratuito e sem restrições.',
    features: ['A-8 autoestrada', 'A-64 direta Oviedo', 'AS-114 desde Gijón', 'Estacionamento grátis', 'Flexibilidade total', 'Sem horários'],
    photo: 'como-llegar-coche',
    badges: ['Flexível', 'Direto', 'Cómodo'],
  },
  {
    id: 'bus',
    tab: 'De autocarro',
    eyebrow: 'Autocarro ALSA',
    route: 'Económico e frequente',
    stats: [
      { v: '~1h15', u: '',  l: 'desde Oviedo' },
      { v: '~1h06', u: '',  l: 'desde Gijón' },
      { v: 'Desde 6€', u: '', l: 'ida' },
    ],
    desc: '<strong>ALSA</strong> liga Arriondas às principais cidades asturianas. Desde <strong>Oviedo (estação Pepe Cosmen)</strong> há <strong>~20 autocarros por dia</strong> (aprox. cada 30 min, primeiro serviço 06:25 e último 22:15), duração ~1 h 15 min. Desde <strong>Gijón</strong> há 4 serviços diretos por dia, duração ~1 h 06 min. A paragem em Arriondas fica na <strong>estação de autocarros</strong>, a poucos minutos a pé dos nossos escritórios. Consulta e compra em <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.',
    features: ['~20 serviços/dia Oviedo', '4 serviços/dia Gijón', 'Desde 6€ ida', 'Estação central', 'Sem carro próprio', 'Compra online'],
    photo: 'como-llegar-bus',
    badges: ['ALSA', 'Frequente', 'Económico'],
  },
  {
    id: 'tren',
    tab: 'De comboio',
    eyebrow: 'Renfe Cercanías AM',
    route: 'Viagem panorâmica pelas Astúrias',
    stats: [
      { v: '~1h50', u: '',  l: 'desde Oviedo' },
      { v: '3/dia', u: '',  l: 'frequência' },
      { v: 'Desde 5€', u: '', l: 'ida' },
    ],
    desc: 'A linha <strong>Renfe Cercanías AM</strong> (antiga FEVE) de Oviedo a Llanes <strong>tem paragem em Arriondas</strong>. Viagem mais lenta mas muito panorâmica por paisagens asturianas: <strong>~1 h 50 min</strong>, primeiro comboio por volta das 07:57 e último por volta das 19:07, <strong>3 serviços por dia</strong>. Desde 5 € o trajeto. A estação de Arriondas fica no centro da vila. Consulta horários atualizados em <a href="https://www.renfe.com/es/es/cercanias/cercanias-am" target="_blank" rel="noopener noreferrer">renfe.com/cercanias-am</a>.',
    features: ['Cercanías AM', '3 comboios/dia', 'Desde 5€ ida', 'Estação centro', 'Paisagem panorâmica', 'Sem carro'],
    photo: 'como-llegar-tren',
    badges: ['Renfe', 'Panorâmico', 'Tranquilo'],
  },
];

// Conselhos práticos (6)
const consejos = [
  { t: 'Horário aberto · 10:30–12:30', s: 'Como a tua reserva é <strong>Premium</strong>, o horário é aberto: chega às nossas instalações <strong>quando te der jeito entre as 10:30 e as 12:30</strong>, sem necessidade de escolher hora concreta. Equipamos-te à chegada e sais ao rio assim que estiveres pronto.' },
  { t: 'Época alta · evita feriados', s: 'Em julho e agosto, especialmente aos fins de semana, a A-8 pode ter tráfego intenso em direção às Astúrias. Se vens de Madrid ou Santander, parte cedo ou considera chegar na tarde anterior.' },
  { t: 'Parking privado · 300 lugares', s: 'Dispomos de <strong>parking privado e vigiado, gratuito, com capacidade para 300 carros e também para autocaravanas</strong>. Sem preocupações — deixa o carro e tratamos do resto.' },
  { t: 'Autocarro · compra com antecedência', s: 'Em época alta os bilhetes da ALSA esgotam-se. Compra <strong>1-2 dias antes</strong> online se vens de autocarro desde Oviedo ou Gijón, especialmente em agosto.' },
  { t: 'Comboio · consulta frequências', s: 'A linha Renfe Cercanías AM tem <strong>poucas frequências por dia</strong> (3-4 serviços). Verifica os horários de ida e volta antes de planear o teu dia.' },
  { t: 'Desde Madrid · considera dormir perto', s: 'Se vens de Madrid, são <strong>4 h 30 de carro</strong>. Pode ser mais cómodo dormir na véspera em Oviedo, Gijón ou Cangas de Onís e descer o Sella fresco no dia seguinte.' },
];

// FAQ específico como chegar (8) · dados verificados com ALSA e Renfe oficial
const faqs = [
  { q: 'Como se chega a Arriondas desde Oviedo?',
    a: 'Desde Oviedo são <strong>cerca de 52 km · 50 min de carro</strong> pela A-64 e N-634. De autocarro com <strong>ALSA</strong>, ~20 serviços diários desde a estação Pepe Cosmen (desde 6 €, duração ~1 h 15 min, primeiro autocarro 06:25 e último 22:15). De comboio <strong>Renfe Cercanías AM</strong>, ~1 h 50 min, com 3 serviços por dia desde 5 €.' },
  { q: 'E desde Gijón?',
    a: 'Desde Gijón são <strong>cerca de 75 km · 55 min de carro</strong> pela A-8 e AS-114. De <strong>autocarro ALSA</strong> há <strong>4 serviços diretos por dia</strong>, com duração de ~1 h 06 min e preços desde 7 €. Compra os bilhetes em <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.' },
  { q: 'Há parking no escritório? Aceitam autocaravanas?',
    a: 'Sim. Dispomos de <strong>parking privado e vigiado com 300 lugares</strong> junto aos nossos escritórios de receção em Arriondas, <strong>gratuito e também apto para autocaravanas</strong>. Não terás problemas para deixar o carro enquanto fazem a descida — e o transfer de regresso deixa-te no mesmo sítio.' },
  { q: 'Vem gente sem carro à descida do Sella?',
    a: 'Muitíssima. Uma parte importante dos nossos clientes chega de <strong>autocarro ALSA</strong> ou <strong>comboio Renfe Cercanías AM</strong> desde Oviedo ou Gijón. A nossa loja fica a <strong>apenas 50 metros a pé</strong> tanto da <strong>estação de autocarros</strong> como da <strong>estação de comboios</strong> de Arriondas — é praticamente uma chegada <strong>porta-a-porta</strong>. Sair de Oviedo de autocarro e começar a descida do Sella sem sair do centro de Arriondas é perfeitamente viável.' },
  { q: 'Até que horas podemos chegar?',
    a: 'A tua reserva é <strong>Premium · horário aberto</strong>. Chega às nossas instalações <strong>quando te der jeito entre as 10:30 e as 12:30</strong>, sem obrigação de cumprir hora concreta — é uma vantagem Premium. Equipamos-te à chegada e sais ao rio assim que estiveres pronto. A <strong>Confederação Hidrográfica do Cantábrico</strong> determina que a <strong>última saída do rio é às 18:00</strong> · por isso fechamos as chegadas às 12:30 (margem segura). Exceções: o sábado da <a href="/pt/descida-internacional-do-sella/">Descida Internacional</a> tem partida única em hora concreta · e se houver temporal ou condições do rio que exijam entrada com monitor, avisamos com antecedência.' },
  { q: 'Qual a distância desde Madrid?',
    a: 'Madrid fica a <strong>cerca de 440 km · 4 h 30 min de carro</strong> pela A-6 (até Benavente), A-66 (Ruta de la Plata) e A-64 (Oviedo → Arriondas). Muitos viajantes preferem dormir na véspera nas Astúrias — Oviedo, Gijón ou Cangas de Onís — para começar o dia da descida frescos.' },
  { q: 'Quantos autocarros/comboios há por dia entre Oviedo e Arriondas?',
    a: '<strong>ALSA: ~20 autocarros diários</strong> (aprox. cada 30 min). <strong>Renfe Cercanías AM: 3 comboios por dia</strong>. O autocarro é mais rápido (~1 h 15 min) e frequente; o comboio é mais panorâmico (~1 h 50 min). Ambos param em Arriondas, no centro da vila.' },
  { q: 'Posso deixar mochilas ou bagagem antes da descida?',
    a: 'Sim. Nos nossos escritórios podes deixar bagagem pequena ou mochilas durante a descida. Ao regressares no nosso transfer, terás acesso a <strong>vestuários com duches quentes</strong> para te mudares antes de continuar o teu dia.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Como chegar a Arriondas · Carro, autocarro e comboio',
      description: 'Guia completo sobre como chegar a Arriondas para a descida do Sella: carro, autocarro ALSA e comboio Renfe desde as principais cidades do norte de Espanha. Parking privado 300 lugares também para autocaravanas.',
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/como-llegar-cta-lg.jpg`, width: 1920, height: 1080 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified:  '2026-05-12',
      articleSection: 'Planeamento · Como chegar',
      keywords: ['como chegar a Arriondas', 'como chegar ao Sella', 'descida do Sella sem carro', 'estação autocarros Arriondas', 'estação comboios Arriondas', 'parking Arriondas descida Sella', 'autocaravanas Arriondas', 'ALSA Oviedo Arriondas', 'Renfe Cercanías AM Arriondas', 'distância Oviedo Arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Como chegar a Arriondas (Astúrias) para a descida do Sella em canoa' },
    },
    {
      '@type': 'Place',
      '@id': `${canonicalUrl}#place`,
      name: 'Aventura en el Sella · Arriondas',
      description: 'Instalações da Aventura en el Sella em Arriondas (Astúrias). Parking privado e vigiado com 300 lugares, também para autocaravanas. Vestuários com duches quentes.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        addressCountry: 'ES',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude:  43.3874223,
        longitude: -5.1866022,
      },
      sameAs: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      url: canonicalUrl,
      amenityFeature: [
        { '@type': 'LocationFeatureSpecification', name: 'A 50 m da estação de autocarros (ALSA)',      value: true },
        { '@type': 'LocationFeatureSpecification', name: 'A 50 m da estação de comboios (Renfe Cercanías AM)', value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Parking privado · 300 lugares',               value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Autocaravanas admitidas',                     value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Vestuários com duches quentes',               value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Cacifos com chave',                           value: true },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',     item: `${baseUrl}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Como chegar', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/pt/como-chegar/" translationKey="como_llegar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · Editorial con signpost card (distinto) ============== -->
  <section class="clh" aria-labelledby="clh-title">

    <div class="clh__shapes" aria-hidden="true">
      <span class="clh__shape clh__shape--1"></span>
      <span class="clh__shape clh__shape--2"></span>
    </div>
    <span class="clh__watermark" aria-hidden="true">Arriondas</span>

    <div class="clh__inner">
      <div class="clh__left">
        <nav class="clh__breadcrumb" aria-label="Breadcrumb">
          <a href={getLocalePath('home', lang)}>Início</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Como chegar</span>
        </nav>
        <span class="clh__eyebrow">— Como chegar a Arriondas</span>
        <h1 id="clh-title" class="clh__title">
          Como chegar<br/>
          <span class="serif-italic">a Arriondas.</span>
        </h1>
        <p class="clh__lead">
          Arriondas fica no <strong>centro oriental das Astúrias</strong>, a 50 km de Oviedo e
          75 km de Gijón. Bem ligada de carro (A-8 e A-64), de autocarro ALSA e de comboio Renfe.
          A nossa loja fica a <strong>50 metros a pé das estações de autocarros e comboios</strong> ·
          porta-a-porta desde Oviedo, Gijón ou Llanes.
        </p>
        <div class="clh__ctas">
          <a href="#clh-medios" class="clh__cta clh__cta--primary">Ver meios de transporte</a>
          <a href={getLocalePath('reservar', lang)} class="clh__cta clh__cta--link">
            Reservar descida
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <aside class="clh__signpost" aria-label="A 50 metros das estações de autocarros e comboios de Arriondas">
        <header class="clh__sigHead">
          <span class="clh__sigKicker">— Sem carro · sem problema</span>
          <h2 class="clh__sigT">A <span class="clh__sigBig">50&nbsp;m</span><br/><span class="serif-italic">das estações</span></h2>
          <p class="clh__sigLead">
            A nossa loja fica a <strong>50 metros a pé</strong> tanto da <strong>estação de autocarros</strong>
            como da <strong>estação de comboios</strong> de Arriondas. Chegada porta-a-porta desde Oviedo, Gijón ou Llanes.
          </p>
        </header>
        <ul class="clh__sigList">
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><circle cx="8.5" cy="15" r="1" fill="currentColor"/><circle cx="15.5" cy="15" r="1" fill="currentColor"/><path d="M7 19l-2 2"/><path d="M17 19l2 2"/></svg>
              <span>Estação autocarros · ALSA</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 12h18"/><path d="M7 19l-2 3"/><path d="M17 19l2 3"/><circle cx="8" cy="16" r="1" fill="currentColor"/><circle cx="16" cy="16" r="1" fill="currentColor"/></svg>
              <span>Estação comboios · Renfe AM</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="7" rx="1"/><path d="M5 11l2-5h10l2 5"/><circle cx="7.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg>
              <span>Parking próprio · 300 lugares</span>
            </span>
            <span class="clh__sigKm"><strong>0</strong><small> m</small></span>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ============== 2 · Distancias cards (grid 5) ============== -->
  <section class="cld">
    <div class="container container--xl">
      <header class="cld__header" data-reveal>
        <span class="cld__eyebrow">— Distância de carro</span>
        <h2 class="cld__title">
          Desde as principais<br/>
          <span class="serif-italic">cidades do norte.</span>
        </h2>
        <p class="cld__lead">
          Km, tempo estimado e rotas principais desde as origens mais habituais dos nossos
          clientes. Sem tráfego denso e cumprindo limites, claro.
        </p>
      </header>

      <ol class="cld__grid">
        {ciudades.map((c, i) => (
          <li class="cld__item" data-reveal data-reveal-delay={(i % 3) + 1}>
            <a
              class="cld__link"
              href={`https://www.google.com/maps/dir/${encodeURIComponent(c.c + ', Espanha')}/Aventura+en+el+Sella/@43.3874223,-5.1866022,9z/data=!4m13!4m12!1m5!1m1!1s0x0:0x0!2m2!1d${c.lng}!2d${c.lat}!1m5!1m1!1s0xd36195b04532889:0x9b2face87069ecfc!2m2!1d-5.1866022!2d43.3874223!3e0`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Abrir Google Maps com rota de carro desde ${c.c} até Aventura en el Sella em Arriondas`}
            >
            <span class="cld__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="cld__city">{c.c}</span>
            <div class="cld__stats">
              <div class="cld__stat">
                <strong>{c.km}<small>km</small></strong>
                <span>distância</span>
              </div>
              <div class="cld__stat">
                <strong>{c.tiempo}</strong>
                <span>de carro</span>
              </div>
            </div>
            <p class="cld__route">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {c.ruta}
            </p>
            <span class="cld__open" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              Ver rota no Google Maps
            </span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 3 · TABS 3 MEDIOS (Coche / Bus / Tren) ============== -->
  <section id="clh-medios" class="clt" aria-labelledby="clt-title">
    <div class="container container--xl">
      <header class="clt__head" data-reveal>
        <div class="clt__headL">
          <span class="clt__kicker">— Meios de transporte</span>
          <h2 id="clt-title" class="clt__title">
            Escolhe a tua<br/>
            <span class="serif-italic">forma de chegar.</span>
          </h2>
        </div>
        <div class="clt__tabs" role="tablist" aria-label="Escolher meio de transporte">
          {medios.map((m, i) => (
            <button type="button" role="tab" id={`clt-tab-${m.id}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`clt-panel-${m.id}`}
                    class={`clt__tab${i === 0 ? ' is-active' : ''}`}
                    data-tab={m.id} tabindex={i === 0 ? 0 : -1}>
              {m.tab}
            </button>
          ))}
        </div>
      </header>

