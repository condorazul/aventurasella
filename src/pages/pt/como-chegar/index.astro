  .clqItem:hover .clqItem__s strong { color: #FBF8F1; }

  @media (prefers-reduced-motion: reduce) {
    .clqItem, .clqItem::before, .clqItem__num, .clqItem__t, .clqItem__s, .clqItem__s strong { transition: none; }
    .clqItem:hover { transform: none; }
    .clqItem:hover::before { transform: translate(-50%, -50%) scale(1); }
  }

