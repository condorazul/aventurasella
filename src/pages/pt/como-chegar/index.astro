  .clx__reservaT { font-family: var(--font-display); font-size: clamp(1.625rem, 3.2vw, 2.125rem); font-weight: 900; line-height: 1; letter-spacing: -0.025em; text-transform: uppercase; color: #FBF8F1; margin: 0; }
