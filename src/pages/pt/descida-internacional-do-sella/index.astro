---
import BaseLayout from '@layouts/BaseLayout.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'pt';
const title = 'Descida Internacional do Sella 2026 · Data e guia';
const description = 'Descida Internacional do Sella 2026: data, percurso, horários, palmarés e como vivê-la. Reserve a sua canoa turística no próprio dia do evento.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/pt/descida-internacional-do-sella/`;

const homeUrl     = getLocalePath('home', lang);
const bookUrl     = getLocalePath('reservar', lang);

// ============== Dados estruturados ==============
const datosClave = [
  { label: 'Nome oficial',    valueLines: ['Descida Internacional', 'do Sella'],         sub: '«Les Piragües»' },
  { label: 'Fundada em',      valueLines: ['1930'],                                       sub: 'quase um século de história' },
  { label: 'Percurso',        valueLines: ['20 km'],                                      sub: 'Arriondas → Ribadesella' },
  { label: 'Participantes',   valueLines: ['+1.200'],                                     sub: 'elite + amadores' },
  { label: 'Espetadores',     valueLines: ['~200.000'],                                   sub: 'nas margens do rio' },
  { label: 'Reconhecimento',  valueLines: ['F. de Interesse Turístico', 'Internacional'], sub: 'declarada em 1981' },
];

const fechas2026 = [
  { day: 'Quinta 6 ago',  hour: 'Todo o dia',       title: 'Chegada das peñas',                 text: 'Concentração em Arriondas. Começa o ambiente festivo.' },
  { day: 'Sexta 7 ago',   hour: 'Todo o dia',       title: 'Festa oficial',                      text: 'Festas populares, fogueiras e música em Arriondas.' },
  { day: 'Sábado 8 ago',  hour: '11:30',            title: 'Partida oficial',                    text: 'A competição arranca a partir da Puente de los Piragüistas.',  highlight: true },
  { day: 'Sábado 8 ago',  hour: '12:00',            title: 'Partida turística · connosco',       text: 'Única partida do dia após a elite. Reserva especial com capacidade limitada.', highlight: true },
  { day: 'Sábado 8 ago',  hour: '14:30–17:00',      title: 'Chegada a Ribadesella',              text: 'Festival de chegada e entrega de troféus junto ao mar.' },
  { day: 'Domingo 9 ago', hour: 'Manhã',            title: 'Entrega de prémios',                 text: 'Cerimónia oficial e Missa do canoísta. Encerra o fim de semana.' },
];

const recorrido = [
  { km: '0 km',    place: 'Arriondas',            note: 'Partida oficial · Puente de los Piragüistas', us: false },
  { km: '3 km',    place: 'Puente de Santianes',  note: 'Primeiro ponto de cronometragem',             us: false },
  { km: '7 km',    place: 'Puente de Toraño',     note: 'Fim da nossa rota Mini Sella',                 us: true  },
  { km: '14,5 km', place: 'Fríes',                note: 'Fim da nossa descida Completa',                us: true  },
  { km: '17 km',   place: 'Llovio',               note: 'Últimos rápidos do traçado',                   us: false },
  { km: '20 km',   place: 'Ribadesella',          note: 'Meta · margem do mar Cantábrico',              us: false },
];

const palmares = [
  { year: '2025', winners: 'Rodrigo Germade / Diego Romero', flag: 'ESP' },
  { year: '2024', winners: 'Javier Reja / Adrián Sieiro',    flag: 'ESP' },
  { year: '2023', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2022', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2021', winners: 'Íñigo Peña / Pedro Vázquez',     flag: 'ESP' },
];

const faqs = [
  { q: 'Quando é a Descida Internacional do Sella 2026?',
    a: 'A edição de 2026 realiza-se no <strong>sábado 8 de agosto</strong>. A partida oficial da elite está marcada para as <strong>11:30</strong> em Arriondas e a chegada a Ribadesella é entre as 14:30 e as 17:00. A nossa partida turística é às <strong>12:00</strong>, logo após os profissionais.' },
  { q: 'Posso descer o Sella no próprio dia da Descida Internacional?',
    a: 'Sim — mas com reserva especial. Oferecemos uma <strong>única partida turística às 12:00</strong>, logo após a partida da elite profissional. O rio abre ao tráfego turístico após a passagem do pelotão. <strong>Preço único de 35 €</strong> por pessoa (sem picnic incluído, porque a logística desse dia é diferente). Pagamento antecipado online. Reserva até <strong>2 dias antes</strong> do evento — os lugares esgotam-se com semanas de antecedência.' },
  { q: 'Porque é que o check-in nesse dia é tão cedo?',
    a: 'O <strong>trânsito de entrada em Arriondas fecha às 10:00</strong> — as ruas tornam-se pedonais e os veículos não conseguem aceder à vila. Por isso, pedimos que chegue a Arriondas <strong>antes das 9:30</strong> para fazer o check-in e deixar o carro no nosso estacionamento privado. Se chegar tarde, não conseguirá aceder e perderia a atividade.' },
  { q: 'Posso levar o meu cão no dia da Descida Internacional?',
    a: '<strong>Não recomendamos</strong>. Embora os animais sejam bem-vindos <a href="' + homeUrl + '">no resto do ano</a>, nesse dia há uma afluência extraordinária (~200.000 espetadores), muito barulho, fogo de artifício, trânsito e tensão. Os cães assustam-se muito e a experiência não será agradável nem para eles nem para si. É melhor reservar em qualquer outro dia da temporada.' },
  { q: 'Quanto custa participar na Descida Internacional como atleta?',
    a: 'A inscrição como atleta federado ronda os <strong>35–45 €</strong> consoante a categoria. Requer licença de canoagem em vigor e acreditação federativa. Não são admitidas canoas turísticas na prova oficial.' },
  { q: 'Onde posso ver a Descida Internacional gratuitamente?',
    a: 'Toda a margem do Sella é de acesso livre. Os melhores pontos são <strong>Arriondas</strong> (partida), o <strong>Puente de Llovio</strong> (últimos rápidos espetaculares) e a chegada em <strong>Ribadesella</strong>.' },
  { q: 'Qual é o palmarés da Descida Internacional do Sella?',
    a: 'Pode consultar a lista completa de vencedores desde 1930 no site oficial da <a href="https://www.rfep.es" target="_blank" rel="nofollow noopener external">Federação Espanhola de Canoagem</a> ou na <a href="https://pt.wikipedia.org/wiki/Descida_Internacional_do_Sella" target="_blank" rel="noopener external">Wikipédia</a>. Aqui em cima tem a tabela das edições recentes, que atualizamos todos os setembros.' },
  { q: 'Há alojamento disponível no fim de semana da Descida Internacional?',
    a: 'Difícil. Reserve com <strong>meses de antecedência</strong> em Arriondas, Cangas de Onís, Ribadesella ou Llanes. A ocupação nessa semana supera os 95 % em toda a zona.' },
  { q: 'Pode-se assistir com crianças?',
    a: 'Sim, é um <strong>evento familiar por excelência</strong>. O ambiente é festivo e a organização prepara zonas de margem seguras. Cuidado com o sol: recomendamos chapéu e protetor solar elevado.' },
  { q: 'Que mais se pode fazer nesse fim de semana nas Astúrias?',
    a: 'Visitar os <strong>Lagos de Covadonga</strong>, descer o <a href="' + homeUrl + '">Sella em modo turístico</a> nos dias anteriores, fazer um percurso de bicicleta pela Senda del Oso, conhecer Ribadesella e a gruta de Tito Bustillo, ou provar a sidra e a gastronomia asturiana nos chigres locais.' },
];

// ============== Schema.org JSON-LD ==============
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descida Internacional do Sella 2026 · Data, percurso e guia completo',
      description,
      inLanguage: 'pt-PT',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/og/og-internacional-pt.jpg`, width: 1200, height: 630 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Eventos · Descida Internacional do Sella',
      keywords: [
        'Descida Internacional do Sella',
        'Descida do Sella 2026',
        'Les Piragües',
        'Festa do Sella',
        'canoagem Astúrias',
        'Arriondas Ribadesella canoa',
      ],
      about: 'Competição internacional de canoagem no rio Sella, Astúrias',
    },
    {
      '@type': 'Event',
      '@id': `${canonicalUrl}#event-2026`,
      name: 'Descida Internacional do Sella 2026 · Les Piragües',
      alternateName: 'Les Piragües',
      description: 'Competição de canoagem de 20 km pelo rio Sella, declarada Festa de Interesse Turístico Internacional. Atrai mais de 1.200 canoístas e 200.000 espetadores.',
      startDate: '2026-08-08T11:30:00+02:00',
      endDate:   '2026-08-08T17:00:00+02:00',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      inLanguage: 'pt-PT',
      isAccessibleForFree: true,
      audience: { '@type': 'Audience', audienceType: 'Público geral · canoagem · turismo desportivo' },
      maximumAttendeeCapacity: 200000,
      location: {
        '@type': 'Place',
        name: 'Rio Sella · Arriondas — Ribadesella',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Puente de los Piragüistas',
          addressLocality: 'Arriondas',
          addressRegion: 'Astúrias',
          postalCode: '33540',
          addressCountry: 'ES',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      },
      organizer: {
        '@type': 'Organization',
        name: 'Federação Espanhola de Canoagem',
        url: 'https://www.rfep.es',
      },
      image: `${baseUrl}/images/og/og-internacional-pt.jpg`,
      url: canonicalUrl,
      offers: {
        '@type': 'Offer',
        name: 'Partida turística da Descida Internacional · 12:00',
        description: 'Única partida turística do dia após a passagem da elite profissional. Capacidade limitada.',
        price: '35',
        priceCurrency: 'EUR',
        availability: 'https://schema.org/LimitedAvailability',
        validFrom: '2026-01-15T00:00:00+02:00',
        url: `${baseUrl}${bookUrl}?dia=2026-08-08`,
      },
      subEvent: [
        { '@type': 'Event', name: 'Chegada das peñas',                    startDate: '2026-08-06', endDate: '2026-08-06', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Festa oficial',                        startDate: '2026-08-07', endDate: '2026-08-07', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Partida turística (12:00)',            startDate: '2026-08-08T12:00:00+02:00', endDate: '2026-08-08T17:00:00+02:00', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Entrega de prémios e Missa do canoísta', startDate: '2026-08-09', endDate: '2026-08-09', eventStatus: 'https://schema.org/EventScheduled' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'Descida do Sella Astúrias · Aventura en el Sella · Aluguer de canoas',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acesso pela Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Astúrias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        'https://share.google/huLLaIz31FiYohuTV',
        'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html',
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início',                          item: `${baseUrl}${homeUrl}` },
        { '@type': 'ListItem', position: 2, name: 'Descida Internacional do Sella', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/og/og-internacional-pt.jpg"
  currentPath="/pt/descida-internacional-do-sella/"
  translationKey="descenso_internacional"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="dih" aria-labelledby="dih-title">

    <div class="dih__inner">
      <nav class="dih__breadcrumb" aria-label="Migalhas">
        <a href={homeUrl}>Início</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Descida Internacional do Sella</span>
      </nav>

      <span class="dih__eyebrow">
        <span class="dih__eyebrow-dot" aria-hidden="true"></span>
        1930 · Festa de Interesse Turístico Internacional
      </span>

      <h1 id="dih-title" class="dih__title">
        Descida Internacional<br/>
        <span class="serif-italic">do Sella</span>
      </h1>

      <p class="dih__lead">
        Uma das <strong>competições de canoagem mais emblemáticas do mundo</strong>
        e a prova desportiva mais antiga das Astúrias. Todos os anos, num sábado
        de agosto, milhares de atletas descem os <strong>20 km</strong> que
        separam Arriondas de Ribadesella, acompanhados por mais de
        <strong>200.000 espetadores</strong> nas margens do rio Sella.
      </p>

      <div class="dih__event">
        <div class="dih__event-col">
          <span class="dih__event-label">Edição 2026</span>
          <span class="dih__event-value">Sábado 8 de agosto</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Partida oficial</span>
          <span class="dih__event-value">11:30 · Arriondas</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Meta</span>
          <span class="dih__event-value">14:30–17:00 · Ribadesella</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== O QUE É + DADOS ============== -->
  <section class="dis">
    <div class="container container--xl">
      <header class="dis__header">
        <span class="dis__eyebrow">— O que é</span>
        <h2 class="dis__title">A festa das canoas <span class="serif-italic">mais antiga de Espanha</span></h2>
        <p class="dis__lead">
          Nascida em <strong>1930</strong> pela mão de Dionisio de la Huerta, a
          Descida Internacional do Sella é a <strong>competição de canoagem
          em águas calmas mais longeva</strong> da canoagem espanhola. Todos os
          anos atrai os melhores kayakistas e canoístas do mundo — de campeões
          olímpicos a atletas amadores — a par de uma multidão que transforma
          as margens num festival contínuo de 20 km.
        </p>
      </header>

      <div class="dis__grid">
        {datosClave.map((d, i) => (
          <div class="disData" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="disData__label">{d.label}</span>
            <span class="disData__value">
              {d.valueLines.map((line, idx) => (
                <>
                  {idx > 0 && <br/>}
                  {line}
                </>
              ))}
            </span>
            <span class="disData__sub">{d.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== DATAS 2026 ============== -->
  <section class="dif">
    <div class="container container--lg">
      <header class="dif__header">
        <span class="dif__eyebrow">— Datas 2026</span>
        <h2 class="dif__title">
          Quatro dias de festa.<br/>
          <span class="serif-italic">Um sábado inesquecível.</span>
        </h2>
        <p class="dif__lead">
          As atividades paralelas começam na quinta-feira anterior com a chegada
          das peñas a Arriondas e culminam no sábado com a
          <strong>partida oficial da competição às 11:30</strong>.
        </p>
      </header>

      <ol class="dif__timeline">
        {fechas2026.map((f, i) => (
          <li class:list={['difStep', f.highlight && 'difStep--top']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <div class="difStep__date">
              <span class="difStep__day">{f.day}</span>
              <span class="difStep__hour">{f.hour}</span>
            </div>
            <div class="difStep__bullet" aria-hidden="true"></div>
            <div class="difStep__body">
              <h3 class="difStep__title">{f.title}</h3>
              <p class="difStep__text">{f.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="dif__note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>A data oficial depende do calendário da Federação Espanhola de Canoagem. Confirmamos em cada janeiro a edição do ano em curso.</span>
      </p>
    </div>
  </section>

  <!-- ============== PERCURSO 20 KM ============== -->
  <section class="dir">
    <div class="container container--xl">
      <header class="dir__header">
        <span class="dir__eyebrow">— Percurso</span>
        <h2 class="dir__title">20 quilómetros entre <span class="serif-italic">Arriondas e Ribadesella</span></h2>
        <p class="dir__lead">
          O traçado da Descida Internacional do Sella reproduz o mesmo rio que
          percorre na sua <a href={homeUrl} class="dir__link">descida turística</a> —
          mas em versão competitiva e multitudinária.
        </p>
      </header>

      <ol class="dir__track">
        {recorrido.map((r, i) => (
          <li class:list={['dirPoint', r.us && 'dirPoint--us']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="dirPoint__km">{r.km}</span>
            <span class="dirPoint__dot" aria-hidden="true"></span>
            <div class="dirPoint__body">
              <span class="dirPoint__place">{r.place}</span>
              <span class="dirPoint__note">{r.note}</span>
              {r.us && <span class="dirPoint__tag">Nosso</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== COMO ASSISTIR ============== -->
  <section class="div">
    <div class="container container--xl">
      <header class="div__header">
        <span class="div__eyebrow">— Guia prático</span>
        <h2 class="div__title">Como assistir à Descida Internacional <span class="serif-italic">sem complicações</span></h2>
        <p class="div__lead">
          Os <strong>melhores pontos</strong> para ver a Descida Internacional
          do Sella são <strong>Arriondas</strong> (partida), o
          <strong>Puente de Llovio</strong> (últimos rápidos espetaculares) e a
          chegada em <strong>Ribadesella</strong>.
        </p>
      </header>

      <div class="div__grid">
        <article class="divCard" data-reveal data-reveal-delay="1">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>
            Estacionamento recomendado
          </h3>
          <ul class="divCard__list">
            <li><strong>Arriondas</strong> · estacionamentos disponibilizados pela câmara desde quinta-feira. Chegar antes das <strong>10:00 no sábado</strong>.</li>
            <li><strong>Toraño / Fríes</strong> · estacionamento mais tranquilo se não se importar de ver a parte intermédia. Boa opção para famílias com crianças.</li>
            <li><strong>Ribadesella</strong> · trânsito intenso desde as 11:00. Alternativa: estacionar em <strong>Llovio</strong> e subir a pé.</li>
          </ul>
        </article>

        <article class="divCard" data-reveal data-reveal-delay="2">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
            O que levar
          </h3>
          <ul class="divCard__list">
            <li><strong>Roupa confortável</strong> e <strong>protetor solar</strong> (muitas horas ao sol de agosto).</li>
            <li><strong>Água e picnic</strong> se não quiser fazer fila nos bares.</li>
            <li><strong>Câmara com bom zoom</strong> — o rio está a 10–20 m da margem em alguns troços.</li>
            <li>Prepare-se para <strong>calor</strong> e <strong>imensa gente</strong>. É um dos grandes eventos do verão asturiano.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== PALMARÉS ============== -->
  <section class="dip">
    <div class="container container--lg">
      <header class="dip__header">
        <span class="dip__eyebrow">— Palmarés recente</span>
