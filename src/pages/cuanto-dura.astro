---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const title = '¿Cuánto dura el descenso del Sella? Tiempos por tramo';
const description = 'Cuánto dura el descenso del Sella: 2-3 h la Mini (7 km) y 4-5 h el Completo (14,5 km). Factores, consejos y reserva sin pagar ahora — mascotas gratis.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/cuanto-dura/`;

// 5 factores que influyen en la duración
const factores = [
  { num: '01', title: 'El recorrido que elijas',   text: 'No tarda lo mismo la <strong>Mini Sella</strong> (7 km) que el <strong>Descenso Completo</strong> (14,5 km). Es la diferencia más importante en la duración total.' },
  { num: '02', title: 'Tu ritmo de remo',          text: 'Hay grupos que reman con continuidad y otros que bajan con mucha calma. <strong>Cuanto más pausado el ritmo, mayor la duración</strong>.' },
  { num: '03', title: 'Las paradas en el camino',  text: 'Muchas personas aprovechan para detenerse, bañarse, descansar o comer el picnic. Es una de las mejores partes — pero suma tiempo total.' },
  { num: '04', title: 'El caudal y el día',        text: 'El <strong>caudal del río</strong>, la corriente y la afluencia en temporada alta pueden hacer el descenso algo más rápido o algo más lento.' },
  { num: '05', title: 'Si vais con niños',         text: 'Con peques el <strong>ritmo es más tranquilo</strong> y las paradas son más frecuentes. El tiempo total es más flexible y se adapta a ellos.' },
];

// 6 consejos prácticos
const consejos = [
  { t: 'Reserva con antelación',        s: 'Especialmente en temporada alta. Elige el horario de salida que encaje con tu día. <strong>Sin pagar ahora</strong> — paga con tarjeta antes o al llegar.' },
  { t: 'Calcula con margen',            s: 'Suma al menos <strong>1 hora extra</strong> al tiempo del tramo: recepción, vestuarios, transfer de vuelta y paradas suman al total.' },
  { t: 'Horario abierto · 10:30–12:30',  s: 'Como tu reserva es <strong>Premium</strong>, el horario es abierto: llegáis a nuestras instalaciones <strong>cuando os venga bien entre las 10:30 y las 12:30</strong>, sin elegir hora concreta. La Confederación Hidrográfica marca que la permanencia en el río es <strong>hasta las 18:00 h</strong> · por eso cerramos llegadas a las 12:30 (margen seguro).' },
  { t: 'Con niños, más flexibilidad',   s: 'Los peques pueden querer parar más, y eso es parte del plan. Si vais con peques, <strong>plantead más margen</strong> y ritmo tranquilo.' },
  { t: 'Llevad agua y algo de picar',   s: 'El <strong>picnic asturiano</strong> va incluido en la reserva. Para paradas intermedias, algo extra siempre suma — sobre todo en verano.' },
  { t: 'Sin prisas',                    s: 'El descenso no es una competición. Disfrutarlo a vuestro ritmo — parando, bañándoos, observando — forma parte de su encanto.' },
];

// Dudas reales (acordeón)
const faqs = [
  { q: '¿Cuánto dura el descenso del Sella completo?',
    a: 'Normalmente entre <strong>4 y 5 horas</strong>, con un recorrido de <strong>14,5 km</strong> desde Arriondas hasta Fríes. El tiempo puede variar según las paradas que hagáis, el caudal del río y el ritmo del grupo. Si remáis sin prisa y paráis a bañaros o comer, se acerca a las 5 horas.' },
  { q: '¿Cuánto dura la Mini Sella?',
    a: 'La <strong>Mini Sella</strong> (Arriondas → Toraño, <strong>7 km</strong>) suele durar entre <strong>2 y 3 horas</strong>. Es la opción ideal si tenéis media jornada, vais con niños pequeños o queréis combinar el descenso con otros planes del día en Arriondas o Ribadesella.' },
  { q: '¿Cuánto se tarda con niños?',
    a: 'Con niños, lo habitual es que el <strong>ritmo sea más tranquilo y las paradas más frecuentes</strong>. Muchas familias eligen la Mini Sella (2-3 h) para que el peque disfrute sin cansarse. Si hacéis la Completa con niños, calcula más hacia 5 h que hacia 4. Puedes <a href="/con-ninos/">leer nuestra guía completa del descenso con niños</a>.' },
  { q: '¿Hay que hacerlo del tirón?',
    a: 'No. Una de las mejores cosas del descenso del Sella es que <strong>puedes parar cuando quieras</strong>: hay playas fluviales tranquilas a lo largo del río donde bañarse, descansar o comer el picnic. Marcáis vosotros el ritmo, no hay horarios en el agua.' },
  { q: '¿La duración cambia si llueve?',
    a: 'Con lluvia suave la actividad se hace igual y el tiempo apenas cambia. Si el <strong>caudal sube mucho</strong>, el descenso puede ser algo más rápido (más corriente); si es muy bajo, un poco más lento. Solo suspendemos por causas objetivas de seguridad (crecida fuerte o tormenta eléctrica), en cuyo caso ofrecemos <strong>cambio de fecha gratis o reembolso íntegro</strong>. Si pagas por adelantado y necesitas cancelar, puedes hacerlo <strong>hasta 24 h antes</strong> sin coste.' },
  { q: '¿Cuál es la duración media más habitual?',
    a: 'La referencia más común de <strong>cuánto se tarda en hacer el descenso del Sella</strong> está <strong>entre 3 y 5 horas</strong>. Hablando de recorrido completo, lo normal es moverse en torno a 4-4,5 h. En Mini Sella, en torno a 2,5 h. Son cifras orientativas — cada grupo va a su ritmo.' },
  { q: '¿Se puede elegir la distancia?',
    a: 'Sí. Tienes <strong>dos rutas</strong>: la <strong>Mini Sella</strong> (7 km, 2-3 h) y el <strong>Descenso Completo</strong> (14,5 km, 4-5 h). Además, si eliges la Completa y en el agua decides terminar antes, puedes hacerlo en <strong>Toraño</strong> (km 7) sin coste extra — solo avisa a nuestro equipo al llegar allí.' },
  { q: '¿El descenso del Sella dura todo el día?',
    a: 'No necesariamente. La <strong>Mini Sella</strong> se hace en media jornada y deja tarde libre. El <strong>Descenso Completo</strong> ocupa gran parte del día si incluyes paradas, picnic y transfer de vuelta. Suma al menos <strong>1 hora extra</strong> al tiempo del tramo para recepción, equipación y regreso — así calculas con realismo.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: '¿Cuánto dura el descenso del Sella? Tiempos por tramo',
      description: 'Guía completa sobre cuánto dura el descenso del Sella: Mini Sella (7 km, 2-3 h), Descenso Completo (14,5 km, 4-5 h), factores que influyen, recomendaciones y FAQ.',
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/sella-atardecer-lg.jpg`,
        width: 1920,
        height: 1280,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      about: 'Duración del descenso del Sella en canoa, tiempos por tramo',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',       item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Cuánto dura',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/cuanto-dura/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Foto full-bleed con Ken Burns + overlay editorial ============== -->
  <section class="cdh" aria-labelledby="cdh-title">

    <div class="cdh__photo" aria-hidden="true">
      <Picture src="cuanto-dura-hero" alt="" sizes="100vw" bare />
    </div>
    <div class="cdh__scrim" aria-hidden="true"></div>
    <div class="cdh__grain" aria-hidden="true"></div>

    <div class="cdh__inner">
      <nav class="cdh__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Cuánto dura</span>
      </nav>

      <span class="cdh__eyebrow">
        <span class="cdh__eyebrowDot" aria-hidden="true"></span>
        Duración del descenso
      </span>

      <h1 id="cdh-title" class="cdh__title">
        ¿Cuánto dura<br/>
        <span class="serif-italic">el Sella?</span>
      </h1>

      <p class="cdh__lead">
        Entre <strong>3 y 5 horas</strong>, según el recorrido que elijas. Aquí
        tienes la guía clara para calcular tu día con realismo.
      </p>

      <div class="cdh__ctas">
        <a href="/precios/" class="cdh__cta cdh__cta--primary">Ver precios</a>
        <a href="/reservar/" class="cdh__cta cdh__cta--link">
          Reservar ahora
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== TABS · Elige tu recorrido (Mini / Completo) ============== -->
  <section class="cdt" aria-labelledby="cdt-title">
    <div class="container container--xl">
      <header class="cdt__head" data-reveal>
        <div class="cdt__headL">
          <span class="cdt__kicker">— Recorridos disponibles</span>
          <h2 id="cdt-title" class="cdt__title">
            ¿Cuál te encaja?<br/>
            <span class="serif-italic">Elige tu recorrido.</span>
          </h2>
        </div>
        <div class="cdt__tabs" role="tablist" aria-label="Elegir entre Mini Sella o Descenso Completo">
          <button
            type="button"
            role="tab"
            id="cdt-tab-mini"
            aria-selected="true"
            aria-controls="cdt-panel-mini"
            class="cdt__tab is-active"
            data-tab="mini"
          >
            Mini Sella
            <span class="cdt__tabKm" aria-hidden="true">· 7 km</span>
          </button>
          <button
            type="button"
            role="tab"
            id="cdt-tab-comp"
            aria-selected="false"
            aria-controls="cdt-panel-comp"
            class="cdt__tab"
            data-tab="comp"
            tabindex="-1"
          >
            Descenso Completo
            <span class="cdt__tabKm" aria-hidden="true">· 14,5 km</span>
          </button>
        </div>
      </header>

      <div class="cdt__card" data-reveal data-reveal-delay="1">
        <!-- Panel MINI -->
        <div
          class="cdt__panel is-active"
          id="cdt-panel-mini"
          role="tabpanel"
          aria-labelledby="cdt-tab-mini"
          data-panel="mini"
        >
          <div class="cdt__content">
            <span class="cdt__eyebrow">Mini Sella</span>
            <h3 class="cdt__route">
              Arriondas
              <span class="cdt__arrow" aria-hidden="true">→</span>
              Toraño
            </h3>
            <div class="cdt__stats">
              <div class="cdt__stat">
                <strong>7<small>km</small></strong>
                <span>distancia</span>
              </div>
              <div class="cdt__stat">
                <strong>2 – 3<small>h</small></strong>
                <span>duración</span>
              </div>
              <div class="cdt__stat">
                <strong>Media<small>jornada</small></strong>
                <span>plan del día</span>
              </div>
            </div>
            <p class="cdt__desc">
              El <strong>tramo corto del descenso del Sella</strong>, ideal para familias con
              niños pequeños, primera vez en canoa o si queréis combinar el día con otros
              planes en Arriondas o Ribadesella. Sin dificultad técnica, con
              <strong>playas fluviales</strong> y merenderos para hacer parada y
              comer el picnic a vuestro ritmo.
            </p>
            <ul class="cdt__features">
              <li>Sin rápidos técnicos</li>
              <li>Playas fluviales</li>
              <li>Apta con niños 5+</li>
              <li>Perros gratis</li>
              <li>Picnic incluido</li>
              <li>Transfer y parking</li>
            </ul>
            <a href="/reservar/" class="cdt__cta">
              Reservar la Mini Sella
              <span class="cdt__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </div>
          <div class="cdt__photo">
            <Picture src="cuanto-dura-mini" alt="Familia bajando el Mini Sella · tramo Arriondas a Toraño" sizes="(min-width: 960px) 45vw, 100vw" bare />
            <div class="cdt__badges" aria-hidden="true">
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
                Familias
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c2-4 5-5 8-5s6 1 8 5"/></svg>
                Niños
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="1.5"/><circle cx="6" cy="7" r="1.5"/><circle cx="16" cy="7" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
                Mascotas
              </span>
            </div>
          </div>
        </div>

        <!-- Panel COMPLETO -->
        <div
          class="cdt__panel"
          id="cdt-panel-comp"
          role="tabpanel"
          aria-labelledby="cdt-tab-comp"
          data-panel="comp"
          hidden
        >
          <div class="cdt__content">
            <span class="cdt__eyebrow cdt__eyebrow--coral">Descenso Completo</span>
            <h3 class="cdt__route">
              Arriondas
              <span class="cdt__arrow" aria-hidden="true">→</span>
              Fríes
            </h3>
            <div class="cdt__stats">
              <div class="cdt__stat">
                <strong>14,5<small>km</small></strong>
                <span>distancia</span>
              </div>
              <div class="cdt__stat">
                <strong>4 – 5<small>h</small></strong>
                <span>duración</span>
              </div>
              <div class="cdt__stat">
                <strong>Día<small>entero</small></strong>
                <span>plan del día</span>
              </div>
            </div>
            <p class="cdt__desc">
              La <strong>ruta clásica del descenso del Sella en canoa</strong>. Más kilómetros, más paisaje abierto y una jornada completa al río con <strong>monitores titulados</strong> al inicio. Varias <strong>playas fluviales y merenderos</strong> a lo largo del recorrido para parar a bañarse, descansar y disfrutar del picnic asturiano sin prisa.
            </p>
            <ul class="cdt__features">
              <li>Experiencia clásica entera</li>
              <li>Paisaje abierto</li>
              <li>Playas y merenderos</li>
              <li>Perros gratis</li>
              <li>Picnic incluido</li>
              <li>Transfer y parking</li>
            </ul>
            <a href="/reservar/" class="cdt__cta">
              Reservar el Completo
              <span class="cdt__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </div>
          <div class="cdt__photo">
            <Picture src="cuanto-dura-completo" alt="Familia y adultos en el Descenso Completo del Sella · Arriondas a Fríes" sizes="(min-width: 960px) 45vw, 100vw" bare />
            <div class="cdt__badges" aria-hidden="true">
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/></svg>
                Paisaje
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12c2-4 4-4 6 0s4 4 6 0 4-4 6 0"/><path d="M3 18c2-4 4-4 6 0s4 4 6 0 4-4 6 0"/></svg>
                Río largo
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Día entero
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============== 5 FACTORES · qué influye en la duración ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Qué influye en el tiempo</span>
        <h2 class="cns__title">
          5 factores que cambian<br/>
          <span class="serif-italic">cuánto vas a tardar</span>
        </h2>
        <p class="cns__lead">
          El <strong>tiempo del descenso del Sella</strong> no es el mismo para todos. Estos son los
          factores que hacen que el mismo recorrido pueda durar 3 h o casi 5 h según el grupo
          y cómo queráis vivir la experiencia.
        </p>
      </header>

      <ol class="cns__grid">
        {factores.map((f, i) => (
          <li class="cns__item" data-reveal data-reveal-delay={i + 1}>
            <svg class="cns__trace" aria-hidden="true">
              <rect pathLength="100" />
            </svg>
            <span class="cns__num" aria-hidden="true">{f.num}</span>
            <h3 class="cns__itemTitle">{f.title}</h3>
            <p class="cns__itemText" set:html={f.text} />
          </li>
        ))}
      </ol>

    </div>
  </section>

  <!-- ============== CTA INTERMEDIO · Quote + hairlines + pill sage (D) ============== -->
  <section class="cdm">
    <div class="container container--md">
      <div class="cdm__wrap" data-reveal>
        <p class="cdm__quote">
          Trabajamos <em>sólo bajo reserva previa</em>. Sin prisas:
          <strong>paga con tarjeta al reservar, o el día que recojas tu canoa.</strong>
        </p>
        <div class="cdm__rule" aria-hidden="false">
          <span class="cdm__ruleLine" aria-hidden="true"></span>
          <a href="/reservar/" class="cdm__pill">
            <span class="cdm__pillDot" aria-hidden="true"></span>
            <span>Reservar mi plaza</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <span class="cdm__ruleLine" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== COMPARATIVA · Barras horizontales editorial ============== -->
  <section class="cdc">
    <div class="container container--xl">
      <header class="cdc__header" data-reveal>
        <span class="cdc__eyebrow">— Tiempo comparado</span>
        <h2 class="cdc__title">
          Visualiza la<br/>
          <span class="serif-italic">diferencia de tiempo.</span>
        </h2>
        <p class="cdc__lead">
          Mini Sella frente a Descenso Completo, <strong>lado a lado</strong>. Así ves de un vistazo
          qué recorrido encaja con las horas que tienes disponibles.
        </p>
      </header>

      <div class="cdc__bars" data-reveal>
        <div class="cdc__bar">
          <div class="cdc__barTop">
            <span class="cdc__barName">Mini Sella</span>
            <span class="cdc__barTime">2 – 3 h · 7 km · Arriondas → Toraño</span>
          </div>
          <div class="cdc__track">
            <div class="cdc__fill cdc__fill--mini">
              <span class="cdc__fillLabel">2 – 3 h</span>
            </div>
          </div>
        </div>
        <div class="cdc__bar">
          <div class="cdc__barTop">
            <span class="cdc__barName">Descenso Completo</span>
            <span class="cdc__barTime">4 – 5 h · 14,5 km · Arriondas → Fríes</span>
          </div>
          <div class="cdc__track">
            <div class="cdc__fill cdc__fill--comp">
              <span class="cdc__fillLabel">4 – 5 h</span>
            </div>
          </div>
        </div>
        <div class="cdc__axis" aria-hidden="true">
          <span>0h</span>
          <span>1h</span>
          <span>2h</span>
          <span>3h</span>
          <span>4h</span>
          <span>5h</span>
        </div>
      </div>

      <p class="cdc__foot" data-reveal data-reveal-delay="1">
        Incluye <strong>remar, paradas y picnic</strong>. Añade ~1 h extra para recepción, equipación y transfer de vuelta.
      </p>
    </div>
  </section>

  <!-- ============== QUÉ LLEVAR ============== -->
  <section class="cnq">
    <div class="container container--xl">
      <header class="cnq__header" data-reveal>
        <span class="cnq__eyebrow">— Calcular con realismo</span>
        <h2 class="cnq__title">
          Consejos para calcular<br/>
          <span class="serif-italic">mejor el tiempo</span>
        </h2>
        <p class="cnq__lead">
          Si estás organizando el día y quieres prever la duración con realismo,
          estos consejos te ayudan a que <strong>no se te queden cortas las horas</strong>.
        </p>
      </header>

      <ol class="cnqL" role="list">
        {consejos.map((c, i) => (
          <li class="cnqItem" data-reveal data-reveal-delay={(i % 2) + 1}>
            <span class="cnqItem__kicker">
              <span class="cnqItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="cnqItem__label">Consejo</span>
            </span>
            <h3 class="cnqItem__t">{c.t}</h3>
