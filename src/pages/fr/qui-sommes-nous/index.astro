---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Qui sommes-nous · Aventura en el Sella · plus de 25 ans à Arriondas';
const description = 'Une équipe de femmes et d\'hommes avec plus de 25 ans à organiser la descente du Sella depuis Arriondas. Nature, sport actif et accueil chaleureux. 4,5★ · 147 avis réels.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/qui-sommes-nous/`;
const dateModified = '2026-05-12';

// 4 compteurs · chiffres réels
const counters = [
  { num: '+25',  unit: 'ans',      label: 'À Arriondas' },
  { num: '4,5',  unit: '★',        label: 'Note moyenne' },
  { num: '+147', unit: 'avis',     label: 'Google + TripAdvisor' },
  { num: '300',  unit: 'places',   label: 'Parking privé · surveillé' },
];

// 4 principes · « Quatre choses qui ne changent pas »
const principios = [
  {
    n: '01',
    title: 'Tarif clair · sans surprises',
    text: 'Le tarif que tu vois en ligne est celui que tu paies. <strong>30 € enfants jusqu\'à 12 ans · 40 € adultes · animaux gratuits</strong>. Même prix Mini Sella ou Complet. Sans suppléments le week-end, sans cautions cachées.',
  },
  {
    n: '02',
    title: 'Tout inclus · sans extras',
    text: 'Canoë insubmersible, pagaie double, gilet homologué, bidon étanche, néoprène si la date l\'exige, mini-cours, pique-nique asturien, transfert, vestiaires avec douches, casiers à clé et assurances. <strong>Tout est dans le prix.</strong>',
  },
  {
    n: '03',
    title: 'Parking privé · 300 places',
    text: '<strong>Parking privé et surveillé</strong> dans nos installations d\'Arriondas — capacité pour <strong>300 voitures et camping-cars</strong>. Sans supplément, sans tickets, sans chercher de place en haute saison.',
  },
  {
    n: '04',
    title: 'Réservation flexible',
    text: 'Tu choisis ce qui te convient le mieux : <strong>paiement par carte à l\'avance</strong> ou <strong>paiement le jour même en récupérant le canoë</strong>. Si tu as payé d\'avance et dois annuler, il suffit de prévenir <strong>24 h à l\'avance</strong>.',
  },
];

// « Ce que nous faisons chaque jour » · 3 fonctions de l\'équipe
const funciones = [
  {
    title: 'Accueil au comptoir',
    text: 'Nous t\'accueillons, enregistrons ta réservation, te donnons les clés du casier et t\'expliquons la journée. <strong>En face à face</strong>, sans écrans tactiles ni longues files — parce que c\'est comme ça que nous aimons être reçues.',
  },
  {
    title: 'En direct sur la rivière',
    text: '<strong>Moniteurs diplômés</strong> qui donnent le mini-cours de pagaie avant le départ et surveillent la descente depuis des kayaks de sécurité. Ils connaissent chaque virage du Sella par cœur, après avoir descendu la rivière des centaines de fois chaque saison.',
  },
  {
    title: 'Entretien et logistique',
    text: 'Vérification quotidienne des canoës, pagaies et gilets. Pique-nique asturien frais chaque matin (empanada de bonite, bollín preñao et eau). Coordination du transfert à la fin du parcours. L\'invisible qui fait que la journée fonctionne.',
  },
];

// 4 info boxes · installations
const instalaciones = [
  {
    title: 'Adresse',
    text: 'Calle Juan Carlos I, 18 — Bajo II<br/><small>(accès par les installations d\'Aipol)</small><br/>33540 Arriondas · Asturias',
  },
  {
    title: 'Parking privé',
    text: '<strong>300 places</strong> · privé · surveillé<br/>Voitures + camping-cars<br/><small>Gratuit · inclus dans la réservation</small>',
  },
  {
    title: 'Vestiaires et douches',
    text: 'Vestiaires séparés avec <strong>douches chaudes</strong> et <strong>casiers à clé</strong> · changement confortable avant et après la descente',
  },
  {
    title: 'Comptoir et mini-cours',
    text: 'Réception · remise du matériel · <strong>mini-cours pratique</strong> de pagaie et sécurité avant le départ · moniteurs diplômés',
  },
];

// Témoignage mis en avant · avis réel
const testimonio = {
  text: 'Bon service, employés attentifs et très sympathiques. L\'expérience géniale, j\'ai adoré.',
  author: 'Anaïs Suárez Blanco',
  source: 'Google · octobre 2025',
};

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'AboutPage',
      '@id': `${canonicalUrl}#aboutpage`,
      url: canonicalUrl,
      name: 'Qui sommes-nous · Aventura en el Sella',
      description,
      inLanguage: 'fr-FR',
      dateModified,
      mainEntity: { '@id': `${baseUrl}/#business` },
    },
    {
      '@type': 'Organization',
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      logo: `${baseUrl}/images/logo/logo.svg`,
      image: `${baseUrl}/images/optimized/aventureros-montana-lg.jpg`,
      foundingLocation: 'Arriondas, Asturias, Espagne',
      slogan: 'Plus de 25 ans à organiser la descente du Sella en canoë',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 4.5,
        reviewCount: 147,
        bestRating: 5,
        worstRating: 1,
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',          item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Qui sommes-nous',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/fr/qui-sommes-nous/" translationKey="quienes_somos">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO ============== -->
  <section class="qsHero" aria-labelledby="qsHero-title">
    <div class="qsHero__inner">
      <nav class="qsHero__breadcrumb" aria-label="Fil d'Ariane">
        <a href={getLocalePath('home', lang)}>Accueil</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Qui sommes-nous</span>
      </nav>

      <span class="qsHero__eyebrow">— Plus de 25 ans à Arriondas</span>

      <h1 id="qsHero-title" class="qsHero__title">
        Une équipe, une rivière,<br/>
        <span class="serif-italic">des milliers de descentes.</span>
      </h1>

      <p class="qsHero__lead">
        Nous sommes un groupe de <strong>femmes et d'hommes</strong> d'âges, de compétences et de spécialités variés — réunis par la passion de la <strong>nature, du sport actif et de l'orient asturien</strong>. Depuis plus de 25 ans à Arriondas, nous voyons descendre le Sella : familles, couples, groupes d'amis, grands-parents avec petits-enfants et bandes qui reviennent chaque été.
      </p>

      <div class="qsHero__media" data-reveal data-reveal-type="slide-right">
        <Picture
          src="quienes-somos-hero"
          alt="Équipe d'Aventura en el Sella · groupe à Arriondas · 25 ans sur le Sella"
          sizes="(min-width: 960px) 1100px, 92vw"
          aspectRatio="16 / 9"
          priority="high"
        />
      </div>
    </div>
  </section>

  <!-- ============== 2 · VALEUR + 4 COMPTEURS ============== -->
  <section class="qsValue" aria-labelledby="qsValue-title">
    <div class="qsValue__inner">
      <div class="qsValue__copy">
        <span class="qsValue__eyebrow">— Ce que nous sommes</span>
        <h2 id="qsValue-title" class="qsValue__title">
          Même endroit,<br/>
          <span class="serif-italic">même façon de travailler.</span>
        </h2>
        <p class="qsValue__lead">
          Nous sommes au centre d'Arriondas, juste au départ de la descente du Sella. <strong>Mêmes personnes, même endroit, même façon de travailler</strong> depuis notre ouverture. Transparence sur les prix, équipe propre sur la rivière et tout le nécessaire pour la journée inclus dans le tarif — parce que c'est comme ça que nous aimons être traitées en voyage.
        </p>
      </div>

      <ul class="qsValue__counters" role="list">
        {counters.map(c => (
          <li class="qsValue__counter">
            <span class="qsValue__counterNum">{c.num}<span class="qsValue__counterUnit">{c.unit}</span></span>
            <span class="qsValue__counterLabel">{c.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 3 · COMMENT NOUS TRAVAILLONS · 4 PRINCIPES ============== -->
  <section class="qsPrin" aria-labelledby="qsPrin-title">
    <div class="qsPrin__inner">
      <header class="qsPrin__header">
        <span class="qsPrin__eyebrow">— Comment nous travaillons</span>
        <h2 id="qsPrin-title" class="qsPrin__title">
          Quatre choses<br/>
          <span class="serif-italic">qui ne changent pas.</span>
        </h2>
        <p class="qsPrin__lead">
          Cela fait plus de 25 ans que nous faisons la même chose parce que ça marche. <strong>Nous ne changeons pas les règles en haute saison</strong> et nous ne durcissons pas les conditions quand la demande monte — ça fait partie de l'accord dès le premier jour.
        </p>
      </header>

      <ul class="qsPrin__grid" role="list">
        {principios.map(p => (
          <li class="qsPrin__card">
            <span class="qsPrin__num">{p.n}</span>
            <h3 class="qsPrin__cardTitle">{p.title}</h3>
            <p class="qsPrin__cardText" set:html={p.text}></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 4 · L'ÉQUIPE ============== -->
  <section class="qsTeam" aria-labelledby="qsTeam-title">
    <div class="qsTeam__inner">
      <div class="qsTeam__intro">
        <span class="qsTeam__eyebrow">— Notre équipe</span>
        <h2 id="qsTeam-title" class="qsTeam__title">
          Femmes et hommes,<br/>
          <span class="serif-italic">des âges variés, une passion.</span>
        </h2>
        <p class="qsTeam__lead">
          Nous ne sommes pas une multinationale en uniforme. Nous sommes un <strong>petit groupe de personnes réelles</strong> — femmes et hommes d'âges, de spécialités et de façons de travailler variés, avec une chose en commun : nous aimons cette rivière et nous voulons que tu l'apprécies autant que nous.
        </p>
        <p class="qsTeam__text">
          Chaque jour quelqu'un accueille au comptoir, quelqu'un révise les canoës à l'atelier, des moniteurs diplômés donnent le cours explicatif avant le départ et surveillent la rivière depuis des kayaks de sécurité, et quelqu'un d'autre conduit le transfert retour. Si tu appelles et que c'est quelqu'un de différent qui décroche, c'est parce que <strong>nous tournons pour qu'il y ait toujours quelqu'un pour te répondre</strong> — pas parce que nous sommes un centre d'appels.
        </p>
      </div>

      <div class="qsTeam__media" data-reveal data-reveal-type="slide-right">
        <Picture
          src="quienes-somos-equipo"
          alt="Équipe d'Aventura en el Sella sur l'eau · moniteurs diplômés de la descente du Sella"
          sizes="(min-width: 900px) 50vw, 92vw"
          aspectRatio="4 / 5"
        />
      </div>
    </div>

    <div class="qsTeam__functions">
      <h3 class="qsTeam__functionsTitle">Ce que nous faisons chaque jour</h3>
      <ul class="qsTeam__functionsGrid" role="list">
        {funciones.map(f => (
          <li class="qsTeam__function">
            <h4 class="qsTeam__functionTitle">{f.title}</h4>
            <p class="qsTeam__functionText" set:html={f.text}></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 5 · INSTALLATIONS ============== -->
  <section class="qsInst" aria-labelledby="qsInst-title">
    <div class="qsInst__inner">
      <header class="qsInst__header">
        <span class="qsInst__eyebrow">— Nos installations</span>
        <h2 id="qsInst-title" class="qsInst__title">
          Au centre<br/>
          <span class="serif-italic">d'Arriondas.</span>
        </h2>
        <p class="qsInst__lead">
          Tout en un seul endroit : <strong>boutique, vestiaires, comptoir et parking privé</strong>. Tu arrives, tu te gares, tu t'enregistres, tu t'équipes et tu pars — sans déplacements entre les sites. L'accès se fait par les installations d'Aipol, en plein cœur d'Arriondas.
        </p>
      </header>

      <ul class="qsInst__grid" role="list">
        {instalaciones.map(i => (
          <li class="qsInst__card">
            <h3 class="qsInst__cardTitle">{i.title}</h3>
            <p class="qsInst__cardText" set:html={i.text}></p>
          </li>
        ))}
      </ul>

      <a href={getLocalePath('como_llegar', lang)} class="qsInst__cta">
        Comment venir
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- ============== 6 · CE QU'ILS DISENT · TÉMOIGNAGE ============== -->
  <section class="qsVoice" aria-labelledby="qsVoice-title">
    <div class="qsVoice__inner">
      <span class="qsVoice__eyebrow">— Ce qu'ils disent</span>
      <h2 id="qsVoice-title" class="qsVoice__title">
        +25 ans<br/>
        <span class="serif-italic">d'accueil qui marque.</span>
      </h2>

      <blockquote class="qsVoice__quote" cite="https://share.google/huLLaIz31FiYohuTV">
        <p>"{testimonio.text}"</p>
        <footer class="qsVoice__cite">
          <cite>— {testimonio.author}</cite>
          <span>{testimonio.source}</span>
        </footer>
      </blockquote>

      <ul class="qsVoice__metrics" role="list">
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">4,5<span class="qsVoice__metricUnit">★</span></span>
          <span class="qsVoice__metricLabel">Note moyenne</span>
        </li>
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">+147</span>
          <span class="qsVoice__metricLabel">Avis vérifiés</span>
        </li>
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">+25</span>
          <span class="qsVoice__metricLabel">Ans à Arriondas</span>
        </li>
      </ul>

      <a href={getLocalePath('opiniones', lang)} class="qsVoice__cta">
        Voir tous les avis
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- ============== 7 · FINAL CTA ============== -->
  <FinalCTA />
</BaseLayout>

<style>
  /* ====================== TOKENS LOCAUX ====================== */
  .qsHero, .qsValue, .qsPrin, .qsTeam, .qsInst, .qsVoice {
    --section-pad: clamp(4rem, 8vw, 7rem);
    --container-max: 1200px;
    --container-pad: clamp(1.25rem, 4vw, 2rem);
  }

  /* ====================== 1 · HERO ====================== */
  .qsHero {
    background: var(--color-bg-warm, #F6F1E3);
    padding-block: clamp(5rem, 9vw, 8rem) clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .qsHero::before {
    content: '';
    position: absolute;
    inset: auto -15% -40% auto;
    width: 60%;
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(233, 133, 111, 0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .qsHero__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    position: relative;
  }
  .qsHero__breadcrumb {
    display: flex; align-items: center; gap: var(--s-2);
    font-size: var(--fs-caption);
    color: var(--color-text-secondary);
    margin-bottom: var(--s-8);
  }
  .qsHero__breadcrumb a { color: var(--color-text-secondary); transition: color var(--duration-base) var(--ease-out); }
  .qsHero__breadcrumb a:hover { color: var(--color-primary); }
  .qsHero__breadcrumb span[aria-current] { color: var(--color-text-primary); font-weight: var(--fw-medium); }
  .qsHero__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-5);
  }
  .qsHero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-6);
    text-wrap: balance;
    max-width: 18ch;
  }
  .qsHero__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsHero__lead {
    font-size: clamp(1.075rem, 1.6vw, 1.3rem);
    line-height: var(--lh-body, 1.65);
    color: var(--color-text-secondary);
    max-width: 60ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .qsHero__lead strong { color: var(--color-text-primary); font-weight: var(--fw-semibold); }
  .qsHero__media {
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
    overflow: hidden;
    box-shadow: 0 24px 56px -32px rgba(26, 31, 46, 0.18);
  }

  /* ====================== 2 · VALEUR + COMPTEURS ====================== */
  .qsValue {
    background: var(--color-bg-base);
    padding-block: var(--section-pad);
  }
  .qsValue__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .qsValue__inner { grid-template-columns: 1.1fr 1fr; gap: clamp(3rem, 6vw, 5rem); }
  }
  .qsValue__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-4);
  }
  .qsValue__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-5);
    text-wrap: balance;
  }
  .qsValue__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsValue__lead {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: var(--lh-body, 1.65);
    color: var(--color-text-secondary);
  }
  .qsValue__lead strong { color: var(--color-text-primary); font-weight: var(--fw-semibold); }

  .qsValue__counters {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
    list-style: none;
    padding: 0; margin: 0;
  }
  .qsValue__counter {
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1rem, 2vw, 1.5rem);
    background: var(--color-bg-warm, #F6F1E3);
    border: 1px solid rgba(26, 31, 46, 0.06);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    display: flex; flex-direction: column; gap: var(--s-2);
    transition: transform 320ms var(--ease-out), border-color 320ms var(--ease-out);
  }
  .qsValue__counter:hover {
    transform: translateY(-3px);
    border-color: rgba(233, 133, 111, 0.3);
  }
  .qsValue__counterNum {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--fw-black);
    line-height: 1;
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    display: inline-flex; align-items: baseline; gap: 0.25rem;
  }
  .qsValue__counterUnit {
    font-size: 0.45em;
    font-weight: var(--fw-bold);
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsValue__counterLabel {
    font-size: var(--fs-caption);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  /* ====================== 3 · PRINCIPES ====================== */
  .qsPrin {
    background: var(--color-bg-warm, #F6F1E3);
    padding-block: var(--section-pad);
  }
  .qsPrin__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .qsPrin__header {
    max-width: 720px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .qsPrin__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-4);
  }
  .qsPrin__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-5);
    text-wrap: balance;
  }
  .qsPrin__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
