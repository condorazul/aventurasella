---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Descente du Sella avec chien · Aventure avec votre animal';
const description = 'Descente du Sella avec chien : animaux gratuits, gilet de sauvetage canin inclus (jusqu’à épuisement), moniteurs dog-friendly. Réservez sans payer maintenant.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/avec-chien/`;
const ogImage = '/images/optimized/con-perro-cta-lg.jpg';

const jornada = [
  { num: '01', title: 'Arrivée avec votre chien',  text: 'Nous vous accueillons à Arriondas. <strong>Parking privé gratuit</strong> pour éviter le stress à l’arrivée. Nous expliquons le plan et répondons aux doutes sur l’activité avec votre animal.' },
  { num: '02', title: 'Évaluation préalable',      text: 'Nous regardons comment est le chien — <strong>calme, nerveux, taille, confiance avec l’eau</strong> — et adaptons le canoë le plus approprié pour que la journée soit confortable pour vous deux.' },
  { num: '03', title: 'Briefing avec moniteur',    text: '<strong>Moniteurs expérimentés dog-friendly</strong> expliquent comment placer le chien dans le canoë, que faire s’il bouge et les consignes de base. <strong>Tout clair avant d’entrer dans l’eau</strong>.' },
  { num: '04', title: 'Embarquement tranquille',   text: 'Départ depuis notre rampe privée de 35 m à la rivière. Le chien descend <strong>libre dans le canoë</strong>, jamais attaché — c’est le plus sûr en cas de mouvement ou de chavirement.' },
  { num: '05', title: 'Pauses quand il faut',      text: 'Des plages fluviales tranquilles pour <strong>s’arrêter, boire de l’eau, étirer les pattes</strong> et laisser le chien respirer. Sans hâte, <strong>au rythme que demande votre animal</strong>.' },
  { num: '06', title: 'Retour et vestiaires',      text: '<strong>Notre transfert</strong> vous ramène. Vestiaires avec douches chaudes pour vous et zone extérieure avec eau pour sécher le chien. Journée bouclée.' },
];

const llevar = [
  { icon: 'leash',    t: 'Laisse + harnais',                  s: 'Obligatoire à terre (embarquement, accès, vestiaires). Harnais confortable mieux que collier' },
  { icon: 'bowl',     t: 'Eau et gamelle pliable',            s: 'Essentiel s’il fait chaud. Nous nous arrêtons autant de fois que nécessaire pour l’hydrater' },
  { icon: 'towel',    t: 'Serviette supplémentaire pour le chien', s: 'Mieux séparée de la vôtre · à la fin du parcours il sort trempé et vous serez content de ne pas partager' },
  { icon: 'bag',      t: 'Sacs hygiéniques',                  s: 'Respect de la rivière et de ses rives. Tout ce qui descend remonte avec nous' },
  { icon: 'human',    t: 'Votre équipement personnel',        s: 'Tenue confortable qui peut se mouiller, chaussures sûres, serviette et change. Comme toute descente' },
];

const beneficios = [
  { t: 'Animaux 100 % gratuits',           s: 'Votre chien ne paie pas. Il vient avec vous dans le canoë sans coût supplémentaire — sauf le samedi de la Descente Internationale.' },
  { t: 'Moniteurs dog-friendly',           s: 'Avec une réelle expérience à descendre le Sella avec des animaux. Dans le briefing préalable, ils vous apprennent quoi regarder avant d’entrer dans l’eau et comment agir si votre chien s’inquiète pendant la descente.' },
  { t: 'Plan tranquille et adaptable',     s: 'Le Sella touristique est une rivière calme — courant tranquille, pauses à la demande, sans white-water ni exigence sportive.' },
  { t: 'Consignes claires avant le départ', s: 'Briefing spécifique sur comment placer le chien, que faire s’il bouge et comment garder le canoë équilibré avec lui à bord.' },
  { t: 'Vestiaires + parking privé',       s: 'Douches chaudes pour vous + zone extérieure avec eau pour rincer le chien à la fin. Parking surveillé toute la journée.' },
  { t: 'Un chien par canoë',               s: 'Pour assurer espace, équilibre et confort. Si vous venez avec plus d’un, nous vous aidons à coordonner les embarcations.' },
  { t: 'Sans payer maintenant',            s: 'Réservez sans avancer d’argent. Payez par carte avant ou le jour même en récupérant le canoë — comme vous préférez.' },
  { t: 'Modifier ou annuler',              s: 'Modifications et annulations flexibles avant le jour. Si vous avez payé par carte, remboursement avec 24 h de préavis.' },
];

const faqs = [
  { q: 'Combien coûte la descente du Sella avec un chien ?',
    a: `Le chien <strong>ne paie pas</strong> — les animaux viennent gratuitement dans le canoë. Les personnes : <strong>40 € par adulte</strong> (à partir de 13 ans) et <strong>30 € par enfant</strong> (5-12 ans, <strong>âge minimum 5 ans révolus et 1,15 m de hauteur</strong>). La seule exception est le samedi de la <a href="${getLocalePath('descenso_internacional', 'fr')}">Descente Internationale du Sella</a>, qui pour le bruit de l’événement n’admet pas les animaux. Vous pouvez <a href="${getLocalePath('precios', 'fr')}">voir le détail complet des tarifs</a>.` },
  { q: 'Peut-on faire la descente du Sella avec un chien ?',
    a: 'Oui, c’est l’une des activités dog-friendly les plus populaires de la rivière. La seule chose que nous demandons, c’est <strong>du bon sens avec le chien</strong> : évaluer s’il tolère l’eau, s’il reste tranquille un moment et s’il obéit aux ordres de base. Si c’est un chien sociable et équilibré, l’expérience se passe en général très bien.' },
  { q: 'Mon chien peut-il monter dans le transfert retour ?',
    a: 'Oui, sans problème. <strong>Votre animal peut monter dans notre transfert retour</strong> à la fin du parcours choisi (Mini Sella ou Complète). Il monte avec vous dans le minibus avec le reste du groupe, comme le canoë — <strong>sans coût supplémentaire</strong>.' },
  { q: 'Mon chien doit-il porter un gilet de sauvetage ?',
    a: `Ce n’est pas obligatoire, mais <strong>c’est recommandé si votre chien ne nage pas bien ou s’il est de petite/moyenne taille</strong>. <strong>Le gilet de sauvetage canin, c’est nous qui le fournissons</strong> sans coût supplémentaire · nous avons plusieurs tailles dans la boutique <em>jusqu’à épuisement des stocks</em>. C’est pourquoi <a href="${getLocalePath('reservar', 'fr')}">réserver à l’avance est clé</a> · ils s’envolent en été. Si vous venez avec un chien et voulez vous assurer, prévenez-nous à la réservation et nous gardons le gilet à votre nom.` },
  { q: 'Peut-il être attaché au canoë ?',
    a: '<strong>Non, jamais.</strong> En cas de chavirement, une laisse attachée est un risque sérieux pour le chien et les personnes. Dans le canoë <strong>il va libre</strong>. Hors de l’eau (embarquement, accès, vestiaires) il doit être en laisse.' },
  { q: 'Combien de chiens peuvent aller par canoë ?',
    a: 'Pour la sécurité et l’équilibre, <strong>l’habituel est un chien par canoë</strong>. Si vous venez avec plus d’un, nous les répartissons entre les canoës du groupe. Pour des cas spéciaux (petit chien + petit chien tranquilles), nous pouvons l’évaluer à l’arrivée.' },
  { q: 'Les grands chiens peuvent-ils venir ?',
    a: 'Oui, à condition que ce soit un chien <strong>tranquille, habitué à sortir et qui tolère l’eau</strong>. Les grands chiens occupent plus d’espace et affectent davantage l’équilibre, c’est pourquoi nous l’évaluons avant l’embarquement. Un grand chien tranquille va en général bien mieux qu’un petit chien très nerveux.' },
  { q: 'Faut-il que mon chien sache nager ?',
    a: 'Ce n’est pas indispensable, mais il est utile de le savoir à l’avance. Si votre chien n’a <strong>pas d’expérience dans l’eau</strong> ou ne transmet pas de sécurité en nageant, <strong>il vaut mieux porter un gilet canin</strong> · nous vous le fournissons jusqu’à épuisement des stocks. Le Sella touristique a un courant tranquille, mais le gilet apporte un vrai plus.' },
  { q: 'Que faire si mon chien stresse ou ne veut pas continuer ?',
    a: 'On s’arrête. Il y a <strong>des plages fluviales tranquilles</strong> où le chien peut descendre, étirer les pattes, boire de l’eau et respirer. S’il stresse beaucoup, nous pouvons trouver une sortie anticipée depuis la rive et coordonner le retour. <strong>Personne ne descend contre la volonté de son chien</strong>.' },
  { q: 'Vaut-il mieux la Mini ou la Complète avec un chien ?',
    a: 'Pour des chiens peu habitués ou âgés, nous recommandons la <strong>Mini Sella</strong> (Arriondas → Toraño, 7 km, 2-3 h) — rythme tranquille et moins de temps dans l’eau. Pour des chiens actifs et en forme, la <strong>Complète</strong> (Arriondas → Fríes, 14,5 km, 4-5 h) est parfaitement viable avec des pauses.' },
  { q: 'Faut-il réserver à l’avance ?',
    a: 'Oui, <strong>surtout en haute saison</strong>. Réservez sans payer maintenant : confirmez votre place, payez par carte avant ou le jour même en récupérant le canoë. Si vous annulez avant le jour, sans coût ; si vous avez payé par carte, remboursement avec 24 h de préavis.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descente du Sella avec chien : guide complet pour profiter avec votre animal',
      description: 'Guide pour la descente du Sella avec chien : règles, gilet de sauvetage canin inclus (jusqu’à épuisement), comment placer le chien dans le canoë, que prendre et pourquoi c’est le plan dog-friendly phare des Asturies.',
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/con-perro-cta-lg.jpg`,
        width: 1920,
        height: 1080,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-19',
      dateModified:  '2026-05-12',
      articleSection: 'Animaux',
      keywords: ['descente du sella avec chien', 'descente du sella animaux gratuits', 'canoë avec chien sella', 'gilet canin sella', 'dog-friendly arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Descente du Sella avec chien · activité dog-friendly aux Asturies' },
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Descente du Sella avec chien',
      description: 'Activité de descente du Sella en canoë dog-friendly. Animaux gratuits. Gilet de sauvetage canin inclus sans coût supplémentaire (jusqu’à épuisement). Moniteurs avec expérience canine, briefing spécifique, consignes claires. Tout inclus : canoë, gilet humain homologué, gilet canin, transfert, parking et vestiaires avec zone extérieure pour sécher le chien.',
      serviceType: 'Descente du Sella dog-friendly',
      category: 'Tourisme actif · Animaux',
      url: canonicalUrl,
      provider: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturies' },
      audience: { '@type': 'Audience', audienceType: 'Familles et propriétaires d’animaux' },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'EUR',
        lowPrice: '0.00',
        highPrice: '40.00',
        offerCount: 3,
        availability: 'https://schema.org/InStock',
        url: `${baseUrl}/fr/reserver/`,
        offers: [
          { '@type': 'Offer', name: 'Animal',             price: '0.00',  priceCurrency: 'EUR', url: `${baseUrl}/fr/reserver/`, description: 'Gratuit · tous les animaux voyagent sans coût' },
          { '@type': 'Offer', name: 'Enfant (5-12 ans)',  price: '30.00', priceCurrency: 'EUR', url: `${baseUrl}/fr/reserver/` },
          { '@type': 'Offer', name: 'Adulte (13+ ans)',   price: '40.00', priceCurrency: 'EUR', url: `${baseUrl}/fr/reserver/` },
        ],
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',     item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Avec chien',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/fr/avec-chien/" translationKey="con_perro">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Crème lumineux ============== -->
  <section class="cnh cnh--cream" aria-labelledby="cnh-title">

    <div class="cnh__inner">
      <nav class="cnh__breadcrumb" aria-label="Breadcrumb">
        <a href="/fr/">Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Avec chien</span>
      </nav>

      <span class="cnh__eyebrow">
        <span class="cnh__eyebrow-dot" aria-hidden="true"></span>
        Dog-friendly · Saison 2026
      </span>

      <h1 id="cnh-title" class="cnh__title">
        Descente du Sella<br/>
        <span class="serif-italic">avec <span class="cnh__underlined">chien<svg class="cnh__swoosh" width="200" height="18" viewBox="0 0 200 18" fill="none" aria-hidden="true"><path d="M3 14C30 6 74 4 118 8c27 2.5 54 6 78 4" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/></svg></span></span>
      </h1>

      <p class="cnh__lead">
        <strong>Aventure avec votre animal aux Asturies</strong>. Une journée dog-friendly pensée
        en détail — avec consignes claires avant le départ, moniteurs ayant de l’expérience canine
        et une rivière calme pour profiter ensemble. <strong>Le chien vient gratuitement</strong>.
      </p>

      <div class="cnh__stats">
        <div class="cnh__stat">
          <span class="cnh__stat-value">Gratuit</span>
          <span class="cnh__stat-label">Votre chien ne paie pas</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">40 €</span>
          <span class="cnh__stat-label">Par personne · tout inclus</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">4.5 ⭐</span>
          <span class="cnh__stat-label">147 avis</span>
        </div>
      </div>

      <div class="cnh__ctas">
        <a href={getLocalePath('reservar', 'fr')} class="cnh__cta cnh__cta--primary">
          Réserver avec mon chien
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+34681093673" class="cnh__cta cnh__cta--phone" aria-label="Appeler le 681 093 673">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Appeler</span>
        </a>
        <a href={getLocalePath('precios', 'fr')} class="cnh__cta cnh__cta--ghost">
          Voir tarifs et formules
        </a>
      </div>
    </div>
  </section>

  <!-- ============== INTRO ============== -->
  <section class="cni">
    <div class="container container--xl">
      <div class="cni__grid">
        <div class="cni__media" data-reveal>
          <div class="cni__mediaMain">
            <Picture src="con-perro-intro-1" alt="Chien à bord d’un canoë sur la descente du Sella" sizes="(min-width: 960px) 44vw, 90vw" aspectRatio="1 / 1" bare />
          </div>
          <div class="cni__mediaSmall" aria-hidden="true">
            <Picture src="con-perro-intro-2" alt="Chien profitant du Sella avec sa famille" sizes="220px" aspectRatio="1 / 1" bare />
          </div>
          <a class="cni__contact" href="https://wa.me/34681093673?text=Bonjour,%20j%27ai%20une%20question%20sur%20la%20descente%20du%20Sella%20avec%20mon%20chien" target="_blank" rel="noopener noreferrer">
            <span class="cni__contactIcon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-1-.5-2-.8-2.9-1.9-.7-.6-1.2-1.4-1.6-2.1-.2-.3 0-.5.1-.7.1-.2.3-.4.5-.6.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5-.2 0-.4 0-.6 0-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6 0 1.6 1.1 3.1 1.3 3.3.2.2 2.3 3.6 5.7 5 3.4 1.4 3.4.9 4 .9.6-.1 1.8-.8 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3z"/></svg>
            </span>
            <div class="cni__contactBody">
              <strong>Doutes avec votre chien ?</strong>
              <span>WhatsApp · réponse rapide</span>
            </div>
          </a>
        </div>

        <div class="cni__content" data-reveal data-reveal-delay="2">
          <span class="cni__eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            La question habituelle
          </span>
          <h2 class="cni__title">
            Peut-on descendre<br/>
            le Sella <span class="serif-italic">avec un chien ?</span>
          </h2>
          <p class="cni__lead">
            <strong>Oui, et les animaux viennent totalement gratuits.</strong> Le Sella est l’un des
            plans dog-friendly phares des Asturies — rivière calme, pauses quand le
            chien le demande, et une équipe qui sait quoi regarder avant d’entrer dans l’eau.
          </p>

          <ul class="cni__features">
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Animaux 100 % gratuits</h3>
                <p class="cni__featureText">Votre chien ne paie pas. Il vient avec vous dans le canoë <strong>sans coût supplémentaire</strong>. La seule exception est le samedi de la Descente Internationale.</p>
              </div>
            </li>
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Moniteurs dog-friendly</h3>
                <p class="cni__featureText">Avec une réelle expérience à descendre le Sella avec des animaux. <strong>Ils savent quoi regarder avant d’entrer dans l’eau</strong> et comment préparer la journée pour vous deux.</p>
              </div>
            </li>
          </ul>

          <a href={getLocalePath('reservar', 'fr')} class="cni__cta">
            Réserver avec mon chien
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== JOURNÉE · 6 étapes ============== -->
  <section class="cnj">
    <div class="container container--xl">
      <header class="cnj__header" data-reveal>
        <span class="cnj__eyebrow">— Comment se passe la journée avec votre chien</span>
        <h2 class="cnj__title">
          Une journée sur le Sella,<br/>
          <span class="serif-italic">étape par étape</span>
        </h2>
        <p class="cnj__lead">
          Savoir comment se déroule la journée aide à décider. Voici comment nous préparons
          l’expérience pour que <strong>vous et votre chien soyez confortables et en sécurité</strong> du début à la fin — sans hâte, sans surprises.
        </p>
      </header>

      <ol class="cnjT">
        {jornada.map((j, i) => (
          <li class={`cnjT__step ${i % 2 === 0 ? 'cnjT__step--left' : 'cnjT__step--right'}`} data-reveal>
            <span class="cnjT__node" aria-hidden="true">{j.num}</span>
            <div class="cnjT__body">
              <h3 class="cnjT__title">{j.title}</h3>
              <p class="cnjT__text" set:html={j.text} />
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- ============== SÉCURITÉ ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Sécurité et confiance</span>
        <h2 class="cns__title">
          Quoi surveiller avec votre chien,<br/>
          <span class="serif-italic">et comment nous le résolvons</span>
        </h2>
        <p class="cns__lead">
          La première question est toujours <strong>« est-ce sûr pour mon chien ? »</strong> — et elle est
