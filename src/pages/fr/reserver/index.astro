---
/**
 * /fr/reserver/ · Page officielle de réservation · Français (tu)
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const title = 'Réserver la descente du Sella · Dès 30 € · Sans payer maintenant';
const description = 'Réserve en ligne ta descente du Sella en canoë depuis Arriondas. Sans payer maintenant, changement ou annulation flexible avant le jour, confirmation immédiate par WhatsApp et email. 4,5★ · 147 avis réels.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/reserver/`;

const tarifas = [
  {
    img: 'reservar-tarifa-adultos',
    imgAlt: 'Groupe d\'adultes descendant le Sella en canoë depuis Arriondas · tarif adulte de la descente',
    badge: 'Le plus réservé',
    title: 'Adultes',
    age: 'Dès 13 ans',
    price: '40',
    note: 'Canoë, pagaie, gilet, pique-nique asturien et transfert · tout inclus',
  },
  {
    img: 'precios-ninos',
    imgAlt: 'Enfants pagayant sur le Sella · tarif enfant de la descente',
    badge: 'Enfants',
    title: 'Enfants',
    age: 'Jusqu\'à 12 ans',
    price: '30',
    note: 'Âge minimum 5 ans · 1,15 m de taille',
  },
  {
    img: 'con-perro-cta',
    imgAlt: 'Chien avec gilet de sauvetage en canoë · descente du Sella avec animaux gratuits',
    badge: 'Animaux · gratuits',
    title: 'Avec chien',
    age: 'Jusqu\'à 25 kg',
    price: '0',
    note: 'Gilet canin inclus jusqu\'à épuisement des stocks',
  },
];

const pasos = [
  { num: '01', title: 'Réserve ton jour',           text: 'Choisis la date, l\'itinéraire et le nombre de personnes dans le calendrier. <strong>Sans rien payer maintenant</strong> : nous bloquons ta place à l\'instant.' },
  { num: '02', title: 'Viens à Arriondas',          text: 'On t\'attend au C/ Juan Carlos I, 18. Parking privé surveillé, vestiaires, douches chaudes et casiers avec clé.' },
  { num: '03', title: 'Tu pars en canoë',           text: 'Mini-cours avec moniteur diplômé, pagaie, gilet, bidon étanche et pique-nique asturien. Créneau Premium ouvert 10 h 30 – 12 h 30.' },
  { num: '04', title: 'Nous te récupérons',          text: 'Transfert retour depuis Toraño (itinéraire mini) ou Fríes (itinéraire complet). Retour confortable · sans voiture supplémentaire, sans attente.' },
];

const faqs = [
  {
    q: 'Dois-je payer maintenant pour réserver ?',
    a: 'Non. Tu peux <strong>réserver sans rien payer maintenant</strong>. Nous bloquons ta place et tu choisis entre payer en ligne à l\'avance (carte ou virement) ou le jour même au retrait du canoë (carte, Bizum, espèces ou virement instantané).',
  },
  {
    q: 'Quelle est la politique d\'annulation ?',
    a: 'Tu peux <strong>changer ou annuler ta réservation à tout moment avant le jour de l\'activité</strong>, sans frais. Si tu as payé par <strong>carte à l\'avance</strong>, pour traiter le remboursement nous avons besoin que tu nous préviennes au moins <strong>24 h avant</strong>. Contacte-nous par WhatsApp ou email et nous t\'aidons à changer la date ou rembourser. Si nous reportons à cause du temps ou des conditions du fleuve, changement sans frais ou remboursement intégral.',
  },
  {
    q: 'Quand est-ce que je reçois la confirmation ?',
    a: 'Au moment même, automatiquement par email. Tu recevras : date confirmée, itinéraire choisi, créneau Premium ouvert (arrivée flexible 10 h 30 – 12 h 30), instructions d\'arrivée et un WhatsApp direct au cas où.',
  },
  {
    q: 'Combien de temps à l\'avance dois-je réserver ?',
    a: 'En basse saison, la veille suffit en général. En <strong>juillet-août, week-ends et jours fériés</strong> nous recommandons 3-7 jours à l\'avance. Le calendrier affiche en temps réel les jours avec des places disponibles.',
  },
  {
    q: 'Que se passe-t-il s\'il pleut le jour de ma réservation ?',
    a: 'Sur le Sella, beaucoup de journées se pagaient sous un ciel couvert sans problème · cela fait partie du charme vert des Asturies. S\'il y a une <strong>alerte météo ou si le fleuve est en crue</strong>, nous reprogrammons sans frais ou remboursons intégralement. Nous décidons toujours du côté de la sécurité.',
  },
  {
    q: 'Y a-t-il une réduction pour les groupes ?',
    a: 'À partir de <strong>15 personnes</strong> nous étudions des conditions spéciales (créneau dédié, pique-nique asturien, facture entreprise). Écris-nous à <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a> avec la date, le nombre de personnes et les âges · nous t\'envoyons un devis fermé.',
  },
];

const resources = [
  { img: 'reservar-resource-precios',   imgAlt: 'Canoë orange sur la rive du Sella · tarifs détaillés de la descente', title: 'Tarifs détaillés', text: 'Prix par âge, ce qu\'ils incluent et comparatif par itinéraire.', href: getLocalePath('precios', 'fr'),        cta: 'Voir les tarifs' },
  { img: 'reservar-resource-recorrido', imgAlt: 'Vue du fleuve Sella aux Asturies · parcours et carte de la descente', title: 'Parcours et carte', text: 'Itinéraire mini (7 km · 2-3 h) ou complet (14,5 km · 4-5 h).',       href: getLocalePath('recorrido_mapa', 'fr'), cta: 'Voir le parcours' },
  { img: 'reservar-resource-premium',   imgAlt: 'Familles et adultes pagayant sur le Sella · Réservation Premium tout inclus', title: 'Réservation Premium', text: 'Casiers, pique-nique asturien et créneau ouvert 10 h 30 – 12 h 30.', href: getLocalePath('reserva_premium', 'fr'), cta: 'Voir Premium' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, 'fr'),
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'fr-FR',
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#business` },
      mainEntityOfPage: canonicalUrl,
      datePublished: '2026-05-14',
      dateModified: '2026-05-14',
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Réservation en ligne de la descente du Sella en canoë',
      description: 'Service de réservation en ligne pour la descente touristique du Sella depuis Arriondas (Asturies). Changement ou annulation flexible avant le jour (24 h si paiement par carte). Sans payer maintenant.',
      provider: { '@id': `${baseUrl}/#business` },
      serviceType: 'Canoe rental and guided river descent',
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturies, Espagne' },
      offers: [
        { '@type': 'Offer', name: 'Enfants jusqu\'à 12 ans', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
        { '@type': 'Offer', name: 'Adultes',                  price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',  item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Réserver', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/fr/reserver/" translationKey="reservar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preload" as="image" href="/images/optimized/hero-canoa-lago-lg.avif" type="image/avif" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>

  <section class="rsvH" aria-labelledby="rsvH-title">
    <div class="rsvH__media" aria-hidden="true">
      <Picture src="hero-canoa-lago" alt="Canoë sur le fleuve Sella au coucher du soleil · descente du Sella depuis Arriondas" priority="high" sizes="100vw" aspectRatio="16 / 10" />
      <div class="rsvH__overlay"></div>
    </div>

    <div class="rsvH__inner">
      <nav class="rsvH__breadcrumb" aria-label="Fil d'Ariane">
        <a href="/fr/">Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Réserver</span>
      </nav>

      <span class="rsvH__eyebrow">
        <span class="rsvH__eyebrow-dot" aria-hidden="true"></span>
        Réservation en 2 minutes · sans payer maintenant
      </span>

      <h1 id="rsvH-title" class="rsvH__title">
        Réserve ta<br/>
        <span class="serif-italic">descente du Sella</span>
      </h1>

      <p class="rsvH__lead">
        Choisis la date, l'itinéraire et le nombre de personnes. Le canoë, l'équipement, le pique-nique, le transfert et tout le reste · déjà inclus. <strong>Sans rien payer maintenant</strong> · tu paies en ligne ou le jour où tu récupères le canoë à Arriondas.
      </p>

      <div class="rsvH__ctas">
        <a class="rsvH__cta rsvH__cta--primary" href="#booking-widget">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Aller au calendrier</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="https://wa.me/34681093673?text=Bonjour%2C%20je%20voudrais%20r%C3%A9server%20la%20descente%20du%20Sella" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.87 11.87 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.56 4.18 1.62 6L0 24l6.18-1.6A11.9 11.9 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="tel:+34681093673" aria-label="Appeler le +34 681 09 36 73">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          <span>+34 681 09 36 73</span>
        </a>
      </div>

      <ul class="rsvH__trust" role="list">
        <li><span class="rsvH__trustNum">4,5★</span><span class="rsvH__trustLabel">147 avis réels</span></li>
        <li><span class="rsvH__trustNum">Flexible</span><span class="rsvH__trustLabel">changement avant le jour</span></li>
        <li><span class="rsvH__trustNum">25 ans</span><span class="rsvH__trustLabel">à Arriondas</span></li>
        <li><span class="rsvH__trustNum">0 €</span><span class="rsvH__trustLabel">pour réserver</span></li>
      </ul>
    </div>
  </section>

  <section class="rsvB" aria-labelledby="rsvB-title">
    <div class="rsvB__inner">
      <header class="rsvB__header">
        <span class="rsvB__eyebrow">— Calendrier en direct</span>
        <h2 id="rsvB-title" class="rsvB__title">
          Choisis ton jour<br/>
          <span class="serif-italic">en moins de 2 minutes</span>
        </h2>
        <p class="rsvB__lead">
          Disponibilité en temps réel · jours avec places en vert · sans surprises. <strong>Confirmation immédiate par WhatsApp et email</strong> · rapide, facile, sans formulaires interminables.
        </p>
      </header>

      <div id="booking-widget" class="rsvB__slot" aria-live="polite">
        <div class="rsvB__placeholder">
          <span class="rsvB__placeholderIcon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <p class="rsvB__placeholderTitle">Calendrier de réservation</p>
          <p class="rsvB__placeholderText">
            Nous chargeons le calendrier en temps réel. S'il n'apparaît pas en quelques secondes, écris-nous sur <a href="https://wa.me/34681093673" target="_blank" rel="noopener noreferrer">WhatsApp</a> ou appelle le <a href="tel:+34681093673">+34 681 09 36 73</a> · nous te réservons immédiatement.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rsvT" aria-labelledby="rsvT-title">
    <div class="rsvT__inner">
      <header class="rsvT__header">
        <span class="rsvT__eyebrow">— Réserver en toute tranquillité</span>
        <h2 id="rsvT-title" class="rsvT__title">
          Sans payer maintenant,<br/>
          <span class="serif-italic">sans petits caractères.</span>
        </h2>
      </header>

      <div class="rsvT__grid">
        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-pago" alt="Rive du fleuve Sella à Arriondas · paiement flexible pour réserver la descente" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag">Paiement flexible</span>
            <h3 class="rsvT__cardTitle">Paie en ligne ou à l'arrivée</h3>
            <ul class="rsvT__cardList">
              <li>Carte en ligne à la réservation</li>
              <li>Ou le jour même : carte, Bizum, espèces ou virement</li>
              <li>Sans acompte · sans extras cachés</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-cambios" alt="Groupe de filles pagayant ensemble sur la descente du Sella · changement ou annulation flexible" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--sage">Changements et annulations flexibles</span>
            <h3 class="rsvT__cardTitle">Change ou annule avant le jour · sans frais</h3>
            <ul class="rsvT__cardList">
              <li>Change ou annule à tout moment avant le jour de l'activité</li>
              <li>Si tu as payé par carte, le remboursement requiert 24 h de préavis</li>
              <li>S'il pleut fort ou si le fleuve monte, nous reprogrammons ou remboursons</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-equipo" alt="Équipe d'Aventura en el Sella à Arriondas · de vraies personnes qui te répondent" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--coral">Confirmation humaine</span>
            <h3 class="rsvT__cardTitle">De vraies personnes, pas de bots</h3>
            <ul class="rsvT__cardList">
              <li>Nous te confirmons par email + WhatsApp</li>
              <li>Nous répondons de 9 h 30 à 19 h tous les jours en saison</li>
              <li>25 ans à accueillir des aventuriers à Arriondas</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="rsvP" aria-labelledby="rsvP-title">
    <div class="rsvP__inner">
      <header class="rsvP__header">
        <span class="rsvP__eyebrow">— Tarifs habituels</span>
        <h2 id="rsvP-title" class="rsvP__title">
          Prix par personne et par jour,<br/>
          <span class="serif-italic">tout inclus.</span>
        </h2>
        <p class="rsvP__lead">
          Même prix pour l'itinéraire mini (7 km · 2-3 h) et l'itinéraire complet (14,5 km · 4-5 h). <strong>Réservation Premium incluse sans frais supplémentaires</strong> · animaux toujours gratuits.
        </p>
      </header>

      <p class="rsvP__premiumBadge">
        <span class="rsvP__premiumStar" aria-hidden="true">✦</span>
        <span><strong>Réservation Premium · Tout inclus</strong> sur n'importe quel tarif · casiers, vestiaires, douches chaudes, pique-nique asturien, transfert et parking privé surveillé</span>
      </p>

      <div class="rsvP__grid">
        {tarifas.map(t => (
          <article class="rsvP__card">
            <div class="rsvP__cardMedia">
              <Picture src={t.img} alt={t.imgAlt} sizes="(min-width: 960px) 25vw, 50vw" aspectRatio="4 / 5" />
              <span class="rsvP__cardBadge">{t.badge}</span>
            </div>
            <div class="rsvP__cardBody">
              <h3 class="rsvP__cardTitle">{t.title}</h3>
              <p class="rsvP__cardAge">{t.age}</p>
              <p class="rsvP__cardPrice">
                {t.price === '0' ? (
                  <span class="rsvP__cardFree">Gratuit</span>
                ) : (
                  <>
                    <span class="rsvP__cardCurrency">€</span>
                    <span class="rsvP__cardAmount">{t.price}</span>
                    <span class="rsvP__cardUnit">/jour</span>
                  </>
                )}
              </p>
              <p class="rsvP__cardNote">{t.note}</p>
              <a class="rsvP__cardLink" href="#booking-widget">
                Réserver
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="rsvP__foot">
        Tu cherches un tarif famille, groupe scolaire ou enterrement de vie de jeune fille/garçon ? <a href={getLocalePath('precios', 'fr')}>Voir tous les tarifs en détail</a>.
      </p>
    </div>
  </section>

  <section class="rsvS" aria-labelledby="rsvS-title">
    <div class="rsvS__inner">
      <header class="rsvS__header">
        <span class="rsvS__eyebrow">— Comment ça marche</span>
        <h2 id="rsvS-title" class="rsvS__title">
          Réserver ta descente<br/>
          <span class="serif-italic">en 4 étapes.</span>
        </h2>
        <div class="rsvS__times">
          <div><strong>Créneau ouvert</strong><span>Arrivée flexible 10 h 30 – 12 h 30</span></div>
          <div><strong>Récupérations</strong><span>De 13 h à 18 h depuis Toraño / Fríes</span></div>
        </div>
      </header>

      <ol class="rsvS__list" role="list">
        {pasos.map(p => (
          <li class="rsvS__step">
            <span class="rsvS__stepNum">{p.num}</span>
            <h3 class="rsvS__stepTitle">{p.title}</h3>
            <p class="rsvS__stepText" set:html={p.text}></p>
          </li>
        ))}
      </ol>

      <p class="rsvS__foot">
        <a href={getLocalePath('cuanto_dura', 'fr')}>Voir comment fonctionne la descente en détail</a> · temps réels par itinéraire et créneau.
      </p>
    </div>
  </section>

  <section class="rsvO" aria-labelledby="rsvO-title">
    <div class="rsvO__inner">
      <header class="rsvO__header">
        <span class="rsvO__eyebrow">— Tu préfères parler à quelqu'un ?</span>
        <h2 id="rsvO-title" class="rsvO__title">
          Autres façons<br/>
          <span class="serif-italic">de réserver.</span>
        </h2>
        <p class="rsvO__lead">
          Réserve toujours à l'avance · nous te confirmons immédiatement en heures d'ouverture. Personne réelle de l'équipe, jamais un bot.
        </p>
      </header>

      <div class="rsvO__row" role="list">
        <a class="rsvO__item" href="https://wa.me/34681093673?text=Bonjour%2C%20je%20voudrais%20r%C3%A9server%20la%20descente%20du%20Sella" target="_blank" rel="noopener noreferrer" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
          </span>
          <span class="rsvO__itemTag">Réponse immédiate</span>
          <h3 class="rsvO__itemTitle">WhatsApp</h3>
          <p class="rsvO__itemText">Nous te répondons en quelques minutes en heures d'ouverture. Sans formulaires, sans attentes.</p>
          <span class="rsvO__itemValue">Ouvrir le chat</span>
          <span class="rsvO__itemCta" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a class="rsvO__item" href="tel:+34681093673" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
