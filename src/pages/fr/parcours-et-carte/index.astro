---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import MapaInteractivoSella from '@components/sections/MapaInteractivoSella.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Descente du Sella · Parcours et carte · Arriondas → Fríes';
const description = 'Carte interactive et parcours de la descente du Sella : 14,5 km depuis Arriondas jusqu\'à Fríes. Buvettes au bord du fleuve, rapides, passerelles et plages fluviales du chemin.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/parcours-et-carte/`;

// Points clés éditoriaux du parcours
const hitos = [
  { km: 0,    tag: 'DÉPART',          name: 'Arriondas',            kind: 'Point de départ',                photo: 'arriondas-inicio',  alt: 'Arriondas · point de départ de la descente du Sella',                  text: 'Là où tout commence. Check-in dans nos bureaux, équipement, pique-nique asturien et mini-cours avant d\'entrer dans l\'eau. Capitale touristique du concejo de Parres.' },
  { km: 1,    tag: 'RAPIDE',          name: 'La Remolina',          kind: 'Premier rapide',                 photo: 'remolina-rapido',   alt: 'La Remolina · premier rapide de la descente du Sella',                 text: 'Le premier rapide doux du chemin — classe I modérée. Il suffit de pagayer calmement : le fleuve te guide.' },
  { km: 3,    tag: 'BUVETTE',         name: 'El Oasis · El Prau',   kind: 'Deux arrêts mythiques',          photo: 'chiringuito-prao',  alt: 'Buvette El Prau au bord du Sella',                                     text: 'Les premières buvettes au bord du fleuve où l\'on s\'arrête pour boire ou se rafraîchir. Ambiance animée en haute saison.' },
  { km: 4,    tag: 'PASSERELLE',      name: 'Pasarela de Fuentes',  kind: 'Réserve de pêche au saumon',     photo: 'pasarela-fuentes',  alt: 'Pasarela de Fuentes sur le Sella dans la réserve de pêche au saumon', text: 'Tu traverses la réserve historique de pêche au saumon de Los Llaos. Villages asturiens sur les berges, chênes verts et hêtraies. L\'un des plus beaux tronçons.' },
  { km: 6,    tag: 'PLAGE',           name: 'Pozo del Arco',        kind: 'Plage fluviale',                 photo: 'pozo-del-arco',     alt: 'Pozo del Arco · plage fluviale du fleuve Sella',                       text: 'Eaux tranquilles et plage fluviale. Arrêt idéal pour se baigner — surtout en juillet et août quand l\'eau est plus chaude.' },
  { km: 7,    tag: 'FIN MINI',        name: 'Toraño',               kind: 'Fin du Mini Sella',              photo: 'torano-mini-fin',   alt: 'Toraño · arrivée de la route Mini Sella',                              text: 'Point de récupération pour ceux qui choisissent le <strong>Mini Sella</strong>. Qui poursuit jusqu\'à Fríes traverse la partie la plus ouverte de la vallée.' },
  { km: 10,   tag: 'ARRÊT',           name: 'Llordón',              kind: 'Mi-parcours',                    photo: 'llordon-parada',    alt: 'Llordón · arrêt de mi-parcours dans la descente du Sella',             text: 'Arrêt habituel pour manger le pique-nique tranquillement ou se rafraîchir avant le tronçon final. Couchers de soleil spectaculaires.' },
  { km: 14.5, tag: 'ARRIVÉE',         name: 'Fríes',                kind: 'Arrivée du Parcours complet',    photo: 'frias-final',       alt: 'Fríes · arrivée du Parcours complet de la descente du Sella',          text: 'Fin du <strong>Parcours complet</strong>. Notre transfert vous récupère et vous ramène à Arriondas. Vestiaires avec douches chaudes vous attendent.' },
];

// 15 tronçons détaillés du parcours
const tramos = [
  { km: 0,    type: 'Départ',                  name: 'Arriondas · Puente de las Piraguas', highlight: true,
    photo: 'arriondas-inicio', alt: 'Arriondas · point de départ de la descente du Sella',
    text: 'Point de départ de la descente. Tu pars depuis notre <strong>rampe de plus de 35 m</strong> ou directement depuis la berge, à côté du mythique <strong>Puente de las Piraguas</strong> (pont des Piraguistes) — le même pont où chaque mois d\'août est donné le départ officiel de la <a href="/fr/descente-internationale-du-sella/">Descente Internationale</a>.' },
  { km: 0.2,  type: 'Rapide',                  name: 'La Raíz',
    text: 'Le premier rapide de la journée. Le courant accélère et le fleuve se rétrécit. <strong>Classe I modérée</strong> — il se passe sans souci, le canoë prend un peu de vitesse et te donne le premier frisson.' },
  { km: 1,    type: 'Rapide',                  name: 'La Remolina',
    text: 'Deuxième rapide avec des eaux en forme de <strong>V</strong>. L\'essentiel est de rester centré entre les deux courants qui convergent — une poussée amusante.' },
  { km: 2,    type: 'Réserve de pêche',        name: 'El Ricao',
    text: 'Tronçon plus étroit avec <strong>des eaux tranquilles serpentantes</strong>. Réserve historique de pêche au saumon — tu trouveras des pêcheurs sur les berges pendant la saison du saumon.' },
  { km: 4,    type: 'Passerelle · village',    name: 'Pasarela de Fuentes · Los Llaos',   highlight: true,
    photo: 'pasarela-fuentes', alt: 'Pasarela de Fuentes sur le fleuve Sella à Triongo',
    text: 'Tu passes sous la <strong>passerelle de la paroisse de Triongo</strong> (Cangas de Onís). Seconde réserve de pêche au saumon et l\'un des plus beaux tronçons du fleuve — villages asturiens sur les berges, chênes verts et hêtraies.' },
  { km: 5,    type: 'Tronçon rocheux',         name: 'Triongo',
    text: 'Tronçon plein de <strong>petits rapides</strong> et de pierres. Sur la rive droite subsiste un brise-lames en ruine qui fait partie du paysage fluvial historique.' },
  { km: 6,    type: 'Plage fluviale',          name: 'Pozo del Arco',                      highlight: true,
    photo: 'pozo-del-arco', alt: 'Pozo del Arco · plage fluviale sur la descente du Sella',
    text: 'L\'une des zones préférées du parcours. <strong>Eaux tranquilles et profondes</strong>, plage fluviale idéale pour se baigner — arrêt incontournable en juillet et août lorsque l\'eau est plus chaude.' },
  { km: 6.5,  type: 'Rapide · frontière',      name: 'El Picu La Vieya',
    text: 'Marque la <strong>frontière entre Cangas de Onís et Ribadesella</strong>, à Margolles. Petit rapide sur la rive droite qui rappelle que le fleuve est encore vivant.' },
  { km: 7,    type: 'Fin Mini Sella',          name: 'Puente de Toraño',                   highlight: true,
    photo: 'torano-mini-fin', alt: 'Puente de Toraño · arrivée de la route Mini Sella',
    text: '<strong>Fin du Mini Sella</strong>. Après environ <strong>2 heures de pagaie</strong>, eaux tranquilles et deux buvettes sur la berge. Notre transfert récupère à partir de <strong>14h30</strong> ceux qui choisissent la route courte.' },
  { km: 8,    type: 'Rapide spectaculaire',    name: 'Rabión del Diablu',
    text: 'Tronçon <strong>spectaculaire et très rocheux</strong>. L\'un des moments les plus passionnants du Parcours complet — classe I intense, toujours sûr avec gilet homologué et le mini-cours préalable.' },
  { km: 9,    type: 'Tronçon droit',           name: 'La Requexada',
    text: 'Le tronçon <strong>droit le plus long</strong> du parcours, avec des eaux très profondes. Moment parfait pour pagayer à son rythme, profiter de la vallée ouverte et discuter sans surprises.' },
  { km: 10,   type: 'Arrêt',                   name: 'Llordón',
    text: 'Arrêt habituel pour <strong>manger le pique-nique</strong> ou se rafraîchir avant le tronçon final. Berges larges et couchers de soleil spectaculaires si tu descends en automne.' },
  { km: 12,   type: 'Passerelle',              name: 'Pasarela de Cuevas',
    text: 'Village de Ribadesella célèbre pour sa <strong>grotte naturelle</strong>. La passerelle sur le fleuve est un accès piéton et de pêcheurs — tronçon très photogénique.' },
  { km: 13,   type: 'Passerelle',              name: 'Pasarela de La Uña',
    text: 'La <strong>dernière passerelle</strong> du parcours. À partir d\'ici le fleuve se calme, apparaissent davantage de <strong>plages fluviales</strong> et la vallée s\'ouvre doucement vers la mer.' },
  { km: 14.5, type: 'Arrivée',                 name: 'Fríes · Llovio',                     highlight: true,
    photo: 'frias-final', alt: 'Fríes · arrivée du Parcours complet de la descente du Sella',
    text: '<strong>Arrivée du Parcours complet</strong>. Entre 3 h 30 et 4 h 30 depuis Arriondas selon le rythme. Notre transfert te récupère et te ramène aux bureaux, où t\'attendent <strong>les vestiaires avec douches chaudes</strong>.' },
];

const iconFor = (type) => {
  const t = type.toLowerCase();
  if (t.includes('fin mini'))   return 'flag-mini';
  if (t.includes('départ'))     return 'flag-start';
  if (t.includes('arrivée'))    return 'flag-finish';
  if (t.includes('rapide'))     return 'wave';
  if (t.includes('pêche'))      return 'fish';
  if (t.includes('passerelle')) return 'bridge';
  if (t.includes('rocheux'))    return 'mountain';
  if (t.includes('plage'))      return 'beach';
  if (t.includes('droit'))      return 'arrow';
  if (t.includes('arrêt'))      return 'coffee';
  return 'dot';
};

const iconPaths = {
  'flag-start':  '<path d="M6 21V4m0 0h12l-3 4 3 4H6"/>',
  'flag-finish': '<path d="M6 21V4m0 0h12l-3 4 3 4H6m0-4h12"/>',
  'flag-mini':   '<path d="M6 21V5m0 0h11l-2 3 2 3H6"/>',
  'wave':        '<path d="M3 10c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/><path d="M3 16c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'fish':        '<path d="M3 12c3-3 7-5 11-5 3 0 6 2 7 5-1 3-4 5-7 5-4 0-8-2-11-5z"/><circle cx="15.5" cy="10.5" r="0.9" fill="currentColor" stroke="none"/>',
  'bridge':      '<path d="M3 19V13a9 9 0 0 1 18 0v6M3 19h18M9 19v-3M15 19v-3"/>',
  'mountain':    '<path d="M3 20l5-9 4 6 3-4 6 7z"/>',
  'beach':       '<circle cx="12" cy="8" r="3"/><path d="M3 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'arrow':       '<line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 6 20 12 14 18"/>',
  'coffee':      '<path d="M4 10h12v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-6zm12 2h2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-2"/><line x1="8" y1="3" x2="8" y2="6"/><line x1="12" y1="3" x2="12" y2="6"/>',
  'parasol':     '<path d="M3 11a9 9 0 0 1 18 0z"/><line x1="12" y1="11" x2="12" y2="20"/><path d="M10 20a2 2 0 0 0 4 0"/>',
  'dot':         '<circle cx="12" cy="12" r="3"/>',
};

// 6 buvettes réelles au bord du fleuve
const chiringuitos = [
  { km: 1, name: 'Riverland',  nota: 'Début du parcours',              icon: 'flag-start' },
  { km: 3, name: 'El Oasis',   nota: 'Premier tiers · berge',          icon: 'coffee'     },
  { km: 3, name: 'El Prau',    nota: 'Premier tiers · plage',          icon: 'parasol'    },
  { km: 4, name: 'El Bosque',  nota: 'Milieu · après la passerelle',   icon: 'bridge'     },
  { km: 4, name: 'La Mediana', nota: 'Milieu · autre rive',            icon: 'wave'       },
  { km: 8, name: 'Toraño',     nota: 'Fin du Mini Sella',              icon: 'flag-finish'},
];

// FAQ spécifique au parcours
const faqs = [
  { q: 'Combien de kilomètres fait la descente du Sella ?',
    a: 'Le <strong>Parcours complet</strong> fait <strong>14,5 km</strong> depuis Arriondas jusqu\'à Fríes. Le <strong>Mini Sella</strong>, option courte, fait <strong>7 km</strong> entre Arriondas et Toraño. Les deux partagent le même tronçon initial.' },
  { q: 'Où commence et où se termine la descente du Sella ?',
    a: 'La descente <strong>commence à Arriondas</strong> (Asturies), dans nos bureaux. Le Parcours complet <strong>se termine à Fríes</strong> après 14,5 km. Le Mini Sella se termine plus tôt, à <strong>Toraño</strong> (km 7). Dans les deux cas, notre transfert te récupère et te ramène au point de départ.' },
  { q: 'Quelles sont les buvettes du parcours ?',
    a: 'Sur la descente, il y a <strong>6 buvettes au bord du fleuve</strong> tout au long du chemin : <strong>Riverland</strong> (km 1), <strong>El Oasis</strong> et <strong>El Prau</strong> (km 3), <strong>El Bosque</strong> et <strong>La Mediana</strong> (km 4) et <strong>Toraño</strong> (km 8, fin du Mini Sella). Tu peux t\'arrêter pour te reposer, prendre quelque chose ou simplement profiter de l\'ambiance.' },
  { q: 'Y a-t-il des plages fluviales où se baigner ?',
    a: 'Oui. La plus connue est le <strong>Pozo del Arco</strong> (km 6), avec des eaux tranquilles parfaites pour la baignade. Il y a aussi plusieurs <strong>berges et plages informelles</strong> tout au long du parcours — surtout après Pasarela de Fuentes et avant Llordón.' },
  { q: 'Quels rapides ou tronçons difficiles y a-t-il ?',
    a: 'Le Sella dans son tronçon touristique est <strong>une rivière douce</strong> — pas de white-water. Il a quelques rapides <strong>classe I modérée</strong> comme <strong>La Raíz</strong> (km 0,2) et <strong>La Remolina</strong> (km 1). Avec le mini-cours préalable et un gilet homologué, ils se font en toute sécurité.' },
  { q: 'Peut-on s\'arrêter à n\'importe quel point du parcours ?',
    a: 'Oui, <strong>c\'est toi qui donnes le rythme</strong>. Tu t\'arrêtes où tu veux : plages fluviales, buvettes ou simplement sur la berge pour t\'étirer. La seule chose à respecter est la <strong>présence maximale jusqu\'à 18h00</strong> par réglementation de la Confédération hydrographique du Cantabrique.' },
  { q: 'Quelle différence entre Mini Sella et Parcours complet ?',
    a: 'Les deux partagent les premiers 7 km (Arriondas → Toraño). Le <strong>Mini Sella</strong> se termine là — idéal avec de petits enfants ou pour une demi-journée. Le <strong>Parcours complet</strong> continue encore 7,5 km jusqu\'à Fríes, ajoutant paysage ouvert, la passerelle de Cuevas, celle de La Uña et la fermeture de la vallée. <a href="/fr/duree/">Plus de détails sur les temps ici</a>.' },
  { q: 'Que va-t-on voir sur le chemin ?',
    a: 'Villages asturiens (Fuentes, Margolles, Toraño, Cuevas), <strong>forêt cantabrique</strong> avec chênes verts et hêtraies, <strong>6 buvettes</strong> sur les berges, la <strong>réserve de pêche au saumon</strong> de Los Llaos, <strong>plages fluviales</strong>, rapides doux et plusieurs passerelles historiques. Le plan le plus panoramique des Asturies.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Parcours et carte de la descente du Sella · Arriondas à Fríes',
      description: 'Guide complet du parcours de la descente du Sella : 14,5 km avec carte interactive, buvettes, rapides, passerelles et plages fluviales.',
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-21',
      dateModified: '2026-05-12',
      about: 'Parcours et carte de la descente du Sella en canoë, 14,5 km entre Arriondas et Fríes',
      keywords: 'descente du Sella, parcours et carte, Arriondas, Fríes, Mini Sella, buvettes, rapides, passerelles, plages fluviales, Asturies',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'fr-FR',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',          item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Parcours et carte', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/fr/parcours-et-carte/" translationKey="recorrido_mapa">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · éditorial avec watermark "Sella" + stats ============== -->
  <section class="rrh" aria-labelledby="rrh-title">

    <div class="rrh__shapes" aria-hidden="true">
      <span class="rrh__shape rrh__shape--1"></span>
      <span class="rrh__shape rrh__shape--2"></span>
    </div>
    <span class="rrh__watermark" aria-hidden="true">Sella</span>

    <div class="rrh__inner">
      <nav class="rrh__breadcrumb" aria-label="Fil d'Ariane">
        <a href={getLocalePath('home', lang)}>Accueil</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Parcours et carte</span>
      </nav>

      <span class="rrh__eyebrow">— Parcours de la descente</span>

      <h1 id="rrh-title" class="rrh__title">
        La carte du<br/>
        <span class="serif-italic">Sella.</span>
      </h1>

      <p class="rrh__lead">
        La descente du Sella en canoë parcourt <strong>14,5 km entre Arriondas et Fríes</strong>,
        traversant des villages asturiens, des rapides doux, des passerelles historiques, des plages
        fluviales et <strong>6 buvettes au bord du fleuve</strong>. Voici la carte interactive
        avec tous les points du chemin.
      </p>

      <ul class="rrh__stats" aria-label="Chiffres du parcours">
        <li class="rrh__stat">
          <strong>14,5<small>km</small></strong>
          <span>parcours complet</span>
        </li>
        <li class="rrh__stat">
          <strong>7<small>km</small></strong>
          <span>Mini Sella</span>
        </li>
        <li class="rrh__stat">
          <strong>6</strong>
          <span>buvettes</span>
        </li>
      </ul>

      <div class="rrh__ctas">
        <a href="#rrh-mapa" class="rrh__cta rrh__cta--primary">Voir la carte interactive</a>
        <a href={getLocalePath('reservar', lang)} class="rrh__cta rrh__cta--link">
          Réserver la descente
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · CARTE INTERACTIVE ============== -->
  <div id="rrh-mapa">
    <MapaInteractivoSella />
  </div>

  <!-- ============== 3 · POINTS CLÉS DU PARCOURS ============== -->
  <section class="rrs" aria-labelledby="rrs-title">
    <div class="container container--xl">
      <header class="rrs__header" data-reveal>
        <div class="rrs__headerMain">
          <span class="rrs__eyebrow">— Points clés du chemin</span>
          <h2 id="rrs-title" class="rrs__title">8 arrêts<br/><span class="serif-italic">canoniques.</span></h2>
        </div>
        <div class="rrs__nav" role="group" aria-label="Navigation points clés">
          <span class="rrs__counter" aria-live="polite">
            <span class="rrs__counterCurrent" data-rrs-current>01</span>
            <small class="rrs__counterTotal">/{String(hitos.length).padStart(2, '0')}</small>
          </span>
          <button type="button" class="rrs__navBtn" data-rrs-nav="prev" aria-label="Point clé précédent">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="rrs__navBtn is-dark" data-rrs-nav="next" aria-label="Point clé suivant">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </header>

      <div class="rrs__track" data-rrs-track data-drag-scroll role="region" aria-label="Points clés du parcours">
        {hitos.map((h, i) => (
          <article class="rrsItem" data-rrs-item={i}>
            <span class="rrsItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rrsItem__media">
              <Picture src={h.photo} alt={h.alt} sizes="(min-width: 960px) 52vw, 90vw" bare />
            </div>
            <div class="rrsItem__body">
              <span class="rrsItem__tag">KM {h.km === Math.floor(h.km) ? h.km : h.km.toFixed(1).replace('.', ',')} · {h.tag}</span>
              <h3 class="rrsItem__name">{h.name}</h3>
              <p class="rrsItem__kind">{h.kind}</p>
              <p class="rrsItem__text" set:html={h.text} />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 3.25 · BANNIÈRE sombre · Prêt pour la descente ? ============== -->
  <section class="rrb" aria-label="Appel à l'action · réserver la descente">
    <div class="container container--xl">
      <div class="rrb__inner" data-reveal>
        <div class="rrb__text">
          <span class="rrb__eyebrow">— Aventura en el Sella</span>
          <h2 class="rrb__title">Prêt à <span class="serif-italic">faire la descente ?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rrb__cta">
          <span>Réserver maintenant</span>
          <span class="rrb__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 3.5 · TRONÇON PAR TRONÇON · timeline éditoriale ============== -->
  <section class="rrt" aria-labelledby="rrt-title">
    <div class="container container--xl">
      <header class="rrt__header" data-reveal>
        <span class="rrt__eyebrow">— Pas à pas</span>
        <h2 id="rrt-title" class="rrt__title">
          Tronçon par tronçon<br/>
          <span class="serif-italic">du Sella.</span>
        </h2>
        <p class="rrt__lead">
