---
import BaseLayout from '@layouts/BaseLayout.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Descente Internationale du Sella 2026 · Date et guide';
const description = 'Descente Internationale du Sella 2026 : date, parcours, horaires, palmarès et comment la vivre. Réservez votre canoë touristique le jour même de l’événement.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/descente-internationale-du-sella/`;

const homeUrl     = getLocalePath('home', lang);
const bookUrl     = getLocalePath('reservar', lang);

// ============== Données structurées ==============
const datosClave = [
  { label: 'Nom officiel',     valueLines: ['Descente Internationale', 'du Sella'],     sub: '« Les Piragües »' },
  { label: 'Fondée en',        valueLines: ['1930'],                                     sub: 'près d’un siècle d’histoire' },
  { label: 'Parcours',         valueLines: ['20 km'],                                    sub: 'Arriondas → Ribadesella' },
  { label: 'Participants',     valueLines: ['+1 200'],                                   sub: 'élite + amateurs' },
  { label: 'Spectateurs',      valueLines: ['~200 000'],                                 sub: 'sur les rives du fleuve' },
  { label: 'Reconnaissance',   valueLines: ['F. d’Intérêt Touristique', 'International'], sub: 'déclarée en 1981' },
];

const fechas2026 = [
  { day: 'Jeudi 6 août',     hour: 'Toute la journée',  title: 'Arrivée des peñas',                  text: 'Concentration à Arriondas. L’ambiance festive commence.' },
  { day: 'Vendredi 7 août',  hour: 'Toute la journée',  title: 'Festivités officielles',             text: 'Fêtes populaires, feux de joie et musique à Arriondas.' },
  { day: 'Samedi 8 août',    hour: '11h30',             title: 'Départ officiel',                     text: 'La compétition démarre depuis le Puente de los Piragüistas.', highlight: true },
  { day: 'Samedi 8 août',    hour: '12h00',             title: 'Départ touristique · avec nous',      text: 'Unique départ de la journée juste après l’élite. Réservation spéciale à capacité limitée.', highlight: true },
  { day: 'Samedi 8 août',    hour: '14h30–17h00',       title: 'Arrivée à Ribadesella',               text: 'Fête d’arrivée et remise des trophées au bord de la mer.' },
  { day: 'Dimanche 9 août',  hour: 'Matin',             title: 'Remise des prix',                     text: 'Cérémonie officielle et Messe du canoéiste. Clôture du week-end.' },
];

const recorrido = [
  { km: '0 km',    place: 'Arriondas',            note: 'Départ officiel · Puente de los Piragüistas', us: false },
  { km: '3 km',    place: 'Puente de Santianes',  note: 'Premier point de chronométrage',              us: false },
  { km: '7 km',    place: 'Puente de Toraño',     note: 'Fin de notre Mini Sella',                     us: true  },
  { km: '14,5 km', place: 'Fríes',                note: 'Fin de notre descente Complète',              us: true  },
  { km: '17 km',   place: 'Llovio',               note: 'Derniers rapides du parcours',                us: false },
  { km: '20 km',   place: 'Ribadesella',          note: 'Arrivée · rive de la mer Cantabrique',        us: false },
];

const palmares = [
  { year: '2025', winners: 'Rodrigo Germade / Diego Romero', flag: 'ESP' },
  { year: '2024', winners: 'Javier Reja / Adrián Sieiro',    flag: 'ESP' },
  { year: '2023', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2022', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2021', winners: 'Íñigo Peña / Pedro Vázquez',     flag: 'ESP' },
];

const faqs = [
  { q: 'Quand a lieu la Descente Internationale du Sella 2026 ?',
    a: 'L’édition 2026 se déroule le <strong>samedi 8 août</strong>. Le départ officiel de l’élite est fixé à <strong>11h30</strong> à Arriondas et l’arrivée à Ribadesella entre 14h30 et 17h00. Notre départ touristique a lieu à <strong>12h00</strong>, juste après les professionnels.' },
  { q: 'Puis-je descendre le Sella le jour de la Descente Internationale ?',
    a: 'Oui — mais avec une réservation spéciale. Nous proposons un <strong>unique départ touristique à 12h00</strong>, juste après le départ de l’élite professionnelle. Le fleuve s’ouvre au trafic touristique après le passage du peloton. <strong>Prix unique de 35 €</strong> par personne (sans pique-nique, car la logistique de ce jour est différente). Paiement anticipé en ligne. Réservation jusqu’à <strong>2 jours avant</strong> l’événement — les places s’épuisent des semaines à l’avance.' },
  { q: 'Pourquoi l’enregistrement est-il si tôt ce jour-là ?',
    a: 'La <strong>circulation à l’entrée d’Arriondas ferme à 10h00</strong> — les rues sont piétonnisées et les véhicules ne peuvent plus accéder au village. C’est pourquoi nous vous demandons d’arriver à Arriondas <strong>avant 9h30</strong> pour faire l’enregistrement et laisser la voiture sur notre parking privé. Si vous arrivez en retard, vous ne pourrez pas accéder et vous perdriez l’activité.' },
  { q: 'Puis-je emmener mon chien le jour de la Descente Internationale ?',
    a: '<strong>Nous ne le recommandons pas</strong>. Bien que les animaux soient les bienvenus <a href="' + homeUrl + '">le reste de l’année</a>, ce jour-là il y a une affluence extraordinaire (~200 000 spectateurs), beaucoup de bruit, des feux d’artifice, du trafic et de la tension. Les chiens prennent peur et l’expérience ne sera agréable ni pour eux ni pour vous. Mieux vaut réserver un autre jour de la saison.' },
  { q: 'Combien coûte la participation à la Descente Internationale en tant qu’athlète ?',
    a: 'L’inscription en tant que sportif fédéré tourne autour de <strong>35–45 €</strong> selon la catégorie. Elle requiert une licence de canoë-kayak en cours de validité et une accréditation fédérale. Les canoës touristiques ne sont pas admis dans l’épreuve officielle.' },
  { q: 'Où puis-je voir la Descente Internationale gratuitement ?',
    a: 'Toute la rive du Sella est en accès libre. Les meilleurs points sont <strong>Arriondas</strong> (départ), le <strong>Puente de Llovio</strong> (derniers rapides spectaculaires) et l’arrivée à <strong>Ribadesella</strong>.' },
  { q: 'Quel est le palmarès de la Descente Internationale du Sella ?',
    a: 'Vous pouvez consulter la liste complète des vainqueurs depuis 1930 sur le site officiel de la <a href="https://www.rfep.es" target="_blank" rel="nofollow noopener external">Fédération Espagnole de Canoë-Kayak</a> ou sur <a href="https://fr.wikipedia.org/wiki/Descente_internationale_du_Sella" target="_blank" rel="noopener external">Wikipédia</a>. Vous avez ci-dessus le tableau des éditions récentes, mis à jour chaque septembre.' },
  { q: 'Y a-t-il des hébergements disponibles le week-end de la Descente Internationale ?',
    a: 'Difficile. Réservez <strong>plusieurs mois à l’avance</strong> à Arriondas, Cangas de Onís, Ribadesella ou Llanes. L’occupation cette semaine-là dépasse 95 % dans toute la région.' },
  { q: 'Peut-on y assister avec des enfants ?',
    a: 'Oui, c’est un <strong>événement familial par excellence</strong>. L’ambiance est festive et l’organisation prépare des zones de berge sécurisées. Attention au soleil : nous recommandons un chapeau et une crème solaire forte.' },
  { q: 'Que faire d’autre ce week-end aux Asturies ?',
    a: 'Visiter les <strong>Lacs de Covadonga</strong>, descendre le <a href="' + homeUrl + '">Sella en mode touristique</a> les jours précédents, faire un parcours à vélo sur la Senda del Oso, découvrir Ribadesella et la grotte de Tito Bustillo, ou goûter au cidre et à la gastronomie asturienne dans les chigres locaux.' },
];

// ============== Schema.org JSON-LD ==============
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descente Internationale du Sella 2026 · Date, parcours et guide complet',
      description,
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/og/og-internacional-fr.jpg`, width: 1200, height: 630 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Événements · Descente Internationale du Sella',
      keywords: [
        'Descente Internationale du Sella',
        'Descente du Sella 2026',
        'Les Piragües',
        'Fête du Sella',
        'canoë-kayak Asturies',
        'Arriondas Ribadesella canoë',
      ],
      about: 'Compétition internationale de canoë-kayak sur le fleuve Sella, Asturies',
    },
    {
      '@type': 'Event',
      '@id': `${canonicalUrl}#event-2026`,
      name: 'Descente Internationale du Sella 2026 · Les Piragües',
      alternateName: 'Les Piragües',
      description: 'Compétition de canoë-kayak de 20 km sur le fleuve Sella, déclarée Fête d’Intérêt Touristique International. Elle attire plus de 1 200 canoéistes et 200 000 spectateurs.',
      startDate: '2026-08-08T11:30:00+02:00',
      endDate:   '2026-08-08T17:00:00+02:00',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      inLanguage: 'fr-FR',
      isAccessibleForFree: true,
      audience: { '@type': 'Audience', audienceType: 'Grand public · canoë-kayak · tourisme sportif' },
      maximumAttendeeCapacity: 200000,
      location: {
        '@type': 'Place',
        name: 'Fleuve Sella · Arriondas — Ribadesella',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Puente de los Piragüistas',
          addressLocality: 'Arriondas',
          addressRegion: 'Asturies',
          postalCode: '33540',
          addressCountry: 'ES',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      },
      organizer: {
        '@type': 'Organization',
        name: 'Fédération Espagnole de Canoë-Kayak',
        url: 'https://www.rfep.es',
      },
      image: `${baseUrl}/images/og/og-internacional-fr.jpg`,
      url: canonicalUrl,
      offers: {
        '@type': 'Offer',
        name: 'Départ touristique de la Descente Internationale · 12h00',
        description: 'Unique départ touristique de la journée après le passage de l’élite professionnelle. Capacité limitée.',
        price: '35',
        priceCurrency: 'EUR',
        availability: 'https://schema.org/LimitedAvailability',
        validFrom: '2026-01-15T00:00:00+02:00',
        url: `${baseUrl}${bookUrl}?dia=2026-08-08`,
      },
      subEvent: [
        { '@type': 'Event', name: 'Arrivée des peñas',                     startDate: '2026-08-06', endDate: '2026-08-06', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Festivités officielles',                startDate: '2026-08-07', endDate: '2026-08-07', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Départ touristique (12h00)',            startDate: '2026-08-08T12:00:00+02:00', endDate: '2026-08-08T17:00:00+02:00', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Remise des prix et Messe du canoéiste', startDate: '2026-08-09', endDate: '2026-08-09', eventStatus: 'https://schema.org/EventScheduled' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'Descente du Sella Asturies · Aventura en el Sella · Location de canoës',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (accès par Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturies',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        'https://share.google/huLLaIz31FiYohuTV',
        'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html',
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',                          item: `${baseUrl}${homeUrl}` },
        { '@type': 'ListItem', position: 2, name: 'Descente Internationale du Sella', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/og/og-internacional-fr.jpg"
  currentPath="/fr/descente-internationale-du-sella/"
  translationKey="descenso_internacional"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="dih" aria-labelledby="dih-title">

    <div class="dih__inner">
      <nav class="dih__breadcrumb" aria-label="Fil d’Ariane">
        <a href={homeUrl}>Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Descente Internationale du Sella</span>
      </nav>

      <span class="dih__eyebrow">
        <span class="dih__eyebrow-dot" aria-hidden="true"></span>
        1930 · Fête d’Intérêt Touristique International
      </span>

      <h1 id="dih-title" class="dih__title">
        Descente Internationale<br/>
        <span class="serif-italic">du Sella</span>
      </h1>

      <p class="dih__lead">
        L’une des <strong>compétitions de canoë-kayak les plus emblématiques au monde</strong>
        et l’épreuve sportive la plus ancienne des Asturies. Chaque année, un samedi
        d’août, des milliers d’athlètes parcourent les <strong>20 km</strong>
        qui séparent Arriondas de Ribadesella, encouragés par plus de
        <strong>200 000 spectateurs</strong> au bord du fleuve Sella.
      </p>

      <div class="dih__event">
        <div class="dih__event-col">
          <span class="dih__event-label">Édition 2026</span>
          <span class="dih__event-value">Samedi 8 août</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Départ officiel</span>
          <span class="dih__event-value">11h30 · Arriondas</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Arrivée</span>
          <span class="dih__event-value">14h30–17h00 · Ribadesella</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== QU’EST-CE QUE C’EST + DONNÉES ============== -->
  <section class="dis">
    <div class="container container--xl">
      <header class="dis__header">
        <span class="dis__eyebrow">— Qu’est-ce que c’est</span>
        <h2 class="dis__title">La fête des canoës <span class="serif-italic">la plus ancienne d’Espagne</span></h2>
        <p class="dis__lead">
          Née en <strong>1930</strong> sous l’impulsion de Dionisio de la Huerta, la
          Descente Internationale du Sella est la <strong>compétition de canoë-kayak
          en eaux calmes la plus ancienne</strong> du canoë-kayak espagnol. Chaque
          année, elle attire les meilleurs kayakistes et canoéistes du monde — des
          champions olympiques aux amateurs — accompagnés d’une foule qui transforme
          les berges en un festival continu de 20 km.
        </p>
      </header>

      <div class="dis__grid">
        {datosClave.map((d, i) => (
          <div class="disData" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="disData__label">{d.label}</span>
            <span class="disData__value">
              {d.valueLines.map((line, idx) => (
                <>
                  {idx > 0 && <br/>}
                  {line}
                </>
              ))}
            </span>
            <span class="disData__sub">{d.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== DATES 2026 ============== -->
  <section class="dif">
    <div class="container container--lg">
      <header class="dif__header">
        <span class="dif__eyebrow">— Dates 2026</span>
        <h2 class="dif__title">
          Quatre jours de fête.<br/>
          <span class="serif-italic">Un samedi inoubliable.</span>
        </h2>
        <p class="dif__lead">
          Les activités parallèles commencent le jeudi précédent avec l’arrivée
          des peñas à Arriondas et culminent le samedi avec le
          <strong>départ officiel de la compétition à 11h30</strong>.
        </p>
      </header>

      <ol class="dif__timeline">
        {fechas2026.map((f, i) => (
          <li class:list={['difStep', f.highlight && 'difStep--top']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <div class="difStep__date">
              <span class="difStep__day">{f.day}</span>
              <span class="difStep__hour">{f.hour}</span>
            </div>
            <div class="difStep__bullet" aria-hidden="true"></div>
            <div class="difStep__body">
              <h3 class="difStep__title">{f.title}</h3>
              <p class="difStep__text">{f.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="dif__note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>La date officielle dépend du calendrier de la Fédération Espagnole de Canoë-Kayak. Nous confirmons chaque janvier l’édition de l’année en cours.</span>
      </p>
    </div>
  </section>

  <!-- ============== PARCOURS 20 KM ============== -->
  <section class="dir">
    <div class="container container--xl">
      <header class="dir__header">
        <span class="dir__eyebrow">— Parcours</span>
        <h2 class="dir__title">20 kilomètres entre <span class="serif-italic">Arriondas et Ribadesella</span></h2>
        <p class="dir__lead">
          Le tracé de la Descente Internationale du Sella reproduit le même fleuve
          que vous descendez lors de votre <a href={homeUrl} class="dir__link">descente
          touristique</a> — mais en version compétitive et multitudinaire.
        </p>
      </header>

      <ol class="dir__track">
        {recorrido.map((r, i) => (
          <li class:list={['dirPoint', r.us && 'dirPoint--us']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="dirPoint__km">{r.km}</span>
            <span class="dirPoint__dot" aria-hidden="true"></span>
            <div class="dirPoint__body">
              <span class="dirPoint__place">{r.place}</span>
              <span class="dirPoint__note">{r.note}</span>
              {r.us && <span class="dirPoint__tag">Le nôtre</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== COMMENT LA VOIR ============== -->
  <section class="div">
    <div class="container container--xl">
      <header class="div__header">
        <span class="div__eyebrow">— Guide pratique</span>
        <h2 class="div__title">Comment voir la Descente Internationale <span class="serif-italic">sans tracas</span></h2>
        <p class="div__lead">
          Les <strong>meilleurs points</strong> pour voir la Descente Internationale
          du Sella sont <strong>Arriondas</strong> (départ), le
          <strong>Puente de Llovio</strong> (derniers rapides spectaculaires)
          et l’arrivée à <strong>Ribadesella</strong>.
        </p>
      </header>

      <div class="div__grid">
        <article class="divCard" data-reveal data-reveal-delay="1">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>
            Stationnement recommandé
          </h3>
          <ul class="divCard__list">
            <li><strong>Arriondas</strong> · parkings aménagés par la mairie dès le jeudi. Arriver avant <strong>10h00 le samedi</strong>.</li>
            <li><strong>Toraño / Fríes</strong> · parking plus tranquille si voir la partie intermédiaire vous suffit. Bonne option pour les familles avec enfants.</li>
            <li><strong>Ribadesella</strong> · embouteillages sévères dès 11h00. Alternative : se garer à <strong>Llovio</strong> et monter à pied.</li>
          </ul>
        </article>

        <article class="divCard" data-reveal data-reveal-delay="2">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
            Quoi apporter
          </h3>
          <ul class="divCard__list">
            <li><strong>Tenue confortable</strong> et <strong>crème solaire</strong> (longues heures au soleil d’août).</li>
            <li><strong>Eau et pique-nique</strong> si vous ne voulez pas faire la queue aux bars.</li>
            <li><strong>Appareil photo avec bon zoom</strong> — le fleuve se trouve à 10–20 m de la berge par endroits.</li>
