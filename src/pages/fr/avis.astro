---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Avis sur la descente du Sella · 4,5★ sur Google et TripAdvisor';
const description = '147 avis réels sur la descente du Sella — 4,5★ sur Google, 4,8★ sur TripAdvisor. Lis ce que disent les familles, les couples et les amis après avoir descendu la rivière avec Aventura en el Sella.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/avis/`;

// Chiffres agrégés officiels (snapshot 2026-04-13 · reference_reviews.md)
const aggregate = {
  global: { rating: '4,5', total: 147, rating_num: 4.5 },
  google: { rating: '4,5', total: 127, url: 'https://share.google/huLLaIz31FiYohuTV', label: 'Google' },
  trip:   { rating: '4,8', total:  20, url: 'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html', label: 'TripAdvisor' },
};

// Témoignages réels approuvés (reference_reviews.md 2026-04-13)
const testimonios = [
  {
    initial: 'A',
    name: 'Anaïs Suárez Blanco',
    source: 'Google',
    date: 'octobre 2025',
    context: 'Expérience',
    rating: 5,
    text: 'Bon service, équipe attentive et très sympathique. L\u2019expérience était géniale, j\u2019ai adoré.',
    sourceUrl: aggregate.google.url,
  },
  {
    initial: 'N',
    name: 'Nacho A.',
    source: 'TripAdvisor',
    date: 'août 2025',
    context: 'Couples',
    rating: 5,
    text: 'Tout à l\u2019heure et très aimables. Une expérience à vivre une fois dans sa vie, recommandée pour les jeunes comme pour les plus âgés.',
    sourceUrl: aggregate.trip.url,
  },
  {
    initial: 'C',
    name: 'Carlos S.',
    source: 'TripAdvisor',
    date: 'mai 2025',
    context: 'Amis',
    rating: 5,
    text: 'Ça vaut le coup. Tu as des vestiaires et tu peux te doucher après l\u2019activité. On te donne des consignes drôles, un bidon où mettre plein de choses et le reste, c\u2019est la rivière qui te le donne.',
    sourceUrl: aggregate.trip.url,
  },
];

// Profils de visiteurs récurrents dans les avis · mots qui reviennent souvent
const perfiles = [
  { tag: 'Familles',  nota: 'Avec enfants dès 5 ans',     words: ['attentifs avec les enfants', 'sécurité', 'consignes claires', 'animaux bienvenus'] },
  { tag: 'Couples',   nota: 'Une fois dans la vie',       words: ['romantique', 'coucher de soleil', 'tranquillité', 'photos'] },
  { tag: 'Amis',      nota: 'Groupe · journée complète',  words: ['ambiance', 'guinguettes', 'amusant', 'douches'] },
  { tag: 'Retraités', nota: 'Rythme tranquille',          words: ['pour les seniors', 'sûr', 'paysage', 'contact chaleureux'] },
];

const faqs = [
  { q: 'Où puis-je lire tous les avis sur la descente du Sella ?',
    a: 'Nous avons <strong>147 avis réels</strong> répartis entre <strong><a href="' + aggregate.google.url + '" target="_blank" rel="noopener">Google</a></strong> (127 avis · 4,5 étoiles) et <strong><a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a></strong> (20 avis · 4,8 étoiles). Sur cette page, nous mettons en avant les plus représentatifs, mais ils sont tous publics sur ces plateformes.' },
  { q: 'Tous les avis sont-ils réels et vérifiés ?',
    a: 'Oui. <strong>Nous n\u2019achetons ni ne fabriquons d\u2019avis</strong>. Chacun provient d\u2019un client qui a vraiment descendu le Sella avec nous et a laissé volontairement son avis sur Google ou TripAdvisor. Tu verras donc un peu de tout : majoritairement 5 étoiles, quelques 4 et, très rarement, un avis critique auquel nous répondons publiquement.' },
  { q: 'Comment laisser mon avis après la descente ?',
    a: 'Le plus simple : après l\u2019activité, nous t\u2019envoyons un message avec le lien direct Google. Tu peux aussi le laisser sur <a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a> en cherchant « Aventura en el Sella · Arriondas ». <strong>Ça nous aide énormément</strong> — c\u2019est ce qui fait que les autres nous font confiance.' },
  { q: 'Comment répondez-vous aux avis négatifs ?',
    a: 'Avec honnêteté et en public. Nous répondons à <strong>tous</strong> les avis critiques depuis le panneau Google Business, en reconnaissant ce que nous n\u2019avons pas bien fait et en expliquant ce que nous avons changé. C\u2019est la seule façon de nous améliorer et que les futurs clients voient comment nous gérons les vrais problèmes.' },
  { q: 'Pourquoi la moyenne Google est de 4,5 et celle de TripAdvisor de 4,8 ?',
    a: 'Parce que ce sont des plateformes avec des profils d\u2019utilisateurs différents. Google reçoit plus de volume et une plus grande diversité d\u2019attentes ; TripAdvisor est plutôt utilisé par le voyageur qui planifie soigneusement et accorde plus d\u2019importance aux détails du service. <strong>La moyenne combinée est de 4,5★ sur 147 avis</strong> — le chiffre que nous utilisons sur tout le site.' },
  { q: 'Depuis combien d\u2019années collectez-vous des avis ?',
    a: 'Aventura en el Sella accumule <strong>des avis depuis plusieurs années</strong> de clients venus à différentes saisons. Ce volume et cette régularité, c\u2019est ce qui nous différencie des nouveaux opérateurs sans historique — <a href="' + getLocalePath('quienes_somos', lang) + '">découvre notre histoire</a>.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Avis réels sur la descente du Sella · 4,5★ · 147 avis vérifiés',
      description: '147 avis réels sur la descente du Sella avec Aventura en el Sella. 4,5 étoiles sur Google et 4,8 sur TripAdvisor.',
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Avis · Évaluations vérifiées',
      keywords: ['avis descente du Sella', 'avis canoë Sella', 'Aventura en el Sella avis', 'descente Sella avis', 'canoë Sella Arriondas avis'],
      about: 'Avis, évaluations et témoignages réels sur la descente du Sella en canoë depuis Arriondas',
      mentions: [
        { '@type': 'Thing', name: 'Avis Google', url: aggregate.google.url },
        { '@type': 'Thing', name: 'TripAdvisor', url: aggregate.trip.url },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'La Descente du Sella Asturies · Aventura en el Sella · Location de canoës',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acceso por Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: aggregate.global.rating_num,
        reviewCount: aggregate.global.total,
        bestRating: 5,
        worstRating: 1,
      },
      review: testimonios.map(t => ({
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5, worstRating: 1 },
        author: { '@type': 'Person', name: t.name },
        datePublished: t.date,
        reviewBody: t.text,
        publisher: { '@type': 'Organization', name: t.source },
      })),
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        aggregate.google.url,
        aggregate.trip.url,
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Avis',    item: canonicalUrl },
      ],
    },
  ],
};

const starSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/fr/avis/" translationKey="opiniones">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="opH" aria-labelledby="opH-title">
    <span class="opH__watermark" aria-hidden="true">4,5</span>

    <div class="opH__inner">
      <nav class="opH__breadcrumb" aria-label="Fil d\u2019Ariane">
        <a href="/fr/">Accueil</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Avis</span>
      </nav>

      <span class="opH__eyebrow">— Avis réels et vérifiés</span>

      <h1 id="opH-title" class="opH__title">
        Le Sella<br/>
        <span class="serif-italic">dans leurs propres mots.</span>
      </h1>

      <div class="opH__badge" aria-hidden="true">
        <span class="opH__badgeStars" set:html={Array(5).fill(starSvg).join('')}></span>
        <span class="opH__badgeRating">4,5</span>
        <span class="opH__badgeSep"></span>
        <span class="opH__badgeCount">147 avis vérifiés</span>
      </div>

      <p class="opH__lead">
        Pendant des années, le <strong>bouche-à-oreille des Asturies</strong> nous suffisait. Depuis peu, nous demandons activement de laisser un avis — d\u2019où ce volume modeste. Mais chacun des <strong>147 avis</strong> est <strong>réel, public et vérifiable</strong> sur Google et TripAdvisor.
      </p>

      <div class="opH__ctas">
        <a href={aggregate.google.url} class="opH__cta opH__cta--primary" target="_blank" rel="noopener noreferrer">Voir sur Google<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
        <a href={aggregate.trip.url} class="opH__cta opH__cta--ghost" target="_blank" rel="noopener noreferrer">Voir sur TripAdvisor<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
      </div>
    </div>
  </section>

  <section class="opB" aria-labelledby="opB-title">
    <div class="container container--xl">
      <header class="opB__header" data-reveal>
        <span class="opB__eyebrow">— La donnée brute</span>
        <h2 id="opB-title" class="opB__title">
          Deux plateformes<br/><span class="serif-italic">et une seule moyenne.</span>
        </h2>
        <p class="opB__lead">
          Transparence totale : voici les chiffres tels qu\u2019ils sont aujourd\u2019hui sur les fiches publiques.
        </p>
      </header>

      <div class="opB__grid">
        <article class="opB__card" data-reveal>
          <span class="opB__cardLabel">Google</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.google.rating}</strong>
          <span class="opB__cardCount">{aggregate.google.total} avis</span>
          <a href={aggregate.google.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Voir sur Google
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--trip" data-reveal data-reveal-delay="1">
          <span class="opB__cardLabel">TripAdvisor</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.trip.rating}</strong>
          <span class="opB__cardCount">{aggregate.trip.total} avis</span>
          <a href={aggregate.trip.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            Voir sur TripAdvisor
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--total" data-reveal data-reveal-delay="2">
          <span class="opB__cardLabel">Moyenne combinée</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.global.rating}</strong>
          <span class="opB__cardCount">{aggregate.global.total} avis au total</span>
          <span class="opB__cardNota">Pondérée entre les deux plateformes</span>
        </article>
      </div>
    </div>
  </section>

  <section class="opT" aria-labelledby="opT-title">
    <div class="container container--xl">
      <header class="opT__header" data-reveal>
        <span class="opT__eyebrow">— Ce qu\u2019ils disent après avoir descendu le Sella</span>
        <h2 id="opT-title" class="opT__title">
          Trois avis<br/><span class="serif-italic">qui résument ce que nous faisons.</span>
        </h2>
      </header>

      <div class="opT__grid">
        {testimonios.map((t, i) => (
          <article class="opT__card" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="opT__head">
              <span class="opT__avatar" aria-hidden="true">{t.initial}</span>
              <div class="opT__meta">
                <strong class="opT__name">{t.name}</strong>
                <span class="opT__src">{t.source} · {t.date}</span>
              </div>
              <span class="opT__tag">{t.context}</span>
            </div>
            <div class="opT__stars" aria-hidden="true" set:html={Array(t.rating).fill(starSvg).join('')}></div>
            <blockquote class="opT__quote">
              <span class="opT__mark" aria-hidden="true">“</span>
              {t.text}
            </blockquote>
            <a href={t.sourceUrl} class="opT__link" target="_blank" rel="noopener noreferrer">
              Voir sur {t.source}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="opP" aria-labelledby="opP-title">
    <div class="container container--xl">
      <header class="opP__intro" data-reveal>
        <span class="opP__eyebrow">— Par profil de visiteur</span>
        <h2 id="opP-title" class="opP__title">
          Quatre façons<br/><span class="serif-italic">de descendre le Sella.</span>
        </h2>
        <p class="opP__lead">
          En lisant les 147 avis, des schémas clairs apparaissent : le profil de ceux qui viennent et les mots qui reviennent le plus souvent.
        </p>
      </header>

      <div class="opP__panel">
        <ol class="opP__grid">
          {perfiles.map(p => (
            <li class="opP__cell">
              <div class="opP__cellBody">
                <h3 class="opP__cellName">{p.tag}</h3>
                <span class="opP__cellNota">{p.nota}</span>
                <ul class="opP__words">
                  {p.words.map(w => <li class="opP__word">“{w}”</li>)}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="opR" aria-label="Appel à l\u2019action · réserver la descente">
    <div class="container container--xl">
      <div class="opR__inner" data-reveal>
        <div class="opR__text">
          <span class="opR__eyebrow">— Aventura en el Sella</span>
          <h2 class="opR__title">Tu sais maintenant ce que pensent <span class="serif-italic">ceux qui l\u2019ont essayé.</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="opR__cta">
          <span>Réserver ma descente</span>
          <span class="opR__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="opX">
    <div class="container container--xl">
      <header class="opX__header" data-reveal>
        <span class="opX__eyebrow">— Avant de venir</span>
        <h2 class="opX__title">Prépare<br/><span class="serif-italic">ta descente du Sella.</span></h2>
      </header>

      <nav class="opX__list" aria-label="Pages liées">
        <a href={getLocalePath('precios', lang)} class="opX__item">
          <span class="opX__num">01</span>
          <h3 class="opX__t">Tarifs de la descente</h3>
          <p class="opX__p">30 € enfants · 40 € adultes · animaux gratuits. Tout inclus.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_ninos', lang)} class="opX__item">
          <span class="opX__num">02</span>
          <h3 class="opX__t">Avec enfants</h3>
          <p class="opX__p">Dès 5 ans · 1,15 m. Sécurité et rythme familial.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_perro', lang)} class="opX__item">
          <span class="opX__num">03</span>
          <h3 class="opX__t">Avec chien</h3>
          <p class="opX__p">Animaux gratuits. Gilet canin inclus.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('recorrido_mapa', lang)} class="opX__item">
          <span class="opX__num">04</span>
          <h3 class="opX__t">Parcours et carte</h3>
          <p class="opX__p">14,5 km · carte interactive · 8 étapes en chemin.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
      </nav>
    </div>
  </section>

  <section class="opF">
    <div class="container container--xl">
      <div class="opF__grid">
        <aside class="opF__aside" data-reveal>
          <span class="opF__eyebrow">— Questions fréquentes</span>
          <h2 class="opF__title">À propos des<br/><span class="serif-italic">avis.</span></h2>
          <p class="opF__lead">
            Comment nous gérons les avis, comment laisser le tien et ce qu\u2019il y a derrière les 4,5★.
            S\u2019il manque quelque chose, <a href={getLocalePath('contacto', lang)}>écris-nous</a>.
          </p>
        </aside>
        <div class="opF__list" data-reveal data-reveal-delay="2">
          {faqs.map((f, i) => (
            <details class="opFI" name="op-faq" open={i === 0}>
              <summary class="opFI__q">
                {f.q}
                <svg class="opFI__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="opFI__a" set:html={f.a} />
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="opCta" aria-labelledby="opCta-title">
    <div class="opCta__bg" aria-hidden="true">
      <Picture src="opiniones-cta" alt="" sizes="100vw" bare />
    </div>
    <div class="opCta__inner">
      <span class="opCta__eyebrow">— Sois le prochain avis</span>
      <h2 id="opCta-title" class="opCta__title">
        De la rivière<br/>
        <span class="serif-italic">à ta propre histoire.</span>
      </h2>
      <p class="opCta__lead">
        Descends le Sella avec nous et décide de ce que tu veux raconter. Réserve sans payer maintenant — <strong>paie par carte ou le jour où tu récupères le canoë</strong>.
      </p>
      <div class="opCta__ctas">
        <a href={getLocalePath('reservar', lang)} class="opCta__primary">
