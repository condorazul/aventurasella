---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Réservation Premium · descente du Sella tout inclus';
const description = 'Descente du Sella Premium · 40 € adulte · 30 € enfant · animaux gratuits. Tout inclus + pique-nique asturien (empanada au thon, petit pain asturien) en cadeau.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/reservation-premium/`;

// Ce qui est inclus · grille éditoriale 4×4 (13 articles, pique-nique pleine largeur dernière ligne)
const includesPremium = [
  { icon: 'parking',   name: 'Parking privé',             nota: 'Surveillé et gratuit · 300 places · camping-cars bienvenus · à côté de la base', highlight: false },
  { icon: 'canoa',     name: 'Canoë insubmersible',       nota: 'Système insubmersible · 1 à 3 places · homologué · entretien quotidien',         highlight: false },
  { icon: 'chaleco',   name: 'Gilet homologué',           nota: 'CHC obligatoire · tailles adulte et enfant · ajustement vérifié',                 highlight: false },
  { icon: 'pala',      name: 'Pagaie double',             nota: 'Double pale en aluminium · une par personne · légère et ergonomique',             highlight: false },
  { icon: 'neopreno',  name: 'Combinaison néoprène',      nota: 'Aux dates froides établies · protection thermique contre l\u2019eau froide',       highlight: false },
  { icon: 'bidon',     name: 'Bidon étanche',             nota: 'Tes affaires au sec toute la descente · téléphone · portefeuille · vêtements',    highlight: false },
  { icon: 'rampa',     name: 'Rampe d\u2019embarquement', nota: 'Optionnelle et gratuite · embarque par la rampe ou directement depuis la berge',  highlight: false },
  { icon: 'monitor',   name: 'Moniteur diplômé',          nota: 'Briefing sécurité · mini-cours de pagayage · équipe asturienne',                   highlight: false },
  { icon: 'transfer',  name: 'Transfert retour',          nota: 'On te récupère à Toraño (Mini) ou Fríes (Complet) et retour à la base',           highlight: false },
  { icon: 'duchas',    name: 'Vestiaires avec douches',   nota: 'Changement confortable avant et après · eau chaude à l\u2019arrivée',              highlight: false },
  { icon: 'taquilla',  name: 'Casiers avec clé',          nota: 'Tes affaires en sécurité · ce que d\u2019autres font payer, inclus dans le prix',  highlight: false },
  { icon: 'seguro',    name: 'Assurances obligatoires',   nota: 'Responsabilité civile et accidents · inclus sans coût supplémentaire',            highlight: false },
  { icon: 'picnic',    name: 'Pique-nique asturien',      nota: 'Empanada au thon · petit pain asturien · bouteille d\u2019eau 500 ml · dans le bidon', highlight: true  },
];

// Tarif actuel (confirmé 2026-04-10 · project_premium_strategy.md)
const tarifas = [
  { label: 'Adulte',   from: 13, to: 99, price: '40', unit: '€' },
  { label: 'Enfant',   from: 5,  to: 12, price: '30', unit: '€' },
  { label: 'Animaux', from: 0,  to: 0,  price: 'Gratuit', unit: '' },
];

// Témoignages réels (reference_reviews.md)
const testimonios = [
  { initial: 'N', name: 'Nacho A.',    source: 'TripAdvisor', date: 'août 2025',    context: 'Couples', rating: 5,
    text: 'Tout à l\u2019heure et très aimables. Une expérience à vivre une fois dans sa vie, recommandée pour les jeunes comme pour les plus âgés.' },
  { initial: 'C', name: 'Carlos S.',   source: 'TripAdvisor', date: 'mai 2025',     context: 'Amis',    rating: 5,
    text: 'Ça vaut le coup. Tu as des vestiaires et tu peux te doucher après l\u2019activité. On te donne des consignes drôles, un bidon où mettre plein de choses et le reste, c\u2019est la rivière qui te le donne.' },
  { initial: 'A', name: 'Anaïs Suárez', source: 'Google',    date: 'octobre 2025', context: 'Expérience', rating: 5,
    text: 'Bon service, équipe attentive et très sympathique. L\u2019expérience était géniale, j\u2019ai adoré.' },
];

const faqs = [
  { q: 'Que comprend exactement la réservation Premium de la descente du Sella ?',
    a: 'Tout ce qu\u2019il faut pour descendre le Sella sans souci : <strong>parking privé surveillé (300 places · camping-cars bienvenus), canoë insubmersible (1-3 places), gilet homologué, pagaie double, combinaison néoprène aux dates froides, bidon étanche, rampe d\u2019embarquement optionnelle (ou tu embarques depuis la berge), moniteur diplômé, transfert retour, vestiaires avec douches chaudes, casiers avec clé (que d\u2019autres facturent en supplément), assurances obligatoires et le <em>pique-nique asturien en cadeau</em></strong>. Ça fait 13 choses, toutes dans le prix. Pas d\u2019extras cachés.' },
  { q: 'Combien coûte la descente Premium ?',
    a: '<strong>40 € par adulte</strong> (à partir de 13 ans) et <strong>30 € par enfant</strong> (de 5 à 12 ans). Les <strong>animaux sont gratuits</strong>. Le prix est le même pour la Mini Sella (7 km) et la Descente Complète (14,5 km) — pas de surprise.' },
  { q: 'En quoi la Premium est-elle différente de la descente basique d\u2019autres opérateurs ?',
    a: 'Les concurrents de la vallée du Sella proposent généralement entre 15 et 35 € sans pique-nique, juste le canoë et le gilet. Notre <strong>réservation Premium coûte un peu plus cher mais inclut : parking privé surveillé, rampe d\u2019embarquement propre (optionnelle et gratuite, ou tu embarques depuis la berge), canoë à système insubmersible, combinaison néoprène aux dates froides, pique-nique asturien, transfert, vestiaires avec douches chaudes, <em>casiers avec clé</em> et assurances — toutes choses que d\u2019autres facturent à part ou ne proposent pas</strong>. C\u2019est la version sans surprises.' },
  { q: 'Que contient le pique-nique asturien ?',
    a: 'Cuisine asturienne traditionnelle : une <strong>empanada au thon</strong>, un <strong>petit pain asturien</strong> (chorizo enveloppé dans le pain) et une <strong>bouteille d\u2019eau 500 ml</strong>. Tout dans le bidon étanche pour arriver sec et frais. Tu peux en profiter où tu veux sur le parcours — sur une plage fluviale, sur une berge ou après le dernier rapide. <em>Le pique-nique est fixe et identique pour tous les clients — nous n\u2019avons pas d\u2019option végane ni végétarienne. Si tu as une allergie spécifique (gluten, fruits à coque...), préviens-nous à la réservation pour qu\u2019on te confirme les ingrédients.</em>' },
  { q: 'Dois-je choisir une heure de départ ?',
    a: 'Non. Ta réservation est <strong>Premium · horaire ouvert</strong> : arrive à nos installations d\u2019Arriondas <strong>quand cela t\u2019arrange entre 10h30 et 12h30</strong>, sans choisir une heure précise. C\u2019est un des <strong>avantages Premium</strong> · on t\u2019équipe à l\u2019arrivée et tu pars sur la rivière dès que tu es prêt. <strong>Exceptions</strong>: le samedi de la <a href="' + getLocalePath('descenso_internacional', lang) + '">Descente Internationale</a> a un départ unique à heure fixe · et si une tempête ou les conditions de la rivière exigent une heure précise ou un départ avec moniteur, on te prévient à l\u2019avance. La Confédération Hydrographique impose une fin de présence sur la rivière à 18h00.' },
  { q: 'Dois-je payer maintenant à la réservation ?',
    a: 'Non. Tu peux payer <strong>par carte à la réservation ou le jour où tu récupères le canoë</strong>. À toi de choisir.' },
  { q: 'Puis-je réserver le jour même ?',
    a: 'Oui — <strong>tant que le calendrier de réservation affiche des disponibilités</strong> pour ce jour. Notre recommandation honnête est de <strong>réserver à l\u2019avance</strong>, surtout en haute saison (juillet-août) et les week-ends, quand les places partent vite. Le <a href="' + getLocalePath('reservar', lang) + '">calendrier en ligne</a> t\u2019affiche les jours libres en temps réel. Réserver prend 2 minutes et <strong>tu n\u2019as rien à payer à ce moment-là</strong>.' },
  { q: 'Peut-on annuler la réservation Premium ?',
    a: 'Oui. Tu peux annuler ou changer de date jusqu\u2019à 48 heures avant sans frais. Si le temps ne permet pas ou si la Confédération Hydrographique ferme la rivière, nous reprogrammons ou remboursons l\u2019intégralité du montant.' },
  { q: 'Y a-t-il une option supérieure à Premium ?',
    a: 'Il n\u2019y a pas d\u2019autres catégories. <strong>Toutes nos réservations sont Premium</strong> — c\u2019est notre façon standard de faire : tout inclus, pique-nique en cadeau, sans plans trompeurs à plusieurs « niveaux ». Ce que tu vois, c\u2019est ce que tu obtiens.' },
  { q: 'Puis-je offrir une descente Premium ?',
    a: 'Oui, c\u2019est parfait comme <strong>cadeau d\u2019anniversaire, de mariage ou d\u2019expérience</strong>. Tu réserves la date et nous émettons une carte cadeau au nom du bénéficiaire. <a href="' + getLocalePath('contacto', lang) + '">Écris-nous</a> et on s\u2019en occupe.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Réservation Premium de la descente du Sella — Tout Inclus + Pique-nique Asturien',
      description: 'Réservation Premium de la descente du Sella : 40 € adulte, 30 € enfant, animaux gratuits, pique-nique asturien inclus. Tout dans le prix.',
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      about: 'Descente du Sella Premium tout inclus avec pique-nique asturien depuis Arriondas',
    },
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descente du Sella · Réservation Premium',
      description: 'Descente du Sella en canoë tout inclus avec pique-nique asturien en cadeau (empanada au thon, petit pain asturien et eau). Depuis Arriondas, 14,5 km (Complet) ou 7 km (Mini Sella).',
      image: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      aggregateRating: { '@type': 'AggregateRating', ratingValue: 4.5, reviewCount: 147, bestRating: 5, worstRating: 1 },
      offers: [
        { '@type': 'Offer', name: 'Adulte', price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/fr/reserver/` },
        { '@type': 'Offer', name: 'Enfant', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/fr/reserver/` },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',              item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Réservation Premium',  item: canonicalUrl },
      ],
    },
  ],
};

const iconPaths = {
  parking:  '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M10 8v8M10 8h3.5a2.5 2.5 0 0 1 0 5H10"/>',
  canoa:    '<path d="M3 14c3 3 7 4 9 4s6-1 9-4"/><path d="M5 14l2-8h10l2 8"/><line x1="12" y1="6" x2="12" y2="14"/>',
  chaleco:  '<path d="M7 4h10v4l-2 2v10H9V10L7 8z"/><line x1="9" y1="14" x2="15" y2="14"/>',
  neopreno: '<path d="M8 4l-2 2v4l2 1v11h8V11l2-1V6l-2-2zM10 4v2h4V4"/>',
  pala:     '<line x1="5.5" y1="12" x2="18.5" y2="12"/><ellipse cx="3" cy="12" rx="2.5" ry="4.5"/><ellipse cx="21" cy="12" rx="2.5" ry="4.5"/>',
  rampa:    '<line x1="3" y1="20" x2="21" y2="20"/><path d="M5 20V13h14v7"/><path d="M3 10c3 2 6 2 9 0s6-2 9 0"/>',
  bidon:    '<path d="M8 4h8v3H8zM7 7h10v14H7zM7 12h10M7 17h10"/>',
  transfer: '<rect x="3" y="8" width="18" height="10" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/><line x1="3" y1="12" x2="21" y2="12"/>',
  duchas:   '<circle cx="7" cy="5" r="2"/><path d="M5 7v3h4V7M3 10h8M5 10v4M7 10v6M9 10v4"/>',
  taquilla: '<rect x="5" y="11" width="14" height="10" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/>',
  monitor:  '<circle cx="12" cy="8" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>',
  seguro:   '<path d="M12 3L5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  picnic:   '<path d="M4 11h16l-2 10H6z"/><path d="M8 11V6a4 4 0 0 1 8 0v5"/><line x1="10" y1="15" x2="10" y2="18"/><line x1="14" y1="15" x2="14" y2="18"/>',
};

const starSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/fr/reservation-premium/" translationKey="reserva_premium">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="rpH" aria-labelledby="rpH-title">
    <span class="rpH__watermark" aria-hidden="true">Premium</span>

    <div class="rpH__inner">
      <nav class="rpH__breadcrumb" aria-label="Fil d\u2019Ariane">
        <a href="/fr/">Accueil</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Réservation Premium</span>
      </nav>

      <div class="rpH__grid">
        <div class="rpH__main">
          <span class="rpH__eyebrow">— Pour ta journée parfaite sur le Sella</span>

          <h1 id="rpH-title" class="rpH__title">
            Tout le Sella.<br/>
            <span class="serif-italic">Sans rien à penser.</span>
          </h1>

          <div class="rpH__deluxe" aria-hidden="true">
            <span class="rpH__deluxeMark"></span>
            <span class="rpH__deluxeWord">Premium</span>
            <span class="rpH__deluxeMark"></span>
          </div>

          <p class="rpH__lead">
            La descente du Sella avec <strong>tout inclus</strong> — canoë, gilet, pagaie, bidon, transfert, douches chaudes et <strong>pique-nique asturien en cadeau</strong>. Un seul tarif honnête, sans extras, sans surprise.
          </p>

          <div class="rpH__stats">
            <span class="rpH__statsKicker">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Tout inclus · sans extras
            </span>
            <div class="rpH__statsRow">
              <div class="rpH__stat">
                <strong>40<small>€</small></strong>
                <span>Adulte</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>30<small>€</small></strong>
                <span>Enfant · 5–12</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>Gratuit</strong>
                <span>Animaux</span>
              </div>
            </div>
          </div>

          <div class="rpH__ctas">
            <a href={getLocalePath('reservar', lang)} class="rpH__cta rpH__cta--primary">
              Réserver maintenant
              <span class="rpH__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
            <a href="#rpH-incluye" class="rpH__cta rpH__cta--ghost">
              Voir ce qui est inclus
            </a>
          </div>
        </div>

        <aside class="rpH__contact" aria-labelledby="rpH-contact-kicker">
          <span class="rpH__contactKicker" id="rpH-contact-kicker">— On parle ?</span>
          <ul class="rpH__contactList" role="list">
            <li>
              <a href="tel:+34681093673" class="rpH__contactPill rpH__contactPill--primary" aria-label="Appeler le 681 09 36 73">
                <strong>Appelle-nous</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Bonjour%2C%20j%27ai%20une%20question%20sur%20la%20R%C3%A9servation%20Premium" target="_blank" rel="noopener noreferrer" class="rpH__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Réponse en minutes</small>
              </a>
            </li>
            <li>
              <a href="mailto:reservas@aventuraenelsella.es" class="rpH__contactPill" aria-label="Email">
                <strong>Email</strong>
                <small>Réservations et questions</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="rpQ" aria-labelledby="rpQ-title">
    <div class="container container--xl">
      <div class="rpQ__grid">
        <header class="rpQ__head" data-reveal>
          <span class="rpQ__eyebrow">— Premium chez nous, c\u2019est quoi</span>
          <h2 id="rpQ-title" class="rpQ__title">
            Pas plus cher.<br/>
            <span class="serif-italic">Tout inclus.</span>
          </h2>
        </header>
        <div class="rpQ__body" data-reveal data-reveal-delay="1">
          <p class="rpQ__lead">
            « Premium » ici n\u2019est pas pompeux ni chic. Ça veut dire <strong>un seul tarif honnête</strong> avec tout ce qu\u2019il faut absolument dans le canoë — et un <strong>pique-nique asturien qui t\u2019attend</strong> dans le bidon étanche.
          </p>
          <p class="rpQ__lead">
            Les opérateurs de la vallée du Sella facturent entre 15 et 35 € pour le canoë de base. Notre tarif de <strong>40 € par adulte</strong> n\u2019est que quelques euros de plus, mais il inclut ce que d\u2019autres te vendent comme extras ou ne proposent pas : <strong>parking privé surveillé</strong>, canoë insubmersible, <strong>rampe d\u2019embarquement propre</strong> (optionnelle et gratuite), combinaison néoprène aux dates froides, bidon, transfert, vestiaires avec douches chaudes, <strong>casiers avec clé</strong>, assurances et le <strong>pique-nique asturien</strong>. <em>Sans surprise à la fin de la journée.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rpI" id="rpH-incluye" aria-labelledby="rpI-title">
    <div class="container container--xl">
      <header class="rpI__header" data-reveal>
        <span class="rpI__eyebrow">— 13 choses incluses</span>
        <h2 id="rpI-title" class="rpI__title">
          Ce qui entre<br/>
          <span class="serif-italic">dans la réservation Premium.</span>
        </h2>
        <p class="rpI__lead">
          Tout ce qui est sur la liste est dans le prix. Rien n\u2019est facturé en plus. <strong>Rien.</strong>
        </p>
      </header>

      <ol class="rpI__grid">
        {includesPremium.map((item, i) => (
          <li class={`rpI__cell${item.highlight ? ' is-highlight' : ''}`}>
            <span class="rpI__cellNum" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rpI__cellBody">
              <span class="rpI__cellIcon" aria-hidden="true">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[item.icon]} />
              </span>
              <h3 class="rpI__cellName">{item.name}</h3>
              <p class="rpI__cellNota">{item.nota}</p>
              {item.highlight && <span class="rpI__cellBadge">CADEAU</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="rpB" aria-label="Appel à l\u2019action · réserver Premium">
    <div class="container container--xl">
      <div class="rpB__inner" data-reveal>
        <div class="rpB__text">
          <span class="rpB__eyebrow">— Aventura en el Sella</span>
          <h2 class="rpB__title">Prêt pour la rivière <span class="serif-italic">et le pique-nique ?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rpB__cta">
          <span>Réserver maintenant</span>
          <span class="rpB__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="rpP" aria-labelledby="rpP-title">
    <div class="container container--xl">
      <div class="rpP__split">
        <div class="rpP__media" data-reveal data-reveal-type="slide-right">
          <Picture src="fiesta-sella" alt="Ambiance et pique-nique asturien sur la descente du Sella · Réservation Premium tout inclus" sizes="(min-width: 960px) 45vw, 100vw" bare />
          <span class="rpP__mediaTag">Inclus · Cadeau</span>
        </div>
        <div class="rpP__body" data-reveal data-reveal-delay="1">
          <span class="rpP__eyebrow">— Ce qui fait la différence</span>
          <h2 id="rpP-title" class="rpP__title">
            Pique-nique asturien<br/>
            <span class="serif-italic">dans le bidon.</span>
          </h2>
          <p class="rpP__lead">
            Cuisine asturienne pure : une <strong>empanada au thon</strong>, un <strong>petit pain asturien</strong> (chorizo enveloppé dans le pain) et une <strong>bouteille d\u2019eau 500 ml</strong>. Simple, honnête, savoureux — dans le bidon étanche pour qu\u2019il arrive sec et frais.
          </p>
