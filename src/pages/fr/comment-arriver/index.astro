---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Comment arriver à Arriondas · À 50 m des gares routière et ferroviaire';
const description = "Comment arriver à Arriondas pour la descente du Sella : à 50 m des gares routière et ferroviaire. Voiture (A-8, A-64), bus ALSA ou train Renfe. Parking 300 places + camping-cars.";

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/comment-arriver/`;
const ogImage = '/images/optimized/como-llegar-cta-lg.jpg';

// Villes d'origine les plus pertinentes · distances par route (itinéraires recommandés)
const ciudades = [
  { c: 'Oviedo',    km: 52,  tiempo: '50 min',     ruta: 'A-64 + N-634',      destacado: true  },
  { c: 'Gijón',     km: 75,  tiempo: '55 min',     ruta: 'A-8 + AS-114',       destacado: true  },
  { c: 'Santander', km: 160, tiempo: '1 h 55 min', ruta: 'A-8',                destacado: false },
  { c: 'Bilbao',    km: 255, tiempo: '2 h 45 min', ruta: 'A-8',                destacado: false },
  { c: 'Madrid',    km: 440, tiempo: '4 h 30 min', ruta: 'A-6 + A-66 + A-64',  destacado: false },
];

// 3 moyens de transport en onglets
const medios = [
  {
    id: 'coche',
    tab: 'En voiture',
    eyebrow: 'En voiture',
    route: "L'option la plus flexible",
    stats: [
      { v: '52',  u: 'km',  l: "d'Oviedo" },
      { v: '75',  u: 'km',  l: 'de Gijón' },
      { v: 'A-8', u: '',    l: 'autoroute' },
    ],
    desc: "Le moyen le plus confortable d'arriver à Arriondas est <strong>en voiture par l'A-8</strong> (autoroute du Cantabrique) depuis Santander, Bilbao ou Gijón, ou par l'<strong>A-64 + N-634</strong> depuis Oviedo. Les accès sont bien signalés, la dernière partie passe par une route secondaire (AS-114 ou N-634) qui traverse de magnifiques villages asturiens. À côté de nos bureaux, nous disposons d'un <strong>parking privé et surveillé de 300 places — aussi pour les camping-cars</strong>, gratuit et sans restrictions.",
    features: ['A-8 autoroute', 'A-64 directe Oviedo', 'AS-114 depuis Gijón', 'Parking gratuit', 'Flexibilité totale', 'Sans horaires'],
    photo: 'como-llegar-coche',
    badges: ['Flexible', 'Direct', 'Confortable'],
  },
  {
    id: 'bus',
    tab: 'En bus',
    eyebrow: 'Bus ALSA',
    route: 'Économique et fréquent',
    stats: [
      { v: '~1h15', u: '',  l: "d'Oviedo" },
      { v: '~1h06', u: '',  l: 'de Gijón' },
      { v: 'Dès 6€', u: '', l: 'aller simple' },
    ],
    desc: "<strong>ALSA</strong> relie Arriondas aux principales villes asturiennes. Depuis <strong>Oviedo (gare Pepe Cosmen)</strong>, il y a <strong>~20 bus par jour</strong> (env. toutes les 30 min, premier service 06:25 et dernier 22:15), durée ~1 h 15 min. Depuis <strong>Gijón</strong>, il y a 4 services directs par jour, durée ~1 h 06 min. L'arrêt à Arriondas se trouve à la <strong>gare routière</strong>, à quelques minutes à pied de nos bureaux. Consulte et achète sur <a href=\"https://www.alsa.com\" target=\"_blank\" rel=\"noopener noreferrer\">alsa.com</a>.",
    features: ['~20 services/jour Oviedo', '4 services/jour Gijón', 'Dès 6€ aller simple', 'Gare centrale', 'Sans voiture', 'Achat en ligne'],
    photo: 'como-llegar-bus',
    badges: ['ALSA', 'Fréquent', 'Économique'],
  },
  {
    id: 'tren',
    tab: 'En train',
    eyebrow: 'Renfe Cercanías AM',
    route: 'Voyage panoramique en Asturies',
    stats: [
      { v: '~1h50', u: '',  l: "d'Oviedo" },
      { v: '3/jour', u: '', l: 'fréquence' },
      { v: 'Dès 5€', u: '', l: 'aller simple' },
    ],
    desc: "La ligne <strong>Renfe Cercanías AM</strong> (ancienne FEVE) d'Oviedo à Llanes <strong>fait un arrêt à Arriondas</strong>. Trajet plus lent mais très panoramique à travers des paysages asturiens : <strong>~1 h 50 min</strong>, premier train vers 07:57 et dernier vers 19:07, <strong>3 services par jour</strong>. Dès 5 € le trajet. La gare d'Arriondas est au centre du village. Consulte les horaires actualisés sur <a href=\"https://www.renfe.com/es/es/cercanias/cercanias-am\" target=\"_blank\" rel=\"noopener noreferrer\">renfe.com/cercanias-am</a>.",
    features: ['Cercanías AM', '3 trains/jour', 'Dès 5€ aller simple', 'Gare au centre', 'Paysage panoramique', 'Sans voiture'],
    photo: 'como-llegar-tren',
    badges: ['Renfe', 'Panoramique', 'Tranquille'],
  },
];

// Conseils pratiques (6)
const consejos = [
  { t: 'Horaires ouverts · 10h30–12h30', s: "Comme ta réservation est <strong>Premium</strong>, les horaires sont ouverts : arrive à nos installations <strong>quand cela t'arrange entre 10h30 et 12h30</strong>, sans devoir choisir une heure précise. Nous t'équipons à l'arrivée et tu pars sur le fleuve dès que tu es prêt." },
  { t: 'Haute saison · évite les ponts', s: "En juillet et août, surtout les week-ends, l'A-8 peut être très chargée vers les Asturies. Si tu viens de Madrid ou Santander, pars tôt ou envisage l'arrivée la veille au soir." },
  { t: 'Parking privé · 300 places', s: "Nous disposons d'un <strong>parking privé et surveillé, gratuit, d'une capacité de 300 voitures et aussi pour les camping-cars</strong>. Sans souci — laisse la voiture et nous nous occupons du reste." },
  { t: "Bus · achète à l'avance", s: "En haute saison, les billets ALSA s'épuisent. Achète <strong>1 à 2 jours avant</strong> en ligne si tu viens en bus depuis Oviedo ou Gijón, surtout en août." },
  { t: 'Train · vérifie les fréquences', s: 'La ligne Renfe Cercanías AM a <strong>peu de fréquences par jour</strong> (3-4 services). Vérifie les horaires aller et retour avant de planifier ta journée.' },
  { t: 'Depuis Madrid · envisage dormir près', s: 'Si tu viens de Madrid, il faut compter <strong>4 h 30 en voiture</strong>. Il peut être plus confortable de dormir la veille à Oviedo, Gijón ou Cangas de Onís et descendre le Sella frais le lendemain.' },
];

// FAQ spécifique comment arriver (8) · données vérifiées avec ALSA et Renfe officiel
const faqs = [
  { q: 'Comment se rendre à Arriondas depuis Oviedo ?',
    a: "Depuis Oviedo, il faut compter <strong>environ 52 km · 50 min en voiture</strong> par l'A-64 et la N-634. En bus avec <strong>ALSA</strong>, ~20 services quotidiens depuis la gare Pepe Cosmen (dès 6 €, durée ~1 h 15 min, premier bus 06:25 et dernier 22:15). En train <strong>Renfe Cercanías AM</strong>, ~1 h 50 min, avec 3 services par jour dès 5 €." },
  { q: 'Et depuis Gijón ?',
    a: "Depuis Gijón, il faut compter <strong>environ 75 km · 55 min en voiture</strong> par l'A-8 et l'AS-114. En <strong>bus ALSA</strong>, il y a <strong>4 services directs par jour</strong>, avec une durée de ~1 h 06 min et des prix dès 7 €. Achète tes billets sur <a href=\"https://www.alsa.com\" target=\"_blank\" rel=\"noopener noreferrer\">alsa.com</a>." },
  { q: 'Y a-t-il un parking au bureau ? Acceptez-vous les camping-cars ?',
    a: "Oui. Nous disposons d'un <strong>parking privé et surveillé de 300 places</strong> à côté de nos bureaux de réception à Arriondas, <strong>gratuit et également adapté aux camping-cars</strong>. Tu n'auras aucun souci pour laisser la voiture pendant la descente — et le transfert retour te dépose au même endroit." },
  { q: 'Y a-t-il des gens qui viennent sans voiture à la descente du Sella ?',
    a: "Beaucoup. Une part importante de nos clients arrive en <strong>bus ALSA</strong> ou en <strong>train Renfe Cercanías AM</strong> depuis Oviedo ou Gijón. Notre boutique est à <strong>seulement 50 mètres à pied</strong> tant de la <strong>gare routière</strong> que de la <strong>gare ferroviaire</strong> d'Arriondas — pratiquement une arrivée <strong>porte à porte</strong>. Partir d'Oviedo en bus et commencer la descente du Sella sans quitter le centre d'Arriondas est tout à fait faisable." },
  { q: "Jusqu'à quelle heure pouvons-nous arriver ?",
    a: "Ta réservation est <strong>Premium · horaires ouverts</strong>. Arrive à nos installations <strong>quand cela t'arrange entre 10h30 et 12h30</strong>, sans obligation de respecter une heure précise — c'est un avantage Premium. Nous t'équipons à l'arrivée et tu pars sur le fleuve dès que tu es prêt. La <strong>Confédération Hydrographique du Cantabrique</strong> impose que <strong>dernière sortie du fleuve à 18h00</strong> · c'est pourquoi nous fermons les arrivées à 12h30 (marge de sécurité). Exceptions : le samedi de la <a href=\"/fr/descente-internationale-du-sella/\">Descente Internationale</a> a un départ unique à une heure précise · et s'il y a une tempête ou des conditions de fleuve nécessitant une entrée avec moniteur, nous t'avertissons à l'avance." },
  { q: 'Quelle est la distance depuis Madrid ?',
    a: "Madrid est à <strong>environ 440 km · 4 h 30 min en voiture</strong> par l'A-6 (jusqu'à Benavente), l'A-66 (Ruta de la Plata) et l'A-64 (Oviedo → Arriondas). Beaucoup de voyageurs préfèrent dormir la veille en Asturies — Oviedo, Gijón ou Cangas de Onís — pour commencer la journée de la descente frais." },
  { q: 'Combien y a-t-il de bus/trains par jour entre Oviedo et Arriondas ?',
    a: "<strong>ALSA : ~20 bus quotidiens</strong> (env. toutes les 30 min). <strong>Renfe Cercanías AM : 3 trains par jour</strong>. Le bus est plus rapide (~1 h 15 min) et fréquent ; le train est plus panoramique (~1 h 50 min). Les deux s'arrêtent à Arriondas, au centre du village." },
  { q: 'Puis-je laisser des sacs à dos ou des bagages avant la descente ?',
    a: "Oui. Dans nos bureaux, tu peux laisser de petits bagages ou des sacs à dos pendant la descente. À ton retour avec notre transfert, tu auras accès à des <strong>vestiaires avec douches chaudes</strong> pour te changer avant de continuer ta journée." },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Comment arriver à Arriondas · Voiture, bus et train',
      description: "Guide complet pour arriver à Arriondas pour la descente du Sella : voiture, bus ALSA et train Renfe depuis les principales villes du nord de l'Espagne. Parking privé 300 places aussi pour les camping-cars.",
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/como-llegar-cta-lg.jpg`, width: 1920, height: 1080 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified:  '2026-05-12',
      articleSection: 'Planification · Comment arriver',
      keywords: ['comment arriver à Arriondas', 'comment arriver au Sella', 'descente du Sella sans voiture', 'gare routière Arriondas', 'gare ferroviaire Arriondas', 'parking Arriondas descente Sella', 'camping-cars Arriondas', 'ALSA Oviedo Arriondas', 'Renfe Cercanías AM Arriondas', 'distance Oviedo Arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: "Comment arriver à Arriondas (Asturies) pour la descente du Sella en canoë" },
    },
    {
      '@type': 'Place',
      '@id': `${canonicalUrl}#place`,
      name: 'Aventura en el Sella · Arriondas',
      description: "Installations d'Aventura en el Sella à Arriondas (Asturies). Parking privé et surveillé de 300 places, également pour les camping-cars. Vestiaires avec douches chaudes.",
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        addressCountry: 'ES',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude:  43.3874223,
        longitude: -5.1866022,
      },
      sameAs: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      url: canonicalUrl,
      amenityFeature: [
        { '@type': 'LocationFeatureSpecification', name: 'À 50 m de la gare routière (ALSA)',           value: true },
        { '@type': 'LocationFeatureSpecification', name: 'À 50 m de la gare ferroviaire (Renfe Cercanías AM)', value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Parking privé · 300 places',                  value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Camping-cars admis',                          value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Vestiaires avec douches chaudes',             value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Casiers à clé',                               value: true },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',         item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Comment arriver', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/fr/comment-arriver/" translationKey="como_llegar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · Editorial con signpost card (distinto) ============== -->
  <section class="clh" aria-labelledby="clh-title">

    <div class="clh__shapes" aria-hidden="true">
      <span class="clh__shape clh__shape--1"></span>
      <span class="clh__shape clh__shape--2"></span>
    </div>
    <span class="clh__watermark" aria-hidden="true">Arriondas</span>

    <div class="clh__inner">
      <div class="clh__left">
        <nav class="clh__breadcrumb" aria-label="Fil d'Ariane">
          <a href={getLocalePath('home', lang)}>Accueil</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Comment arriver</span>
        </nav>
        <span class="clh__eyebrow">— Comment arriver à Arriondas</span>
        <h1 id="clh-title" class="clh__title">
          Comment arriver<br/>
          <span class="serif-italic">à Arriondas.</span>
        </h1>
        <p class="clh__lead">
          Arriondas se trouve dans le <strong>centre oriental des Asturies</strong>, à 50 km d'Oviedo et
          75 km de Gijón. Bien connectée en voiture (A-8 et A-64), en bus ALSA et en train Renfe.
          Notre boutique est à <strong>50 mètres à pied des gares routière et ferroviaire</strong> ·
          porte à porte depuis Oviedo, Gijón ou Llanes.
        </p>
        <div class="clh__ctas">
          <a href="#clh-medios" class="clh__cta clh__cta--primary">Voir les moyens de transport</a>
          <a href={getLocalePath('reservar', lang)} class="clh__cta clh__cta--link">
            Réserver descente
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <aside class="clh__signpost" aria-label="À 50 mètres des gares routière et ferroviaire d'Arriondas">
        <header class="clh__sigHead">
          <span class="clh__sigKicker">— Sans voiture · sans problème</span>
          <h2 class="clh__sigT">À <span class="clh__sigBig">50&nbsp;m</span><br/><span class="serif-italic">des gares</span></h2>
          <p class="clh__sigLead">
            Notre boutique est à <strong>50 mètres à pied</strong> tant de la <strong>gare routière</strong>
            que de la <strong>gare ferroviaire</strong> d'Arriondas. Arrivée porte à porte depuis Oviedo, Gijón ou Llanes.
          </p>
        </header>
        <ul class="clh__sigList">
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><circle cx="8.5" cy="15" r="1" fill="currentColor"/><circle cx="15.5" cy="15" r="1" fill="currentColor"/><path d="M7 19l-2 2"/><path d="M17 19l2 2"/></svg>
              <span>Gare routière · ALSA</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 12h18"/><path d="M7 19l-2 3"/><path d="M17 19l2 3"/><circle cx="8" cy="16" r="1" fill="currentColor"/><circle cx="16" cy="16" r="1" fill="currentColor"/></svg>
              <span>Gare ferroviaire · Renfe AM</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="7" rx="1"/><path d="M5 11l2-5h10l2 5"/><circle cx="7.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg>
              <span>Parking propre · 300 places</span>
            </span>
            <span class="clh__sigKm"><strong>0</strong><small> m</small></span>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ============== 2 · Distancias cards (grid 5) ============== -->
  <section class="cld">
    <div class="container container--xl">
      <header class="cld__header" data-reveal>
        <span class="cld__eyebrow">— Distance en voiture</span>
        <h2 class="cld__title">
          Depuis les principales<br/>
          <span class="serif-italic">villes du nord.</span>
        </h2>
        <p class="cld__lead">
          Km, temps estimé et itinéraires principaux depuis les origines les plus habituelles de nos
          clients. Sans trafic dense et en respectant les limites, bien sûr.
        </p>
      </header>

      <ol class="cld__grid">
        {ciudades.map((c, i) => (
          <li class="cld__item" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="cld__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="cld__city">{c.c}</span>
            <div class="cld__stats">
              <div class="cld__stat">
                <strong>{c.km}<small>km</small></strong>
                <span>distance</span>
              </div>
              <div class="cld__stat">
                <strong>{c.tiempo}</strong>
                <span>en voiture</span>
              </div>
            </div>
            <p class="cld__route">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {c.ruta}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 3 · TABS 3 MEDIOS (Coche / Bus / Tren) ============== -->
  <section id="clh-medios" class="clt" aria-labelledby="clt-title">
    <div class="container container--xl">
      <header class="clt__head" data-reveal>
        <div class="clt__headL">
          <span class="clt__kicker">— Moyens de transport</span>
          <h2 id="clt-title" class="clt__title">
            Choisis ta<br/>
            <span class="serif-italic">façon d'arriver.</span>
          </h2>
        </div>
        <div class="clt__tabs" role="tablist" aria-label="Choisir un moyen de transport">
          {medios.map((m, i) => (
            <button type="button" role="tab" id={`clt-tab-${m.id}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`clt-panel-${m.id}`}
                    class={`clt__tab${i === 0 ? ' is-active' : ''}`}
                    data-tab={m.id} tabindex={i === 0 ? 0 : -1}>
              {m.tab}
            </button>
          ))}
        </div>
      </header>

      <div class="clt__card" data-reveal data-reveal-delay="1">
        {medios.map((m, i) => (
          <div class={`clt__panel${i === 0 ? ' is-active' : ''}`}
               id={`clt-panel-${m.id}`} role="tabpanel"
               aria-labelledby={`clt-tab-${m.id}`} data-panel={m.id} hidden={i !== 0}>
            <div class="clt__content">
              <span class={`clt__eyebrow clt__eyebrow--${m.id}`}>{m.eyebrow}</span>
              <h3 class="clt__route">{m.route}</h3>
              <div class="clt__stats">
                {m.stats.map(s => (
                  <div class="clt__stat">
                    <strong>{s.v}<small>{s.u}</small></strong>
                    <span>{s.l}</span>
                  </div>
                ))}
              </div>
              <p class="clt__desc" set:html={m.desc} />
              <ul class="clt__features">{m.features.map(f => <li>{f}</li>)}</ul>
              <a href={getLocalePath('reservar', lang)} class="clt__cta">
                Réserver descente
                <span class="clt__ctaIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
            <div class="clt__photo">
