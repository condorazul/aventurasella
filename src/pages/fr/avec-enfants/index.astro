---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import Marquee from '@components/sections/Marquee.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Descente du Sella avec enfants · Aventure en famille';
const description = 'Descente du Sella avec enfants dès 5 ans et 1,15 m : sûre, en famille, tout inclus. Moniteurs diplômés. Réservez sans payer maintenant.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/avec-enfants/`;
const ogImage = '/images/optimized/peques-cta-lg.jpg';

// 6 étapes de la journée
const jornada = [
  { num: '01', title: 'Arrivée et accueil',         text: 'Nous vous accueillons dans nos installations d’Arriondas. Nous répondons aux doutes, vérifions votre réservation et expliquons le plan de la journée. <strong>Parking privé gratuit inclus</strong>.' },
  { num: '02', title: 'Équipement par taille',      text: 'Nous remettons canoë, pagaies, gilets de sauvetage homologués et <strong>matériel adapté à la taille de chaque enfant</strong>. En saison froide, néoprène enfant inclus.' },
  { num: '03', title: 'Mini-cours avec moniteur',   text: 'Avant d’entrer dans l’eau, <strong>les moniteurs diplômés</strong> expliquent comment pagayer, tourner, que faire si le canoë chavire et les consignes de sécurité. Adapté au niveau du groupe.' },
  { num: '04', title: 'Départ depuis la rampe',     text: 'Nous partons de notre rampe privée de 35 m à la rivière — un départ spectaculaire que les enfants adorent. Les enfants descendent <strong>dans un canoë partagé avec un adulte responsable</strong>.' },
  { num: '05', title: 'Pauses et baignades',        text: 'Il y a des plages fluviales tranquilles tout le long du parcours pour s’arrêter, manger le pique-nique, se baigner ou simplement se reposer. Sans hâte, <strong>à votre rythme familial</strong>.' },
  { num: '06', title: 'Retour en transfert',        text: 'À la fin, <strong>notre transfert vous récupère</strong> et vous ramène à Arriondas. Vestiaires avec douches chaudes et casiers vous attendent. Journée bouclée.' },
];

const llevar = [
  { icon: 'tshirt', t: 'Tenue confortable qui peut se mouiller', s: 'Maillot de bain + t-shirt technique ou coton fin' },
  { icon: 'shoe',   t: 'Chaussures sûres pour l’eau',             s: 'Chaussons, crocs avec sangle, vieilles baskets — pas de tongs lâches' },
  { icon: 'towel',  t: 'Serviette + change complet',              s: 'Pour vous changer après la douche à la fin' },
  { icon: 'sun',    t: 'Protection solaire résistante à l’eau',   s: 'SPF 50+ pour les enfants — le reflet de la rivière multiplie le soleil' },
  { icon: 'water',  t: 'Eau et un en-cas',                         s: 'Le pique-nique asturien, c’est nous, mais un extra pour les petits aide toujours' },
  { icon: 'kid',    t: 'Vêtements de rechange pour enfants',       s: 'Manches longues + pantalon long au cas où il rafraîchirait à la fin' },
];

const beneficios = [
  { t: 'Moniteurs diplômés',           s: 'Champions de la Descente Internationale, avec des années sur le Sella et de l’expérience avec les familles.' },
  { t: 'Tout inclus, sans extras',     s: 'Canoë, gilets, néoprène en saison, mini-cours, pique-nique, transfert, parking surveillé, vestiaires avec douches et casiers avec clé.' },
  { t: 'Rythme familial flexible',     s: 'Vous choisissez sur l’eau entre la Mini (Toraño, 7 km) et la Complète (Fríes, 14,5 km). Sans supplément pour changer.' },
  { t: 'Rampe privée · optionnelle',   s: 'Départ confortable depuis notre rampe de plus de 35 m — les petits adorent et ça rassure. Sinon, vous embarquez au niveau de la rivière.' },
  { t: 'Pique-nique apprécié des enfants', s: 'Empanada au thon, petit pain asturien et eau. Cuisine asturienne que les enfants mangent bien et qui donne de l’énergie pour la seconde moitié.' },
  { t: 'Animaux gratuits',             s: 'Si vous venez en famille avec le chien, il vient gratuitement dans le canoë. Toute la tribu ensemble.' },
  { t: 'Sans payer maintenant',        s: 'Réservez votre place sans avancer d’argent. Payez par carte avant ou le jour même en récupérant le canoë — comme vous préférez.' },
  { t: 'Modifier ou annuler',          s: 'Modifications et annulations flexibles avant le jour. Si vous avez payé par carte, remboursement avec 24 h de préavis.' },
];

const faqs = [
  { q: 'À partir de quel âge les enfants peuvent-ils descendre le Sella ?',
    a: 'Les mineurs peuvent participer à partir de <strong>5 ans révolus et 1,15 m de hauteur minimum</strong>. C’est une <strong>exigence stricte de sécurité</strong> — non seulement pour le gilet, mais aussi pour les compagnies d’assurance et la nature de la rivière (courant, profondeur variable, sections avec rapides doux). Les mineurs n’atteignant pas le minimum ne sont pas admis, même accompagnés d’un adulte ou sachant nager.' },
  { q: 'La descente du Sella est-elle sûre avec les enfants ?',
    a: 'Oui, lorsqu’elle est faite avec une entreprise expérimentée et un matériel adéquat. Les enfants descendent <strong>toujours dans un canoë partagé avec un adulte responsable</strong>, avec gilet de sauvetage homologué par taille, après un mini-cours préalable avec un moniteur diplômé. Le Sella sur sa section touristique est une <strong>rivière calme</strong>, pas du white-water — courant tranquille avec quelques rapides classe I très modérés. La grande majorité des descentes se déroulent sans incidents.' },
  { q: 'Faut-il savoir nager ?',
    a: 'Oui. <strong>Savoir nager est une obligation légale</strong> pour tous les participants, y compris les enfants. Le gilet de sauvetage est une aide, pas un substitut. Il est aussi important que l’enfant <strong>n’ait pas peur de l’eau</strong> et suive les indications du moniteur. Si votre petit ne nage pas encore avec aisance, mieux vaut attendre une autre saison.' },
  { q: 'Combien dure la descente avec enfants ?',
    a: 'Cela dépend de la route et du rythme familial. La <strong>Mini Sella</strong> (Arriondas → Toraño, 7 km) dure <strong>2-3 h</strong> et est la plus recommandée avec les jeunes enfants. La <strong>Complète</strong> (Arriondas → Fríes, 14,5 km) dure <strong>4-5 h</strong> — idéale pour les enfants à partir de 8-9 ans avec bonne disposition. Vous choisissez sur l’eau, pas à la réservation.' },
  { q: 'Peut-on s’arrêter pendant le parcours ?',
    a: 'Oui, et c’est l’un des meilleurs aspects de la descente en famille. Il y a des <strong>plages fluviales tranquilles</strong> le long de la rivière où vous pouvez vous arrêter pour manger le pique-nique, vous baigner, vous reposer ou simplement contempler. Pas d’horaires ni de hâte — vous fixez le rythme.' },
  { q: 'Que faire si le petit se fatigue ou veut s’arrêter ?',
    a: 'Pas de souci. Si l’enfant se fatigue, <strong>les adultes peuvent continuer à pagayer</strong> et l’enfant se repose dans le canoë. Si la route choisie est trop longue, sur la Complète il y a une halte intermédiaire à <strong>Toraño</strong> (km 7) où vous pouvez terminer — il suffit de prévenir notre équipe à l’arrivée. Le prix et ce qui est inclus ne changent pas.' },
  { q: 'Que se passe-t-il s’il pleut ?',
    a: 'L’activité a lieu de la même manière — descendre le Sella sous une pluie légère a son charme. Elle n’est suspendue que pour <strong>raisons objectives de sécurité</strong> (crue, orage). Dans ce cas, <strong>changement de date gratuit ou remboursement intégral</strong>.' },
  { q: 'Convient-elle aux enfants qui n’ont jamais fait de canoë ?',
    a: 'Parfaitement. <strong>Aucune expérience préalable n’est nécessaire</strong>. Nos canoës sont à <strong>fond plat et très stables</strong>, et avant de partir vous recevez un bref briefing technique avec des moniteurs diplômés pour apprendre à manier la pagaie. La grande majorité des familles qui descendent le Sella avec nous n’ont jamais pagayé auparavant — les premières minutes sur l’eau donnent déjà confiance.' },
  { q: 'Avez-vous des vestiaires et douches chaudes ?',
    a: 'Oui. À la fin du parcours et au retour en transfert, vous disposez de <strong>vestiaires avec douches d’eau chaude, casiers avec clé et toilettes</strong>. Vous pouvez vous changer tranquillement avant de continuer la journée ou rentrer à l’hôtel/appartement.' },
  { q: 'Combien coûte la descente du Sella avec enfants ?',
    a: `<strong>30 € par enfant</strong> (5-12 ans, partageant un canoë avec un adulte) et <strong>40 € par adulte</strong> (à partir de 13 ans). C’est <strong>prix par personne</strong>, pas par canoë. Tout inclus, sans extras, animaux gratuits. Vous pouvez <a href="${getLocalePath('precios', 'fr')}">voir le détail complet sur la page des tarifs</a>.` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descente du Sella avec enfants : comment organiser la journée en famille',
      description: 'Guide complet pour la descente du Sella avec enfants : âge minimum 5 ans et 1,15 m, sécurité, quoi apporter, durée, prix et déroulement de la journée.',
      inLanguage: 'fr-FR',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/peques-cta-lg.jpg`,
        width: 1920,
        height: 1080,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-17',
      dateModified:  '2026-05-12',
      articleSection: 'Famille',
      keywords: ['descente du sella avec enfants', 'descente du sella en famille', 'canoë avec enfants sella', 'arriondas enfants', 'âge minimum descente sella'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Descente du Sella avec enfants · aventure familiale en Asturies' },
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Descente du Sella avec enfants',
      description: 'Activité de descente du Sella en canoë adaptée aux familles avec enfants dès 5 ans et 1,15 m. Tout inclus : canoë, gilet de sauvetage, mini-cours avec moniteur diplômé, pique-nique asturien, transfert retour et vestiaires avec douches chaudes.',
      serviceType: 'Descente du Sella en famille',
      category: 'Tourisme actif · Familles',
      url: canonicalUrl,
      provider: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturies' },
      audience: { '@type': 'PeopleAudience', suggestedMinAge: 5, audienceType: 'Familles avec enfants' },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'EUR',
        lowPrice: '30.00',
        highPrice: '40.00',
        offerCount: 2,
        availability: 'https://schema.org/InStock',
        url: `${baseUrl}/fr/reserver/`,
        offers: [
          { '@type': 'Offer', name: 'Enfant (5-12 ans)',  price: '30.00', priceCurrency: 'EUR', url: `${baseUrl}/fr/reserver/` },
          { '@type': 'Offer', name: 'Adulte (13+ ans)',   price: '40.00', priceCurrency: 'EUR', url: `${baseUrl}/fr/reserver/` },
        ],
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil',       item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Avec enfants',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/fr/avec-enfants/" translationKey="con_ninos">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="cnh" aria-labelledby="cnh-title">

    <div class="cnh__inner">
      <nav class="cnh__breadcrumb" aria-label="Breadcrumb">
        <a href="/fr/">Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Avec enfants</span>
      </nav>

      <span class="cnh__eyebrow">
        <span class="cnh__eyebrow-dot" aria-hidden="true"></span>
        En famille · Saison 2026
      </span>

      <h1 id="cnh-title" class="cnh__title">
        Descente du Sella<br/>
        <span class="serif-italic">avec <span class="cnh__underlined">enfants<svg class="cnh__swoosh" width="200" height="18" viewBox="0 0 200 18" fill="none" aria-hidden="true"><path d="M3 14C30 6 74 4 118 8c27 2.5 54 6 78 4" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/></svg></span></span>
      </h1>

      <p class="cnh__lead">
        <strong>Aventure en famille dans les Asturies</strong>. Une journée sûre, organisée et
        adaptée au rythme des petits — avec moniteurs diplômés, tout l’équipement
        enfant inclus et une rivière pensée pour profiter ensemble.
      </p>

      <div class="cnh__stats">
        <div class="cnh__stat">
          <span class="cnh__stat-value">5 ans</span>
          <span class="cnh__stat-label">+ 1,15 m · âge minimum</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">30 €</span>
          <span class="cnh__stat-label">Par enfant · tout inclus</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">4.5 ⭐</span>
          <span class="cnh__stat-label">147 avis</span>
        </div>
      </div>

      <div class="cnh__ctas">
        <a href={getLocalePath('reservar', 'fr')} class="cnh__cta cnh__cta--primary">
          Réserver en famille
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+34681093673" class="cnh__cta cnh__cta--phone" aria-label="Appeler le 681 093 673">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Appeler</span>
        </a>
        <a href={getLocalePath('precios', 'fr')} class="cnh__cta cnh__cta--ghost">
          Voir tarifs et formules
        </a>
      </div>
    </div>
  </section>

  <!-- ============== INTRO · Peut-on ? ============== -->
  <section class="cni">
    <div class="container container--xl">
      <div class="cni__grid">
        <div class="cni__content" data-reveal>
          <span class="cni__eyebrow">— La question habituelle</span>
          <h2 class="cni__title">
            Peut-on faire la descente<br/>
            du Sella <span class="serif-italic">avec des enfants ?</span>
          </h2>

          <div class="cni__answer">
            <span class="cni__yes" aria-hidden="true">Oui.</span>
            <div class="cni__prose">
              <p class="cni__lead">
                <strong>Oui, et c’est l’une des meilleures façons de profiter des Asturies en famille.</strong> C’est
                un plan en plein air, très visuel, excitant et adaptable au rythme des
                petits. Avec une bonne organisation, du matériel à la taille et des moniteurs diplômés,
                la journée devient un souvenir qu’on a envie de répéter.
              </p>
              <p class="cni__text">
                La clé n’est pas dans la rivière, elle est dans <strong>la préparation de l’activité</strong> : gilet
                homologué par taille, mini-cours avant le départ, canoë partagé avec un
                adulte, pauses sans hâte et une équipe qui vous récupère à la fin pour que la
                logistique ne soit pas une charge. C’est ce que nous faisons.
              </p>
            </div>
          </div>
        </div>

        <aside class="cni__polaroids" data-reveal data-reveal-delay="2" aria-hidden="true">
          <figure class="cni__polaroid cni__polaroid--1">
            <div class="cni__polaroidImg">
              <Picture src="peques-polaroid-1" alt="Famille avec enfants descendant ensemble le Sella en canoë" sizes="220px" aspectRatio="4 / 5" bare />
            </div>
            <figcaption class="cni__polaroidCap">En famille</figcaption>
          </figure>

          <figure class="cni__polaroid cni__polaroid--2">
            <div class="cni__polaroidImg">
              <Picture src="peques-polaroid-2" alt="Enfant pagayant avec une pagaie double sur la descente du Sella" sizes="220px" aspectRatio="4 / 5" bare />
            </div>
            <figcaption class="cni__polaroidCap">On pagaye ensemble</figcaption>
          </figure>

          <figure class="cni__polaroid cni__polaroid--3">
            <div class="cni__polaroidImg">
              <Picture src="peques-polaroid-3" alt="Enfants et adulte naviguant tranquillement sur le Sella" sizes="220px" aspectRatio="4 / 5" bare />
            </div>
            <figcaption class="cni__polaroidCap">Sans hâte</figcaption>
          </figure>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== JOURNÉE · 6 étapes ============== -->
  <section class="cnj">
    <div class="container container--xl">
      <header class="cnj__header" data-reveal>
        <span class="cnj__eyebrow">— Comment se passe la journée</span>
        <h2 class="cnj__title">
          Une journée sur le Sella,<br/>
          <span class="serif-italic">étape par étape</span>
        </h2>
        <p class="cnj__lead">
          Savoir comment se déroule la journée aide les familles à se décider. Voici le
          déroulé habituel de l’expérience — <strong>sans hâte, sans surprises</strong>.
        </p>
      </header>

      <ol class="cnjL">
        {jornada.map((j, i) => (
          <li class="cnjItem" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="cnjItem__num" aria-hidden="true">{j.num}</span>
            <div class="cnjItem__body">
              <h3 class="cnjItem__title">{j.title}</h3>
              <p class="cnjItem__text" set:html={j.text} />
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- ============== SÉCURITÉ ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Sécurité et confiance</span>
        <h2 class="cns__title">
          Ce qui inquiète les parents,<br/>
          <span class="serif-italic">et comment nous le résolvons</span>
        </h2>
        <p class="cns__lead">
          La première question de toute famille est <strong>« est-ce sûr ? »</strong> — et elle est
          logique. La réponse courte est oui, lorsque c’est fait avec bon sens,
          matériel adéquat et explication claire avant le départ.
        </p>
      </header>

      <ol class="cns__grid">
        <li class="cns__item" data-reveal data-reveal-delay="1">
          <span class="cns__num" aria-hidden="true">01</span>
          <h3 class="cns__itemTitle">Gilets homologués par taille</h3>
          <p class="cns__itemText">Gilets enfants spécifiques, vérifiés et adaptés. <strong>Pas de génériques</strong>.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="2">
          <span class="cns__num" aria-hidden="true">02</span>
          <h3 class="cns__itemTitle">Moniteurs diplômés et champions du Sella</h3>
          <p class="cns__itemText"><strong>Pas des stagiaires d’été</strong>. Des années à descendre la rivière avec des familles.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="3">
          <span class="cns__num" aria-hidden="true">03</span>
          <h3 class="cns__itemTitle">Canoë partagé avec un adulte responsable</h3>
          <p class="cns__itemText">L’enfant n’est jamais seul. <strong>Il y a toujours quelqu’un aux commandes</strong>.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="4">
          <span class="cns__num" aria-hidden="true">04</span>
          <h3 class="cns__itemTitle">Le Sella touristique est une rivière calme</h3>
          <p class="cns__itemText"><strong>Pas du white-water</strong>. Courant tranquille avec quelques rapides classe I modérés.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="5">
          <span class="cns__num" aria-hidden="true">05</span>
          <h3 class="cns__itemTitle">Assurance obligatoire incluse</h3>
          <p class="cns__itemText"><strong>Couverture complète</strong> pour toute la famille pendant l’activité.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="6">
          <span class="cns__num" aria-hidden="true">06</span>
          <h3 class="cns__itemTitle">Mini-cours avant le départ</h3>
          <p class="cns__itemText">Comment pagayer, comment s’arrêter et les consignes de base de la rivière, expliquées avant d’entrer dans l’eau. <strong>Personne ne part sans savoir quoi faire</strong>.</p>
        </li>
      </ol>

      <div class="cns__cta" data-reveal>
        <a href={getLocalePath('reservar', 'fr')} class="cns__ctaBtn">
          <span>Réserver en 2 minutes</span>
          <span class="cns__ctaBtnIcon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== ÂGE MINIMUM + EXIGENCES ============== -->
  <section class="cnr">
    <div class="container container--xl">
      <header class="cnr__header" data-reveal>
        <span class="cnr__eyebrow">— Âge et conditions</span>
        <h2 class="cnr__title">
          Ce qu’il faut savoir<br/>
          <span class="serif-italic">avant de réserver</span>
        </h2>
      </header>

      <div class="cnrG">
