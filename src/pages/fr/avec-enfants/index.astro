      linear-gradient(90deg, rgba(251, 248, 241, 0.045) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 30% 20%, black 10%, transparent 70%);
  }
  .cnh__inner {
    position: relative; z-index: 1;
    max-width: 1000px; margin: 0 auto;
    padding: clamp(7rem, 14vw, 10rem) clamp(1.5rem, 4vw, 4rem) clamp(2rem, 4vw, 3rem);
  }
  .cnh__breadcrumb {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-sans); font-size: 0.6875rem;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(251, 248, 241, 0.45);
    margin-bottom: var(--s-8);
  }
  .cnh__breadcrumb a {
    color: rgba(251, 248, 241, 0.7);
    transition: color 200ms;
  }
  .cnh__breadcrumb a:hover { color: var(--color-primary-soft, #F4B5A3); }

  .cnh__eyebrow {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    background: rgba(251, 248, 241, 0.1);
    border: 1px solid rgba(251, 248, 241, 0.22);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: #FBF8F1;
    margin-bottom: var(--s-6);
  }
  .cnh__eyebrow-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: cnhPulse 2.2s ease-in-out infinite;
  }
  @keyframes cnhPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(233, 133, 111, 0.55); }
    50%      { box-shadow: 0 0 0 8px rgba(233, 133, 111, 0); }
  }


  .cnh__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    font-weight: 900; line-height: 0.98;
    letter-spacing: -0.02em; text-transform: uppercase;
    color: var(--color-text-on-dark);
    margin: 0 0 var(--s-5);
  }
  .cnh__title .serif-italic {
    color: var(--color-primary-soft, #F4B5A3); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }

  .cnh__lead {
    max-width: 620px;
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: rgba(251, 248, 241, 0.82);
    margin: 0 0 var(--s-6);
  }
  .cnh__lead strong { color: #FBF8F1; font-weight: 700; }

  .cnh__stats {
    display: flex; flex-wrap: wrap;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2rem);
    padding-block: var(--s-5);
    border-top: 1px solid rgba(251, 248, 241, 0.14);
    border-bottom: 1px solid rgba(251, 248, 241, 0.14);
    margin-bottom: var(--s-6);
  }
  .cnh__stat { display: flex; flex-direction: column; gap: 4px; }
  .cnh__stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-primary-soft, #F4B5A3);
  }

  /* Swoosh subrayado bajo "niños" */
  .cnh__underlined {
    position: relative;
    display: inline-block;
  }
  .cnh__swoosh {
    position: absolute;
    bottom: -0.12em; left: 50%;
    transform: translateX(-50%);
    width: 102%; height: auto;
    pointer-events: none;
    color: var(--color-primary);
  }
  .cnh__stat-label {
    font-family: var(--font-sans); font-size: 0.75rem;
    letter-spacing: 0.5px;
    color: rgba(251, 248, 241, 0.62);
  }
  .cnh__stat-divider {
    width: 1px; height: 32px;
    background: rgba(251, 248, 241, 0.14);
    display: none;
  }
  @media (min-width: 600px) { .cnh__stat-divider { display: block; } }

  .cnh__ctas {
    display: flex; flex-wrap: wrap; gap: var(--s-3);
  }
  .cnh__cta {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 1rem 1.5rem;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    transition: all 240ms cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  .cnh__cta--primary {
    background: var(--color-primary); color: #fff;
    box-shadow: 0 10px 28px rgba(233, 133, 111, 0.4);
  }
  .cnh__cta--primary:hover {
    background: var(--color-primary-hover, #D66F59);
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(233, 133, 111, 0.55);
  }
  .cnh__cta--ghost {
    background: rgba(251, 248, 241, 0.06);
    color: #FBF8F1;
    border: 1px solid rgba(251, 248, 241, 0.28);
  }
  .cnh__cta--ghost:hover {
    background: rgba(251, 248, 241, 0.12);
    border-color: rgba(251, 248, 241, 0.5);
  }
  .cnh__cta--phone {
    background: rgba(251, 248, 241, 0.06);
    color: #FBF8F1;
    border: 1px solid rgba(251, 248, 241, 0.28);
    gap: 0.5rem;
    letter-spacing: 0.3px;
  }
  .cnh__cta--phone:hover {
    background: rgba(251, 248, 241, 0.14);
    border-color: rgba(251, 248, 241, 0.5);
  }
  .cnh__cta--phone svg { transition: transform 260ms ease; }
  .cnh__cta--phone:hover svg { transform: rotate(-10deg); }
  .cnh__cta svg { transition: transform 200ms; }
  .cnh__cta:hover svg { transform: translateX(3px); }
  .cnh__cta--phone:hover svg { transform: rotate(-10deg); }

  @keyframes cniFloatSlow {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }
  /* ============== INTRO · ¿Se puede? ============== */
  .cni {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-base);
    overflow: hidden;
  }
  .cni__grid {
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
    max-width: 1200px; margin: 0 auto;
  }
  @media (min-width: 900px) {
    .cni__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  .cni__content { min-width: 0; }
  .cni__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cni__title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4.8vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .cni__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }

  .cni__answer {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }
  .cni__yes {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 10vw, 7rem);
    font-style: italic; font-weight: 400;
    line-height: 0.82;
    color: var(--color-sage, #3D4F3A);
    letter-spacing: -0.03em;
    margin-top: -0.08em;
    animation: cniFloatSlow 5.5s ease-in-out infinite;
  }
  .cni__prose {
    display: flex; flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .cni__lead {
    font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.75;
    color: var(--color-text-primary);
    margin: 0;
  }
  .cni__lead strong { color: var(--color-text-primary); font-weight: 700; }
  .cni__text {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.8;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cni__text strong { color: var(--color-text-primary); font-weight: 700; }

  /* Cluster de 3 polaroids a la derecha */
  .cni__polaroids {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    aspect-ratio: 1 / 1.15;
  }
  .cni__polaroid {
    position: absolute;
    width: clamp(150px, 44%, 210px);
    padding: 10px 10px 14px;
    background: #fff;
    border-radius: 4px;
    box-shadow:
      0 24px 44px rgba(26, 31, 46, 0.18),
      0 6px 14px rgba(26, 31, 46, 0.08);
    margin: 0;
  }
  .cni__polaroidImg {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 2px;
    margin-bottom: 8px;
  }
  .cni__polaroidImg :global(picture),
  .cni__polaroidImg :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    filter: saturate(0.96) contrast(1.02);
  }
  .cni__polaroidCap {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-align: center;
    letter-spacing: 0.2px;
  }

  /* Posiciones + rotaciones — dispersión natural tipo mesa */
  .cni__polaroid--1 {
    top: 0;
    right: 4%;
    z-index: 2;
    animation: cniFloat1 6.5s ease-in-out infinite;
  }
  .cni__polaroid--2 {
    top: 26%;
    left: 0;
    z-index: 3;
    animation: cniFloat2 7.8s ease-in-out infinite;
  }
  .cni__polaroid--3 {
    bottom: 0;
    right: 12%;
    z-index: 1;
    animation: cniFloat3 5.9s ease-in-out infinite;
  }

  @keyframes cniFloat1 {
    0%, 100% { transform: rotate(-7deg) translateY(0); }
    50%      { transform: rotate(-5deg) translateY(-10px); }
  }
  @keyframes cniFloat2 {
    0%, 100% { transform: rotate(5deg) translateY(0); }
    50%      { transform: rotate(7deg) translateY(-8px); }
  }
  @keyframes cniFloat3 {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50%      { transform: rotate(-1deg) translateY(-12px); }
  }

  @media (max-width: 899.98px) {
    /* En móvil el cluster se apila en columna con rotaciones sutiles */
    .cni__polaroids {
      aspect-ratio: auto;
      min-height: auto;
      display: flex; flex-direction: column; align-items: center;
      gap: 1.25rem;
      max-width: 280px;
    }
    .cni__polaroid--1,
    .cni__polaroid--2,
    .cni__polaroid--3 {
      position: static;
      width: 100%;
      animation: none;
    }
    .cni__polaroid--1 { transform: rotate(-3deg); }
    .cni__polaroid--2 { transform: rotate(2deg); }
    .cni__polaroid--3 { transform: rotate(-2deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cni__polaroid--1,
    .cni__polaroid--2,
    .cni__polaroid--3,
    .cni__yes,
    .cnh__eyebrow-dot { animation: none; }
  }

  /* ============== JORNADA ============== */
  .cnj { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnj__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .cnj__eyebrow,
  .cns__eyebrow,
  .cnr__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnj__title,
  .cns__title,
  .cnr__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cnj__title .serif-italic,
  .cns__title .serif-italic,
  .cnr__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cnj__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnj__lead strong { color: var(--color-text-primary); font-weight: 700; }

  .cnjL {
    list-style: none; padding: 0; margin: 0;
    counter-reset: cnj;
    display: grid; grid-template-columns: 1fr; gap: var(--s-4);
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 720px)  { .cnjL { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cnjL { grid-template-columns: repeat(3, 1fr); } }

  /* Card base · "radial fill hover" — un círculo sage crece desde el centro cubriendo la card.
     El texto cambia a crema para contraste. Patrón reusable en otras secciones. */
  .cnjItem {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    display: flex; flex-direction: column; gap: var(--s-3);
    overflow: hidden;
    isolation: isolate;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 360ms cubic-bezier(0.22, 1, 0.36, 1),
                border-color 360ms ease;
  }
  .cnjItem::before {
    content: "";
    position: absolute;
    top: 50%; left: 50%;
    width: 150%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%) scale(0);
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      #4A5E47 0%,
      #3D4F3A 45%,
      #2C3B2A 100%
    );
    transition: transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
    z-index: -1;
    pointer-events: none;
  }
  .cnjItem:hover::before {
    transform: translate(-50%, -50%) scale(1);
  }
  .cnjItem:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px rgba(61, 79, 58, 0.32);
    border-color: transparent;
  }

  .cnjItem__num {
    font-family: var(--font-display);
    font-size: 2.25rem; font-weight: 900;
    letter-spacing: -0.03em; line-height: 0.9;
    color: rgba(61, 79, 58, 0.22);
    transition: color 360ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }
  .cnjItem:hover .cnjItem__num {
    color: var(--color-primary-soft, #F4B5A3);
    transform: scale(1.08);
  }

  .cnjItem__title {
    font-family: var(--font-display); font-size: 1.125rem; font-weight: 800;
    line-height: 1.2; letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0;
    transition: color 360ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }
  .cnjItem:hover .cnjItem__title { color: #FBF8F1; }

  .cnjItem__text {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    transition: color 360ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }
  .cnjItem:hover .cnjItem__text { color: rgba(251, 248, 241, 0.9); }
  .cnjItem__text strong {
    color: var(--color-text-primary); font-weight: 700;
    transition: color 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cnjItem:hover .cnjItem__text strong { color: #FBF8F1; }

  @media (prefers-reduced-motion: reduce) {
    .cnjItem,
    .cnjItem::before,
    .cnjItem__num,
    .cnjItem__title,
    .cnjItem__text,
    .cnjItem__text strong { transition: none; }
    .cnjItem:hover { transform: none; }
    .cnjItem:hover::before { transform: translate(-50%, -50%) scale(1); }
  }

  /* ============== SEGURIDAD ============== */
  .cns { padding-block: clamp(5rem, 9vw, 7rem); background: var(--color-bg-base); }
  .cns__header {
    max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center;
  }
  .cns__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cns__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cns__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cns__lead {
    font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 auto;
    max-width: 640px;
  }
  .cns__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Grid 3×2 con número watermark sage muy tenue detrás del contenido */
  .cns__grid {
    list-style: none; padding: 0; margin: 0 auto clamp(3rem, 5vw, 4rem);
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.5rem);
    max-width: 1200px;
  }
  @media (min-width: 720px)  { .cns__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cns__grid { grid-template-columns: repeat(3, 1fr); } }

  .cns__item {
    position: relative;
    padding-top: clamp(3rem, 5vw, 4rem);
  }
  .cns__num {
    position: absolute;
    top: -0.15em;
    left: -0.08em;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 8vw, 7.5rem);
    line-height: 0.85;
    color: rgba(61, 79, 58, 0.12);
    letter-spacing: -0.04em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
  .cns__itemTitle {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 0.875rem;
  }
  .cns__itemText {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cns__itemText strong { color: var(--color-text-primary); font-weight: 700; }

  /* CTA oscuro con pill pattern (como el mock de referencia) */
  .cns__cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }
  .cns__ctaBtn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0.5rem 0.5rem 1.75rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.6px; text-transform: uppercase;
    transition: transform 260ms cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 260ms ease;
  }
  .cns__ctaBtn:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(26, 31, 46, 0.35);
  }
  .cns__ctaBtnIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #fff;
    color: var(--color-text-primary, #1A1F2E);
    transition: transform 260ms ease;
  }
  .cns__ctaBtn:hover .cns__ctaBtnIcon { transform: rotate(-12deg); }

  /* ============== REQUISITOS ============== */
  .cnr { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnr__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  .cnrG {
    display: grid; grid-template-columns: 1fr; gap: var(--s-4);
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 720px)  { .cnrG { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .cnrG { grid-template-columns: 1.3fr 1fr 1fr 1fr; }
    .cnrC--highlight { grid-row: span 2; }
  }

  .cnrC {
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    display: flex; flex-direction: column; gap: var(--s-2);
    transition: transform 280ms ease, box-shadow 280ms ease;
  }
  .cnrC:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px rgba(26, 31, 46, 0.08);
  }
  .cnrC--highlight {
    background: linear-gradient(160deg, #3D4F3A 0%, #2C3B2A 100%);
    color: #FBF8F1;
    border-color: transparent;
  }
  .cnrC__badge {
    display: inline-block; width: fit-content;
    padding: 4px 10px;
    background: var(--color-primary-soft, #F4B5A3);
    color: #1A1F2E;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.4px; text-transform: uppercase;
    margin-bottom: var(--s-2);
  }
  .cnrC__title {
    font-family: var(--font-display); font-size: 1.125rem; font-weight: 800;
    line-height: 1.2; letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-2);
  }
  .cnrC--highlight .cnrC__title { color: #FBF8F1; }
  .cnrC__big {
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 800;
    line-height: 1.1;
    color: #FBF8F1;
    margin: 0;
  }
  .cnrC__big strong {
    font-size: 2.25rem; font-weight: 900;
    color: var(--color-primary-soft, #F4B5A3);
    display: inline-block;
  }
  .cnrC__text {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnrC--highlight .cnrC__text {
    color: rgba(251, 248, 241, 0.85);
    margin-top: var(--s-3);
  }
  .cnrC__text strong { color: var(--color-text-primary); font-weight: 700; }
  .cnrC--highlight .cnrC__text strong { color: #FBF8F1; }

  /* ============== QUÉ LLEVAR ============== */
  .cnq { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .cnq__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .cnq__eyebrow,
  .cnb__eyebrow,
  .cnrev__eyebrow,
  .cnl__eyebrow,
  .cnf__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnq__title,
  .cnb__title,
  .cnrev__title,
  .cnl__title,
  .cnf__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cnq__title .serif-italic,
  .cnb__title .serif-italic,
  .cnrev__title .serif-italic,
  .cnl__title .serif-italic,
  .cnf__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cnq__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary); margin: 0;
  }
  .cnq__lead strong { color: var(--color-text-primary); font-weight: 700; }

  .cnqL {
    list-style: none; padding: 0;
    margin: clamp(2.5rem, 5vw, 3.5rem) auto clamp(2rem, 4vw, 3rem);
    /* margin-top mayor para que los iconos overlap tengan aire respecto al lead */
    display: grid; grid-template-columns: 1fr;
    gap: clamp(3rem, 5vw, 4rem) var(--s-3);
    /* row-gap mayor para que los iconos flotantes no se solapen entre filas */
    max-width: 1000px;
  }
  @media (min-width: 640px)  { .cnqL { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px)  { .cnqL { grid-template-columns: repeat(3, 1fr); } }

  /* Card cuadrada con "border trace hover" + icono en círculo overlap top-center con flip.
     Icono mitad fuera / mitad dentro al más puro estilo Envy/Smart Pest Control. */
  .cnqItem {
    position: relative;
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: clamp(3rem, 5vw, 3.75rem) clamp(1.5rem, 3vw, 2rem) clamp(1.75rem, 3vw, 2.25rem);
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: clamp(1.25rem, 2.5vw, 1.75rem);
    min-height: 200px;
    isolation: isolate;
    perspective: 800px;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 360ms cubic-bezier(0.22, 1, 0.36, 1),
                border-color 360ms ease;
  }
  .cnqItem:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 44px rgba(26, 31, 46, 0.09);
    border-color: transparent;
  }

  /* Border trace SVG */
  .cnqItem__trace {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }
  .cnqItem__trace rect {
    fill: none;
    stroke: var(--color-sage, #3D4F3A);
    stroke-width: 1.5;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 880ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cnqItem:hover .cnqItem__trace rect { stroke-dashoffset: 0; }

  /* Wrapper del icono — se encarga del posicionamiento (top center, overlap) */
  .cnqItem__iconWrap {
    position: absolute;
    top: 0; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
  }
  /* Icono — circulo sage con icono cream (flip 180° en Y al hover · invierte a blanco/sage) */
  .cnqItem__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 76px; height: 76px;
    border-radius: 50%;
    background: var(--color-sage, #3D4F3A);
    color: #FBF8F1;
    border: 1px solid rgba(61, 79, 58, 0.18);
    box-shadow:
      0 14px 32px rgba(61, 79, 58, 0.24),
      0 5px 12px rgba(61, 79, 58, 0.14);
    transform-style: preserve-3d;
    transition: transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
                background 360ms ease,
                color 360ms ease,
                box-shadow 360ms ease;
  }
  .cnqItem:hover .cnqItem__icon {
    transform: rotateY(180deg);
    background: #fff;
    color: var(--color-sage, #3D4F3A);
    border-color: rgba(61, 79, 58, 0.1);
    box-shadow:
      0 16px 34px rgba(26, 31, 46, 0.14),
      0 6px 14px rgba(61, 79, 58, 0.1);
  }

  .cnqItem__body { position: relative; z-index: 2; width: 100%; }
  .cnqItem__t {
    font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin: 0 0 8px;
  }
  .cnqItem__s {
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .cnqItem,
    .cnqItem__trace rect,
    .cnqItem__icon { transition: none; }
    .cnqItem:hover { transform: none; }
  }
  .cnq__note {
    max-width: 860px; margin: 0 auto;
    display: flex; align-items: flex-start; gap: var(--s-2);
    padding: var(--s-3) var(--s-4);
    background: rgba(61, 79, 58, 0.06);
    border-left: 2px solid var(--color-sage, #3D4F3A);
    border-radius: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.6;
    color: var(--color-text-secondary);
  }
  .cnq__note svg { color: var(--color-sage, #3D4F3A); flex-shrink: 0; margin-top: 3px; }
  .cnq__note strong { color: var(--color-text-primary); font-weight: 700; }

  /* ============== BENEFICIOS ============== */
  .cnb { padding-block: clamp(5rem, 9vw, 7rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnb__header { max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center; }
  .cnb__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnb__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }
  .cnb__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }

  .cnb__list {
    list-style: none; padding: 0; margin: 0 auto;
    max-width: 1080px;
    display: grid; grid-template-columns: 1fr;
    column-gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 760px) { .cnb__list { grid-template-columns: 1fr 1fr; } }

  .cnbItem {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
    align-items: start;
    padding: clamp(1.5rem, 2.8vw, 2rem) 0;
    border-bottom: 1px solid rgba(26, 31, 46, 0.08);
  }
  /* Última fila: sin border-bottom */
  .cnbItem:nth-last-child(-n+2) { border-bottom: none; }
  @media (max-width: 759.98px) {
    .cnbItem:last-child { border-bottom: none; }
    .cnbItem:nth-last-child(-n+2) { border-bottom: 1px solid rgba(26, 31, 46, 0.08); }
    .cnbItem:last-child { border-bottom: none; }
  }

  .cnbItem__num {
    font-family: var(--font-serif);
    font-style: italic; font-weight: 400;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    line-height: 0.88;
    color: var(--color-sage, #3D4F3A);
    letter-spacing: -0.02em;
    opacity: 0.85;
    min-width: 2.5ch;
  }
  .cnbItem__body { min-width: 0; padding-top: 0.35em; }
  .cnbItem__t {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    font-weight: 800; line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 0.375rem;
  }
  .cnbItem__s {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }


  /* ============== OPINIONES ============== */
  .cnrev { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .cnrev__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .cnrev__rating {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-sans); font-size: 0.875rem;
    color: var(--color-text-secondary);
    padding: 8px 16px;
    background: var(--color-bg-warm, #F5F1E8);
    border-radius: 999px;
  }
  .cnrev__rating strong { color: var(--color-text-primary); font-weight: 800; }
  .cnrev__stars { display: inline-flex; gap: 1px; color: #E8B339; }

  .cnrevG {
    display: grid; grid-template-columns: 1fr; gap: var(--s-4);
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 760px)  { .cnrevG { grid-template-columns: repeat(3, 1fr); } }
  .cnrevC {
    position: relative;
    padding: clamp(1.75rem, 2.8vw, 2.25rem);
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 1.25rem;
    display: flex; flex-direction: column; gap: var(--s-4);
  }
  .cnrevC__quote {
    color: rgba(61, 79, 58, 0.16);
  }
  .cnrevC__text {
    font-family: var(--font-serif); font-size: 1rem; line-height: 1.65;
    color: var(--color-text-primary);
    font-style: italic;
    margin: 0;
    flex: 1;
  }
  .cnrevC__text strong { font-style: normal; font-weight: 700; }
  .cnrevC__meta {
    display: flex; flex-direction: column; gap: 2px;
    padding-top: var(--s-3);
    border-top: 1px solid var(--color-border-subtle);
  }
  .cnrevC__name {
    font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700;
    color: var(--color-text-primary);
  }
  .cnrevC__src {
    font-family: var(--font-sans); font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.3px;
  }

  /* ============== INTERLINKING ============== */
  .cnl { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnl__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  .cnlG {
    display: grid; grid-template-columns: 1fr; gap: clamp(1rem, 2vw, 1.5rem);
    max-width: 1100px; margin: 0 auto;
    counter-reset: cnlCount;
  }
  @media (min-width: 720px)  { .cnlG { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cnlG { grid-template-columns: repeat(4, 1fr); } }

  /* Card editorial · transparente sobre warm cream · counter Fraunces italic + arrow svg circular */
  .cnlC {
    counter-increment: cnlCount;
    position: relative;
    display: flex; flex-direction: column; gap: 0.65rem;
    padding: clamp(1.5rem, 2.6vw, 1.9rem);
    background: transparent;
    border: 1px solid rgba(61, 79, 58, 0.16);
    border-radius: clamp(1.25rem, 2.5vw, 1.75rem);
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
                border-color 320ms ease,
                box-shadow 360ms ease,
                background 360ms ease;
    text-decoration: none;
    overflow: hidden;
    min-height: 240px;
  }
  /* Counter "01" Fraunces italic coral · ancla editorial top-left */
  .cnlC::before {
    content: counter(cnlCount, decimal-leading-zero);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-primary);
    letter-spacing: 0.04em;
    opacity: 0.95;
    margin-bottom: 0.15rem;
    transition: color 280ms ease;
  }
  .cnlC:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.4);
    box-shadow: 0 18px 42px -22px rgba(26, 31, 46, 0.18);
  }
  .cnlC:hover::before {
    color: var(--color-primary-active, #c85c44);
  }
  .cnlC__eyebrow {
    font-family: var(--font-sans); font-size: 0.66rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-primary);
  }
  .cnlC__t {
    font-family: var(--font-display); font-size: clamp(1.05rem, 1.5vw, 1.175rem); font-weight: 800;
    line-height: 1.25; letter-spacing: -0.008em;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
    transition: color 280ms ease;
  }
  .cnlC:hover .cnlC__t { color: var(--color-primary); }
  .cnlC__s {
    font-family: var(--font-sans); font-size: 0.86rem; line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }
  /* Arrow svg en círculo sage subtle · hover invierte a coral fill */
  .cnlC__arrow {
    margin-top: auto;
    align-self: flex-start;
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-sage-subtle, #e8ece6);
    color: var(--color-sage, #3D4F3A);
    transition: background 320ms ease, color 320ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cnlC:hover .cnlC__arrow {
    background: var(--color-primary);
    color: #fff;
    transform: translateX(6px);
  }

  /* ============== FAQ ============== */
  .cnf { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .cnf__grid {
    display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 5vw, 4rem);
    max-width: 1200px; margin: 0 auto;
  }
  @media (min-width: 960px) { .cnf__grid { grid-template-columns: 1fr 1.3fr; } }

  .cnf__aside { position: sticky; top: 6rem; align-self: start; display: flex; flex-direction: column; gap: clamp(2rem, 3.5vw, 2.5rem); }
  @media (max-width: 959.98px) { .cnf__aside { position: static; } }

  /* ¿Tienes más preguntas? · sin caja · hairline top como separador editorial */
  .cnfMore {
    background: transparent;
    border-radius: 0;
    border-top: 1px solid var(--color-border-subtle);
    padding: clamp(1.5rem, 2.6vw, 1.9rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .cnfMore__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .cnfMore__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 1.7rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin: 0;
    text-transform: none;
  }
  .cnfMore__title .serif-italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-sage, #3d4f3a);
    letter-spacing: 0;
  }
  .cnfMore__lead {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 0.4rem;
  }
  .cnfMore__channels {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .cnfMore__ch {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.9rem 0.7rem 0.7rem;
    background: #fff;
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background 280ms ease, transform 280ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 280ms ease;
  }
  .cnfMore__ch:hover {
    background: var(--color-text-primary);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 14px 32px -18px rgba(26, 31, 46, 0.28);
  }
  .cnfMore__chIcon {
    width: 36px; height: 36px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-sage-subtle, #e8ece6);
    color: var(--color-sage, #3d4f3a);
    transition: background 280ms ease, color 280ms ease;
  }
  .cnfMore__ch--wa .cnfMore__chIcon {
    background: rgba(37, 211, 102, 0.16);
    color: #25D366;
  }
  .cnfMore__ch:hover .cnfMore__chIcon {
    background: var(--color-primary);
    color: #fff;
  }
  .cnfMore__chBody {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
  }
  .cnfMore__chBody strong {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.005em;
  }
  .cnfMore__chBody small {
    font-size: 0.74rem;
