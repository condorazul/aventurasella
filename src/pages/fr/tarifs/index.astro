---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'fr';
const title = 'Tarifs de la descente du Sella · À partir de 30 € tout inclus';
const description = 'Tarifs de la descente du Sella : 30 € enfants · 40 € adultes. Tout inclus (canoë, pique-nique, transfert, parking). Animaux gratuits. Réservez sans payer maintenant.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/fr/tarifs/`;

const incluido = [
  { icon: 'canoe',    title: 'Canoës K1, K2 et K3',            sub: 'Insubmersibles, avec pagaie et bidon étanche' },
  { icon: 'shield',   title: 'Gilet de sauvetage',             sub: 'Homologué, adapté à la taille' },
  { icon: 'wetsuit',  title: 'Combinaison néoprène',           sub: 'Sauf du 15/06 au 28/09' },
  { icon: 'teacher',  title: 'Mini-cours + moniteurs',         sub: 'Diplômés et champions du Sella' },
  { icon: 'picnic',   title: 'Pique-nique asturien',           sub: 'Empanada au thon, petit pain asturien et eau' },
  { icon: 'bus',      title: 'Transfert retour',               sub: 'Depuis Toraño ou Fríes' },
  { icon: 'shower',   title: 'Vestiaires avec douches',        sub: 'Casiers avec clé inclus' },
  { icon: 'parking',  title: 'Parking privé',                  sub: '300 places · surveillé · camping-cars' },
  { icon: 'paw',      title: 'Animaux gratuits',               sub: 'Toute la famille en canoë' },
  { icon: 'ticket',   title: 'Assurance obligatoire',          sub: 'Couverture complète incluse' },
  { icon: 'ramp',     title: "Rampe d'embarquement",           sub: 'Optionnelle et gratuite · ou embarquement au bord de l’eau' },
  { icon: 'heart',    title: 'Un accueil chaleureux',          sub: 'Sans files, sans robots, sans extras' },
];

const rutas = [
  {
    name: 'Mini Sella',   km: '7 km',   dur: '2 – 3 h',   desc: 'Parcours court d’Arriondas à Toraño. Idéal avec des petits, si vous voulez faire beaucoup de pauses ou préférez une descente tranquille.', tone: 'sage',
  },
  {
    name: 'Parcours complet', km: '14,5 km', dur: '4 – 5 h',  desc: 'Parcours classique d’Arriondas à Fríes. Plus de kilomètres, plus de paysages, plus de pauses pour se baigner. L’expérience la plus complète.', tone: 'coral',
  },
];

const faqs = [
  { q: 'Combien coûte la descente du Sella ?',
    a: `Descendre le Sella en canoë avec nous coûte <strong>40 € par adulte</strong> (à partir de 13 ans) et <strong>30 € par enfant</strong> (de 5 à 12 ans). Le prix est <strong>tout inclus</strong> : canoë insubmersible, gilet, pagaie double, néoprène en dates froides, bidon étanche, mini-cours avec moniteur diplômé, pique-nique asturien (empanada au thon, petit pain asturien et eau), transfert retour, <strong>parking privé surveillé (300 places · aussi pour camping-cars)</strong>, vestiaires avec douches, casiers avec clé et assurance. <strong>Animaux gratuits</strong>. Le seul jour avec un tarif différent est le samedi de la <a href="${getLocalePath('descenso_internacional', 'fr')}">Descente Internationale du Sella</a> — 35 € avec conditions particulières.` },
  { q: 'Le prix est par personne ou par canoë ?',
    a: 'Le prix est <strong>par personne</strong>, pas par canoë. Si vous êtes deux adultes partageant un K2, vous payez <strong>40 € chacun</strong>. Si vous êtes trois dans un K3, c’est pareil — partager le canoë ne change pas le tarif individuel.' },
  { q: 'Le parcours Mini coûte-t-il pareil que le Complet ?',
    a: 'Oui — <strong>une seule réservation, un seul prix</strong>. Vous choisissez le parcours sur l’eau, pas à la réservation. Vous pouvez partir en pensant faire le Complet et vous arrêter à Toraño (km 7) si l’envie vous prend, ou commencer en pensant à la Mini et continuer jusqu’à Fríes. Ni le prix ni ce qui est inclus ne changent.' },
  { q: 'Y a-t-il des réductions pour les groupes ?',
    a: 'Pour les groupes de <strong>10 personnes ou plus</strong>, nous appliquons des conditions spéciales. Écrivez-nous par <a href="https://wa.me/34681093673?text=Bonjour,%20nous%20sommes%20un%20groupe%20de...">WhatsApp</a> ou <a href="mailto:info@aventuraenelsella.es">email</a> avec le nombre de personnes et la date approximative, et nous vous préparons une offre personnalisée.' },
  { q: 'Comment paie-t-on ? Faut-il payer à l’avance ?',
    a: `Réservez <strong>sans payer maintenant</strong>. Choisissez ce qui vous convient le mieux : <strong>paiement par carte à l’avance</strong> ou <strong>paiement le jour même au retrait du canoë</strong>. La seule exception est <a href="${getLocalePath('descenso_internacional', 'fr')}">le samedi de la Descente Internationale</a>, qui se réserve uniquement avec paiement anticipé.` },
  { q: 'Puis-je changer la date ou annuler ?',
    a: 'Vous pouvez <strong>changer ou annuler à tout moment avant le jour de l’activité</strong>, sans frais. Si vous avez payé par <strong>carte à l’avance</strong>, pour effectuer le remboursement nous avons besoin d’être prévenus au minimum <strong>24 h à l’avance</strong>. Prévenez-nous par WhatsApp ou email et nous déplaçons la date ou remboursons le montant.' },
  { q: 'Faut-il choisir une heure de départ ?',
    a: `Non. Votre réservation est <strong>Premium · horaire ouvert</strong> : arrivez à nos installations d’Arriondas <strong>quand vous voulez entre 10h30 et 12h30</strong>, sans choisir d’heure précise. C’est l’un des <strong>avantages Premium</strong>. La seule exception est le samedi de la <a href="${getLocalePath('descenso_internacional', 'fr')}">Descente Internationale</a> (départ unique à 12h00) et les jours avec conditions du fleuve nécessitant une entrée avec moniteur (nous vous prévenons à l’avance). La Confederación Hidrográfica fixe la fermeture du fleuve à 18h00.` },
  { q: 'À partir de quel âge les enfants peuvent-ils descendre ?',
    a: 'Les mineurs peuvent descendre à partir de <strong>5 ans révolus et 1,15 m de taille minimum</strong>. C’est une <strong>exigence stricte de sécurité</strong>, pas seulement pour le gilet — aussi à cause de la nature du fleuve (courant, profondeur variable, sections avec rapides) et à la demande des compagnies d’assurance. <strong>Les mineurs n’atteignant pas le minimum ne sont pas admis</strong>, même accompagnés d’un adulte ou sachant nager.' },
  { q: 'Que se passe-t-il le jour de la Descente Internationale ?',
    a: `Le samedi de la <a href="${getLocalePath('descenso_internacional', 'fr')}">Descente Internationale du Sella</a>, un prix unique de <strong>35 € par personne</strong> s’applique, avec des conditions propres : départ unique à 12h00, paiement anticipé obligatoire, sans pique-nique inclus et places très limitées. Tout est expliqué sur sa page dédiée.` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Descente du Sella en canoë · Tout inclus',
      description: 'Descente touristique en canoë sur le fleuve Sella depuis Arriondas. Tout inclus : canoë, équipement, mini-cours avec moniteurs diplômés, transfert retour, pique-nique asturien, vestiaires et parking. Animaux gratuits.',
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      image: `${baseUrl}/images/optimized/includes-b.jpg`,
      offers: [
        { '@type': 'Offer', name: 'Enfants (jusqu’à 12 ans)', price: '30.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/fr/reserver/` },
        { '@type': 'Offer', name: 'Adulte',                   price: '40.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/fr/reserver/` },
        { '@type': 'Offer', name: 'Jour de la Descente Internationale', price: '35.00', priceCurrency: 'EUR', availability: 'https://schema.org/LimitedAvailability', url: `${baseUrl}/fr/descente-internationale-du-sella/` },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5', reviewCount: '147', bestRating: '5', worstRating: '1',
      },
      inLanguage: 'fr-FR',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'fr-FR',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${baseUrl}/fr/` },
        { '@type': 'ListItem', position: 2, name: 'Tarifs',  item: canonicalUrl },
      ],
    },
    {
      '@type': 'WebPage',
      '@id': canonicalUrl,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'fr-FR',
      keywords: 'tarifs descente du sella, prix canoë sella, location canoë arriondas, descente sella prix',
      dateModified: '2026-05-12',
      isPartOf: { '@id': `${baseUrl}/#website` },
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/fr/tarifs/" translationKey="precios">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="prh" aria-labelledby="prh-title">

    <div class="prh__inner">
      <nav class="prh__breadcrumb" aria-label="Fil d’Ariane">
        <a href={getLocalePath('home', 'fr')}>Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Tarifs</span>
      </nav>

      <div class="prh__grid">
        <div class="prh__main">
          <span class="prh__eyebrow">
            <span class="prh__eyebrow-dot" aria-hidden="true"></span>
            À partir de 30 € · Saison 2026
          </span>

          <h1 id="prh-title" class="prh__title">
            Tarifs de la<br/>
            <span class="serif-italic">descente du Sella</span>
          </h1>

          <p class="prh__lead">
            <strong>Un seul prix, tout inclus</strong>. Vous choisissez le parcours
            sur l’eau, pas sur le site. Le coût dépend uniquement de l’âge — pas
            des kilomètres ni du fait que vous vous arrêtiez à Toraño ou alliez
            jusqu’à Fríes.
          </p>

          <div class="prh__stats">
            <span class="prh__statsKicker">
              <span class="prh__statsKickerMark" aria-hidden="true"></span>
              Tarif unique · tout inclus
            </span>
            <div class="prh__statsRow">
              <div class="prh__stat">
                <strong>30<small>€</small></strong>
                <span>Enfants · 5–12</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>40<small>€</small></strong>
                <span>Adultes</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>Gratuit</strong>
                <span>Animaux</span>
              </div>
            </div>
          </div>
        </div>

        <aside class="prh__contact" aria-label="Réserver ou contacter">
          <span class="prh__contactKicker">— Réservez votre place</span>
          <ul class="prh__contactList" role="list">
            <li>
              <a href={getLocalePath('reservar', 'fr')} class="prh__contactPill prh__contactPill--primary">
                <strong>Réserver maintenant</strong>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </li>
            <li>
              <a href="tel:+34681093673" class="prh__contactPill" aria-label="Appeler le 681 09 36 73">
                <strong>Appelez-nous</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Bonjour%2C%20j%27aimerais%20plus%20d%27infos%20sur%20les%20tarifs" target="_blank" rel="noopener noreferrer" class="prh__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Réponse en minutes</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== CARTES TARIFS ============== -->
  <section class="prp">
    <div class="container container--xl">
      <header class="prp__header" data-reveal>
        <span class="prp__eyebrow">— Tarifs</span>
        <h2 class="prp__title">
          Prix par personne,<br/>
          <span class="serif-italic">tout inclus</span>
        </h2>
        <p class="prp__lead">
          Sans extras. Sans frais pour aller jusqu’à Fríes. Sans ajouter le néoprène, le transfert ou le pique-nique.<br/>
          <strong>Le prix affiché est le prix final.</strong>
        </p>
      </header>

      <div class="prp__grid">
        <!-- CARD 1: ENFANTS -->
        <article class="prpCard prpCard--sage" data-reveal data-reveal-delay="1">
          <div class="prpCard__media">
            <Picture src="precios-ninos" alt="Enfants profitant de la descente du Sella en canoë" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarif enfant</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">30&nbsp;€ <span>/ enfant</span></p>
              <p class="prpCard__mediaSub">5-12 ans · Canoë partagé</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Place enfant</h3>
              <span class="prpCard__rating" aria-label="Note moyenne 4,9 sur 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">5-12</span><span class="prpCard__stat-lbl">Ans</span></li>
              <li><span class="prpCard__stat-val">K2/K3</span><span class="prpCard__stat-lbl">Canoë</span></li>
              <li><span class="prpCard__stat-val">Oui</span><span class="prpCard__stat-lbl">Équipement</span></li>
              <li><span class="prpCard__stat-val">Oui</span><span class="prpCard__stat-lbl">Pique-nique</span></li>
            </ul>
            <p class="prpCard__desc">
              L’option la plus accessible pour les familles · les petits descendent en partageant le canoë avec un adulte, avec <strong>la même couverture complète que le tarif adulte</strong>.
            </p>
            <ul class="prpCard__list">
              <li>Âge minimum <strong>5 ans et 1,15 m</strong> · sans exceptions</li>
              <li>Canoë partagé avec un adulte responsable</li>
              <li>Équipement enfant, pique-nique et services inclus · <a href="#pri-title">voir le détail plus bas</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'fr')} class="prpCard__cta prpCard__cta--primary">
              Réserver place enfant
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 2: ADULTES -->
        <article class="prpCard prpCard--coral" data-reveal data-reveal-delay="2">
          <div class="prpCard__media">
            <Picture src="precios-adultos" alt="Groupe d’amis lors de la descente du Sella en canoë" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Tarif adulte</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">40&nbsp;€ <span>/ adulte</span></p>
              <p class="prpCard__mediaSub">À partir de 13 ans · Tout inclus</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Place adulte</h3>
              <span class="prpCard__rating" aria-label="Note moyenne 4,9 sur 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">13+</span><span class="prpCard__stat-lbl">Ans</span></li>
              <li><span class="prpCard__stat-val">K1/K2/K3</span><span class="prpCard__stat-lbl">Canoë</span></li>
              <li><span class="prpCard__stat-val">Oui</span><span class="prpCard__stat-lbl">Équipement</span></li>
              <li><span class="prpCard__stat-val">Oui</span><span class="prpCard__stat-lbl">Pique-nique</span></li>
            </ul>
            <p class="prpCard__desc">
              Le tarif standard · choisissez <strong>K1 en solo, K2 en duo ou K3 entre amis</strong> — le prix par personne reste le même.
            </p>
            <ul class="prpCard__list">
              <li>À partir de <strong>13 ans</strong></li>
              <li>Canoë individuel, double ou triple <strong>(K1/K2/K3)</strong></li>
              <li>Vous choisissez le parcours sur l’eau (Mini ou Complet) sans frais supplémentaires · <a href="#pri-title">voir le détail plus bas</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'fr')} class="prpCard__cta prpCard__cta--primary">
              Réserver place adulte
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 3: CTA IMAGE -->
        <article class="prpCardCTA" data-reveal data-reveal-delay="3">
          <div class="prpCardCTA__media">
            <video
              class="prpCardCTA__video"
              muted loop playsinline
              preload="none"
              poster="/videos/rio-sella-loop-poster.jpg"
              aria-hidden="true"
              data-src="/videos/rio-sella-loop.mp4"
            ></video>
          </div>
          <div class="prpCardCTA__inner">
            <div class="prpCardCTA__bottom">
              <span class="prpCardCTA__kicker">Aventura en el Sella &nbsp;·&nbsp; Location de canoës</span>
              <h3 class="prpCardCTA__title">
                Réservez<br/>avec nous
              </h3>
              <a href={getLocalePath('reservar', 'fr')} class="prpCardCTA__btn">
                <span>Réserver maintenant</span>
                <span class="prpCardCTA__btnIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
          </div>
        </article>
      </div>

      <p class="prp__note" data-reveal>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Animaux gratuits tous les jours — <strong>sauf le samedi de la <a href={getLocalePath('descenso_internacional', 'fr')}>Descente Internationale</a></strong>, en raison de l’affluence et du bruit de l’événement.</span>
      </p>
    </div>
  </section>

  <!-- ============== TOUT INCLUS ============== -->
  <section class="pri" id="pri-title">
    <div class="container container--xl">
      <header class="pri__header" data-reveal>
        <span class="pri__eyebrow">— Tout inclus signifie tout</span>
        <h2 class="pri__title">
          Le jour de votre descente,<br/>
          <span class="serif-italic">vous avez déjà tout</span>
        </h2>
        <p class="pri__lead">
          Découvrez tout ce qu’inclut votre <strong>réservation Premium</strong> — votre journée
          réglée dans les moindres détails. Vous arrivez, on vous accueille, on vous équipe,
          vous descendez la rivière et on vous ramène. <strong>Vous n’avez plus qu’à
          oublier vos soucis et profiter</strong>.
        </p>
      </header>

      <ul class="priD">
        {incluido.map((it, i) => (
          <li class="priDItem" data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="priDItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="priDItem__body">
              <h3 class="priDItem__title">
                <span class="priDItem__icon" aria-hidden="true">
                  {it.icon === 'canoe'   && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 14c3-4 7-6 10-6s7 2 10 6"/><path d="M2 14c3 4 7 6 10 6s7-2 10-6"/></svg>}
                  {it.icon === 'shield'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {it.icon === 'wetsuit' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8l1 4-2 3v10a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V10L7 7z"/></svg>}
                  {it.icon === 'teacher' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>}
                  {it.icon === 'picnic'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h18l-1 5H4z"/><path d="M5 13l1 8M19 13l-1 8"/></svg>}
