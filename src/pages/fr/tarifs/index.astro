  .prcta__text { font-family: var(--font-sans); font-size: 1rem; line-height: 1.6; color: #FBF8F1; max-width: 50ch; margin: 0 auto clamp(2rem, 4vw, 2.5rem); text-shadow: 0 1px 16px rgba(0, 0, 0, 0.6), 0 0 24px rgba(0, 0, 0, 0.35); }
