  .prcta__primary { display: inline-flex; align-items: center; gap: var(--s-2); padding: 1.125rem 2rem; background: var(--color-primary); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; box-shadow: 0 10px 28px rgba(233, 133, 111, 0.38); transition: all 240ms cubic-bezier(0.34, 1.2, 0.64, 1); }
  .prcta__primary:hover { background: var(--color-primary-hover, #D66F59); transform: translateY(-3px); box-shadow: 0 16px 32px rgba(233, 133, 111, 0.5); }
