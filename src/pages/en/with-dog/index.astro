    font-size: 1rem;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 24px rgba(61, 79, 58, 0.28);
    position: relative;
    z-index: 1;
  }
  .cnjT__body { min-width: 0; }
  .cnjT__title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.3125rem);
    font-weight: 800; line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 0.625rem;
  }
  .cnjT__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnjT__text strong { color: var(--color-text-primary); font-weight: 700; }

  .cnjT__step--left .cnjT__body {
    grid-column: 1;
    text-align: right;
    padding-right: 1rem;
  }
  .cnjT__step--right .cnjT__body {
    grid-column: 3;
    padding-left: 1rem;
  }

  @media (max-width: 767.98px) {
    .cnjT::before { left: 28px; }
    .cnjT__step,
    .cnjT__step--left,
    .cnjT__step--right {
      grid-template-columns: 56px 1fr;
      gap: 1rem;
    }
    .cnjT__step--left .cnjT__node,
    .cnjT__step--right .cnjT__node {
      grid-column: 1;
      justify-self: start;
    }
    .cnjT__step--left .cnjT__body,
    .cnjT__step--right .cnjT__body {
      grid-column: 2;
      text-align: left;
      padding: 0;
    }
  }

  /* ============== SEGURIDAD ============== */
  .cns { padding-block: clamp(5rem, 9vw, 7rem); background: var(--color-bg-base); }
  .cns__header {
    max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center;
  }
  .cns__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cns__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cns__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cns__lead {
    font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 auto;
    max-width: 640px;
  }
  .cns__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Grid 3×2 con número watermark sage muy tenue detrás del contenido */
  .cns__grid {
    list-style: none; padding: 0; margin: 0 auto clamp(3rem, 5vw, 4rem);
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.5rem);
    max-width: 1200px;
  }
  @media (min-width: 720px)  { .cns__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cns__grid { grid-template-columns: repeat(3, 1fr); } }

  .cns__item {
    position: relative;
    padding-top: clamp(3rem, 5vw, 4rem);
  }
  .cns__num {
    position: absolute;
    top: -0.15em;
    left: -0.08em;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 8vw, 7.5rem);
    line-height: 0.85;
    color: rgba(61, 79, 58, 0.12);
    letter-spacing: -0.04em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
  .cns__itemTitle {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 0.875rem;
  }
  .cns__itemText {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cns__itemText strong { color: var(--color-text-primary); font-weight: 700; }

  /* CTA oscuro con pill pattern (como el mock de referencia) */
  .cns__cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }
  .cns__ctaBtn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0.5rem 0.5rem 1.75rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.6px; text-transform: uppercase;
    transition: transform 260ms cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 260ms ease;
  }
  .cns__ctaBtn:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(26, 31, 46, 0.35);
  }
  .cns__ctaBtnIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #fff;
    color: var(--color-text-primary, #1A1F2E);
    transition: transform 260ms ease;
  }
  .cns__ctaBtn:hover .cns__ctaBtnIcon { transform: rotate(-12deg); }

  /* ============== REQUISITOS ============== */
  .cnr { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnr__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  /* Lead del header requisitos */
  .cnr__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.75;
    color: var(--color-text-secondary);
    margin: var(--s-4) auto 0;
    max-width: 640px;
  }
  .cnr__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Editorial VS · stat-big labels + divisor central (estilo precios rutas) */
  .cnrVS {
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    max-width: 1100px; margin: 0 auto;
    align-items: start;
  }
  @media (min-width: 900px) {
    .cnrVS {
      grid-template-columns: 1fr auto 1fr;
      gap: clamp(1.5rem, 3vw, 2rem);
    }
  }

  .cnrVS__col {
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    padding: clamp(1rem, 2vw, 1.5rem);
  }
  .cnrVS__bigLabel {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 900; line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }
  .cnrVS__bigLabel--ok { color: var(--color-sage, #3D4F3A); }
  .cnrVS__bigLabel--warn { color: var(--color-primary); }

  .cnrVS__sub {
    font-family: var(--font-sans);
    font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .cnrVS__title {
    font-family: var(--font-display); font-size: clamp(1.125rem, 2vw, 1.3125rem);
    font-weight: 800; line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 clamp(0.75rem, 1.5vw, 1rem);
  }

  .cnrVS__sep {
    width: clamp(60px, 10vw, 100px);
    height: 1px;
    background: rgba(26, 31, 46, 0.18);
    margin: 0 auto clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .cnrVS__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: 0.625rem;
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 380px;
  }
  .cnrVS__list li strong { color: var(--color-text-primary); font-weight: 700; }

  /* Divisor central con "vs" rotado */
  .cnrVS__divider {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    justify-self: center;
  }
  .cnrVS__divider::before {
    content: "";
    position: absolute;
    top: clamp(1.5rem, 3vw, 2.5rem);
    bottom: clamp(1.5rem, 3vw, 2.5rem);
    width: 1px;
    background: rgba(26, 31, 46, 0.15);
  }
  .cnrVS__vs {
    position: relative;
    z-index: 1;
    font-family: var(--font-serif);
    font-style: italic; font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    color: var(--color-text-muted);
    background: var(--color-bg-warm, #F5F1E8);
    padding: 0.5rem 0.875rem;
    letter-spacing: 0.2px;
  }
  @media (max-width: 899.98px) {
    .cnrVS__divider { display: none; }
  }


  /* --- Shared base eyebrow/title para Beneficios · Interlinking · FAQ --- */
  .cnb__eyebrow,
  .cnl__eyebrow,
  .cnf__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnb__title,
  .cnl__title,
  .cnf__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cnb__title .serif-italic,
  .cnl__title .serif-italic,
  .cnf__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }

  /* ============== QUÉ LLEVAR · Sage dark editorial + cards alternando cream/coral ============== */
  .cnq {
    position: relative;
    padding-block: clamp(4rem, 8vw, 6rem);
    background: linear-gradient(180deg, #3D4F3A 0%, #344028 100%);
    color: #FBF8F1;
    overflow: hidden;
    isolation: isolate;
  }
  .cnq::before {
    content: ""; position: absolute; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(251, 248, 241, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(251, 248, 241, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 30% 20%, black 15%, transparent 75%);
    pointer-events: none;
  }
  .cnq > * { position: relative; z-index: 1; }

  .cnq__header {
    max-width: 920px; margin: 0 auto clamp(3rem, 5vw, 4rem);
  }
  @media (min-width: 720px) {
    .cnq__header { padding-right: clamp(2rem, 5vw, 4rem); }
  }
  .cnq__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700;
    letter-spacing: 2.4px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    margin-bottom: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .cnq__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 900; line-height: 0.98;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: #FBF8F1;
    margin: 0 0 var(--s-5);
  }
  .cnq__title .serif-italic {
    color: var(--color-primary-soft, #F4B5A3); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cnq__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: rgba(251, 248, 241, 0.8);
    margin: 0;
    max-width: 620px;
  }
  .cnq__lead strong { color: #FBF8F1; font-weight: 700; }

  /* Slider horizontal deslizable · scroll-snap + hover zoom · flechas de navegación */
  .cnqSlider {
    position: relative;
    max-width: 1400px;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
  }
  .cnqSlider__track {
    list-style: none; padding: clamp(1rem, 2vw, 1.5rem) 0 clamp(1.5rem, 3vw, 2rem);
    margin: 0;
    display: flex;
    gap: clamp(1rem, 2vw, 1.5rem);
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-inline: clamp(1rem, 3vw, 2.5rem);
  }
  .cnqSlider__track::-webkit-scrollbar { display: none; }

  .cnqCard {
    flex: 0 0 min(360px, 85vw);
    scroll-snap-align: center;
    display: flex; flex-direction: column;
    gap: clamp(1rem, 2vw, 1.5rem);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    border-radius: clamp(1.25rem, 2vw, 1.75rem);
    min-height: 320px;
    transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center center;
  }
  .cnqCard:hover {
    transform: translateY(-4px) scale(1.02);
    z-index: 2;
  }

  /* Navegación del slider */
  .cnqSlider__nav {
    display: flex; justify-content: flex-end; gap: 12px;
    padding-inline: clamp(1rem, 3vw, 2.5rem);
    margin-top: clamp(0.5rem, 1.5vw, 1rem);
  }
  .cnqSlider__btn {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: rgba(251, 248, 241, 0.1);
    border: 1px solid rgba(251, 248, 241, 0.28);
    color: #FBF8F1;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 240ms ease, border-color 240ms ease,
                transform 240ms cubic-bezier(0.34, 1.2, 0.64, 1);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  }
  .cnqSlider__btn:hover {
    background: var(--color-primary-soft, #F4B5A3);
    border-color: var(--color-primary-soft, #F4B5A3);
    color: #3D4F3A;
    transform: translateY(-2px);
  }
  .cnqSlider__btn:active { transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .cnqSlider__track { scroll-behavior: auto; }
    .cnqCard { transition: none; }
    .cnqCard:hover { transform: none; }
    .cnqSlider__btn { transition: none; }
  }
  .cnqCard--cream {
    background: #FDF8F1;
    color: var(--color-text-primary);
    box-shadow: 0 18px 36px rgba(20, 28, 18, 0.2);
  }
  .cnqCard--coral {
    background: #EE9680;
    color: #FBF8F1;
    box-shadow: 0 18px 36px rgba(20, 28, 18, 0.22);
  }

  .cnqCard__badge {
    display: inline-flex; align-items: center; gap: 8px;
    width: fit-content;
    padding: 6px 12px 6px 6px;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.4px; text-transform: uppercase;
  }
  .cnqCard--cream .cnqCard__badge {
    background: rgba(26, 31, 46, 0.06);
    color: var(--color-sage, #3D4F3A);
  }
  .cnqCard--coral .cnqCard__badge {
    background: rgba(26, 31, 46, 0.18);
    color: #FBF8F1;
  }
  .cnqCard__badgeIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .cnqCard--cream .cnqCard__badgeIcon {
    background: #FBF8F1;
    color: var(--color-sage, #3D4F3A);
  }
  .cnqCard--coral .cnqCard__badgeIcon {
    background: rgba(251, 248, 241, 0.2);
    color: #FBF8F1;
  }

  .cnqCard__title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 900; line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0;
    text-transform: uppercase;
  }
  .cnqCard--cream .cnqCard__title { color: var(--color-text-primary); }
  .cnqCard--coral .cnqCard__title { color: #FBF8F1; }

  .cnqCard__text {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    margin: 0;
    margin-top: auto;
  }
  .cnqCard--cream .cnqCard__text { color: var(--color-text-secondary); }
  .cnqCard--coral .cnqCard__text { color: rgba(251, 248, 241, 0.92); }

  .cnq__note {
    max-width: 860px; margin: 0 auto;
    display: flex; align-items: flex-start; gap: var(--s-2);
    padding: var(--s-3) var(--s-4);
    background: rgba(251, 248, 241, 0.08);
    border-left: 2px solid var(--color-primary-soft, #F4B5A3);
    border-radius: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.6;
    color: rgba(251, 248, 241, 0.82);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  }
  .cnq__note svg { color: var(--color-primary-soft, #F4B5A3); flex-shrink: 0; margin-top: 3px; }
  .cnq__note strong { color: #FBF8F1; font-weight: 700; }

  /* ============== BENEFICIOS · Ticker marquee sage · ancho + tipografía mixta + estrellas animadas ============== */
  .cnb {
    padding: 0;
    background: #B4C58D;
    overflow: hidden;
  }
  .cnb__srOnly {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }
  .cnb__band {
    background: linear-gradient(90deg, #C1D19B 0%, #B4C58D 100%);
    padding: clamp(1.75rem, 3.2vw, 2.5rem) 0;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      inset 0 -1px 0 rgba(26, 31, 46, 0.1);
  }
  .cnb__track {
    display: flex;
    width: max-content;
    gap: clamp(2.5rem, 5vw, 4rem);
    animation: cnbScroll 50s linear infinite;
  }
  .cnb__item {
    display: inline-flex; align-items: center; gap: clamp(2.5rem, 5vw, 4rem);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .cnb__label {
    display: inline-block;
    font-size: clamp(1.5rem, 3.2vw, 2.625rem);
    line-height: 1;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  /* Tipografía alternada · impar (italic serif sage) vs par (bold display navy/coral) */
  .cnb__item:nth-child(odd) .cnb__label {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: #3D4F3A;
    letter-spacing: -0.015em;
  }
  .cnb__item:nth-child(even) .cnb__label {
    font-family: var(--font-display);
    font-weight: 900;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }
  /* Cada 4º item usa coral para variedad cromática */
  .cnb__item:nth-child(4n) .cnb__label {
    color: var(--color-primary);
  }

  /* Estrellas animadas con rotación suave */
  .cnb__star {
    color: var(--color-primary);
    flex-shrink: 0;
    animation: cnbStarSpin 7s ease-in-out infinite;
    transform-origin: center;
  }
  .cnb__item:nth-child(even) .cnb__star { animation-delay: 2s; }
  .cnb__item:nth-child(3n) .cnb__star {
    color: var(--color-text-primary);
    animation-delay: 3.5s;
  }

  @keyframes cnbScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes cnbStarSpin {
    0%, 100% { transform: rotate(0deg) scale(1); opacity: 0.85; }
    50%      { transform: rotate(90deg) scale(1.15); opacity: 1; }
  }

  /* Fade bordes izq/dcha para scroll elegante */
  .cnb__band::before,
  .cnb__band::after {
    content: "";
    position: absolute;
    top: 0; bottom: 0;
    width: clamp(60px, 8vw, 140px);
    z-index: 2;
    pointer-events: none;
  }
  .cnb__band::before {
    left: 0;
    background: linear-gradient(90deg, rgba(193, 209, 155, 1) 0%, rgba(193, 209, 155, 0) 100%);
  }
  .cnb__band::after {
    right: 0;
    background: linear-gradient(270deg, rgba(180, 197, 141, 1) 0%, rgba(180, 197, 141, 0) 100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .cnb__track, .cnb__star { animation: none; }
    .cnb__band { overflow-x: auto; }
    .cnb__band::before, .cnb__band::after { display: none; }
  }

  /* ============== OPINIONES · Cream (corte con sage olive del ticker) ============== */
  .cnrev {
    padding-block: clamp(5rem, 9vw, 7rem);
    background: var(--color-bg-base);
