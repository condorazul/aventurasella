---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Sella River descent with dog · Adventure with your pet';
const description = 'Sella River descent with dog: pets travel free, dog life jacket included (while supplies last), dog-friendly instructors. Book without paying now.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/with-dog/`;
const ogImage = '/images/optimized/con-perro-cta-lg.jpg';

// 6 steps of the day (adapted for arriving with a pet)
const jornada = [
  { num: '01', title: 'Arrival with your dog',     text: 'We welcome you in Arriondas. <strong>Free private parking</strong> to avoid stress on arrival. We explain the plan and resolve doubts about the activity with your pet.' },
  { num: '02', title: 'Prior assessment',          text: 'We look at how the dog is — <strong>calm, nervous, size, confidence with water</strong> — and adjust the most suitable canoe so the day is comfortable for both of you.' },
  { num: '03', title: 'Briefing with instructor',  text: '<strong>Dog-friendly experienced instructors</strong> explain how to place the dog in the canoe, what to do if it moves and the basic guidelines. <strong>Everything clear before getting on the water</strong>.' },
  { num: '04', title: 'Calm embarkation',          text: 'Launch from our private 35 m ramp to the river. The dog goes <strong>loose inside the canoe</strong>, never tied — that’s safest if there is movement or a capsize.' },
  { num: '05', title: 'Stops when needed',         text: 'There are calm river beaches to <strong>stop, drink water, stretch paws</strong> and let the dog breathe. No rush, <strong>at the pace your pet sets</strong>.' },
  { num: '06', title: 'Return and changing rooms', text: '<strong>Our transfer</strong> takes you back. Changing rooms with hot showers for you and outdoor area with water to dry the dog. Day fully sorted.' },
];

// Checklist what to bring (dog-specific items)
const llevar = [
  { icon: 'leash',    t: 'Leash + harness',                s: 'Mandatory on land (embarkation, accesses, changing rooms). Comfortable harness better than collar' },
  { icon: 'bowl',     t: 'Water and foldable water bowl',  s: 'Essential if it is hot. We stop as many times as needed to hydrate the dog' },
  { icon: 'towel',    t: 'Extra towel for the dog',        s: 'Better separate from yours · at the end of the route the dog comes out soaked and you’ll be glad not to share' },
  { icon: 'bag',      t: 'Waste bags',                     s: 'Respect the river and its banks. Everything that goes down comes up with us' },
  { icon: 'human',    t: 'Your personal gear',             s: 'Comfortable clothes that can get wet, secure footwear, towel and a change of clothes. Like any descent' },
];

// Concrete benefits (dog-friendly USPs)
const beneficios = [
  { t: '100% free pets',               s: 'Your dog doesn’t pay. It comes with you in the canoe at no extra cost — except on the Saturday of the International Descent.' },
  { t: 'Dog-friendly instructors',     s: 'With real experience descending the Sella with pets. In the briefing before launching they explain what to look for before getting on the water and how to act if your dog gets restless during the descent.' },
  { t: 'Calm and adaptable plan',      s: 'The tourist Sella is a calm river — quiet current, stops on demand, no white-water or athletic demands.' },
  { t: 'Clear guidelines before launching', s: 'Specific briefing on how to place the dog, what to do if it moves and how to keep the canoe balanced with it on board.' },
  { t: 'Changing rooms + private parking', s: 'Hot showers for you + outdoor area with water to rinse the dog when finished. Guarded parking all day.' },
  { t: 'One dog per canoe',            s: 'To ensure space, balance and comfort. If you come with more than one, we help you coordinate the boats.' },
  { t: 'No payment now',               s: 'Reserve without paying upfront. Pay by card before or on the day when picking up the canoe — as you prefer.' },
  { t: 'Change or cancel',             s: 'Flexible changes and cancellations before the day. If you paid by card, refund with 24 h notice.' },
];

// Real questions about descending with dog (accordion)
const faqs = [
  { q: 'How much does it cost to descend the Sella with a dog?',
    a: `The dog <strong>doesn’t pay</strong> — pets travel free in the canoe. People: <strong>€40 per adult</strong> (from age 13) and <strong>€30 per child</strong> (5-12 years, <strong>minimum age 5 and 1.15 m tall</strong>). The only exception is the Saturday of the <a href="${getLocalePath('descenso_internacional', 'en')}">International Sella Descent</a>, when due to the event’s noise pets are not admitted. You can <a href="${getLocalePath('precios', 'en')}">see the full price breakdown</a>.` },
  { q: 'Can you do the Sella descent with a dog?',
    a: 'Yes, it is one of the most popular dog-friendly activities on the river. The only thing we ask is <strong>common sense with the dog</strong>: assess if it tolerates water, stays calm for a while, and follows basic commands. If it’s a sociable and balanced dog, the experience usually goes very well.' },
  { q: 'Can my dog get on the return transfer?',
    a: 'Yes, no problem. <strong>Your pet can get on our return transfer</strong> at the end of the route you chose (Mini Sella or Full). It rides with you in the van with the rest of the group, like the canoe — <strong>at no additional cost</strong>.' },
  { q: 'Does my dog have to wear a life jacket?',
    a: `It is not mandatory, but <strong>it is recommended if your dog doesn’t swim well or is small/medium-sized</strong>. <strong>We provide the dog life jacket</strong> at no extra cost · we have several sizes in the shop <em>while supplies last</em>. That’s why <a href="${getLocalePath('reservar', 'en')}">booking ahead is key</a> · they fly in summer. If you come with a dog and want to make sure, let us know when booking and we’ll save the jacket in your name.` },
  { q: 'Can it be tied to the canoe?',
    a: '<strong>No, never.</strong> If there is a capsize, a tied leash is a serious risk both for the dog and the people. Inside the canoe <strong>it goes loose</strong>. Out of the water (embarkation, accesses, changing rooms) it must wear a leash.' },
  { q: 'How many dogs can go per canoe?',
    a: 'For safety and balance, <strong>the usual is one dog per canoe</strong>. If you come with more than one, we share them between the canoes of the group. For special cases (calm small dog + calm small dog) we can assess on arrival.' },
  { q: 'Can large dogs go?',
    a: 'Yes, as long as it is a <strong>calm dog, used to going out and tolerating water</strong>. Large dogs take more space and affect balance more, so we assess it before embarkation. A calm large dog usually goes much better than a very nervous small dog.' },
  { q: 'Does my dog need to know how to swim?',
    a: 'It is not essential, but it helps to know in advance. If your dog has <strong>no experience in water</strong> or doesn’t convey confidence swimming, <strong>it’s better to wear a dog life jacket</strong> · we provide it while supplies last. The tourist Sella has calm current, but the jacket gives a real plus.' },
  { q: 'What do I do if my dog gets stressed or doesn’t want to continue?',
    a: 'We stop. There are <strong>calm river beaches</strong> where the dog can get out, stretch paws, drink water and breathe. If it gets very stressed, we can find an early exit from the bank and coordinate the return. <strong>No one descends against their dog’s will</strong>.' },
  { q: 'Is the Mini or Full route better with a dog?',
    a: 'For dogs not very used to it or older, we recommend the <strong>Mini Sella</strong> (Arriondas → Toraño, 7 km, 2-3 h) — calm pace and less time on water. For active and fit dogs, the <strong>Full one</strong> (Arriondas → Fríes, 14.5 km, 4-5 h) is perfectly viable with stops.' },
  { q: 'Do I need to book in advance?',
    a: 'Yes, <strong>especially in high season</strong>. Book without paying now: confirm your spot, pay by card before or on the day when picking up the canoe. If you cancel before the day, no cost; if you paid by card, refund with 24 h notice.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Sella River descent with dog: complete guide to enjoy with your pet',
      description: 'Guide to descending the Sella River with a dog: rules, dog life jacket included (while supplies last), how the dog is placed in the canoe, what to bring and why it is the dog-friendly star plan in Asturias.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/con-perro-cta-lg.jpg`,
        width: 1920,
        height: 1080,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-19',
      dateModified:  '2026-05-12',
      articleSection: 'Pets',
      keywords: ['sella descent with dog', 'sella descent pets free', 'canoe with dog sella', 'dog life jacket sella', 'dog-friendly arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Sella River descent with dog · dog-friendly activity in Asturias' },
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Sella River descent with dog',
      description: 'Dog-friendly Sella River canoe descent activity. Pets travel free. Dog life jacket included at no extra cost (while supplies last). Instructors with canine experience, specific briefing, clear guidelines. All inclusive: canoe, certified human life jacket, dog life jacket, transfer, parking and changing rooms with outdoor area to dry the dog.',
      serviceType: 'Dog-friendly Sella descent',
      category: 'Active tourism · Pets',
      url: canonicalUrl,
      provider: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturias' },
      audience: { '@type': 'Audience', audienceType: 'Families and owners with pets' },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'EUR',
        lowPrice: '0.00',
        highPrice: '40.00',
        offerCount: 3,
        availability: 'https://schema.org/InStock',
        url: `${baseUrl}/en/book/`,
        offers: [
          { '@type': 'Offer', name: 'Pet',                price: '0.00',  priceCurrency: 'EUR', url: `${baseUrl}/en/book/`, description: 'Free · all pets travel at no cost' },
          { '@type': 'Offer', name: 'Child (5-12 years)', price: '30.00', priceCurrency: 'EUR', url: `${baseUrl}/en/book/` },
          { '@type': 'Offer', name: 'Adult (13+ years)',  price: '40.00', priceCurrency: 'EUR', url: `${baseUrl}/en/book/` },
        ],
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',     item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'With dog', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/en/with-dog/" translationKey="con_perro">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Luminous cream ============== -->
  <section class="cnh cnh--cream" aria-labelledby="cnh-title">

    <div class="cnh__inner">
      <nav class="cnh__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">With dog</span>
      </nav>

      <span class="cnh__eyebrow">
        <span class="cnh__eyebrow-dot" aria-hidden="true"></span>
        Dog-friendly · 2026 season
      </span>

      <h1 id="cnh-title" class="cnh__title">
        Sella River descent<br/>
        <span class="serif-italic">with <span class="cnh__underlined">dog<svg class="cnh__swoosh" width="200" height="18" viewBox="0 0 200 18" fill="none" aria-hidden="true"><path d="M3 14C30 6 74 4 118 8c27 2.5 54 6 78 4" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/></svg></span></span>
      </h1>

      <p class="cnh__lead">
        <strong>Adventure with your pet in Asturias</strong>. A dog-friendly day planned in
        detail — with clear guidelines before launching, instructors with canine experience
        and a calm river to enjoy together. <strong>The dog comes free</strong>.
      </p>

      <div class="cnh__stats">
        <div class="cnh__stat">
          <span class="cnh__stat-value">Free</span>
          <span class="cnh__stat-label">Your dog doesn’t pay</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">€40</span>
          <span class="cnh__stat-label">Per person · all inclusive</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">4.5 ⭐</span>
          <span class="cnh__stat-label">147 reviews</span>
        </div>
      </div>

      <div class="cnh__ctas">
        <a href={getLocalePath('reservar', 'en')} class="cnh__cta cnh__cta--primary">
          Book with my dog
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+34681093673" class="cnh__cta cnh__cta--phone" aria-label="Call 681 093 673">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Call</span>
        </a>
        <a href={getLocalePath('precios', 'en')} class="cnh__cta cnh__cta--ghost">
          See prices and options
        </a>
      </div>
    </div>
  </section>

  <!-- ============== INTRO · Can you descend with a dog? ============== -->
  <section class="cni">
    <div class="container container--xl">
      <div class="cni__grid">
        <div class="cni__media" data-reveal>
          <div class="cni__mediaMain">
            <Picture src="con-perro-intro-1" alt="Dog on board a canoe on the Sella descent" sizes="(min-width: 960px) 44vw, 90vw" aspectRatio="1 / 1" bare />
          </div>
          <div class="cni__mediaSmall" aria-hidden="true">
            <Picture src="con-perro-intro-2" alt="Dog enjoying the Sella River with its family" sizes="220px" aspectRatio="1 / 1" bare />
          </div>
          <a class="cni__contact" href="https://wa.me/34681093673?text=Hello,%20I%20have%20a%20question%20about%20descending%20the%20Sella%20with%20my%20dog" target="_blank" rel="noopener noreferrer">
            <span class="cni__contactIcon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-1-.5-2-.8-2.9-1.9-.7-.6-1.2-1.4-1.6-2.1-.2-.3 0-.5.1-.7.1-.2.3-.4.5-.6.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5-.2 0-.4 0-.6 0-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6 0 1.6 1.1 3.1 1.3 3.3.2.2 2.3 3.6 5.7 5 3.4 1.4 3.4.9 4 .9.6-.1 1.8-.8 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3z"/></svg>
            </span>
            <div class="cni__contactBody">
              <strong>Doubts about your dog?</strong>
              <span>WhatsApp · we reply fast</span>
            </div>
          </a>
        </div>

        <div class="cni__content" data-reveal data-reveal-delay="2">
          <span class="cni__eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            The classic question
          </span>
          <h2 class="cni__title">
            Can you descend<br/>
            the Sella <span class="serif-italic">with a dog?</span>
          </h2>
          <p class="cni__lead">
            <strong>Yes, and pets travel completely free.</strong> The Sella is one of the
            star dog-friendly plans in Asturias — calm river, stops when the
            dog asks for them, and a team that knows what to look for before getting on the water.
          </p>

          <ul class="cni__features">
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">100% free pets</h3>
                <p class="cni__featureText">Your dog doesn’t pay. It comes with you in the canoe <strong>at no extra cost</strong>. The only exception is the Saturday of the International Descent.</p>
              </div>
            </li>
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Dog-friendly instructors</h3>
                <p class="cni__featureText">With real experience descending the Sella with pets. <strong>They know what to look for before getting on the water</strong> and how to prepare the day for both of you.</p>
              </div>
            </li>
          </ul>

          <a href={getLocalePath('reservar', 'en')} class="cni__cta">
            Book with my dog
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== DAY · 6 steps ============== -->
  <section class="cnj">
    <div class="container container--xl">
      <header class="cnj__header" data-reveal>
        <span class="cnj__eyebrow">— How the day with your dog goes</span>
        <h2 class="cnj__title">
          A day on the Sella,<br/>
          <span class="serif-italic">step by step</span>
        </h2>
        <p class="cnj__lead">
          Knowing how the day unfolds helps decide. This is how we prepare the
          experience so that <strong>you and your dog are comfortable and safe</strong> from start to finish — no rush, no surprises.
        </p>
      </header>

      <ol class="cnjT">
        {jornada.map((j, i) => (
          <li class={`cnjT__step ${i % 2 === 0 ? 'cnjT__step--left' : 'cnjT__step--right'}`} data-reveal>
            <span class="cnjT__node" aria-hidden="true">{j.num}</span>
            <div class="cnjT__body">
              <h3 class="cnjT__title">{j.title}</h3>
              <p class="cnjT__text" set:html={j.text} />
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- ============== SAFETY ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Safety and confidence</span>
        <h2 class="cns__title">
          What to watch with your dog,<br/>
          <span class="serif-italic">and how we resolve it</span>
        </h2>
        <p class="cns__lead">
          The first question is always <strong>"is it safe for my dog?"</strong> — and it is
          logical. The short answer is yes, when done with common sense, clear guidelines
          and an honest assessment of how your pet is.
        </p>
      </header>

      <ol class="cns__grid">
        <li class="cns__item" data-reveal data-reveal-delay="1">
          <span class="cns__num" aria-hidden="true">01</span>
          <h3 class="cns__itemTitle">100% free pets</h3>
          <p class="cns__itemText">Your dog doesn’t pay. It comes with you in the canoe <strong>at no extra cost</strong>, with dog-friendly guidelines explained before launching.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="2">
          <span class="cns__num" aria-hidden="true">02</span>
          <h3 class="cns__itemTitle">The dog goes loose in the canoe</h3>
          <p class="cns__itemText"><strong>Never tied</strong>. If there is a capsize or sudden movement, a tied leash is a serious risk — for both the dog and you.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="3">
          <span class="cns__num" aria-hidden="true">03</span>
          <h3 class="cns__itemTitle">Leash mandatory on land</h3>
          <p class="cns__itemText">At embarkation, accesses and changing rooms always on a leash. <strong>Total respect for other users and other dogs</strong>.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="4">
          <span class="cns__num" aria-hidden="true">04</span>
          <h3 class="cns__itemTitle">Dog life jacket recommended</h3>
          <p class="cns__itemText">It is not mandatory, but <strong>we do recommend it</strong> if your dog doesn’t swim well or you want a real safety plus.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="5">
          <span class="cns__num" aria-hidden="true">05</span>
          <h3 class="cns__itemTitle">One dog per canoe</h3>
          <p class="cns__itemText">To ensure <strong>space, balance and comfort</strong>. If you come with more than one, we distribute them between the canoes of the group.</p>
        </li>
        <li class="cns__item" data-reveal data-reveal-delay="6">
          <span class="cns__num" aria-hidden="true">06</span>
          <h3 class="cns__itemTitle">Instructors with canine experience</h3>
          <p class="cns__itemText">They know what to look for before getting on the water, how to place the dog in the canoe and how to act if it moves. <strong>We don’t improvise</strong>.</p>
        </li>
      </ol>

      <div class="cns__cta" data-reveal>
        <a href={getLocalePath('reservar', 'en')} class="cns__ctaBtn">
          <span>Book with my dog</span>
          <span class="cns__ctaBtnIcon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== REQUIREMENTS · Editorial VS ============== -->
  <section class="cnr">
    <div class="container container--xl">
