---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Cookie policy · Aventura en el Sella';
const description = 'Cookie policy of Aventura en el Sella. Which cookies we use, what they do and how you can configure or disable them.';
const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/legal/cookies/`;
const lastUpdated = '2026-05-12';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#page`,
  name: 'Cookie policy',
  description,
  inLanguage: 'en-GB',
  url: canonicalUrl,
  isPartOf: { '@type': 'WebSite', name: 'Aventura en el Sella', url: baseUrl },
  dateModified: lastUpdated,
};

const cookies = [
  { nombre: 'astro-*',                tipo: 'Technical · own',         duracion: 'Session',     finalidad: 'Basic website operation (navigation, rendering, preferences).' },
  { nombre: '_ga / _ga_*',            tipo: 'Analytics · Google',      duracion: '24 months',    finalidad: 'Aggregated usage statistics (pages visited, device, duration).' },
  { nombre: '_gid',                   tipo: 'Analytics · Google',      duracion: '24 hours',     finalidad: 'Distinguish users in short sessions.' },
  { nombre: 'cookies-consent',        tipo: 'Technical · own',         duracion: '6 months',     finalidad: 'Remember your choice in the cookie banner.' },
];
---

<BaseLayout title={title} description={description} currentPath="/en/legal/cookies/" translationKey="legal_cookies">
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="lgl">

    <div class="lgl__inner">
      <nav class="lgl__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', lang)}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={getLocalePath('legal_aviso', lang)}>Legal</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Cookies</span>
      </nav>

      <span class="lgl__eyebrow">— Legal information</span>
      <h1 class="lgl__title">Cookie policy</h1>
      <p class="lgl__updated">Last updated: <time datetime={lastUpdated}>12 May 2026</time></p>

      <nav class="lgl__toc" aria-label="Table of contents">
        <h2 class="lgl__tocTitle">Contents</h2>
        <ol>
          <li><a href="#what">1. What are cookies?</a></li>
          <li><a href="#types">2. Types of cookies we use</a></li>
          <li><a href="#detail">3. Cookie details</a></li>
          <li><a href="#consent">4. Consent</a></li>
          <li><a href="#configure">5. How to configure or disable cookies</a></li>
          <li><a href="#third-party">6. Third-party cookies</a></li>
          <li><a href="#updates">7. Updates</a></li>
        </ol>
      </nav>

      <article class="lgl__prose">

        <section id="what">
          <h2>1. What are cookies?</h2>
          <p>
            Cookies are small text files that websites store on your device (computer,
            mobile phone, tablet) when you visit them. They allow information about the
            visit to be remembered — such as preferred language, session state or
            aggregated usage statistics — to improve your experience on future visits.
          </p>
          <p>
            The use of cookies on this website is governed by Spanish
            <strong>Law 34/2002 on Information Society Services (LSSI-CE, article 22.2)</strong>,
            the <strong>EU General Data Protection Regulation 2016/679 (GDPR)</strong> and the
            Spanish <strong>Organic Law 3/2018 on Data Protection (LOPDGDD)</strong>, as well
            as the <strong>AEPD guidelines</strong> on the use of cookies.
          </p>
        </section>

        <section id="types">
          <h2>2. Types of cookies we use</h2>
          <p>We classify cookies by <strong>ownership</strong>, <strong>purpose</strong> and <strong>duration</strong>:</p>
          <ul>
            <li><strong>By ownership:</strong>
              <ul>
                <li><strong>Own:</strong> managed directly by us.</li>
                <li><strong>Third-party:</strong> managed by an external provider (e.g. Google Analytics).</li>
              </ul>
            </li>
            <li><strong>By purpose:</strong>
              <ul>
                <li><strong>Necessary (strictly required):</strong> enable navigation and use of basic features. <strong>No consent required</strong>.</li>
                <li><strong>Preferences or personalization:</strong> remember your settings.</li>
                <li><strong>Analytics:</strong> measure use of the site in aggregated and anonymous form.</li>
                <li><strong>Marketing or advertising:</strong> used to track visitors across websites in order to display relevant ads. <strong>We are not currently using active marketing cookies</strong> on this site. This category is included for possible future integrations (Google Ads, Meta Pixel, etc.) which will always require your <strong>prior consent</strong>.</li>
              </ul>
            </li>
            <li><strong>By duration:</strong>
              <ul>
                <li><strong>Session:</strong> deleted when you close the browser.</li>
                <li><strong>Persistent:</strong> remain on your device for a defined period.</li>
              </ul>
            </li>
          </ul>
        </section>

        <section id="detail">
          <h2>3. Cookie details</h2>
          <p>Below is the list of cookies currently used on this website:</p>
          <div class="lgl__table">
            <table>
              <thead>
                <tr>
                  <th scope="col">Name</th>
                  <th scope="col">Type</th>
                  <th scope="col">Duration</th>
                  <th scope="col">Purpose</th>
                </tr>
              </thead>
              <tbody>
                {cookies.map(c => (
                  <tr>
                    <td><code>{c.nombre}</code></td>
                    <td>{c.tipo}</td>
                    <td>{c.duracion}</td>
                    <td>{c.finalidad}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="lgl__note">
            <strong>Note:</strong> this table is kept up to date. If you spot a cookie not listed here,
            write to us at <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a>.
          </p>
        </section>

        <section id="consent">
          <h2>4. Consent</h2>
          <p>
            When you first visit the website, we display an <strong>information banner</strong>
            where you can:
          </p>
          <ul>
            <li><strong>Accept all</strong> cookies.</li>
            <li><strong>Reject</strong> cookies that are not strictly necessary.</li>
            <li><strong>Configure preferences</strong> by category.</li>
          </ul>
          <p>
            <strong>Necessary</strong> cookies are essential for the site to function and
            do not require consent under article 22.2 LSSI-CE. The other categories are
            only activated if you give express consent.
          </p>
          <p>
            You can <strong>modify or withdraw your consent</strong> at any time via the
            "Configure cookies" link in the footer, without affecting the lawfulness of
            prior processing.
          </p>
        </section>

        <section id="configure">
          <h2>5. How to configure or disable cookies</h2>
          <p>
            In addition to the banner on our site, you can manage cookies directly from
            your browser. Official guides:
          </p>
          <ul>
            <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer">Google Chrome</a></li>
            <li><a href="https://support.mozilla.org/en-US/kb/enable-and-disable-cookies-website-preferences" target="_blank" rel="noopener noreferrer">Mozilla Firefox</a></li>
            <li><a href="https://support.apple.com/guide/safari/sfri11471/mac" target="_blank" rel="noopener noreferrer">Apple Safari</a></li>
            <li><a href="https://support.microsoft.com/en-us/windows/delete-and-manage-cookies-168dab11-0753-043d-7c16-ede5947fc64d" target="_blank" rel="noopener noreferrer">Microsoft Edge</a></li>
          </ul>
          <p>
            <strong>Important:</strong> if you disable all cookies, some site features may
            stop working properly.
          </p>
        </section>

        <section id="third-party">
          <h2>6. Third-party cookies</h2>
          <p>
            When you use certain features (for example, viewing a Google map, statistics
            via Google Analytics or paying through an external gateway), third-party
            cookies may be installed. These providers are governed by their own privacy
            policies:
          </p>
          <ul>
            <li><strong>Google LLC</strong> (Google Analytics, Google Maps, possible future Google Ads integrations): <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a></li>
            <li><strong>Payment gateway</strong>: when we process online card payments we use a <strong>certified external PCI-DSS payment gateway</strong>. The gateway is governed by its own privacy policy and we do not store card data in our systems.</li>
          </ul>
        </section>

        <section id="updates">
          <h2>7. Updates</h2>
          <p>
            We may update this Cookie Policy whenever the cookies used or applicable
            regulations change. The last update date appears at the top of the document.
            We recommend reviewing it periodically.
          </p>
        </section>

        <div class="lgl__contact" aria-label="Cookies contact">
          <p>
            For questions about this Cookie Policy, write to us at
            <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a>
            or call <a href="tel:+34681093673">+34 681 09 36 73</a>.
          </p>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .lgl {
    position: relative;
    background:
      radial-gradient(ellipse 60% 45% at 10% 0%, rgba(61, 79, 58, 0.05) 0%, transparent 60%),
      var(--color-bg-base);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    min-height: 80vh;
  }
  .lgl__inner { max-width: 900px; margin: 0 auto; padding: clamp(7rem, 14vw, 10rem) clamp(1.5rem, 4vw, 3rem) 0; }
  .lgl__breadcrumb {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
    font-family: var(--font-sans); font-size: 0.6875rem;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(26, 31, 46, 0.4);
    margin-bottom: 1.5rem;
  }
  .lgl__breadcrumb a { color: var(--color-sage, #3D4F3A); transition: color 200ms; }
  .lgl__breadcrumb a:hover { color: var(--color-primary); }
  .lgl__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1rem;
  }
  .lgl__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }
  .lgl__updated {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .lgl__toc {
    background: rgba(61, 79, 58, 0.04);
    border: 1px solid rgba(61, 79, 58, 0.12);
    border-radius: 0.875rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .lgl__tocTitle {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin: 0 0 1rem;
  }
  .lgl__toc ol { padding-left: 1.25rem; margin: 0; columns: 1; column-gap: 2rem; font-family: var(--font-sans); font-size: 0.9375rem; color: var(--color-text-secondary); }
  @media (min-width: 720px) { .lgl__toc ol { columns: 2; } }
  .lgl__toc ol li { margin-bottom: 0.5rem; }
  .lgl__toc a { color: var(--color-text-primary); transition: color 200ms; border-bottom: 1px solid transparent; }
  .lgl__toc a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  .lgl__prose { font-family: var(--font-sans); font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary); }
  .lgl__prose section { padding-top: clamp(2rem, 4vw, 3rem); scroll-margin-top: 5rem; }
  .lgl__prose section:first-child { padding-top: 0; }
  .lgl__prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 900; line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .lgl__prose p { margin: 0 0 1rem; color: var(--color-text-secondary); }
  .lgl__prose p strong { color: var(--color-text-primary); font-weight: 700; }
  .lgl__prose ul { padding-left: 1.25rem; margin: 0 0 1rem; }
  .lgl__prose ul li { margin-bottom: 0.5rem; color: var(--color-text-secondary); }
  .lgl__prose ul ul { margin-top: 0.5rem; }

  .lgl__table {
    overflow-x: auto;
    margin: 0 0 1rem;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: 0.75rem;
  }
  .lgl__table table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans); font-size: 0.875rem;
    background: #fff;
  }
  .lgl__table thead { background: rgba(61, 79, 58, 0.06); }
  .lgl__table th {
    padding: 0.875rem 1rem;
    text-align: left;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(26, 31, 46, 0.08);
  }
  .lgl__table td {
    padding: 0.875rem 1rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(26, 31, 46, 0.05);
    vertical-align: top;
  }
  .lgl__table tr:last-child td { border-bottom: 0; }
  .lgl__table code {
    font-family: 'SFMono-Regular', 'Consolas', 'Liberation Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-text-primary);
    background: rgba(61, 79, 58, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .lgl__note {
    padding: 0.875rem 1.25rem;
    background: rgba(232, 179, 57, 0.1);
    border-left: 3px solid #E8B339;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.9375rem;
  }
  .lgl__note strong { color: var(--color-text-primary); font-weight: 800; }

  .lgl__prose a {
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(61, 79, 58, 0.4);
    transition: color 200ms, border-color 200ms;
  }
  .lgl__prose a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .lgl__contact {
    margin-top: clamp(3rem, 5vw, 4rem);
    padding: 1.5rem 1.75rem;
    background: rgba(61, 79, 58, 0.06);
    border-left: 3px solid var(--color-sage, #3D4F3A);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .lgl__contact p { margin: 0; }
</style>
