---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Legal notice · Aventura en el Sella';
const description = 'Legal information for Aventura en el Sella: owner identification, scope, intellectual property and terms of use of this website.';
const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/legal/legal-notice/`;
const lastUpdated = '2026-05-12';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#page`,
  name: 'Legal notice',
  description,
  inLanguage: 'en-GB',
  url: canonicalUrl,
  isPartOf: { '@type': 'WebSite', name: 'Aventura en el Sella', url: baseUrl },
  dateModified: lastUpdated,
};
---

<BaseLayout title={title} description={description} currentPath="/en/legal/legal-notice/" translationKey="legal_aviso">
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="lgl">

    <div class="lgl__inner">
      <nav class="lgl__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', lang)}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={getLocalePath('legal_aviso', lang)}>Legal</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Legal notice</span>
      </nav>

      <span class="lgl__eyebrow">— Legal information</span>
      <h1 class="lgl__title">Legal notice</h1>
      <p class="lgl__updated">Last updated: <time datetime={lastUpdated}>12 May 2026</time></p>

      <nav class="lgl__toc" aria-label="Table of contents">
        <h2 class="lgl__tocTitle">Contents</h2>
        <ol>
          <li><a href="#owner">1. Owner identification</a></li>
          <li><a href="#scope">2. Scope</a></li>
          <li><a href="#conditions">3. Terms of use</a></li>
          <li><a href="#property">4. Intellectual and industrial property</a></li>
          <li><a href="#liability">5. Exclusion of liability</a></li>
          <li><a href="#links">6. Third-party links</a></li>
          <li><a href="#data-protection">7. Data protection</a></li>
          <li><a href="#cookies">8. Cookie policy</a></li>
          <li><a href="#changes">9. Changes</a></li>
          <li><a href="#law">10. Governing law and jurisdiction</a></li>
        </ol>
      </nav>

      <article class="lgl__prose">

        <section id="owner">
          <h2>1. Owner identification</h2>
          <p>
            In compliance with <strong>Spanish Law 34/2002, of 11 July, on Information Society
            Services and Electronic Commerce</strong> (LSSI-CE), users are informed of the
            following identifying details of the website owner:
          </p>
          <ul class="lgl__data">
            <li><strong>Owner:</strong> David Javier Pintado Laruelo (individual self-employed)</li>
            <li><strong>NIF (Spanish Tax ID):</strong> 09394016B</li>
            <li><strong>Trading name:</strong> Aventuraenelsella.es</li>
            <li><strong>Activity:</strong> Adventure sports</li>
            <li><strong>Tourism authorization:</strong> TA-188-AS · holder Aipol Aventura (activity carried out under its authorization at the shared premises in Arriondas)</li>
            <li><strong>Registered address:</strong> Bermudo I el Diácono 3 Bajo, 33012 Oviedo, Asturias</li>
            <li><strong>Activity address:</strong> Calle Juan Carlos I, 18, Bajo II (access via Aipol), 33540 Arriondas, Asturias</li>
            <li><strong>Phone:</strong> <a href="tel:+34681093673">+34 681 09 36 73</a></li>
            <li><strong>Email:</strong> <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a></li>
            <li><strong>Domain:</strong> <a href="https://aventuraenelsella.es">aventuraenelsella.es</a></li>
          </ul>
        </section>

        <section id="scope">
          <h2>2. Scope</h2>
          <p>
            This Legal Notice governs the use of the website
            <a href="https://aventuraenelsella.es">aventuraenelsella.es</a>
            (hereinafter, "the website"), owned by the person identified above. Accessing
            the website implies full and unreserved acceptance of these general conditions.
          </p>
          <p>
            The website provides information about the canoe descent activity along the
            River Sella that we offer from Arriondas (Asturias, Spain), and enables booking
            the activity, communication with potential customers and related commercial
            management.
          </p>
        </section>

        <section id="conditions">
          <h2>3. Terms of use</h2>
          <p>
            The user agrees to use the website, its content and services in accordance with
            the law, morality, public order and these general conditions. In particular,
            the user undertakes to:
          </p>
          <ul>
            <li>Not use the website for purposes or effects contrary to the law, morality or public order.</li>
            <li>Not provide false, inaccurate or incorrect data when making bookings or contacting us.</li>
            <li>Not perform any act that may damage, disable, overload or impair the website.</li>
            <li>Not attempt to access restricted areas of the owner's IT systems.</li>
            <li>Not introduce or spread computer viruses or any other systems liable to cause damage.</li>
          </ul>
        </section>

        <section id="property">
          <h2>4. Intellectual and industrial property</h2>
          <p>
            All website content — including, but not limited to, texts, photographs,
            graphics, images, icons, technology, software, links and other audiovisual or
            audio content, as well as its graphic design and source code — is
            <strong>the intellectual property of the owner</strong> or of third parties
            who have authorized its use. None of the exploitation rights recognized under
            current intellectual property regulations shall be deemed transferred to the user.
          </p>
          <p>
            Trademarks, trade names and distinctive signs belong to the website owner. Access
            to the website does not grant any right over them.
          </p>
          <p>
            The total or partial reproduction, distribution, public communication,
            transformation or any other form of exploitation of website content is
            prohibited without the express written authorization of the owner.
          </p>
        </section>

        <section id="liability">
          <h2>5. Exclusion of liability</h2>
          <p>
            The website owner is not responsible for:
          </p>
          <ul>
            <li>Any damage of any kind arising from access to, use, copy or download of website content.</li>
            <li>Possible errors or deficiencies in accessing the website, including technical failures or service interruptions.</li>
            <li>The presence of viruses or any other harmful element that may alter the user's IT systems.</li>
            <li>The accuracy, currency or completeness of content on external links referenced on the website.</li>
          </ul>
          <p>
            The owner reserves the right to modify, suspend or interrupt, temporarily or
            permanently, the content and services offered, without prior notice.
          </p>
        </section>

        <section id="links">
          <h2>6. Third-party links</h2>
          <p>
            The website may contain links to third-party websites. The owner is not
            responsible for the content, accuracy, commercial practices or privacy
            policies of those external sites. These links are provided for informational
            purposes only and do not imply any recommendation or affiliation.
          </p>
        </section>

        <section id="data-protection">
          <h2>7. Data protection</h2>
          <p>
            The processing of users' personal data is governed by the
            <strong>EU General Data Protection Regulation 2016/679 (GDPR)</strong> and the
            Spanish <strong>Organic Law 3/2018, of 5 December, on the Protection of Personal
            Data and Guarantee of Digital Rights (LOPDGDD)</strong>. For detailed information,
            see our <a href={getLocalePath('legal_privacidad', lang)}>Privacy Policy</a>.
          </p>
        </section>

        <section id="cookies">
          <h2>8. Cookie policy</h2>
          <p>
            The website uses its own and third-party cookies to ensure proper operation and
            to improve the browsing experience. For detailed information, see our
            <a href={getLocalePath('legal_cookies', lang)}>Cookie Policy</a>.
          </p>
        </section>

        <section id="changes">
          <h2>9. Changes</h2>
          <p>
            The owner reserves the right to make, without prior notice, any modifications
            considered appropriate to the website, and may change, remove or add content
            and services, as well as the way they appear or are organized. The date of
            the last update of this Legal Notice appears at the top of this document.
          </p>
        </section>

        <section id="law">
          <h2>10. Governing law and jurisdiction</h2>
          <p>
            These conditions are governed by <strong>Spanish law</strong>. For the resolution
            of any dispute arising from access to the website or use of its content and
            services, the owner and the user submit to the Courts of the owner's domicile,
            unless current legislation establishes a different mandatory forum.
          </p>
        </section>

        <div class="lgl__contact" aria-label="Legal contact">
          <p>
            For any question regarding this Legal Notice, you can write to us at
            <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a>
            or call <a href="tel:+34681093673">+34 681 09 36 73</a>.
          </p>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .lgl {
    position: relative;
    background:
      radial-gradient(ellipse 60% 45% at 10% 0%, rgba(61, 79, 58, 0.05) 0%, transparent 60%),
      var(--color-bg-base);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    min-height: 80vh;
  }
  .lgl__inner {
    max-width: 900px; margin: 0 auto;
    padding: clamp(7rem, 14vw, 10rem) clamp(1.5rem, 4vw, 3rem) 0;
  }
  .lgl__breadcrumb {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
    font-family: var(--font-sans); font-size: 0.6875rem;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(26, 31, 46, 0.4);
    margin-bottom: 1.5rem;
  }
  .lgl__breadcrumb a { color: var(--color-sage, #3D4F3A); transition: color 200ms; }
  .lgl__breadcrumb a:hover { color: var(--color-primary); }
  .lgl__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1rem;
  }
  .lgl__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }
  .lgl__updated {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .lgl__toc {
    background: rgba(61, 79, 58, 0.04);
    border: 1px solid rgba(61, 79, 58, 0.12);
    border-radius: 0.875rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .lgl__tocTitle {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin: 0 0 1rem;
  }
  .lgl__toc ol { padding-left: 1.25rem; margin: 0; columns: 1; column-gap: 2rem; font-family: var(--font-sans); font-size: 0.9375rem; color: var(--color-text-secondary); }
  @media (min-width: 720px) { .lgl__toc ol { columns: 2; } }
  .lgl__toc ol li { margin-bottom: 0.5rem; }
  .lgl__toc a { color: var(--color-text-primary); transition: color 200ms; border-bottom: 1px solid transparent; }
  .lgl__toc a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  .lgl__prose { font-family: var(--font-sans); font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary); }
  .lgl__prose section { padding-top: clamp(2rem, 4vw, 3rem); scroll-margin-top: 5rem; }
  .lgl__prose section:first-child { padding-top: 0; }
  .lgl__prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 900; line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .lgl__prose p { margin: 0 0 1rem; color: var(--color-text-secondary); }
  .lgl__prose p strong { color: var(--color-text-primary); font-weight: 700; }
  .lgl__prose ul { padding-left: 1.25rem; margin: 0 0 1rem; }
  .lgl__prose ul li { margin-bottom: 0.5rem; color: var(--color-text-secondary); }
  .lgl__prose ul.lgl__data {
    background: #fff;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem 1.25rem 2.75rem;
    list-style: none;
  }
  .lgl__prose ul.lgl__data li { padding-left: 0; position: relative; margin-bottom: 0.625rem; }
  .lgl__prose ul.lgl__data li::before { content: "·"; position: absolute; left: -1.25rem; color: var(--color-sage, #3D4F3A); font-weight: 900; }
  .lgl__prose a {
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(61, 79, 58, 0.4);
    transition: color 200ms, border-color 200ms;
  }
  .lgl__prose a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .lgl__contact {
    margin-top: clamp(3rem, 5vw, 4rem);
    padding: 1.5rem 1.75rem;
    background: rgba(61, 79, 58, 0.06);
    border-left: 3px solid var(--color-sage, #3D4F3A);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .lgl__contact p { margin: 0; }
</style>
