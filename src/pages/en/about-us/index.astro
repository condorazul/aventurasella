---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'About us · Aventura en el Sella · over 25 years in Arriondas';
const description = 'A team of men and women with over 25 years organising the Sella River descent from Arriondas. Nature, active sport and close customer care. 4.5★ · 147 real reviews.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/about-us/`;
const dateModified = '2026-05-12';

// 4 counters · real figures
const counters = [
  { num: '+25',  unit: 'years',    label: 'In Arriondas' },
  { num: '4.5',  unit: '★',        label: 'Average rating' },
  { num: '+147', unit: 'reviews',  label: 'Google + TripAdvisor' },
  { num: '300',  unit: 'spaces',   label: 'Private car park · monitored' },
];

// 4 principles · "Four things that don't change"
const principios = [
  {
    n: '01',
    title: 'Clear price · no surprises',
    text: 'The price you see online is the price you pay. <strong>€30 children up to 12 years · €40 adults · pets free</strong>. Same price Mini Sella or Full. No weekend surcharges, no hidden deposits.',
  },
  {
    n: '02',
    title: 'All included · no extras',
    text: 'Unsinkable canoe, double paddle, certified life jacket, dry barrel, wetsuit if the date calls for it, mini-class, Asturian picnic, transfer, changing rooms with showers, locked lockers and insurance. <strong>Everything in the price.</strong>',
  },
  {
    n: '03',
    title: 'Private car park · 300 spaces',
    text: '<strong>Private and monitored car park</strong> at our Arriondas premises — capacity for up to <strong>300 cars and motorhomes</strong>. No surcharge, no tickets, no hunting for a space when high season hits.',
  },
  {
    n: '04',
    title: 'Flexible booking',
    text: 'You choose whatever suits you best: <strong>pay by card in advance</strong> or <strong>pay on the day when picking up the canoe</strong>. If you paid in advance and need to cancel, just let us know <strong>24 h before</strong>.',
  },
];

// "What we do every day" · 3 team functions
const funciones = [
  {
    title: 'Counter service',
    text: 'We welcome you, register your booking, hand you the locker key and walk you through the day. <strong>Face to face</strong>, no touch screens or long queues — because that\'s how we like to be looked after ourselves.',
  },
  {
    title: 'Live on the river',
    text: '<strong>Certified instructors</strong> who run the paddling briefing class before setting off and patrol the descent from safety kayaks. They know every bend of the Sella by heart, after running the river hundreds of times each season.',
  },
  {
    title: 'Maintenance and logistics',
    text: 'Daily check of canoes, paddles and life jackets. Fresh Asturian picnic every morning (tuna pie, traditional bun and water). Coordination of the return transfer at the end of the route. The invisible work that makes the day flow.',
  },
];

// 4 info boxes · facilities
const instalaciones = [
  {
    title: 'Address',
    text: 'Calle Juan Carlos I, 18 — Bajo II<br/><small>(access via the Aipol premises)</small><br/>33540 Arriondas · Asturias',
  },
  {
    title: 'Private car park',
    text: '<strong>300 spaces</strong> · private · monitored<br/>Cars + motorhomes<br/><small>Free · included in the booking</small>',
  },
  {
    title: 'Changing rooms and showers',
    text: 'Separate changing rooms with <strong>hot showers</strong> and <strong>locked lockers</strong> · comfortable change before and after the descent',
  },
  {
    title: 'Counter and briefing class',
    text: 'Reception · equipment handover · <strong>practical briefing class</strong> on paddling and safety before setting off · certified instructors',
  },
];

// Featured testimonial · real review
const testimonio = {
  text: 'Great service, attentive and very friendly staff. The experience was wonderful, I loved it.',
  author: 'Anaïs Suárez Blanco',
  source: 'Google · October 2025',
};

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'AboutPage',
      '@id': `${canonicalUrl}#aboutpage`,
      url: canonicalUrl,
      name: 'About us · Aventura en el Sella',
      description,
      inLanguage: 'en-GB',
      dateModified,
      mainEntity: { '@id': `${baseUrl}/#business` },
    },
    {
      '@type': 'Organization',
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      logo: `${baseUrl}/images/logo/logo.svg`,
      image: `${baseUrl}/images/optimized/aventureros-montana-lg.jpg`,
      foundingLocation: 'Arriondas, Asturias, Spain',
      slogan: 'Over 25 years organising the Sella River canoe descent',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 4.5,
        reviewCount: 147,
        bestRating: 5,
        worstRating: 1,
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',     item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'About us', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/about-us/" translationKey="quienes_somos">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO ============== -->
  <section class="qsHero" aria-labelledby="qsHero-title">
    <div class="qsHero__inner">
      <nav class="qsHero__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', lang)}>Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">About us</span>
      </nav>

      <span class="qsHero__eyebrow">— Over 25 years in Arriondas</span>

      <h1 id="qsHero-title" class="qsHero__title">
        One team, one river,<br/>
        <span class="serif-italic">thousands of descents.</span>
      </h1>

      <p class="qsHero__lead">
        We're a group of <strong>men and women</strong> of different ages, skills and specialities — united by a passion for <strong>nature, active sport and eastern Asturias</strong>. For over 25 years we've been in Arriondas watching the Sella flow by, with families, couples, groups of friends, grandparents with grandchildren and gangs who come back every summer.
      </p>

      <div class="qsHero__media" data-reveal data-reveal-type="slide-right">
        <Picture
          src="quienes-somos-hero"
          alt="Aventura en el Sella team · group in Arriondas · 25 years on the Sella River"
          sizes="(min-width: 960px) 1100px, 92vw"
          aspectRatio="16 / 9"
          priority="high"
        />
      </div>
    </div>
  </section>

  <!-- ============== 2 · VALUE + 4 COUNTERS ============== -->
  <section class="qsValue" aria-labelledby="qsValue-title">
    <div class="qsValue__inner">
      <div class="qsValue__copy">
        <span class="qsValue__eyebrow">— Who we are</span>
        <h2 id="qsValue-title" class="qsValue__title">
          Same place,<br/>
          <span class="serif-italic">same way of working.</span>
        </h2>
        <p class="qsValue__lead">
          We're in the centre of Arriondas, right by the start of the Sella River descent. <strong>Same people, same place, same way of working</strong> since we opened. Transparent pricing, our own crew on the river and everything you need for the day included in the rate — because that's how we like to be treated when we travel ourselves.
        </p>
      </div>

      <ul class="qsValue__counters" role="list">
        {counters.map(c => (
          <li class="qsValue__counter">
            <span class="qsValue__counterNum">{c.num}<span class="qsValue__counterUnit">{c.unit}</span></span>
            <span class="qsValue__counterLabel">{c.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 3 · HOW WE WORK · 4 PRINCIPLES ============== -->
  <section class="qsPrin" aria-labelledby="qsPrin-title">
    <div class="qsPrin__inner">
      <header class="qsPrin__header">
        <span class="qsPrin__eyebrow">— How we work</span>
        <h2 id="qsPrin-title" class="qsPrin__title">
          Four things<br/>
          <span class="serif-italic">that don't change.</span>
        </h2>
        <p class="qsPrin__lead">
          We've been doing the same thing for over 25 years because it works. <strong>We don't change the rules in high season</strong> nor tighten the terms when demand is up — it's part of the deal from day one.
        </p>
      </header>

      <ul class="qsPrin__grid" role="list">
        {principios.map(p => (
          <li class="qsPrin__card">
            <span class="qsPrin__num">{p.n}</span>
            <h3 class="qsPrin__cardTitle">{p.title}</h3>
            <p class="qsPrin__cardText" set:html={p.text}></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 4 · THE TEAM ============== -->
  <section class="qsTeam" aria-labelledby="qsTeam-title">
    <div class="qsTeam__inner">
      <div class="qsTeam__intro">
        <span class="qsTeam__eyebrow">— Our team</span>
        <h2 id="qsTeam-title" class="qsTeam__title">
          Men and women,<br/>
          <span class="serif-italic">different ages, one passion.</span>
        </h2>
        <p class="qsTeam__lead">
          We're not a multinational with uniforms. We're a <strong>small group of real people</strong> — men and women of different ages, specialities and ways of working, with one thing in common: we love this river and we want you to enjoy it just as much as we do.
        </p>
        <p class="qsTeam__text">
          Every day someone's welcoming people at the counter, someone's checking canoes in the workshop, certified instructors are running the briefing class before launch and watching the river from safety kayaks, and someone else is driving the return transfer. If you call and a different person picks up, it's because <strong>we rotate so someone is always available to answer you</strong> — not because we're a call-centre.
        </p>
      </div>

      <div class="qsTeam__media" data-reveal data-reveal-type="slide-right">
        <Picture
          src="quienes-somos-equipo"
          alt="Aventura en el Sella team on the water · certified Sella River descent instructors"
          sizes="(min-width: 900px) 50vw, 92vw"
          aspectRatio="4 / 5"
        />
      </div>
    </div>

    <div class="qsTeam__functions">
      <h3 class="qsTeam__functionsTitle">What we do every day</h3>
      <ul class="qsTeam__functionsGrid" role="list">
        {funciones.map(f => (
          <li class="qsTeam__function">
            <h4 class="qsTeam__functionTitle">{f.title}</h4>
            <p class="qsTeam__functionText" set:html={f.text}></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============== 5 · FACILITIES ============== -->
  <section class="qsInst" aria-labelledby="qsInst-title">
    <div class="qsInst__inner">
      <header class="qsInst__header">
        <span class="qsInst__eyebrow">— Our facilities</span>
        <h2 id="qsInst-title" class="qsInst__title">
          In the centre<br/>
          <span class="serif-italic">of Arriondas.</span>
        </h2>
        <p class="qsInst__lead">
          Everything in a single spot: <strong>shop, changing rooms, counter and private car park</strong>. You arrive, park, register, kit up and set off — no shuttling between locations. Access is via the Aipol premises, right in the heart of Arriondas.
        </p>
      </header>

      <ul class="qsInst__grid" role="list">
        {instalaciones.map(i => (
          <li class="qsInst__card">
            <h3 class="qsInst__cardTitle">{i.title}</h3>
            <p class="qsInst__cardText" set:html={i.text}></p>
          </li>
        ))}
      </ul>

      <a href={getLocalePath('como_llegar', lang)} class="qsInst__cta">
        How to get there
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- ============== 6 · WHAT THEY SAY · TESTIMONIAL ============== -->
  <section class="qsVoice" aria-labelledby="qsVoice-title">
    <div class="qsVoice__inner">
      <span class="qsVoice__eyebrow">— What they say</span>
      <h2 id="qsVoice-title" class="qsVoice__title">
        +25 years<br/>
        <span class="serif-italic">of care that leaves a mark.</span>
      </h2>

      <blockquote class="qsVoice__quote" cite="https://share.google/huLLaIz31FiYohuTV">
        <p>"{testimonio.text}"</p>
        <footer class="qsVoice__cite">
          <cite>— {testimonio.author}</cite>
          <span>{testimonio.source}</span>
        </footer>
      </blockquote>

      <ul class="qsVoice__metrics" role="list">
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">4.5<span class="qsVoice__metricUnit">★</span></span>
          <span class="qsVoice__metricLabel">Average rating</span>
        </li>
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">+147</span>
          <span class="qsVoice__metricLabel">Verified reviews</span>
        </li>
        <li class="qsVoice__metric">
          <span class="qsVoice__metricNum">+25</span>
          <span class="qsVoice__metricLabel">Years in Arriondas</span>
        </li>
      </ul>

      <a href={getLocalePath('opiniones', lang)} class="qsVoice__cta">
        See all reviews
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- ============== 7 · FINAL CTA ============== -->
  <FinalCTA />
</BaseLayout>

<style>
  /* ====================== LOCAL TOKENS ====================== */
  .qsHero, .qsValue, .qsPrin, .qsTeam, .qsInst, .qsVoice {
    --section-pad: clamp(4rem, 8vw, 7rem);
    --container-max: 1200px;
    --container-pad: clamp(1.25rem, 4vw, 2rem);
  }

  /* ====================== 1 · HERO ====================== */
  .qsHero {
    background: var(--color-bg-warm, #F6F1E3);
    padding-block: clamp(5rem, 9vw, 8rem) clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .qsHero::before {
    content: '';
    position: absolute;
    inset: auto -15% -40% auto;
    width: 60%;
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(233, 133, 111, 0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .qsHero__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    position: relative;
  }
  .qsHero__breadcrumb {
    display: flex; align-items: center; gap: var(--s-2);
    font-size: var(--fs-caption);
    color: var(--color-text-secondary);
    margin-bottom: var(--s-8);
  }
  .qsHero__breadcrumb a { color: var(--color-text-secondary); transition: color var(--duration-base) var(--ease-out); }
  .qsHero__breadcrumb a:hover { color: var(--color-primary); }
  .qsHero__breadcrumb span[aria-current] { color: var(--color-text-primary); font-weight: var(--fw-medium); }
  .qsHero__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-5);
  }
  .qsHero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-6);
    text-wrap: balance;
    max-width: 18ch;
  }
  .qsHero__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsHero__lead {
    font-size: clamp(1.075rem, 1.6vw, 1.3rem);
    line-height: var(--lh-body, 1.65);
    color: var(--color-text-secondary);
    max-width: 60ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .qsHero__lead strong { color: var(--color-text-primary); font-weight: var(--fw-semibold); }
  .qsHero__media {
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
    overflow: hidden;
    box-shadow: 0 24px 56px -32px rgba(26, 31, 46, 0.18);
  }

  /* ====================== 2 · VALUE + COUNTERS ====================== */
  .qsValue {
    background: var(--color-bg-base);
    padding-block: var(--section-pad);
  }
  .qsValue__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .qsValue__inner { grid-template-columns: 1.1fr 1fr; gap: clamp(3rem, 6vw, 5rem); }
  }
  .qsValue__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-4);
  }
  .qsValue__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-5);
    text-wrap: balance;
  }
  .qsValue__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsValue__lead {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: var(--lh-body, 1.65);
    color: var(--color-text-secondary);
  }
  .qsValue__lead strong { color: var(--color-text-primary); font-weight: var(--fw-semibold); }

  .qsValue__counters {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
    list-style: none;
    padding: 0; margin: 0;
  }
  .qsValue__counter {
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1rem, 2vw, 1.5rem);
    background: var(--color-bg-warm, #F6F1E3);
    border: 1px solid rgba(26, 31, 46, 0.06);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    display: flex; flex-direction: column; gap: var(--s-2);
    transition: transform 320ms var(--ease-out), border-color 320ms var(--ease-out);
  }
  .qsValue__counter:hover {
    transform: translateY(-3px);
    border-color: rgba(233, 133, 111, 0.3);
  }
  .qsValue__counterNum {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--fw-black);
    line-height: 1;
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    display: inline-flex; align-items: baseline; gap: 0.25rem;
  }
  .qsValue__counterUnit {
    font-size: 0.45em;
    font-weight: var(--fw-bold);
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsValue__counterLabel {
    font-size: var(--fs-caption);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  /* ====================== 3 · PRINCIPLES ====================== */
  .qsPrin {
    background: var(--color-bg-warm, #F6F1E3);
    padding-block: var(--section-pad);
  }
  .qsPrin__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .qsPrin__header {
    max-width: 720px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .qsPrin__eyebrow {
    display: block;
    font-size: var(--fs-label-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--s-4);
  }
  .qsPrin__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight, 1.05);
    letter-spacing: var(--ls-tightest);
    color: var(--color-text-primary);
    margin-bottom: var(--s-5);
    text-wrap: balance;
  }
  .qsPrin__title .serif-italic {
    font-family: var(--font-serif);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }
  .qsPrin__lead {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: var(--lh-body, 1.65);
    color: var(--color-text-secondary);
  }
  .qsPrin__lead strong { color: var(--color-text-primary); font-weight: var(--fw-semibold); }

  .qsPrin__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    list-style: none;
    padding: 0; margin: 0;
  }
  @media (min-width: 720px) {
    .qsPrin__grid { grid-template-columns: repeat(2, 1fr); }
  }
  .qsPrin__card {
    padding: clamp(1.75rem, 3vw, 2.5rem);
    background: var(--color-bg-elevated, #FFFFFF);
    border: 1px solid rgba(26, 31, 46, 0.06);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    display: flex; flex-direction: column; gap: var(--s-3);
    transition: transform 380ms var(--ease-out), box-shadow 380ms var(--ease-out), border-color 380ms var(--ease-out);
  }
  .qsPrin__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px -28px rgba(26, 31, 46, 0.16);
    border-color: rgba(233, 133, 111, 0.25);
  }
  .qsPrin__num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: var(--fw-black);
    color: var(--color-primary);
    letter-spacing: var(--ls-wide);
  }
  .qsPrin__cardTitle {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
    font-weight: var(--fw-bold);
    line-height: 1.2;
