---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Sella River descent prices · From €30 all inclusive';
const description = 'Sella River descent prices: €30 children · €40 adults. All inclusive (canoe, picnic, transfer, parking). Pets travel free. Book without paying now.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/prices/`;

// All inclusive · ordered by relevance for those checking prices
const incluido = [
  { icon: 'canoe',    title: 'K1, K2 and K3 canoes',           sub: 'Unsinkable, with paddle and dry barrel' },
  { icon: 'shield',   title: 'Life jacket',                    sub: 'Certified, fitted by size' },
  { icon: 'wetsuit',  title: 'Wetsuit',                        sub: 'Except from 15/06 to 28/09' },
  { icon: 'teacher',  title: 'Mini class + instructors',       sub: 'Certified and Sella champions' },
  { icon: 'picnic',   title: 'Asturian picnic',                sub: 'Tuna pie, traditional bun and water' },
  { icon: 'bus',      title: 'Return transfer',                sub: 'From Toraño or Fríes' },
  { icon: 'shower',   title: 'Changing rooms with showers',    sub: 'Locked lockers included' },
  { icon: 'parking',  title: 'Private parking',                sub: '300 spaces · guarded · motorhomes' },
  { icon: 'paw',      title: 'Pets travel free',               sub: 'The whole family in the canoe' },
  { icon: 'ticket',   title: 'Mandatory insurance',            sub: 'Full coverage included' },
  { icon: 'ramp',     title: 'Boarding ramp',                  sub: 'Optional and free · or board at the riverbank' },
  { icon: 'heart',    title: 'A warm, personal welcome',       sub: 'No queues, no robots, no extras' },
];

const rutas = [
  {
    name: 'Mini Sella',   km: '7 km',   dur: '2 – 3 h',   desc: 'Short route from Arriondas to Toraño. Ideal if you are with little ones, want to make plenty of stops or prefer a relaxed paddle.', tone: 'sage',
  },
  {
    name: 'Full route',     km: '14.5 km', dur: '4 – 5 h',  desc: 'Classic route from Arriondas to Fríes. More kilometres, more landscape, more stops for a swim. The most complete experience.', tone: 'coral',
  },
];

const faqs = [
  { q: 'How much does it cost to descend the Sella?',
    a: `Descending the Sella by canoe with us costs <strong>€40 per adult</strong> (from 13 years) and <strong>€30 per child</strong> (5 to 12 years). The price is <strong>all inclusive</strong>: unsinkable canoe, life jacket, double paddle, wetsuit on cold dates, dry barrel, mini class with certified instructor, Asturian picnic (tuna pie, traditional Asturian bun and water), return transfer, <strong>guarded private parking (300 spaces · also for motorhomes)</strong>, changing rooms with showers, locked lockers and insurance. <strong>Pets travel free</strong>. The only day with a different rate is the Saturday of the <a href="${getLocalePath('descenso_internacional', 'en')}">International Sella River Descent</a> — €35 with special conditions.` },
  { q: 'Is the price per person or per canoe?',
    a: 'The price is <strong>per person</strong>, not per canoe. If two adults share a K2, you each pay <strong>€40</strong>. If three of you share a K3, the same — sharing a canoe does not change the individual rate.' },
  { q: 'Does the Mini route cost the same as the Full route?',
    a: 'Yes — <strong>one booking, one single price</strong>. You choose your route on the water, not when you book. You can set off thinking of the Full route and stop in Toraño (km 7) if you feel like it, or start with the Mini in mind and continue all the way to Fríes. Neither the price nor what is included changes.' },
  { q: 'Are there group discounts?',
    a: 'For groups of <strong>10 or more people</strong> we offer special conditions. Drop us a line on <a href="https://wa.me/34681093673?text=Hello,%20we%20are%20a%20group%20of...">WhatsApp</a> or <a href="mailto:info@aventuraenelsella.es">email</a> with the number of people and approximate date, and we will prepare a tailored proposal.' },
  { q: 'How do I pay? Do I have to pay in advance?',
    a: `Book <strong>without paying now</strong>. Choose whatever is most convenient for you: <strong>card payment in advance</strong> or <strong>pay on the day when you pick up the canoe</strong>. The only exception is <a href="${getLocalePath('descenso_internacional', 'en')}">the Saturday of the International Descent</a>, which can only be booked with advance payment.` },
  { q: 'Can I change the date or cancel?',
    a: 'You can <strong>change or cancel at any time before the day of the activity</strong>, free of charge. If you paid by <strong>card in advance</strong>, to process the refund we need you to let us know at least <strong>24 hours</strong> beforehand. Get in touch via WhatsApp or email and we will move the date or refund the amount.' },
  { q: 'Do I have to choose a departure time?',
    a: `No. Your booking is <strong>Premium · open schedule</strong>: arrive at our Arriondas premises <strong>whenever suits you between 10:30 and 12:30</strong>, without picking a specific time. It is one of the <strong>Premium advantages</strong>. The only exception is the Saturday of the <a href="${getLocalePath('descenso_internacional', 'en')}">International Descent</a> (single departure at 12:00) and days with river conditions requiring a guided entry with an instructor (we let you know in advance). The river authority (Confederación Hidrográfica) limits permanence on the river until 18:00.` },
  { q: 'From what age can children take part?',
    a: 'Children can take part from <strong>5 years old and a minimum height of 1.15 m</strong>. It is a <strong>strict safety requirement</strong>, not only because of the life jacket — also because of the nature of the river (current, variable depth, sections with rapids) and as required by our insurance providers. <strong>Children below the minimum are not admitted</strong>, even when accompanied by an adult or if they can swim.' },
  { q: 'What happens on the day of the International Descent?',
    a: `On the Saturday of the <a href="${getLocalePath('descenso_internacional', 'en')}">International Sella River Descent</a> a single price of <strong>€35 per person</strong> applies, with its own conditions: single departure at 12:00, mandatory advance payment, no picnic included and very limited places. Everything is explained on its dedicated page.` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Sella River canoe descent · All inclusive',
      description: 'Touristic canoe descent along the Sella River from Arriondas. All inclusive: canoe, equipment, mini class with certified instructors, return transfer, Asturian picnic, changing rooms and parking. Pets travel free.',
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      image: `${baseUrl}/images/optimized/includes-b.jpg`,
      offers: [
        { '@type': 'Offer', name: 'Children (up to 12 years)', price: '30.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/en/book/` },
        { '@type': 'Offer', name: 'Adult',                    price: '40.00', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/en/book/` },
        { '@type': 'Offer', name: 'International Descent day', price: '35.00', priceCurrency: 'EUR', availability: 'https://schema.org/LimitedAvailability', url: `${baseUrl}/en/international-sella-descent/` },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5', reviewCount: '147', bestRating: '5', worstRating: '1',
      },
      inLanguage: 'en-GB',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'en-GB',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',   item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Prices', item: canonicalUrl },
      ],
    },
    {
      '@type': 'WebPage',
      '@id': canonicalUrl,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'en-GB',
      keywords: 'sella river descent prices, canoe rental sella, arriondas canoeing prices, sella river canoe tour cost',
      dateModified: '2026-05-12',
      isPartOf: { '@id': `${baseUrl}/#website` },
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/prices/" translationKey="precios">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="prh" aria-labelledby="prh-title">

    <div class="prh__inner">
      <nav class="prh__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', 'en')}>Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Prices</span>
      </nav>

      <div class="prh__grid">
        <div class="prh__main">
          <span class="prh__eyebrow">
            <span class="prh__eyebrow-dot" aria-hidden="true"></span>
            From €30 · 2026 Season
          </span>

          <h1 id="prh-title" class="prh__title">
            Prices for the<br/>
            <span class="serif-italic">Sella River descent</span>
          </h1>

          <p class="prh__lead">
            <strong>One single price, all inclusive</strong>. You pick your route on the
            water, not on the website. The cost depends only on age — not on the
            kilometres or on whether you stop at Toraño or paddle on to Fríes.
          </p>

          <div class="prh__stats">
            <span class="prh__statsKicker">
              <span class="prh__statsKickerMark" aria-hidden="true"></span>
              Single rate · all inclusive
            </span>
            <div class="prh__statsRow">
              <div class="prh__stat">
                <strong>30<small>€</small></strong>
                <span>Children · 5–12</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>40<small>€</small></strong>
                <span>Adults</span>
              </div>
              <div class="prh__stat-divider" aria-hidden="true"></div>
              <div class="prh__stat">
                <strong>Free</strong>
                <span>Pets</span>
              </div>
            </div>
          </div>
        </div>

        <aside class="prh__contact" aria-label="Book or get in touch">
          <span class="prh__contactKicker">— Book your spot</span>
          <ul class="prh__contactList" role="list">
            <li>
              <a href={getLocalePath('reservar', 'en')} class="prh__contactPill prh__contactPill--primary">
                <strong>Book now</strong>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </li>
            <li>
              <a href="tel:+34681093673" class="prh__contactPill" aria-label="Call 681 09 36 73">
                <strong>Call us</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Hello%2C%20I%27d%20like%20more%20info%20about%20prices" target="_blank" rel="noopener noreferrer" class="prh__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Reply in minutes</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== PRICE CARDS ============== -->
  <section class="prp">
    <div class="container container--xl">
      <header class="prp__header" data-reveal>
        <span class="prp__eyebrow">— Rates</span>
        <h2 class="prp__title">
          Price per person,<br/>
          <span class="serif-italic">all inclusive</span>
        </h2>
        <p class="prp__lead">
          No extras. No fee for going all the way to Fríes. No add-on for the wetsuit, transfer or picnic.<br/>
          <strong>The price you see is the final price.</strong>
        </p>
      </header>

      <div class="prp__grid">
        <!-- CARD 1: CHILDREN -->
        <article class="prpCard prpCard--sage" data-reveal data-reveal-delay="1">
          <div class="prpCard__media">
            <Picture src="precios-ninos" alt="Children enjoying the Sella River canoe descent" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Child rate</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">€30&nbsp; <span>/ child</span></p>
              <p class="prpCard__mediaSub">5–12 years · Shared canoe</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Child seat</h3>
              <span class="prpCard__rating" aria-label="Average rating 4.9 out of 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">5–12</span><span class="prpCard__stat-lbl">Years</span></li>
              <li><span class="prpCard__stat-val">K2/K3</span><span class="prpCard__stat-lbl">Canoe</span></li>
              <li><span class="prpCard__stat-val">Yes</span><span class="prpCard__stat-lbl">Gear</span></li>
              <li><span class="prpCard__stat-val">Yes</span><span class="prpCard__stat-lbl">Picnic</span></li>
            </ul>
            <p class="prpCard__desc">
              The most affordable option for families · the little ones paddle sharing a canoe with an adult, with the <strong>same full coverage as the adult rate</strong>.
            </p>
            <ul class="prpCard__list">
              <li>Minimum age <strong>5 years and 1.15 m</strong> · no exceptions</li>
              <li>Canoe shared with a responsible adult</li>
              <li>Children's gear, picnic and services included · <a href="#pri-title">see detail below</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'en')} class="prpCard__cta prpCard__cta--primary">
              Book child place
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 2: ADULTS -->
        <article class="prpCard prpCard--coral" data-reveal data-reveal-delay="2">
          <div class="prpCard__media">
            <Picture src="precios-adultos" alt="Group of friends on the Sella River canoe descent" sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw" aspectRatio="4 / 3" bare />
            <span class="prpCard__mediaTag">Adult rate</span>
            <div class="prpCard__mediaContent">
              <p class="prpCard__mediaTitle">€40&nbsp; <span>/ adult</span></p>
              <p class="prpCard__mediaSub">From 13 years · All inclusive</p>
            </div>
          </div>
          <div class="prpCard__body">
            <div class="prpCard__head">
              <h3 class="prpCard__name">Adult seat</h3>
              <span class="prpCard__rating" aria-label="Average rating 4.9 out of 5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.9
              </span>
            </div>
            <ul class="prpCard__stats">
              <li><span class="prpCard__stat-val">13+</span><span class="prpCard__stat-lbl">Years</span></li>
              <li><span class="prpCard__stat-val">K1/K2/K3</span><span class="prpCard__stat-lbl">Canoe</span></li>
              <li><span class="prpCard__stat-val">Yes</span><span class="prpCard__stat-lbl">Gear</span></li>
              <li><span class="prpCard__stat-val">Yes</span><span class="prpCard__stat-lbl">Picnic</span></li>
            </ul>
            <p class="prpCard__desc">
              The standard rate · choose <strong>K1 solo, K2 as a pair or K3 with friends</strong> — the per-person price stays the same.
            </p>
            <ul class="prpCard__list">
              <li>From <strong>13 years old</strong></li>
              <li>Single, double or triple canoe <strong>(K1/K2/K3)</strong></li>
              <li>You pick your route on the water (Mini or Full) at no extra cost · <a href="#pri-title">see detail below</a></li>
            </ul>
            <a href={getLocalePath('reservar', 'en')} class="prpCard__cta prpCard__cta--primary">
              Book adult place
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- CARD 3: CTA IMAGE -->
        <article class="prpCardCTA" data-reveal data-reveal-delay="3">
          <div class="prpCardCTA__media">
            <video
              class="prpCardCTA__video"
              muted loop playsinline
              preload="none"
              poster="/videos/rio-sella-loop-poster.jpg"
              aria-hidden="true"
              data-src="/videos/rio-sella-loop.mp4"
            ></video>
          </div>
          <div class="prpCardCTA__inner">
            <div class="prpCardCTA__bottom">
              <span class="prpCardCTA__kicker">Aventura en el Sella &nbsp;·&nbsp; Canoe rental</span>
              <h3 class="prpCardCTA__title">
                Book your spot<br/>with us
              </h3>
              <a href={getLocalePath('reservar', 'en')} class="prpCardCTA__btn">
                <span>Book now</span>
                <span class="prpCardCTA__btnIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
          </div>
        </article>
      </div>

      <p class="prp__note" data-reveal>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Pets travel free any day — <strong>except on the Saturday of the <a href={getLocalePath('descenso_internacional', 'en')}>International Descent</a></strong>, due to the crowds and noise of the event.</span>
      </p>
    </div>
  </section>

  <!-- ============== ALL INCLUDED ============== -->
  <section class="pri" id="pri-title">
    <div class="container container--xl">
      <header class="pri__header" data-reveal>
        <span class="pri__eyebrow">— All inclusive means all of it</span>
        <h2 class="pri__title">
          The day of your descent,<br/>
          <span class="serif-italic">you already have it all</span>
        </h2>
        <p class="pri__lead">
          See everything your <strong>Premium booking</strong> includes — your day
          sorted down to the last detail. You arrive, we welcome you, we kit you
          out, you paddle the river and we bring you back. <strong>All you have to
          do is forget your worries and enjoy</strong>.
        </p>
      </header>

      <ul class="priD">
        {incluido.map((it, i) => (
          <li class="priDItem" data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="priDItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="priDItem__body">
              <h3 class="priDItem__title">
                <span class="priDItem__icon" aria-hidden="true">
                  {it.icon === 'canoe'   && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 14c3-4 7-6 10-6s7 2 10 6"/><path d="M2 14c3 4 7 6 10 6s7-2 10-6"/></svg>}
                  {it.icon === 'shield'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {it.icon === 'wetsuit' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8l1 4-2 3v10a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V10L7 7z"/></svg>}
                  {it.icon === 'teacher' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>}
                  {it.icon === 'picnic'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h18l-1 5H4z"/><path d="M5 13l1 8M19 13l-1 8"/></svg>}
                  {it.icon === 'bus'     && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/></svg>}
                  {it.icon === 'shower'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6M8 9h8"/><path d="M6 12c0 5 2 9 6 9s6-4 6-9z"/></svg>}
                  {it.icon === 'parking' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>}
                  {it.icon === 'paw'     && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>}
                  {it.icon === 'ticket'  && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v3a2 2 0 0 1 0 4v3a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-3a2 2 0 0 1 0-4V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"/></svg>}
                  {it.icon === 'ramp'    && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21L21 3"/><path d="M3 21h18"/></svg>}
