    color: #FBF8F1;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    z-index: 3;
    box-shadow: 0 8px 22px rgba(61, 79, 58, 0.35);
    animation: metRibbonFloat 4s ease-in-out infinite;
