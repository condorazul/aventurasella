---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const lang = 'en';
const title = 'Best time to do the Sella River descent · month by month';
const description = 'The best time to do the Sella River descent: month by month, climate, flow, crowd and tips. Book without paying now · pets free.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/best-time/`;

// 12-month calendar · ideal rating (0=off-season · 1=start/end · 2=good · 3=very good · 4=ideal)
const meses = [
  { n: 'Jan', full: 'January',   rating: 0, label: 'Off-season',                  tone: 'off'   },
  { n: 'Feb', full: 'February',  rating: 0, label: 'Off-season',                  tone: 'off'   },
  { n: 'Mar', full: 'March',     rating: 0, label: 'Off-season',                  tone: 'off'   },
  { n: 'Apr', full: 'April',     rating: 2, label: 'Start of season',             tone: 'soft'  },
  { n: 'May', full: 'May',       rating: 3, label: 'Very good — low crowd',       tone: 'mid'   },
  { n: 'Jun', full: 'June',      rating: 4, label: 'Ideal — flow + climate',      tone: 'high'  },
  { n: 'Jul', full: 'July',      rating: 3, label: 'Popular — good climate',      tone: 'warm'  },
  { n: 'Aug', full: 'August',    rating: 2, label: 'Maximum crowd — book now',    tone: 'coral' },
  { n: 'Sep', full: 'September', rating: 4, label: 'Ideal — calm + climate',      tone: 'high'  },
  { n: 'Oct', full: 'October',   rating: 2, label: 'End of season · autumn landscape', tone: 'ocre' },
  { n: 'Nov', full: 'November',  rating: 0, label: 'Off-season',                  tone: 'off'   },
  { n: 'Dec', full: 'December',  rating: 0, label: 'Off-season',                  tone: 'off'   },
];

// 4 seasons for the tabs
const estaciones = [
  {
    id: 'primavera',
    tab: 'Spring',
    meses: 'Apr – Jun',
    eyebrow: 'Spring',
    route: 'Lively flow, Cantabrian green',
    stats: [
      { v: '14–18', u: '°C',    l: 'water' },
      { v: 'High',  u: '',      l: 'flow' },
      { v: 'Low',   u: '',      l: 'crowd' },
    ],
    desc: 'The best time to do the Sella River descent if you seek <strong>calm and green landscape</strong>. The flow is more active due to snowmelt and spring rains, the river is at its best and there are very few people. Cooler water temperature — <strong>wetsuit recommended</strong>, available at pickup.',
    features: ['Active flow', 'Low crowd', 'Intense green', 'Wetsuit recommended', 'Long days', 'Clean air'],
    photo: 'sella-primavera',
    badges: ['Green', 'Calm', 'High flow'],
  },
  {
    id: 'verano',
    tab: 'Summer',
    meses: 'Jun – Aug',
    eyebrow: 'Summer',
    route: 'Sun, atmosphere and warm water',
    popular: true,
    ribbon: 'The favourite · most lively',
    stats: [
      { v: '18–22', u: '°C',    l: 'water' },
      { v: 'Medium', u: '',     l: 'flow' },
      { v: 'High',  u: '',      l: 'crowd' },
    ],
    desc: 'The Sella River descent <strong>in summer</strong> is the most popular option of the year. Good climate, warm water for swimming and lively atmosphere on the river beaches. <strong>August</strong> concentrates the season at its peak — days with more light, more life on the river and the best atmosphere. <a href="/en/book/">Check the booking calendar</a>: you will see which days are active and which are not. With 5-7 days in advance is usually enough, the sooner the better.',
    features: ['Warm water', 'Stable climate', 'Lively atmosphere', 'Book in advance', 'Riverside picnics', 'Family and friends'],
    photo: 'sella-verano',
    badges: ['Sunny', 'Family', 'Warm water'],
  },
  {
    id: 'otono',
    tab: 'Autumn',
    meses: 'Sep – Oct',
    eyebrow: 'Autumn',
    route: 'The best-kept secret of the Sella',
    stats: [
      { v: '16–20', u: '°C',    l: 'water' },
      { v: 'Medium', u: '',     l: 'flow' },
      { v: 'Low',   u: '',      l: 'crowd' },
    ],
    desc: '<strong>September</strong> is usually the best month of the year: still warm climate, fewer people and the river with good flow. October brings <strong>autumn landscape</strong> among the ochre tones of the forest. An intimate plan, without rush — for those who seek <strong>the calmest Sella</strong>.',
    features: ['Perfect balance', 'Few people', 'Autumn landscape', 'Mild climate', 'Golden light', 'Spectacular photos'],
    photo: 'sella-otono',
    badges: ['Calm', 'Ochre landscape', 'Golden light'],
  },
  {
    id: 'invierno',
    tab: 'Winter',
    meses: 'Nov – Mar',
    eyebrow: 'Winter',
    route: 'Off-season · to consult',
    stats: [
      { v: '8–14',  u: '°C',     l: 'water' },
      { v: 'Very high', u: '',   l: 'flow' },
      { v: '—',     u: '',       l: 'closed' },
    ],
    desc: 'The <strong>regular Sella River descent season is from April to October</strong>. Outside those months, the activity is not regularly operative due to high flow, water temperatures and variable conditions. If you have a specific date in mind, <strong>write to us</strong> and we will see.',
    features: ['Off-season', 'Very high flow', 'Cold water', 'Variable conditions', 'Check availability', 'Plan for spring'],
    photo: 'sella-invierno',
    badges: ['Consult', 'Off-season'],
  },
];

// Crowd per month · % relative to peak (August = 100) + seasonal photo + flip info
const afluencia = [
  { m: 'Jan', full: 'January',   p: 0,   photo: 'sella-enero',       temp: '—',      nota: 'Off-season' },
  { m: 'Feb', full: 'February',  p: 0,   photo: 'sella-febrero',     temp: '—',      nota: 'Off-season' },
  { m: 'Mar', full: 'March',     p: 0,   photo: 'sella-marzo',       temp: '—',      nota: 'Off-season' },
  { m: 'Apr', full: 'April',     p: 18,  photo: 'sella-abril',       temp: '14 °C',  nota: 'Start of season · green' },
  { m: 'May', full: 'May',       p: 35,  photo: 'sella-mayo',        temp: '16 °C',  nota: 'Spring · lively flow' },
  { m: 'Jun', full: 'June',      p: 60,  photo: 'sella-junio',       temp: '18 °C',  nota: 'Ideal · few people' },
  { m: 'Jul', full: 'July',      p: 85,  photo: 'sella-julio',       temp: '20 °C',  nota: 'Popular · good climate' },
  { m: 'Aug', full: 'August',    p: 100, photo: 'sella-agosto',      temp: '22 °C',  nota: 'The liveliest' },
  { m: 'Sep', full: 'September', p: 40,  photo: 'sella-septiembre',  temp: '20 °C',  nota: 'Secret · best balance' },
  { m: 'Oct', full: 'October',   p: 22,  photo: 'sella-octubre',     temp: '16 °C',  nota: 'Autumn · golden landscape' },
  { m: 'Nov', full: 'November',  p: 0,   photo: 'sella-noviembre',   temp: '—',      nota: 'Off-season' },
  { m: 'Dec', full: 'December',  p: 0,   photo: 'sella-diciembre',   temp: '—',      nota: 'Off-season' },
];

// Seasonal tips (6)
const consejos = [
  { t: 'August · book in advance',                  s: 'It is the month with <strong>the most demand of the year</strong>. In peak season, with <strong>5-7 days</strong> is usually enough — the sooner, the better. In the <a href="/en/book/">booking calendar</a> you will see which days are available (active) and which are not.' },
  { t: 'September · the secret',                    s: 'Warm climate, few people and the calm river. The <strong>best balance of the year</strong> if you can choose date.' },
  { t: 'Spring · bring wetsuit',                    s: 'The water is cool (14–18 °C). The wetsuit keeps body temperature and makes the experience much more comfortable.' },
  { t: 'Weekends · or weekdays',                    s: 'In July and August Saturdays are saturated. <strong>Tuesday, Wednesday or Thursday</strong> offer the same river with half the crowd.' },
  { t: 'Check the daily report',                    s: 'Flow, temperature and wind affect the pace of the descent. We notify you if there are changes the afternoon before.' },
  { t: 'Open hours · 10:30–12:30',                  s: '<strong>Premium · open hours</strong> booking: you arrive at our Arriondas facilities whenever it suits you <strong>between 10:30 and 12:30</strong>, without choosing a specific time. By regulation of the <strong>Confederación Hidrográfica del Cantábrico</strong>, the stay on the river is <strong>until 18:00</strong>.' },
];

// FAQ (8 questions adapted to season)
const faqs = [
  { q: 'What is the best time to do the Sella River descent?',
    a: 'The best times are <strong>June and September</strong>: good climate, stable flow and low-medium crowd. July and August have the best climate but also the highest demand. May and October are ideal for those who seek total calm, assuming the water is cooler.' },
  { q: 'Can you do the Sella River descent in summer?',
    a: 'Yes, the Sella River descent <strong>in summer</strong> (June-August) is the most popular option. Good climate, warm water and lively atmosphere. August concentrates the highest crowd of the year — with <strong>5-7 days in advance</strong> is usually enough (the sooner, the better). In the <a href="/en/book/">booking calendar</a> you will see which days are active.' },
  { q: 'And in spring? Is it worth it?',
    a: 'Spring is <strong>excellent if you seek calm</strong>: more active flow due to snowmelt, green landscape and very few people. The water temperature is cooler (14–18 °C), so we recommend wearing a wetsuit — we give it to you at pickup.' },
  { q: 'Can you do the descent in winter?',
    a: 'The <strong>regular season is from April to October</strong>. Outside those months the activity is not regularly operative due to high flow and water temperature. If you want a specific date off-season, write to us and we will evaluate it.' },
  { q: 'When are there fewer people on the Sella?',
    a: 'The months of <strong>May, September and October</strong> are the calmest. If you prefer to go in peak season avoiding saturation, choose <strong>weekdays</strong> (Tuesday to Thursday) and early departure times.' },
  { q: 'Does the descent depend on the river flow?',
    a: 'It affects the pace and time. With <strong>high flow</strong> (spring, autumn after rains), the river goes down faster and the current pushes. With low flow (end of dry summer), the pace is slower. It is only suspended due to <strong>extreme floods</strong> or storm — in those cases we offer date change at no cost.' },
  { q: 'What temperature does the water have in the Sella?',
    a: 'It varies according to the season: <strong>14–18 °C in spring</strong>, <strong>18–22 °C in summer</strong>, <strong>16–20 °C in autumn</strong>. The wetsuit is available at pickup for the cooler seasons.' },
  { q: 'Until when can I book?',
    a: 'We recommend booking <strong>with at least 48 h in advance</strong>. In peak season (July and August) with <strong>5-7 days is usually enough</strong> — the sooner, the better. In the <a href="/en/book/">booking calendar</a> you will see which days are active and which are not. Last-minute bookings we manage via <strong>WhatsApp or phone</strong> according to availability.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Best time to do the Sella River descent · month by month',
      description: 'Complete guide on when to do the Sella River descent: climate, flow, crowd and recommendations month by month and by season.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
        width: 1920,
        height: 1280,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified: '2026-05-12',
      about: 'Best time to do the Sella River canoe descent, month by month',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'en-GB',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',      item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Best time', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/best-time/" translationKey="mejor_epoca">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Warm editorial con watermark 4 estaciones ============== -->
  <section class="meh" aria-labelledby="meh-title">

    <div class="meh__shapes" aria-hidden="true">
      <span class="meh__shape meh__shape--1"></span>
      <span class="meh__shape meh__shape--2"></span>
      <span class="meh__shape meh__shape--3"></span>
    </div>

    <!-- Decorative watermark behind · "4 SEASONS" in large serif italic, almost invisible -->
    <span class="meh__watermark" aria-hidden="true">4&nbsp;seasons</span>

    <div class="meh__inner">
      <nav class="meh__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Best time</span>
      </nav>

      <span class="meh__eyebrow">— Best time · 2026 season</span>

      <h1 id="meh-title" class="meh__title">
        When to do<br/>
        the <span class="serif-italic">Sella River descent</span>?
      </h1>

      <p class="meh__lead">
        There is a perfect moment for every plan. Climate, flow, crowd and water
        temperature change a lot from one month to another on the Sella — here is the
        <strong>month-by-month guide from Arriondas</strong> to choose the best day of the year
        for your descent.
      </p>

      <div class="meh__ctas">
        <a href="#meh-calendar" class="meh__cta meh__cta--primary">See calendar</a>
        <a href="/en/book/" class="meh__cta meh__cta--link">
          Book now
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · CALENDARIO 12 MESES (NEW PATTERN) ============== -->
  <section id="meh-calendar" class="mec" aria-labelledby="mec-title">
    <div class="container container--xl">
      <header class="mec__header" data-reveal>
        <span class="mec__eyebrow">— Month by month</span>
        <h2 id="mec-title" class="mec__title">
          The <span class="serif-italic">best month</span><br/>
          to descend the Sella.
        </h2>
        <p class="mec__lead">
          Every month of the year has its character on the river. Hover over each month to see
          its <strong>ideality</strong>, climate and usual crowd.
        </p>
      </header>

      <ol class="mec__grid" aria-label="Yearly calendar of the Sella River descent">
        {meses.map((m, i) => (
          <li class={`mec__m mec__m--${m.tone}`} data-reveal data-reveal-delay={(i % 4) + 1} data-rating={m.rating}>
            <span class="mec__mN">{m.n}</span>
            <span class="mec__mDots" aria-hidden="true">
              {Array.from({ length: 4 }).map((_, idx) => (
                <span class={`mec__mDot ${idx < m.rating ? 'is-on' : ''}`}></span>
              ))}
            </span>
            <span class="mec__mL">{m.label}</span>
          </li>
        ))}
      </ol>

      <div class="mec__legend" data-reveal data-reveal-delay="2">
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--high"></span>Ideal</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--mid"></span>Very good</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--warm"></span>Popular</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--coral"></span>Maximum crowd</span>
        <span class="mec__legendItem"><span class="mec__legendSwatch mec__legendSwatch--off"></span>Off-season</span>
      </div>
    </div>
  </section>

  <!-- ============== 3 · TABS · 4 ESTACIONES (REUSE) ============== -->
  <section class="met" aria-labelledby="met-title">
    <div class="container container--xl">
      <header class="met__head" data-reveal>
        <div class="met__headL">
          <span class="met__kicker">— By season</span>
          <h2 id="met-title" class="met__title">
            Each season,<br/>
            <span class="serif-italic">its moment.</span>
          </h2>
        </div>
        <div class="met__tabs" role="tablist" aria-label="Choose season of the year">
          {estaciones.map((e, i) => (
            <button
              type="button"
              role="tab"
              id={`met-tab-${e.id}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`met-panel-${e.id}`}
              class={`met__tab${i === 0 ? ' is-active' : ''}`}
              data-tab={e.id}
              tabindex={i === 0 ? 0 : -1}
            >
              {e.tab}
              <span class="met__tabMeses" aria-hidden="true">· {e.meses}</span>
            </button>
          ))}
        </div>
      </header>

      <div class="met__card" data-reveal data-reveal-delay="1">
        {estaciones.map((e, i) => (
          <div
            class={`met__panel${i === 0 ? ' is-active' : ''}${e.popular ? ' met__panel--popular' : ''}`}
            id={`met-panel-${e.id}`}
            role="tabpanel"
            aria-labelledby={`met-tab-${e.id}`}
            data-panel={e.id}
            hidden={i !== 0}
          >
            {e.popular && (
              <span class="met__ribbon" aria-label="Public favourite">
                <span class="met__ribbonDot" aria-hidden="true"></span>
                <svg class="met__ribbonIcon" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {e.ribbon}
              </span>
            )}
            <div class="met__content">
              <span class={`met__eyebrow met__eyebrow--${e.id}`}>{e.eyebrow}</span>
              <h3 class="met__route">{e.route}</h3>
              <div class="met__stats">
                {e.stats.map(s => (
                  <div class="met__stat">
                    <strong>{s.v}<small>{s.u}</small></strong>
                    <span>{s.l}</span>
                  </div>
                ))}
              </div>
              <p class="met__desc" set:html={e.desc} />
              <ul class="met__features">
                {e.features.map(f => <li>{f}</li>)}
              </ul>
              <a href="/en/book/" class="met__cta">
                Book in {e.tab.toLowerCase()}
                <span class="met__ctaIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
            <div class="met__photo">
              <Picture src={e.photo} alt={`Sella River descent in ${e.tab.toLowerCase()}`} sizes="(min-width: 960px) 45vw, 100vw" bare />
              <div class="met__badges" aria-hidden="true">
                {e.badges.map(b => (
                  <span class="met__badge">{b}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 4 · CTA intermedio Sage Dark (REUSE) ============== -->
  <section class="mem">
    <div class="container container--md">
      <div class="mem__wrap" data-reveal>
        <p class="mem__quote">
          <em>Prior booking is required</em> all year round. Don't worry:
          <strong>flexible payment — by card now or on the day you pick up your canoe.</strong>
        </p>
        <div class="mem__rule">
          <span class="mem__ruleLine" aria-hidden="true"></span>
          <a href="/en/book/" class="mem__pill">
            <span class="mem__pillDot" aria-hidden="true"></span>
            <span>Book my spot</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <span class="mem__ruleLine" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 5 · BARRAS AFLUENCIA 12 MESES (REUSE) ============== -->
  <section class="mea">
    <div class="container container--xl">
      <header class="mea__header" data-reveal>
        <span class="mea__eyebrow">— Monthly crowd</span>
        <h2 class="mea__title">
          How many people<br/>
          <span class="serif-italic">descend each month.</span>
        </h2>
        <p class="mea__lead">
          Usual occupancy percentage relative to the August peak. Choose your moment according to
          the <strong>calm</strong> you seek.
        </p>
      </header>

      <div class="mea__chart" data-reveal>
        <!-- 12 photo-cards · flip 180° Y al hover · reflejo brillo horizontal -->
        <ol class="mea__cards" aria-label="Monthly Sella gallery">
          {afluencia.map((a, i) => (
            <li class="mea__card" aria-label={a.full}>
              <div class="mea__cardInner">
                <div class="mea__cardFront">
                  <div class="mea__cardPhoto">
                    <Picture src={a.photo} alt="" sizes="120px" bare />
                    <span class="mea__cardShine" aria-hidden="true"></span>
                  </div>
                  <span class="mea__cardM">{a.m}</span>
                </div>
                <div class="mea__cardBack" aria-hidden="true">
                  <span class="mea__cardFull">{a.full}</span>
                  <span class="mea__cardTemp">{a.temp}</span>
                  <span class="mea__cardNota">{a.nota}</span>
                </div>
              </div>
            </li>
          ))}
        </ol>

        <ol class="mea__bars">
          {afluencia.map((a, i) => (
            <li class="mea__bar" data-level={a.p}>
              <span class="mea__barTrack" aria-hidden="true">
                <span class="mea__barFill" style={`--p: ${a.p}%`}></span>
              </span>
              <span class="mea__barM">{a.m}</span>
              <span class="mea__barV">{a.p > 0 ? `${a.p}%` : '—'}</span>
            </li>
          ))}
        </ol>
        <p class="mea__foot">
          The peak is in <strong>August</strong>. For fewer people with the same river,
          choose <strong>May, September or October</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ============== 6 · CONSEJOS · editorial carrusel (Variante B · 1 línea slide) ============== -->
  <section class="meq" aria-labelledby="meq-title">
    <div class="container container--xl">
      <header class="meq__header" data-reveal>
        <div class="meq__headerMain">
          <span class="meq__eyebrow">Recommendations</span>
          <h2 id="meq-title" class="meq__title">Choose your moment.</h2>
        </div>
        <div class="meq__nav" role="group" aria-label="Tips navigation">
          <span class="meq__counter" aria-live="polite">
            <span class="meq__counterCurrent" data-meq-current>01</span>
            <span class="meq__counterSep" aria-hidden="true">/</span>
            <span class="meq__counterTotal">{String(consejos.length).padStart(2, '0')}</span>
          </span>
          <button type="button" class="meq__navBtn" data-meq-nav="prev" aria-label="Previous tip">
