  .mec__legend {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 1.5rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600;
