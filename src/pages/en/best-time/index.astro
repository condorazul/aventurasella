  .mec__legendSwatch--high  { background: linear-gradient(135deg, #B8E0B0, #D8EED0); }
  .mec__legendSwatch--mid   { background: linear-gradient(135deg, #C8D8B0, #E0E8C8); }
  .mec__legendSwatch--warm  { background: linear-gradient(135deg, #F7DE9C, #F8E8B8); }
  .mec__legendSwatch--coral { background: linear-gradient(135deg, #F5B5A0, #FAC8B5); }
  .mec__legendSwatch--off   { background: linear-gradient(135deg, #D4D4D0, #E4E4DE); }

  @media (prefers-reduced-motion: reduce) {
    .mec__m:hover { transform: none; }
  }

  /* ============== 3 · TABS 4 ESTACIONES (REUSE patrón /cuanto-dura/ .cdt con clase .met) ============== */
  .met {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-warm, #F5F1E8);
    position: relative;
