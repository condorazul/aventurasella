<!-- JS · tabs + barras IntersectionObserver -->
<script>
  // Tabs 4 estaciones · slide direccional
  (function () {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.met__tab');
    const panels = document.querySelectorAll<HTMLElement>('.met__panel');
    const card = document.querySelector<HTMLElement>('.met__card');
    if (!tabs.length || !card) return;

    let currentIndex = 0;

    const activate = (key: string, dir?: 'right' | 'left') => {
      // Set direction on card BEFORE toggling panels · fuerza reflow para reiniciar la animación
      if (dir) {
        card.dataset.dir = dir;
        // Forzar reflow (por si reactiva el mismo panel y queremos que la animación se reinicie)
        void card.offsetWidth;
      }
      tabs.forEach((t) => {
        const isActive = t.dataset.tab === key;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        t.setAttribute('tabindex', isActive ? '0' : '-1');
      });
      panels.forEach((p) => {
        const isActive = p.dataset.panel === key;
        p.classList.toggle('is-active', isActive);
        if (isActive) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    };

    const clickHandler = (t: HTMLButtonElement) => {
      const arr = Array.from(tabs);
      const newIndex = arr.indexOf(t);
      const dir: 'right' | 'left' = newIndex > currentIndex ? 'right' : (newIndex < currentIndex ? 'left' : (card.dataset.dir as 'right' | 'left') || 'right');
      currentIndex = newIndex;
      const key = t.dataset.tab;
      if (key) activate(key, dir);
    };

    tabs.forEach((t) => {
      t.addEventListener('click', () => clickHandler(t));
      t.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const arr = Array.from(tabs);
        const idx = arr.indexOf(t);
        const nextIdx = e.key === 'ArrowRight' ? (idx + 1) % arr.length : (idx - 1 + arr.length) % arr.length;
        const next = arr[nextIdx];
        next.focus();
        clickHandler(next);
      });
    });
  })();

  // Barras afluencia · detectar cuando entran en viewport y aplicar is-visible
  (function () {
    const chart = document.querySelector<HTMLElement>('.mea__chart');
    if (!chart) return;
    if (!('IntersectionObserver' in window)) { chart.classList.add('is-visible'); return; }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          chart.classList.add('is-visible');
          io.unobserve(chart);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -80px 0px' });
    io.observe(chart);
  })();

  // Carrusel Consejos · prev/next + counter + progress
  (function () {
    const track = document.querySelector<HTMLElement>('[data-meq-track]');
    const prev  = document.querySelector<HTMLButtonElement>('[data-meq-nav="prev"]');
    const next  = document.querySelector<HTMLButtonElement>('[data-meq-nav="next"]');
    const cur   = document.querySelector<HTMLElement>('[data-meq-current]');
    const prog  = document.querySelector<HTMLElement>('[data-meq-progress]');
    if (!track || !prev || !next) return;

    const items = track.querySelectorAll<HTMLElement>('[data-meq-item]');
    const getCardWidth = () => {
      if (!items[0]) return 0;
      const rect = items[0].getBoundingClientRect();
      const styles = getComputedStyle(items[0].parentElement as HTMLElement);
      const gap = parseFloat(styles.columnGap || styles.gap || '16') || 16;
      return rect.width + gap;
    };

    const update = () => {
      const sMax = track.scrollWidth - track.clientWidth;
      const cw   = getCardWidth();
      const idx  = cw > 0 ? Math.round(track.scrollLeft / cw) : 0;
      const clamped = Math.max(0, Math.min(idx, items.length - 1));
      // Toggle .is-active · zoom+dark en la card centrada
      items.forEach((item, i) => {
        item.classList.toggle('is-active', i === clamped);
      });
      if (cur) cur.textContent = String(clamped + 1).padStart(2, '0');
      if (prog) {
        const pct = sMax > 0 ? (track.scrollLeft / sMax) * 100 : 0;
        prog.style.width = pct + '%';
      }
      prev.disabled = track.scrollLeft <= 1;
      next.disabled = track.scrollLeft >= sMax - 1;
    };

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
    });
    next.addEventListener('click', () => {
      track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
    });
    track.addEventListener('scroll', () => {
      window.requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener('resize', update);
    // Init
    update();
  })();
</script>
