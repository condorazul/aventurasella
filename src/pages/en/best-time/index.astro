  .met__tabMeses { font-weight: 500; opacity: 0.7; }
  .met__tab.is-active .met__tabMeses { opacity: 0.85; }
  .met__tab:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }

  .met__card {
    position: relative;
    max-width: 1200px; margin: 0 auto;
    background: #fff;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
    box-shadow: 0 30px 60px rgba(26, 31, 46, 0.08);
    overflow: hidden;
  }
  .met__panel {
    display: grid; grid-template-columns: 1fr;
  }
  @media (min-width: 900px) { .met__panel { grid-template-columns: 1.1fr 1fr; } }
  .met__panel[hidden] { display: none; }
  /* Animación default (primera carga) · fade-up sutil */
  .met__panel.is-active { animation: metPanelIn 500ms cubic-bezier(0.22, 1, 0.36, 1); }
  @keyframes metPanelIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  /* Slide direccional al cambiar de tab · según si la nueva tab está a la derecha o a la izquierda */
  .met__card[data-dir="right"] .met__panel.is-active { animation: metPanelSlideFromRight 520ms cubic-bezier(0.22, 1, 0.36, 1); }
  .met__card[data-dir="left"]  .met__panel.is-active { animation: metPanelSlideFromLeft  520ms cubic-bezier(0.22, 1, 0.36, 1); }
  @keyframes metPanelSlideFromRight {
    from { opacity: 0; transform: translateX(72px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes metPanelSlideFromLeft {
    from { opacity: 0; transform: translateX(-72px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
