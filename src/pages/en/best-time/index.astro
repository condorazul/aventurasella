    box-shadow: 0 14px 32px -10px rgba(233, 133, 111, 0.45);
  }
  .meb__btn--primary:hover .meb__btnIcon { transform: translateX(3px); }

  /* Outline · WhatsApp (cream + sutil border + acento verde en svg) */
  .meb__btn--outline {
    background: transparent;
    color: var(--color-text-primary, #1A1F2E);
    border-color: rgba(26, 31, 46, 0.2);
  }
  .meb__btn--outline svg { color: #25D366; }
  .meb__btn--outline:hover {
    border-color: #25D366;
    background: rgba(37, 211, 102, 0.08);
  }

  /* Outline · Llamar (mismo formato que WhatsApp · acento sage) */
  .meb__btn--link {
    background: transparent;
    color: var(--color-text-primary, #1A1F2E);
    border-color: rgba(26, 31, 46, 0.2);
  }
  .meb__btn--link svg { color: var(--color-sage, #3D4F3A); }
  .meb__btn--link:hover {
    border-color: var(--color-sage, #3D4F3A);
    background: rgba(61, 79, 58, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .meb__btn { transition: background-color 200ms ease, border-color 200ms ease; }
    .meb__btn:hover { transform: none; }
    .meb__btnIcon { transition: none; }
    .meb__btn--primary:hover .meb__btnIcon { transform: none; }
  }

  /* ============== 8 · FAQ (REUSE cnf sage sidebar) ============== */
  .mef { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .mef__grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 5vw, 4rem); max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 4rem); }
  @media (min-width: 960px) { .mef__grid { grid-template-columns: 1fr 1.3fr; } }
  .mef__aside { position: sticky; top: 6rem; align-self: start; }
  .mef__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1.25rem;
  }
  .mef__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.02em; text-transform: uppercase;
    color: var(--color-text-primary);
