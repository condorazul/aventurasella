    .met__card[data-dir="left"]  .met__panel.is-active { animation: none; }
  }

  /* Ribbon "El favorito" sobre el panel Verano · sage dark, destacado arriba */
  .met__panel--popular { position: relative; }
  .met__ribbon {
    position: absolute;
    top: clamp(1.25rem, 2.5vw, 1.75rem);
    left: clamp(1.5rem, 3vw, 2.25rem);
