  /* ============== 2 · CALENDAR 12 MESES (NEW PATTERN) ============== */
  .mec {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: var(--color-bg-base);
    position: relative;
  }
  .mec__header { max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center; }
  .mec__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1.5rem;
  }
  .mec__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }
  .mec__title .serif-italic {
    color: var(--color-primary);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    letter-spacing: -0.01em; text-transform: none;
  }
  .mec__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .mec__lead strong { color: var(--color-text-primary); font-weight: 700; }

  .mec__grid {
    list-style: none; padding: 0;
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 540px)  { .mec__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 820px)  { .mec__grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1100px) { .mec__grid { grid-template-columns: repeat(6, 1fr); } }

  /* Cada mes tiene su degradado pastel vibrante de base. El hover intensifica. */
  .mec__m {
    position: relative;
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    gap: 0.625rem;
    padding: 1.25rem 0.875rem 1.125rem;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: 0.75rem;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 300ms cubic-bezier(0.22, 1, 0.36, 1),
                border-color 300ms ease;
    overflow: hidden;
    isolation: isolate;
  }
  /* Gradient base · visible desde inicio · más saturado al hover */
  .mec__m::before {
    content: "";
    position: absolute; inset: 0;
    border-radius: inherit;
    z-index: -1;
    transition: opacity 300ms ease, filter 300ms ease;
    opacity: 0.55;
  }
  /* High (junio/septiembre) · mint pastel  */
  .mec__m--high  { background: #F5FBF4; }
  .mec__m--high::before   { background: linear-gradient(135deg, #B8E0B0 0%, #D8EED0 60%, #F0F7E8 100%); }
  /* Mid (mayo) · sage verdoso suave */
  .mec__m--mid   { background: #F6F9EF; }
  .mec__m--mid::before    { background: linear-gradient(135deg, #C8D8B0 0%, #E0E8C8 60%, #F0F4E0 100%); }
  /* Warm (julio) · amarillo mantequilla */
  .mec__m--warm  { background: #FDF7E5; }
  .mec__m--warm::before   { background: linear-gradient(135deg, #F7DE9C 0%, #F8E8B8 60%, #FCF3D8 100%); }
  /* Coral (agosto) · rosa coral pastel */
  .mec__m--coral { background: #FEF1EC; }
  .mec__m--coral::before  { background: linear-gradient(135deg, #F5B5A0 0%, #FAC8B5 60%, #FDE0D2 100%); }
  /* Ocre (octubre) · melocotón otoñal */
  .mec__m--ocre  { background: #FDF3E8; }
  .mec__m--ocre::before   { background: linear-gradient(135deg, #F5C8A0 0%, #F8D8B8 60%, #FCE6D0 100%); }
  /* Soft (abril) · crema sage muy suave */
  .mec__m--soft  { background: #F6F7EF; }
  .mec__m--soft::before   { background: linear-gradient(135deg, #D0DAC0 0%, #E8ECD8 60%, #F4F5E8 100%); }
  /* Off (noviembre-marzo) · gris neutro */
  .mec__m--off   { background: #F2F2EC; }
  .mec__m--off::before    { background: linear-gradient(135deg, #D4D4D0 0%, #E4E4DE 60%, #EFEFE8 100%); opacity: 0.35; }

  /* Hover · bg más saturado + lift + glow en borde del tono */
  .mec__m:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 36px rgba(26, 31, 46, 0.1);
  }
  .mec__m:hover::before { opacity: 0.95; filter: saturate(1.15); }
  .mec__m--high:hover   { border-color: #8AC68A; }
  .mec__m--mid:hover    { border-color: #A4B788; }
  .mec__m--warm:hover   { border-color: #E6BE5E; }
  .mec__m--coral:hover  { border-color: var(--color-primary, #E8856F); }
  .mec__m--ocre:hover   { border-color: #E8A86E; }
  .mec__m--soft:hover   { border-color: #B4C29C; }
  .mec__m--off:hover    { border-color: rgba(26, 31, 46, 0.25); }

  .mec__mN {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    font-weight: 900;
    letter-spacing: -0.01em; text-transform: uppercase;
