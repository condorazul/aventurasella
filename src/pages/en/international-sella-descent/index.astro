---
import BaseLayout from '@layouts/BaseLayout.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'International Sella River Descent 2026 · Date and guide';
const description = 'International Sella River Descent 2026: date, route, schedule, past winners and how to live it. Book your tourist canoe on the very day of the event.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/international-sella-descent/`;

const homeUrl     = getLocalePath('home', lang);
const bookUrl     = getLocalePath('reservar', lang);

// ============== Structured data ==============
const datosClave = [
  { label: 'Official name',     valueLines: ['International Sella', 'River Descent'], sub: '“Les Piragües”' },
  { label: 'Founded',           valueLines: ['1930'],                                  sub: 'nearly a century of history' },
  { label: 'Route',             valueLines: ['20 km'],                                 sub: 'Arriondas → Ribadesella' },
  { label: 'Participants',      valueLines: ['+1,200'],                                sub: 'elite + amateurs' },
  { label: 'Spectators',        valueLines: ['~200,000'],                              sub: 'along the riverbanks' },
  { label: 'Recognition',       valueLines: ['Int’l Tourist', 'Interest Festival'],    sub: 'declared in 1981' },
];

const fechas2026 = [
  { day: 'Thursday 6 August',  hour: 'All day',           title: 'Arrival of the peñas',                text: 'Festive groups gather in Arriondas. The party atmosphere kicks off.' },
  { day: 'Friday 7 August',    hour: 'All day',           title: 'Official festivity',                   text: 'Folk celebrations, bonfires and music in Arriondas.' },
  { day: 'Saturday 8 August',  hour: '11:30',             title: 'Official start',                       text: 'The race begins at the Puente de los Piragüistas.',              highlight: true },
  { day: 'Saturday 8 August',  hour: '12:00',             title: 'Tourist start · with us',              text: 'Only tourist start of the day, right after the elite. Special booking with limited capacity.', highlight: true },
  { day: 'Saturday 8 August',  hour: '14:30–17:00',       title: 'Arrival in Ribadesella',               text: 'Finish-line festival and trophy ceremony by the sea.' },
  { day: 'Sunday 9 August',    hour: 'Morning',           title: 'Awards ceremony',                      text: 'Official ceremony and Canoeist’s Mass. The weekend wraps up.' },
];

const recorrido = [
  { km: '0 km',    place: 'Arriondas',            note: 'Official start · Puente de los Piragüistas',   us: false },
  { km: '3 km',    place: 'Puente de Santianes',  note: 'First timing point',                            us: false },
  { km: '7 km',    place: 'Puente de Toraño',     note: 'End of our Mini Sella route',                   us: true  },
  { km: '14.5 km', place: 'Fríes',                note: 'End of our Full descent',                       us: true  },
  { km: '17 km',   place: 'Llovio',               note: 'Last rapids of the course',                     us: false },
  { km: '20 km',   place: 'Ribadesella',          note: 'Finish line · shore of the Cantabrian Sea',     us: false },
];

const palmares = [
  { year: '2025', winners: 'Rodrigo Germade / Diego Romero', flag: 'ESP' },
  { year: '2024', winners: 'Javier Reja / Adrián Sieiro',    flag: 'ESP' },
  { year: '2023', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2022', winners: 'Walter Bouzán / Manuel Vargas',  flag: 'ESP' },
  { year: '2021', winners: 'Íñigo Peña / Pedro Vázquez',     flag: 'ESP' },
];

const faqs = [
  { q: 'When is the International Sella River Descent 2026?',
    a: 'The 2026 edition takes place on <strong>Saturday 8 August</strong>. The official elite start is set for <strong>11:30</strong> in Arriondas, and the arrival in Ribadesella is between 14:30 and 17:00. Our tourist start is at <strong>12:00</strong>, right after the professionals.' },
  { q: 'Can I paddle the Sella on the day of the International Descent?',
    a: 'Yes — but with a special booking. We offer a <strong>single tourist start at 12:00</strong>, right after the elite professional race. The river opens to tourist traffic once the peloton has passed. <strong>Single price of €35</strong> per person (no picnic included, because logistics are different that day). Online prepayment. Book up to <strong>2 days before</strong> the event — spots sell out weeks in advance.' },
  { q: 'Why is check-in so early that day?',
    a: 'Vehicle traffic into Arriondas <strong>closes at 10:00</strong> — the streets are pedestrianised and cars can no longer enter the town. That is why we ask you to arrive in Arriondas <strong>before 9:30</strong> to check in and leave your car in our private parking. If you arrive late, you will not be able to access and would miss the activity.' },
  { q: 'Can I bring my dog on the day of the International Descent?',
    a: '<strong>We do not recommend it</strong>. Although pets are welcome <a href="' + homeUrl + '">the rest of the year</a>, that day there is extraordinary attendance (~200,000 spectators), a lot of noise, fireworks, traffic and tension. Dogs get very startled and the experience will not be pleasant for them or for you. Better book any other day of the season.' },
  { q: 'How much does it cost to compete in the International Descent as an athlete?',
    a: 'Registration as a federated athlete is around <strong>€35–45</strong> depending on category. It requires a current canoeing licence and federation accreditation. Tourist canoes are not allowed in the official race.' },
  { q: 'Where can I watch the International Descent for free?',
    a: 'The entire bank of the Sella has free access. The best spots are <strong>Arriondas</strong> (start), the <strong>Puente de Llovio</strong> (spectacular final rapids) and the finish in <strong>Ribadesella</strong>.' },
  { q: 'What is the past winners list of the Sella Descent?',
    a: 'You can check the complete list of winners since 1930 on the official site of the <a href="https://www.rfep.es" target="_blank" rel="nofollow noopener external">Spanish Canoeing Federation</a> or on <a href="https://en.wikipedia.org/wiki/International_Descent_of_the_Sella_River" target="_blank" rel="noopener external">Wikipedia</a>. Above you have the table of recent editions, which we update every September.' },
  { q: 'Is there accommodation available the weekend of the International Descent?',
    a: 'Tough. Book <strong>months in advance</strong> in Arriondas, Cangas de Onís, Ribadesella or Llanes. Occupancy that week exceeds 95% throughout the area.' },
  { q: 'Can I attend with kids?',
    a: 'Yes — it is a <strong>family event par excellence</strong>. The atmosphere is festive and the organisation prepares safe riverside areas. Watch out for the sun: we recommend a hat and strong sunscreen.' },
  { q: 'What else can I do that weekend in Asturias?',
    a: 'Visit the <strong>Lakes of Covadonga</strong>, do the <a href="' + homeUrl + '">Sella descent as a tourist</a> the days before, ride a bike along the Senda del Oso, explore Ribadesella and the Tito Bustillo cave, or try cider and Asturian cuisine in the local chigres.' },
];

// ============== Schema.org JSON-LD ==============
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'International Sella River Descent 2026 · Date, route and complete guide',
      description,
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/og/og-internacional-en.jpg`, width: 1200, height: 630 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Events · International Sella River Descent',
      keywords: [
        'International Sella River Descent',
        'Sella Descent 2026',
        'Les Piragües',
        'Sella Festival',
        'canoeing Asturias',
        'Arriondas Ribadesella canoe',
      ],
      about: 'International canoeing competition on the Sella River, Asturias',
    },
    {
      '@type': 'Event',
      '@id': `${canonicalUrl}#event-2026`,
      name: 'International Sella River Descent 2026 · Les Piragües',
      alternateName: 'Les Piragües',
      description: '20 km canoeing competition along the Sella River, declared an International Tourist Interest Festival. Draws more than 1,200 canoeists and 200,000 spectators.',
      startDate: '2026-08-08T11:30:00+02:00',
      endDate:   '2026-08-08T17:00:00+02:00',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      inLanguage: 'en-GB',
      isAccessibleForFree: true,
      audience: { '@type': 'Audience', audienceType: 'General public · canoeing · sports tourism' },
      maximumAttendeeCapacity: 200000,
      location: {
        '@type': 'Place',
        name: 'Sella River · Arriondas — Ribadesella',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Puente de los Piragüistas',
          addressLocality: 'Arriondas',
          addressRegion: 'Asturias',
          postalCode: '33540',
          addressCountry: 'ES',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      },
      organizer: {
        '@type': 'Organization',
        name: 'Spanish Canoeing Federation',
        url: 'https://www.rfep.es',
      },
      image: `${baseUrl}/images/og/og-internacional-en.jpg`,
      url: canonicalUrl,
      offers: {
        '@type': 'Offer',
        name: 'Tourist start of the International Descent · 12:00',
        description: 'Only tourist start of the day after the elite professional race has passed. Limited capacity.',
        price: '35',
        priceCurrency: 'EUR',
        availability: 'https://schema.org/LimitedAvailability',
        validFrom: '2026-01-15T00:00:00+02:00',
        url: `${baseUrl}${bookUrl}?dia=2026-08-08`,
      },
      subEvent: [
        { '@type': 'Event', name: 'Arrival of the peñas',           startDate: '2026-08-06', endDate: '2026-08-06', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Official festivity',             startDate: '2026-08-07', endDate: '2026-08-07', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Tourist start (12:00)',          startDate: '2026-08-08T12:00:00+02:00', endDate: '2026-08-08T17:00:00+02:00', eventStatus: 'https://schema.org/EventScheduled' },
        { '@type': 'Event', name: 'Awards ceremony and Canoeist’s Mass', startDate: '2026-08-09', endDate: '2026-08-09', eventStatus: 'https://schema.org/EventScheduled' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'Sella Descent Asturias · Aventura en el Sella · Canoe Rental',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (access via Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        'https://share.google/huLLaIz31FiYohuTV',
        'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html',
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',                              item: `${baseUrl}${homeUrl}` },
        { '@type': 'ListItem', position: 2, name: 'International Sella River Descent', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/og/og-internacional-en.jpg"
  currentPath="/en/international-sella-descent/"
  translationKey="descenso_internacional"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="dih" aria-labelledby="dih-title">

    <div class="dih__inner">
      <nav class="dih__breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl}>Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">International Sella River Descent</span>
      </nav>

      <span class="dih__eyebrow">
        <span class="dih__eyebrow-dot" aria-hidden="true"></span>
        1930 · International Tourist Interest Festival
      </span>

      <h1 id="dih-title" class="dih__title">
        International Sella<br/>
        <span class="serif-italic">River Descent</span>
      </h1>

      <p class="dih__lead">
        One of the <strong>most iconic canoeing competitions in the world</strong>
        and the oldest sporting event in Asturias. Every year, on a Saturday in August,
        thousands of athletes paddle the <strong>20 km</strong> separating Arriondas
        from Ribadesella, cheered on by more than <strong>200,000 spectators</strong>
        along the banks of the Sella.
      </p>

      <div class="dih__event">
        <div class="dih__event-col">
          <span class="dih__event-label">2026 edition</span>
          <span class="dih__event-value">Saturday 8 August</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Official start</span>
          <span class="dih__event-value">11:30 · Arriondas</span>
        </div>
        <div class="dih__event-col">
          <span class="dih__event-label">Finish</span>
          <span class="dih__event-value">14:30–17:00 · Ribadesella</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== WHAT IT IS + KEY DATA ============== -->
  <section class="dis">
    <div class="container container--xl">
      <header class="dis__header">
        <span class="dis__eyebrow">— What it is</span>
        <h2 class="dis__title">Spain’s <span class="serif-italic">oldest paddling festival</span></h2>
        <p class="dis__lead">
          Born in <strong>1930</strong> at the hand of Dionisio de la Huerta, the
          International Sella River Descent is the <strong>longest-running flatwater
          canoeing competition</strong> in Spanish canoeing history. Every year it
          attracts the world’s best kayakers and canoeists — from Olympic champions
          to amateur athletes — alongside a crowd that turns the riverbanks into a
          continuous 20-km festival.
        </p>
      </header>

      <div class="dis__grid">
        {datosClave.map((d, i) => (
          <div class="disData" data-reveal data-reveal-delay={(i % 3) + 1}>
            <span class="disData__label">{d.label}</span>
            <span class="disData__value">
              {d.valueLines.map((line, idx) => (
                <>
                  {idx > 0 && <br/>}
                  {line}
                </>
              ))}
            </span>
            <span class="disData__sub">{d.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 2026 DATES ============== -->
  <section class="dif">
    <div class="container container--lg">
      <header class="dif__header">
        <span class="dif__eyebrow">— 2026 dates</span>
        <h2 class="dif__title">
          Four days of celebration.<br/>
          <span class="serif-italic">One unforgettable Saturday.</span>
        </h2>
        <p class="dif__lead">
          The side activities begin the Thursday before with the arrival of the
          peñas in Arriondas and peak on Saturday with the
          <strong>official race start at 11:30</strong>.
        </p>
      </header>

      <ol class="dif__timeline">
        {fechas2026.map((f, i) => (
          <li class:list={['difStep', f.highlight && 'difStep--top']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <div class="difStep__date">
              <span class="difStep__day">{f.day}</span>
              <span class="difStep__hour">{f.hour}</span>
            </div>
            <div class="difStep__bullet" aria-hidden="true"></div>
            <div class="difStep__body">
              <h3 class="difStep__title">{f.title}</h3>
              <p class="difStep__text">{f.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="dif__note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>The official date depends on the Spanish Canoeing Federation calendar. We confirm each January the edition for the current year.</span>
      </p>
    </div>
  </section>

  <!-- ============== 20 KM ROUTE ============== -->
  <section class="dir">
    <div class="container container--xl">
      <header class="dir__header">
        <span class="dir__eyebrow">— Route</span>
        <h2 class="dir__title">20 kilometres between <span class="serif-italic">Arriondas and Ribadesella</span></h2>
        <p class="dir__lead">
          The course of the International Sella River Descent traces the same river
          you paddle on your <a href={homeUrl} class="dir__link">tourist descent</a> —
          only in its competitive, crowd-packed version.
        </p>
      </header>

      <ol class="dir__track">
        {recorrido.map((r, i) => (
          <li class:list={['dirPoint', r.us && 'dirPoint--us']} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="dirPoint__km">{r.km}</span>
            <span class="dirPoint__dot" aria-hidden="true"></span>
            <div class="dirPoint__body">
              <span class="dirPoint__place">{r.place}</span>
              <span class="dirPoint__note">{r.note}</span>
              {r.us && <span class="dirPoint__tag">Ours</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== HOW TO WATCH ============== -->
  <section class="div">
    <div class="container container--xl">
      <header class="div__header">
        <span class="div__eyebrow">— Practical guide</span>
        <h2 class="div__title">How to watch the International Descent <span class="serif-italic">hassle-free</span></h2>
        <p class="div__lead">
          The <strong>best spots</strong> to watch the International Sella River Descent
          are <strong>Arriondas</strong> (start), the <strong>Puente de Llovio</strong>
          (spectacular last rapids) and the finish in <strong>Ribadesella</strong>.
        </p>
      </header>

      <div class="div__grid">
        <article class="divCard" data-reveal data-reveal-delay="1">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>
            Recommended parking
          </h3>
          <ul class="divCard__list">
            <li><strong>Arriondas</strong> · parkings set up by the town council from Thursday. Arrive before <strong>10:00 on Saturday</strong>.</li>
            <li><strong>Toraño / Fríes</strong> · quieter parking if you don’t mind watching the middle section. Good option for families with kids.</li>
            <li><strong>Ribadesella</strong> · severe traffic jams from 11:00. Alternative: park in <strong>Llovio</strong> and walk up.</li>
          </ul>
        </article>

        <article class="divCard" data-reveal data-reveal-delay="2">
          <h3 class="divCard__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
            What to bring
          </h3>
          <ul class="divCard__list">
            <li><strong>Comfortable clothes</strong> and <strong>sunscreen</strong> (long hours under the August sun).</li>
            <li><strong>Water and a picnic</strong> if you don’t want to queue at the bars.</li>
            <li><strong>Camera with a good zoom</strong> — the river is 10–20 m from the bank along some sections.</li>
            <li>Be ready for <strong>heat</strong> and <strong>huge crowds</strong>. It is one of the biggest events of the Asturian summer.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== PAST WINNERS ============== -->
  <section class="dip">
    <div class="container container--lg">
      <header class="dip__header">
        <span class="dip__eyebrow">— Recent winners</span>
        <h2 class="dip__title">Past winners of the Sella Descent <span class="serif-italic">K2 senior absolute</span></h2>
        <p class="dip__lead">
          Recent editions of the flagship category of the International Sella River
          Descent. We update the table every September after the official ceremony.
        </p>
      </header>

      <div class="dip__table-wrap">
        <table class="dip__table">
          <thead>
            <tr>
              <th scope="col">Year</th>
              <th scope="col">Absolute winners (K2 senior)</th>
              <th scope="col">Nationality</th>
            </tr>
          </thead>
          <tbody>
            {palmares.map((p, i) => (
              <tr class={i === 0 ? 'is-current' : ''}>
                <td class="dip__year">{p.year}</td>
                <td class="dip__winners">{p.winners}</td>
                <td class="dip__flag">🇪🇸 {p.flag}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="dip__source">
        Source: <a href="https://www.rfep.es" target="_blank" rel="nofollow noopener external">Spanish Canoeing Federation</a> ·
        For the full record since 1930, see the <a href="https://en.wikipedia.org/wiki/International_Descent_of_the_Sella_River" target="_blank" rel="noopener external">Wikipedia entry</a>.
      </p>
    </div>
  </section>

  <!-- ============== SPECIAL BOOKING · BIG DAY ============== -->
  <section class="did">
    <div class="container container--xl">
      <header class="did__header">
        <span class="did__eyebrow">— Special booking · 8 August</span>
        <h2 class="did__title">
          Paddle the river the very day<br/>
          <span class="serif-italic">of the International Descent</span>
        </h2>
        <p class="did__lead">
          Right after the elite professional start, the river opens to tourist
          descent. A <strong>single departure of the day at 12:00</strong>, with
          limited capacity and special conditions — an unrepeatable experience
          living the atmosphere of Asturias’ biggest day.
        </p>
      </header>

      <div class="did__main">
        <!-- Pricing + CTA -->
        <aside class="did__price" data-reveal>
          <span class="did__price-tag">Book the Sella’s biggest day</span>
          <div class="did__price-block">
            <span class="did__price-value">€35</span>
