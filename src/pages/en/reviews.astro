---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Sella River descent reviews · 4.5★ on Google and TripAdvisor';
const description = '147 real reviews of the Sella River descent — 4.5★ on Google, 4.8★ on TripAdvisor. Read what families, couples and friends say after paddling the river with Aventura en el Sella.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/reviews/`;

// Official aggregate numbers (snapshot 2026-04-13 · reference_reviews.md)
const aggregate = {
  global: { rating: '4.5', total: 147, rating_num: 4.5 },
  google: { rating: '4.5', total: 127, url: 'https://share.google/huLLaIz31FiYohuTV', label: 'Google' },
  trip:   { rating: '4.8', total:  20, url: 'https://www.tripadvisor.es/Attraction_Review-g608995-d12635919-Reviews-Aventura_en_el_Sella-Arriondas_Parres_Municipality_Asturias.html', label: 'TripAdvisor' },
};

// Real approved testimonials (reference_reviews.md 2026-04-13)
const testimonios = [
  {
    initial: 'A',
    name: 'Anaïs Suárez Blanco',
    source: 'Google',
    date: 'October 2025',
    context: 'Experience',
    rating: 5,
    text: 'Great service, attentive and very friendly staff. The experience was amazing, I absolutely loved it.',
    sourceUrl: aggregate.google.url,
  },
  {
    initial: 'N',
    name: 'Nacho A.',
    source: 'TripAdvisor',
    date: 'August 2025',
    context: 'Couples',
    rating: 5,
    text: 'Everything punctual and very kind. A once-in-a-lifetime experience, recommended for young and old alike.',
    sourceUrl: aggregate.trip.url,
  },
  {
    initial: 'C',
    name: 'Carlos S.',
    source: 'TripAdvisor',
    date: 'May 2025',
    context: 'Friends',
    rating: 5,
    text: 'Totally worth it. You get changing rooms and can shower after the activity. They give you fun instructions, a barrel to put lots of things inside, and the rest is what the river gives you.',
    sourceUrl: aggregate.trip.url,
  },
];

// Recurring visitor profiles in the reviews · words that come up again and again
const perfiles = [
  { tag: 'Families', nota: 'Kids from age 5',          words: ['attentive with kids', 'safety', 'clear instructions', 'pets welcome'] },
  { tag: 'Couples',  nota: 'Once in a lifetime',       words: ['romantic', 'sunset', 'peaceful', 'photos'] },
  { tag: 'Friends',  nota: 'Group · full day',         words: ['atmosphere', 'riverside bars', 'fun', 'showers'] },
  { tag: 'Retirees', nota: 'Easy pace',                words: ['for seniors', 'safe', 'landscape', 'close treatment'] },
];

const faqs = [
  { q: 'Where can I read all the reviews of the Sella River descent?',
    a: 'We have <strong>147 real reviews</strong> split between <strong><a href="' + aggregate.google.url + '" target="_blank" rel="noopener">Google</a></strong> (127 reviews · 4.5 stars) and <strong><a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a></strong> (20 reviews · 4.8 stars). On this page we highlight the most representative ones, but all of them are public on those platforms.' },
  { q: 'Are all the reviews real and verified?',
    a: 'Yes. <strong>We do not buy or fabricate reviews</strong>. Every single one comes from a customer who actually paddled the Sella with us and voluntarily left their review on Google or TripAdvisor. That means you will see a bit of everything: mostly 5 stars, a few 4s and, very occasionally, a critical review that we answer publicly.' },
  { q: 'How do I leave my review after the descent?',
    a: 'The easiest way: after the activity we send you a message with the direct Google link. You can also leave it on <a href="' + aggregate.trip.url + '" target="_blank" rel="noopener">TripAdvisor</a> by searching "Aventura en el Sella · Arriondas". <strong>It helps us enormously</strong> — it is what makes others trust us.' },
  { q: 'How do you respond to negative reviews?',
    a: 'Honestly and in public. We reply to <strong>every</strong> critical review from the Google Business panel, acknowledging what we did not get right and explaining what we have changed. It is the only way to improve and for future customers to see how we handle real problems.' },
  { q: 'Why is the Google average 4.5 and TripAdvisor 4.8?',
    a: 'Because they are platforms with different user profiles. Google gets more volume and a wider range of expectations; TripAdvisor tends to be used by the traveller who plans carefully and values service details more. <strong>The combined average is 4.5★ across 147 reviews</strong> — the number we use across the whole site.' },
  { q: 'How long have you been collecting reviews?',
    a: 'Aventura en el Sella has been gathering <strong>reviews for several years</strong> from customers across different seasons. That volume and consistency is what sets us apart from new operators with no track record — <a href="' + getLocalePath('quienes_somos', lang) + '">discover more about our story</a>.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Real reviews of the Sella River descent · 4.5★ · 147 verified reviews',
      description: '147 real reviews of the Sella River descent with Aventura en el Sella. 4.5 stars on Google and 4.8 on TripAdvisor.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      articleSection: 'Reviews · Verified ratings',
      keywords: ['Sella River descent reviews', 'Sella canoe reviews', 'Aventura en el Sella reviews', 'Sella descent ratings', 'canoeing Sella Arriondas reviews'],
      about: 'Reviews, ratings and real testimonials about the Sella River canoe descent from Arriondas',
      mentions: [
        { '@type': 'Thing', name: 'Google reviews', url: aggregate.google.url },
        { '@type': 'Thing', name: 'TripAdvisor', url: aggregate.trip.url },
      ],
    },
    {
      '@type': 'LocalBusiness',
      additionalType: ['https://schema.org/TouristAttraction', 'https://schema.org/SportsActivityLocation'],
      '@id': `${baseUrl}/#business`,
      name: 'Aventura en el Sella',
      alternateName: 'The Sella Descent Asturias · Aventura en el Sella · Canoe Rental',
      url: baseUrl,
      telephone: '+34681093673',
      email: 'info@aventuraenelsella.es',
      image: `${baseUrl}/images/logo/logo-schema.png`,
      priceRange: '€€',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Calle Juan Carlos I, 18, BAJO II (acceso por Aipol)',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        postalCode: '33540',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.3874223, longitude: -5.1866022 },
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '09:00',
        closes: '20:00',
      }],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: aggregate.global.rating_num,
        reviewCount: aggregate.global.total,
        bestRating: 5,
        worstRating: 1,
      },
      review: testimonios.map(t => ({
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5, worstRating: 1 },
        author: { '@type': 'Person', name: t.name },
        datePublished: t.date,
        reviewBody: t.text,
        publisher: { '@type': 'Organization', name: t.source },
      })),
      sameAs: [
        'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
        aggregate.google.url,
        aggregate.trip.url,
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',    item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Reviews', item: canonicalUrl },
      ],
    },
  ],
};

// Stars helper
const starSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/en/reviews/" translationKey="opiniones">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · big stars + media aggregate ============== -->
  <section class="opH" aria-labelledby="opH-title">
    <span class="opH__watermark" aria-hidden="true">4.5</span>

    <div class="opH__inner">
      <nav class="opH__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Reviews</span>
      </nav>

      <span class="opH__eyebrow">— Real and verified reviews</span>

      <h1 id="opH-title" class="opH__title">
        The Sella<br/>
        <span class="serif-italic">in their own words.</span>
      </h1>

      <div class="opH__badge" aria-hidden="true">
        <span class="opH__badgeStars" set:html={Array(5).fill(starSvg).join('')}></span>
        <span class="opH__badgeRating">4.5</span>
        <span class="opH__badgeSep"></span>
        <span class="opH__badgeCount">147 verified reviews</span>
      </div>

      <p class="opH__lead">
        For years we relied on <strong>word of mouth in Asturias</strong>. We only recently started actively asking you to leave a review — that is why the volume is modest. But every one of the <strong>147 reviews</strong> is <strong>real, public and verifiable</strong> on Google and TripAdvisor.
      </p>

      <div class="opH__ctas">
        <a href={aggregate.google.url} class="opH__cta opH__cta--primary" target="_blank" rel="noopener noreferrer">See on Google<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
        <a href={aggregate.trip.url} class="opH__cta opH__cta--ghost" target="_blank" rel="noopener noreferrer">See on TripAdvisor<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · BREAKDOWN · Google + TripAdvisor + Combined ============== -->
  <section class="opB" aria-labelledby="opB-title">
    <div class="container container--xl">
      <header class="opB__header" data-reveal>
        <span class="opB__eyebrow">— The raw data</span>
        <h2 id="opB-title" class="opB__title">
          Two platforms<br/><span class="serif-italic">and one single average.</span>
        </h2>
        <p class="opB__lead">
          Total transparency: these are the numbers exactly as they show today on the public listings.
        </p>
      </header>

      <div class="opB__grid">
        <article class="opB__card" data-reveal>
          <span class="opB__cardLabel">Google</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.google.rating}</strong>
          <span class="opB__cardCount">{aggregate.google.total} reviews</span>
          <a href={aggregate.google.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            See on Google
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--trip" data-reveal data-reveal-delay="1">
          <span class="opB__cardLabel">TripAdvisor</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.trip.rating}</strong>
          <span class="opB__cardCount">{aggregate.trip.total} reviews</span>
          <a href={aggregate.trip.url} class="opB__cardLink" target="_blank" rel="noopener noreferrer">
            See on TripAdvisor
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </article>

        <article class="opB__card opB__card--total" data-reveal data-reveal-delay="2">
          <span class="opB__cardLabel">Combined average</span>
          <div class="opB__stars" aria-hidden="true" set:html={Array(5).fill(starSvg).join('')}></div>
          <strong class="opB__cardRating">{aggregate.global.rating}</strong>
          <span class="opB__cardCount">{aggregate.global.total} total reviews</span>
          <span class="opB__cardNota">Weighted across both platforms</span>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== 3 · FEATURED TESTIMONIALS · feature cards ============== -->
  <section class="opT" aria-labelledby="opT-title">
    <div class="container container--xl">
      <header class="opT__header" data-reveal>
        <span class="opT__eyebrow">— What they say after paddling the Sella</span>
        <h2 id="opT-title" class="opT__title">
          Three reviews<br/><span class="serif-italic">that sum up what we do.</span>
        </h2>
      </header>

      <div class="opT__grid">
        {testimonios.map((t, i) => (
          <article class="opT__card" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="opT__head">
              <span class="opT__avatar" aria-hidden="true">{t.initial}</span>
              <div class="opT__meta">
                <strong class="opT__name">{t.name}</strong>
                <span class="opT__src">{t.source} · {t.date}</span>
              </div>
              <span class="opT__tag">{t.context}</span>
            </div>
            <div class="opT__stars" aria-hidden="true" set:html={Array(t.rating).fill(starSvg).join('')}></div>
            <blockquote class="opT__quote">
              <span class="opT__mark" aria-hidden="true">“</span>
              {t.text}
            </blockquote>
            <a href={t.sourceUrl} class="opT__link" target="_blank" rel="noopener noreferrer">
              See on {t.source}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 4 · PROFILES · who recommends us ============== -->
  <section class="opP" aria-labelledby="opP-title">
    <div class="container container--xl">
      <header class="opP__intro" data-reveal>
        <span class="opP__eyebrow">— By visitor profile</span>
        <h2 id="opP-title" class="opP__title">
          Four ways<br/><span class="serif-italic">to paddle the Sella.</span>
        </h2>
        <p class="opP__lead">
          Reading the 147 reviews, clear patterns emerge: the profile of who comes and the words that get repeated most.
        </p>
      </header>

      <div class="opP__panel">
        <ol class="opP__grid">
          {perfiles.map(p => (
            <li class="opP__cell">
              <div class="opP__cellBody">
                <h3 class="opP__cellName">{p.tag}</h3>
                <span class="opP__cellNota">{p.nota}</span>
                <ul class="opP__words">
                  {p.words.map(w => <li class="opP__word">“{w}”</li>)}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ============== 5 · DARK BANNER · ready to paddle? ============== -->
  <section class="opR" aria-label="Call to action · book descent">
    <div class="container container--xl">
      <div class="opR__inner" data-reveal>
        <div class="opR__text">
          <span class="opR__eyebrow">— Aventura en el Sella</span>
          <h2 class="opR__title">Now you know what they think <span class="serif-italic">of those who tried it.</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="opR__cta">
          <span>Book my descent</span>
          <span class="opR__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 6 · INTERLINKING sage dark ============== -->
  <section class="opX">
    <div class="container container--xl">
      <header class="opX__header" data-reveal>
        <span class="opX__eyebrow">— Before you come</span>
        <h2 class="opX__title">Get ready<br/><span class="serif-italic">for your Sella descent.</span></h2>
      </header>

      <nav class="opX__list" aria-label="Related pages">
        <a href={getLocalePath('precios', lang)} class="opX__item">
          <span class="opX__num">01</span>
          <h3 class="opX__t">Descent prices</h3>
          <p class="opX__p">€30 kids · €40 adults · pets free. All inclusive.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_ninos', lang)} class="opX__item">
          <span class="opX__num">02</span>
          <h3 class="opX__t">With kids</h3>
          <p class="opX__p">From age 5 · 1.15 m. Safety and family pace.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('con_perro', lang)} class="opX__item">
          <span class="opX__num">03</span>
          <h3 class="opX__t">With dog</h3>
          <p class="opX__p">Pets travel free. Dog life jacket included.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href={getLocalePath('recorrido_mapa', lang)} class="opX__item">
          <span class="opX__num">04</span>
          <h3 class="opX__t">Route and map</h3>
          <p class="opX__p">14.5 km · interactive map · 8 landmarks on the way.</p>
          <span class="opX__arrow" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
      </nav>
    </div>
  </section>

  <!-- ============== 7 · FAQ sage sidebar ============== -->
  <section class="opF">
    <div class="container container--xl">
      <div class="opF__grid">
        <aside class="opF__aside" data-reveal>
          <span class="opF__eyebrow">— Frequently asked questions</span>
          <h2 class="opF__title">About the<br/><span class="serif-italic">reviews.</span></h2>
          <p class="opF__lead">
            How we handle reviews, how to leave yours and what is behind the 4.5★.
            If something is missing, <a href={getLocalePath('contacto', lang)}>write to us</a>.
          </p>
        </aside>
        <div class="opF__list" data-reveal data-reveal-delay="2">
          {faqs.map((f, i) => (
            <details class="opFI" name="op-faq" open={i === 0}>
              <summary class="opFI__q">
                {f.q}
                <svg class="opFI__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="opFI__a" set:html={f.a} />
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 8 · FINAL CTA dark photo ============== -->
  <section class="opCta" aria-labelledby="opCta-title">
    <div class="opCta__bg" aria-hidden="true">
      <Picture src="opiniones-cta" alt="" sizes="100vw" bare />
    </div>
    <div class="opCta__inner">
      <span class="opCta__eyebrow">— Be part of the next review</span>
      <h2 id="opCta-title" class="opCta__title">
        From the river<br/>
        <span class="serif-italic">to your own story.</span>
      </h2>
      <p class="opCta__lead">
        Paddle the Sella with us and decide what you want to tell. Book without paying now — <strong>pay by card or the day you pick up the canoe</strong>.
      </p>
      <div class="opCta__ctas">
        <a href={getLocalePath('reservar', lang)} class="opCta__primary">
          Book my descent
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={getLocalePath('precios', lang)} class="opCta__ghost">See prices</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ==================== 1 · HERO ==================== */
  .opH {
    position: relative;
    background:
      radial-gradient(ellipse 70% 55% at 90% 0%, rgba(184, 210, 230, 0.22) 0%, transparent 60%),
      radial-gradient(ellipse 60% 45% at 10% 100%, rgba(61, 79, 58, 0.1) 0%, transparent 60%),
      linear-gradient(180deg, #F9F5EA 0%, #F0E9D3 100%);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    overflow: hidden; isolation: isolate;
  }
  .opH__watermark {
    position: absolute;
    top: 3%; right: -2%;
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    font-size: clamp(14rem, 28vw, 26rem);
    line-height: 0.85;
    color: rgba(26, 31, 46, 0.04);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
