---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import MapaInteractivoSella from '@components/sections/MapaInteractivoSella.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Sella River descent · Route and map · Arriondas → Fríes';
const description = 'Interactive map and route of the Sella River descent: 14.5 km from Arriondas to Fríes. Riverside snack bars, rapids, footbridges and river beaches along the way.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/route-and-map/`;

// Editorial highlights of the route · narrative complement to the map
const hitos = [
  { km: 0,    tag: 'START',         name: 'Arriondas',            kind: 'Starting point',           photo: 'arriondas-inicio',  alt: 'Arriondas · starting point of the Sella River descent',                text: 'Where it all begins. Check-in at our offices, gear, Asturian picnic and mini-class before getting in the water. Capital of the Parres district.' },
  { km: 1,    tag: 'RAPID',         name: 'La Remolina',          kind: 'First rapid',              photo: 'remolina-rapido',   alt: 'La Remolina · first rapid of the Sella River descent',                 text: 'The first gentle rapid of the way — moderate class I. All you need is to paddle calmly: the river guides you.' },
  { km: 3,    tag: 'SNACK BAR',     name: 'El Oasis · El Prau',   kind: 'Two iconic stops',         photo: 'chiringuito-prao',  alt: 'El Prau riverside snack bar by the Sella River',                       text: 'The first riverside snack bars where people stop for a drink or to cool off. Lively atmosphere in high season.' },
  { km: 4,    tag: 'FOOTBRIDGE',    name: 'Pasarela de Fuentes',  kind: 'Salmon fishing reserve',   photo: 'pasarela-fuentes',  alt: 'Pasarela de Fuentes over the Sella in the salmon fishing reserve',      text: 'You cross the historic salmon fishing reserve of Los Llaos. Asturian villages on the banks, holm oaks and beech woods. One of the most beautiful stretches.' },
  { km: 6,    tag: 'BEACH',         name: 'Pozo del Arco',        kind: 'River beach',              photo: 'pozo-del-arco',     alt: 'Pozo del Arco · river beach of the Sella River',                       text: 'Calm waters and river beach. An ideal stop for a swim — especially in July and August when the water is warmer.' },
  { km: 7,    tag: 'END MINI',      name: 'Toraño',               kind: 'End of Mini Sella',        photo: 'torano-mini-fin',   alt: 'Toraño · end of the Mini Sella route',                                  text: 'Pick-up point for those choosing the <strong>Mini Sella</strong>. Whoever continues to Fríes crosses the most open part of the valley.' },
  { km: 10,   tag: 'STOP',          name: 'Llordón',              kind: 'Mid-journey',              photo: 'llordon-parada',    alt: 'Llordón · mid-journey stop on the Sella River descent',                text: 'A usual stop to enjoy the picnic calmly or to cool off before the final stretch. Spectacular sunsets.' },
  { km: 14.5, tag: 'FINISH',        name: 'Fríes',                kind: 'End of Full route',        photo: 'frias-final',       alt: 'Fríes · end of the Full Sella River descent',                          text: 'End of the <strong>Full descent</strong>. Our transfer picks you up and takes you back to Arriondas. Changing rooms with hot showers await.' },
];

// 15 detailed sections of the route · editorial timeline for long-tail SEO
const tramos = [
  { km: 0,    type: 'Start',                 name: 'Arriondas · Puente de las Piraguas', highlight: true,
    photo: 'arriondas-inicio', alt: 'Arriondas · starting point of the Sella River descent',
    text: 'Starting point of the descent. You set off from our <strong>ramp over 35 m long</strong> or directly from the bank, next to the legendary <strong>Puente de las Piraguas</strong> (Canoeists\' Bridge) — the same bridge where every August the official start of the <a href="/en/international-sella-descent/">International Descent</a> is given.' },
  { km: 0.2,  type: 'Rapid',                 name: 'La Raíz',
    text: 'The first rapid of the day. The current speeds up and the river narrows. <strong>Moderate class I</strong> — passed without trouble, the canoe gains some speed and gives you the first thrill.' },
  { km: 1,    type: 'Rapid',                 name: 'La Remolina',
    text: 'Second rapid with <strong>V-shaped</strong> waters. The only important thing is to stay centred between the two converging currents — a fun push.' },
  { km: 2,    type: 'Salmon reserve',        name: 'El Ricao',
    text: 'A narrower stretch with <strong>calm meandering waters</strong>. Historic salmon fishing reserve — you will find anglers on the banks during the salmon season.' },
  { km: 4,    type: 'Footbridge · village',  name: 'Pasarela de Fuentes · Los Llaos',   highlight: true,
    photo: 'pasarela-fuentes', alt: 'Pasarela de Fuentes over the Sella River in Triongo',
    text: 'You pass beneath the <strong>footbridge of the parish of Triongo</strong> (Cangas de Onís). Second salmon reserve and one of the most beautiful stretches of the river — Asturian villages on the banks, holm oaks and beech woods.' },
  { km: 5,    type: 'Rocky stretch',         name: 'Triongo',
    text: 'A stretch full of <strong>small rapids</strong> and stones. On the right bank stands a ruined breakwater that is part of the historic river landscape.' },
  { km: 6,    type: 'River beach',           name: 'Pozo del Arco',                      highlight: true,
    photo: 'pozo-del-arco', alt: 'Pozo del Arco · river beach on the Sella River descent',
    text: 'One of the favourite spots of the route. <strong>Calm, deep waters</strong>, a river beach ideal for swimming — a must-stop in July and August when the water is warmer.' },
  { km: 6.5,  type: 'Rapid · border',        name: 'El Picu La Vieya',
    text: 'Marks the <strong>border between Cangas de Onís and Ribadesella</strong>, in Margolles. Small rapid on the right bank that reminds you the river is still alive.' },
  { km: 7,    type: 'End Mini Sella',        name: 'Puente de Toraño',                   highlight: true,
    photo: 'torano-mini-fin', alt: 'Puente de Toraño · end of the Mini Sella route',
    text: '<strong>End of the Mini Sella</strong>. After about <strong>2 hours of paddling</strong>, calm waters and two snack bars on the bank. Our transfer picks up from <strong>2:30 pm</strong> those who choose the short route.' },
  { km: 8,    type: 'Spectacular rapid',     name: 'Rabión del Diablu',
    text: '<strong>Spectacular and very rocky</strong> stretch. One of the most exciting moments of the Full descent — intense class I, always safe with a certified life jacket and the previous mini-class.' },
  { km: 9,    type: 'Straight stretch',      name: 'La Requexada',
    text: 'The <strong>longest straight stretch</strong> of the route, with very deep waters. Perfect time to paddle at your rhythm, enjoy the open valley and chat without surprises.' },
  { km: 10,   type: 'Stop',                  name: 'Llordón',
    text: 'A usual stop to <strong>eat the picnic</strong> or cool off before the final stretch. Wide banks and spectacular sunsets if you come down in autumn.' },
  { km: 12,   type: 'Footbridge',            name: 'Pasarela de Cuevas',
    text: 'A village in Ribadesella famous for its <strong>natural cave</strong>. The footbridge over the river is a pedestrian and anglers\' access — a very photogenic stretch.' },
  { km: 13,   type: 'Footbridge',            name: 'Pasarela de La Uña',
    text: 'The <strong>last footbridge</strong> of the route. From here the river calms down, more <strong>river beaches</strong> appear and the valley opens gently towards the sea.' },
  { km: 14.5, type: 'Finish',                name: 'Fríes · Llovio',                     highlight: true,
    photo: 'frias-final', alt: 'Fríes · end of the Full Sella River descent',
    text: '<strong>End of the Full descent</strong>. Between 3 h 30 and 4 h 30 from Arriondas depending on pace. Our transfer picks you up and takes you back to the offices, where <strong>changing rooms with hot showers</strong> are waiting.' },
];

// Timeline icons · one clean glyph per section type
const iconFor = (type) => {
  const t = type.toLowerCase();
  if (t.includes('end mini')) return 'flag-mini';
  if (t.includes('start'))    return 'flag-start';
  if (t.includes('finish'))   return 'flag-finish';
  if (t.includes('rapid'))    return 'wave';
  if (t.includes('salmon'))   return 'fish';
  if (t.includes('footbridge')) return 'bridge';
  if (t.includes('rocky'))    return 'mountain';
  if (t.includes('beach'))    return 'beach';
  if (t.includes('straight')) return 'arrow';
  if (t.includes('stop'))     return 'coffee';
  return 'dot';
};

const iconPaths = {
  'flag-start':  '<path d="M6 21V4m0 0h12l-3 4 3 4H6"/>',
  'flag-finish': '<path d="M6 21V4m0 0h12l-3 4 3 4H6m0-4h12"/>',
  'flag-mini':   '<path d="M6 21V5m0 0h11l-2 3 2 3H6"/>',
  'wave':        '<path d="M3 10c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/><path d="M3 16c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'fish':        '<path d="M3 12c3-3 7-5 11-5 3 0 6 2 7 5-1 3-4 5-7 5-4 0-8-2-11-5z"/><circle cx="15.5" cy="10.5" r="0.9" fill="currentColor" stroke="none"/>',
  'bridge':      '<path d="M3 19V13a9 9 0 0 1 18 0v6M3 19h18M9 19v-3M15 19v-3"/>',
  'mountain':    '<path d="M3 20l5-9 4 6 3-4 6 7z"/>',
  'beach':       '<circle cx="12" cy="8" r="3"/><path d="M3 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  'arrow':       '<line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 6 20 12 14 18"/>',
  'coffee':      '<path d="M4 10h12v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-6zm12 2h2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-2"/><line x1="8" y1="3" x2="8" y2="6"/><line x1="12" y1="3" x2="12" y2="6"/>',
  'parasol':     '<path d="M3 11a9 9 0 0 1 18 0z"/><line x1="12" y1="11" x2="12" y2="20"/><path d="M10 20a2 2 0 0 0 4 0"/>',
  'dot':         '<circle cx="12" cy="12" r="3"/>',
};

// 6 real riverside snack bars along the route
const chiringuitos = [
  { km: 1, name: 'Riverland',  nota: 'Start of the route',         icon: 'flag-start' },
  { km: 3, name: 'El Oasis',   nota: 'First third · bank',         icon: 'coffee'     },
  { km: 3, name: 'El Prau',    nota: 'First third · beach',        icon: 'parasol'    },
  { km: 4, name: 'El Bosque',  nota: 'Middle · after the bridge',  icon: 'bridge'     },
  { km: 4, name: 'La Mediana', nota: 'Middle · other bank',        icon: 'wave'       },
  { km: 8, name: 'Toraño',     nota: 'End of the Mini Sella',      icon: 'flag-finish'},
];

// Route-specific FAQ
const faqs = [
  { q: 'How many kilometres is the Sella River descent?',
    a: 'The <strong>Full descent</strong> is <strong>14.5 km</strong> from Arriondas to Fríes. The <strong>Mini Sella</strong>, the short option, is <strong>7 km</strong> between Arriondas and Toraño. Both share the same initial stretch.' },
  { q: 'Where does the Sella River descent start and end?',
    a: 'The descent <strong>starts in Arriondas</strong> (Asturias), at our offices. The Full route <strong>ends in Fríes</strong> after 14.5 km. The Mini Sella ends earlier, in <strong>Toraño</strong> (km 7). In both cases our transfer picks you up and takes you back to the starting point.' },
  { q: 'What are the snack bars along the way?',
    a: 'There are <strong>6 riverside snack bars</strong> along the route: <strong>Riverland</strong> (km 1), <strong>El Oasis</strong> and <strong>El Prau</strong> (km 3), <strong>El Bosque</strong> and <strong>La Mediana</strong> (km 4) and <strong>Toraño</strong> (km 8, end of the Mini Sella). You can stop to rest, have a drink or simply enjoy the atmosphere.' },
  { q: 'Are there river beaches to swim in?',
    a: 'Yes. The most well-known is <strong>Pozo del Arco</strong> (km 6), with calm waters perfect for a swim. There are also several <strong>informal banks and beaches</strong> along the route — especially after Pasarela de Fuentes and before Llordón.' },
  { q: 'What rapids or difficult stretches are there?',
    a: 'The Sella in its tourist stretch is <strong>gentle river</strong> — not white-water. It has some <strong>moderate class I</strong> rapids such as <strong>La Raíz</strong> (km 0.2) and <strong>La Remolina</strong> (km 1). With the previous mini-class and a certified life jacket they are done with total safety.' },
  { q: 'Can you stop at any point along the route?',
    a: 'Yes, <strong>you set the pace</strong>. You stop wherever you wish: at river beaches, snack bars or simply on the bank to stretch. The only thing to comply with is the <strong>maximum permanence until 6:00 pm</strong> by regulation of the Cantabrian Hydrographic Confederation.' },
  { q: 'What is the difference between Mini Sella and Full route?',
    a: 'Both share the first 7 km (Arriondas → Toraño). The <strong>Mini Sella</strong> ends there — ideal with small children or for half a day. The <strong>Full descent</strong> continues another 7.5 km to Fríes, adding open landscape, the Cuevas footbridge, the La Uña footbridge and the closing of the valley. <a href="/en/how-long-does-it-take/">More detail on times here</a>.' },
  { q: 'What will we see along the way?',
    a: 'Asturian villages (Fuentes, Margolles, Toraño, Cuevas), <strong>Cantabrian forest</strong> with holm oaks and beech woods, <strong>6 snack bars</strong> on the banks, the <strong>salmon reserve</strong> of Los Llaos, <strong>river beaches</strong>, gentle rapids and several historic footbridges. The most scenic plan in Asturias.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Route and map of the Sella River descent · Arriondas to Fríes',
      description: 'Complete guide to the route of the Sella River descent: 14.5 km with interactive map, snack bars, rapids, footbridges and river beaches.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-21',
      dateModified: '2026-05-12',
      about: 'Route and map of the Sella River canoe descent, 14.5 km between Arriondas and Fríes',
      keywords: 'Sella River descent, route and map, Arriondas, Fríes, Mini Sella, snack bars, rapids, footbridges, river beaches, Asturias',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'en-GB',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',          item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Route and map', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/route-and-map/" translationKey="recorrido_mapa">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · editorial with "Sella" watermark + stats ============== -->
  <section class="rrh" aria-labelledby="rrh-title">

    <div class="rrh__shapes" aria-hidden="true">
      <span class="rrh__shape rrh__shape--1"></span>
      <span class="rrh__shape rrh__shape--2"></span>
    </div>
    <span class="rrh__watermark" aria-hidden="true">Sella</span>

    <div class="rrh__inner">
      <nav class="rrh__breadcrumb" aria-label="Breadcrumb">
        <a href={getLocalePath('home', lang)}>Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Route and map</span>
      </nav>

      <span class="rrh__eyebrow">— Route of the descent</span>

      <h1 id="rrh-title" class="rrh__title">
        The map of the<br/>
        <span class="serif-italic">Sella.</span>
      </h1>

      <p class="rrh__lead">
        The Sella River canoe descent covers <strong>14.5 km between Arriondas and Fríes</strong>,
        crossing Asturian villages, gentle rapids, historic footbridges, river beaches
        and <strong>6 riverside snack bars</strong>. Here is the interactive map with every point
        along the way.
      </p>

      <ul class="rrh__stats" aria-label="Route figures">
        <li class="rrh__stat">
          <strong>14.5<small>km</small></strong>
          <span>full route</span>
        </li>
        <li class="rrh__stat">
          <strong>7<small>km</small></strong>
          <span>Mini Sella</span>
        </li>
        <li class="rrh__stat">
          <strong>6</strong>
          <span>snack bars</span>
        </li>
      </ul>

      <div class="rrh__ctas">
        <a href="#rrh-mapa" class="rrh__cta rrh__cta--primary">See interactive map</a>
        <a href={getLocalePath('reservar', lang)} class="rrh__cta rrh__cta--link">
          Book descent
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 2 · INTERACTIVE MAP (reused component) ============== -->
  <div id="rrh-mapa">
    <MapaInteractivoSella />
  </div>

  <!-- ============== 3 · ROUTE HIGHLIGHTS · editorial feature spread ============== -->
  <section class="rrs" aria-labelledby="rrs-title">
    <div class="container container--xl">
      <header class="rrs__header" data-reveal>
        <div class="rrs__headerMain">
          <span class="rrs__eyebrow">— Highlights along the way</span>
          <h2 id="rrs-title" class="rrs__title">8 canonical<br/><span class="serif-italic">stops.</span></h2>
        </div>
        <div class="rrs__nav" role="group" aria-label="Highlights navigation">
          <span class="rrs__counter" aria-live="polite">
            <span class="rrs__counterCurrent" data-rrs-current>01</span>
            <small class="rrs__counterTotal">/{String(hitos.length).padStart(2, '0')}</small>
          </span>
          <button type="button" class="rrs__navBtn" data-rrs-nav="prev" aria-label="Previous highlight">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="rrs__navBtn is-dark" data-rrs-nav="next" aria-label="Next highlight">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </header>

      <div class="rrs__track" data-rrs-track data-drag-scroll role="region" aria-label="Route highlights">
        {hitos.map((h, i) => (
          <article class="rrsItem" data-rrs-item={i}>
            <span class="rrsItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rrsItem__media">
              <Picture src={h.photo} alt={h.alt} sizes="(min-width: 960px) 52vw, 90vw" bare />
            </div>
            <div class="rrsItem__body">
              <span class="rrsItem__tag">KM {h.km === Math.floor(h.km) ? h.km : h.km.toFixed(1)} · {h.tag}</span>
              <h3 class="rrsItem__name">{h.name}</h3>
              <p class="rrsItem__kind">{h.kind}</p>
              <p class="rrsItem__text" set:html={h.text} />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 3.25 · DARK BANNER · Ready for the descent? ============== -->
  <section class="rrb" aria-label="Call to action · book the descent">
    <div class="container container--xl">
      <div class="rrb__inner" data-reveal>
        <div class="rrb__text">
          <span class="rrb__eyebrow">— Aventura en el Sella</span>
          <h2 class="rrb__title">Ready to <span class="serif-italic">do the descent?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rrb__cta">
          <span>Book now</span>
          <span class="rrb__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 3.5 · STEP BY STEP · editorial timeline with story ============== -->
  <section class="rrt" aria-labelledby="rrt-title">
    <div class="container container--xl">
      <header class="rrt__header" data-reveal>
        <span class="rrt__eyebrow">— Step by step</span>
        <h2 id="rrt-title" class="rrt__title">
          Section by section<br/>
          <span class="serif-italic">of the Sella.</span>
        </h2>
        <p class="rrt__lead">
          The Sella River canoe descent was born in <strong>1929</strong>, when three Asturians
          — Manés Fernández, Dionisio de la Huerta and Benigno Morán — paddled down for the
          first time between Coya and Arriondas. Today, the <strong>tourist route between Arriondas
          and Fríes</strong> still keeps each historic landmark of the river: gentle rapids,
          footbridges, river beaches and unforgettable stretches. This is the complete guide,
          spot by spot.
        </p>
      </header>

      <div class="rrt__track">
        <div class="rrt__spine" aria-hidden="true">
          <span class="rrt__spineBg"></span>
          <span class="rrt__spineFg" data-rrt-spine></span>
        </div>

        <ol class="rrt__timeline" data-rrt-timeline>
          {tramos.map((t, i) => (
            <li class={`rrtItem${t.highlight ? ' is-highlight' : ''}`} data-rrt-item>
              <div class="rrtItem__pane" data-reveal data-reveal-delay={(i % 3) + 1}>
                <div class="rrtItem__meta">
                  <span class="rrtItem__km">km {t.km === Math.floor(t.km) ? t.km : t.km.toFixed(1)}</span>
                  <span class="rrtItem__sep" aria-hidden="true"></span>
                  <span class="rrtItem__tag">{t.type}</span>
                </div>
                <h3 class="rrtItem__name">{t.name}</h3>
                <p class="rrtItem__text" set:html={t.text} />
              </div>

              <div class="rrtItem__axis" aria-hidden="true">
                <span class="rrtItem__node">
                  <svg class="rrtItem__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[iconFor(t.type)]} />
                </span>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ============== 4 · SNACK BARS · intro + 6-cell grid ============== -->
  <section class="rrc" aria-labelledby="rrc-title">
    <div class="container container--xl">
      <header class="rrc__intro" data-reveal>
        <span class="rrc__eyebrow">— Stops along the way</span>
        <h2 id="rrc-title" class="rrc__title">
          6 riverside snack bars<br/>
          <span class="serif-italic">along the Sella.</span>
        </h2>
        <p class="rrc__lead">
          Along the route you can stop at any of the <strong>6 riverside snack bars</strong>
          on the banks of the river — to cool off, eat or simply rest before keeping on
          downstream.
        </p>
      </header>

      <div class="rrc__panel" data-reveal data-reveal-delay="1">
        <ol class="rrc__grid">
          {chiringuitos.map((c) => (
