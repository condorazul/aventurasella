<!-- JS · highlights carousel + timeline spine fill -->
<script>
  (function () {
    const track = document.querySelector<HTMLElement>('[data-rrs-track]');
    const prev  = document.querySelector<HTMLButtonElement>('[data-rrs-nav="prev"]');
    const next  = document.querySelector<HTMLButtonElement>('[data-rrs-nav="next"]');
    const cur   = document.querySelector<HTMLElement>('[data-rrs-current]');
    if (!track || !prev || !next) return;
    const items = track.querySelectorAll<HTMLElement>('[data-rrs-item]');
    const cw = () => {
      if (!items[0]) return 0;
      const r = items[0].getBoundingClientRect();
      const s = getComputedStyle(track);
      const g = parseFloat(s.columnGap || s.gap || '16') || 16;
      return r.width + g;
    };
    const upd = () => {
      const sMax = track.scrollWidth - track.clientWidth;
      const width = cw();
      const idx = width > 0 ? Math.round(track.scrollLeft / width) : 0;
      const c = Math.max(0, Math.min(idx, items.length - 1));
      if (cur) cur.textContent = String(c + 1).padStart(2, '0');
      prev.disabled = track.scrollLeft <= 1;
      next.disabled = track.scrollLeft >= sMax - 1;
    };
    prev.addEventListener('click', () => track.scrollBy({ left: -cw(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: cw(),  behavior: 'smooth' }));
    track.addEventListener('scroll', () => requestAnimationFrame(upd), { passive: true });
    window.addEventListener('resize', upd);
    upd();
  })();

  (function () {
    const spine    = document.querySelector<HTMLElement>('[data-rrt-spine]');
    const timeline = document.querySelector<HTMLElement>('[data-rrt-timeline]');
    if (!spine || !timeline) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { spine.style.setProperty('--rrt-progress', '1'); return; }

    let ticking = false;
    const update = () => {
      ticking = false;
      const rect = timeline.getBoundingClientRect();
      const anchor = window.innerHeight * 0.62;
      const progressed = anchor - rect.top;
      const pct = Math.max(0, Math.min(1, progressed / Math.max(rect.height, 1)));
      spine.style.setProperty('--rrt-progress', pct.toFixed(4));
    };
    const onScroll = () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    };
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  })();
</script>
