<!-- JS · tabs medios transporte + slider mobile sincronizado -->
<script>
  (function () {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.clt__tab');
    const panels = document.querySelectorAll<HTMLElement>('.clt__panel');
    const card = document.querySelector<HTMLElement>('.clt__card');
    if (!tabs.length || !card) return;
    const isSliderMode = () => window.matchMedia('(max-width: 899.98px)').matches;
    const updateActiveTab = (key: string) => {
      tabs.forEach((t) => {
        const isActive = t.dataset.tab === key;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        t.setAttribute('tabindex', isActive ? '0' : '-1');
      });
    };
    const updateHiddenPanels = (key: string) => {
      panels.forEach((p) => {
        const isActive = p.dataset.panel === key;
        p.classList.toggle('is-active', isActive);
        if (isSliderMode()) { p.removeAttribute('hidden'); }
        else { if (isActive) p.removeAttribute('hidden'); else p.setAttribute('hidden', ''); }
      });
    };
    const activate = (key: string, fromScroll = false) => {
      updateActiveTab(key);
      updateHiddenPanels(key);
      if (isSliderMode() && !fromScroll) {
        const target = Array.from(panels).find(p => p.dataset.panel === key);
        if (target) card.scrollTo({ left: target.offsetLeft - card.offsetLeft, behavior: 'smooth' });
      }
    };
    const initSliderState = () => { if (isSliderMode()) panels.forEach(p => p.removeAttribute('hidden')); };
    initSliderState();
    window.addEventListener('resize', () => {
      initSliderState();
      if (!isSliderMode()) {
        const activeTab = Array.from(tabs).find(t => t.classList.contains('is-active'));
        if (activeTab?.dataset.tab) updateHiddenPanels(activeTab.dataset.tab);
      }
    });
    tabs.forEach((t) => {
      t.addEventListener('click', () => { const k = t.dataset.tab; if (k) activate(k); });
      t.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const arr = Array.from(tabs);
        const idx = arr.indexOf(t);
        const nextIdx = e.key === 'ArrowRight' ? (idx + 1) % arr.length : (idx - 1 + arr.length) % arr.length;
        const next = arr[nextIdx];
        const k = next.dataset.tab;
        if (k) { activate(k); next.focus(); }
      });
    });
    let scrollTimer: number | null = null;
    card.addEventListener('scroll', () => {
      if (!isSliderMode()) return;
      if (scrollTimer) cancelAnimationFrame(scrollTimer);
      scrollTimer = requestAnimationFrame(() => {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;
        let bestKey: string | undefined;
        let bestDist = Infinity;
        panels.forEach(p => {
          const pRect = p.getBoundingClientRect();
          const pCenter = pRect.left + pRect.width / 2;
          const dist = Math.abs(pCenter - cardCenter);
          if (dist < bestDist) { bestDist = dist; bestKey = p.dataset.panel; }
        });
        if (bestKey) { updateActiveTab(bestKey); updateHiddenPanels(bestKey); }
      });
    }, { passive: true });
  })();
</script>
