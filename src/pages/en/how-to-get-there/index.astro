---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'How to get to Arriondas · 50 m from the bus and train stations';
const description = 'How to get to Arriondas for the Sella descent: 50 m from the bus and train stations. By car (A-8, A-64), ALSA bus or Renfe train. Parking 300 spaces + motorhomes.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/how-to-get-there/`;
const ogImage = '/images/optimized/como-llegar-cta-lg.jpg';

// Most relevant origin cities · road distances (recommended routes)
// lat/lng: needed in Google Maps `data=` to calc route when destination is set by FTID.
const ciudades = [
  { c: 'Oviedo',    lat: 43.36029, lng: -5.84476, km: 52,  tiempo: '50 min',     ruta: 'A-64 + N-634',      destacado: true  },
  { c: 'Gijón',     lat: 43.53573, lng: -5.66152, km: 75,  tiempo: '55 min',     ruta: 'A-8 + AS-114',       destacado: true  },
  { c: 'Santander', lat: 43.46472, lng: -3.80444, km: 160, tiempo: '1 h 55 min', ruta: 'A-8',                destacado: false },
  { c: 'Bilbao',    lat: 43.26271, lng: -2.92528, km: 255, tiempo: '2 h 45 min', ruta: 'A-8',                destacado: false },
  { c: 'Madrid',    lat: 40.41678, lng: -3.70379, km: 440, tiempo: '4 h 30 min', ruta: 'A-6 + A-66 + A-64',  destacado: false },
];

// 3 transport options in tabs
const medios = [
  {
    id: 'coche',
    tab: 'By car',
    eyebrow: 'By car',
    route: 'The most flexible option',
    stats: [
      { v: '52',  u: 'km',  l: 'from Oviedo' },
      { v: '75',  u: 'km',  l: 'from Gijón' },
      { v: 'A-8', u: '',    l: 'motorway' },
    ],
    desc: 'The most convenient way to reach Arriondas is <strong>by car on the A-8</strong> (Cantabrian motorway) from Santander, Bilbao or Gijón, or on the <strong>A-64 + N-634</strong> from Oviedo. Access is well signposted; the last section is on a secondary road (AS-114 or N-634) that crosses beautiful Asturian villages. Next to our offices we have <strong>private guarded parking with 300 spaces — also for motorhomes</strong>, free and with no restrictions.',
    features: ['A-8 motorway', 'A-64 direct from Oviedo', 'AS-114 from Gijón', 'Free parking', 'Total flexibility', 'No timetables'],
    photo: 'como-llegar-coche',
    badges: ['Flexible', 'Direct', 'Comfortable'],
  },
  {
    id: 'bus',
    tab: 'By bus',
    eyebrow: 'ALSA bus',
    route: 'Affordable and frequent',
    stats: [
      { v: '~1h15', u: '',  l: 'from Oviedo' },
      { v: '~1h06', u: '',  l: 'from Gijón' },
      { v: 'From €6', u: '', l: 'one way' },
    ],
    desc: '<strong>ALSA</strong> connects Arriondas with the main Asturian cities. From <strong>Oviedo (Pepe Cosmen station)</strong> there are <strong>~20 buses per day</strong> (approx. every 30 min, first service 06:25 and last 22:15), journey ~1 h 15 min. From <strong>Gijón</strong> there are 4 direct services per day, journey ~1 h 06 min. The stop in Arriondas is at the <strong>bus station</strong>, a few minutes walk from our offices. Check timetables and buy at <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.',
    features: ['~20 services/day Oviedo', '4 services/day Gijón', 'From €6 one way', 'Central station', 'No car needed', 'Buy online'],
    photo: 'como-llegar-bus',
    badges: ['ALSA', 'Frequent', 'Affordable'],
  },
  {
    id: 'tren',
    tab: 'By train',
    eyebrow: 'Renfe Cercanías AM',
    route: 'Scenic journey through Asturias',
    stats: [
      { v: '~1h50', u: '',  l: 'from Oviedo' },
      { v: '3/day', u: '',  l: 'frequency' },
      { v: 'From €5', u: '', l: 'one way' },
    ],
    desc: 'The <strong>Renfe Cercanías AM</strong> line (former FEVE) from Oviedo to Llanes <strong>has a stop in Arriondas</strong>. A slower but very scenic journey through Asturian landscapes: <strong>~1 h 50 min</strong>, first train around 07:57 and last around 19:07, <strong>3 services per day</strong>. From €5 per trip. Arriondas station is in the centre of town. Check updated timetables at <a href="https://www.renfe.com/es/es/cercanias/cercanias-am" target="_blank" rel="noopener noreferrer">renfe.com/cercanias-am</a>.',
    features: ['Cercanías AM', '3 trains/day', 'From €5 one way', 'Central station', 'Scenic route', 'No car needed'],
    photo: 'como-llegar-tren',
    badges: ['Renfe', 'Scenic', 'Quiet'],
  },
];

// Practical tips (6)
const consejos = [
  { t: 'Open hours · 10:30–12:30', s: 'Since your booking is <strong>Premium</strong>, the timetable is open: arrive at our facilities <strong>whenever it suits you between 10:30 and 12:30</strong>, with no need to choose a specific time. We kit you out on arrival and you set off down the river as soon as you\'re ready.' },
  { t: 'High season · avoid bank holidays', s: 'In July and August, especially at weekends, the A-8 can have heavy traffic towards Asturias. If you\'re coming from Madrid or Santander, leave early or consider arriving the previous afternoon.' },
  { t: 'Private parking · 300 spaces', s: 'We have <strong>private guarded parking, free, with capacity for 300 cars and also for motorhomes</strong>. No worries — leave the car and we take care of the rest.' },
  { t: 'Bus · buy in advance', s: 'In high season ALSA tickets sell out. Buy <strong>1-2 days in advance</strong> online if you\'re coming by bus from Oviedo or Gijón, especially in August.' },
  { t: 'Train · check frequencies', s: 'The Renfe Cercanías AM line has <strong>few daily services</strong> (3-4). Check outbound and return times before planning your day.' },
  { t: 'From Madrid · consider sleeping nearby', s: 'If you\'re coming from Madrid, it\'s <strong>4 h 30 by car</strong>. It may be more comfortable to spend the night before in Oviedo, Gijón or Cangas de Onís and head down the Sella fresh the next day.' },
];

// Specific how-to-get-there FAQ (8) · data verified with ALSA and Renfe official sources
const faqs = [
  { q: 'How do I get to Arriondas from Oviedo?',
    a: 'From Oviedo it\'s <strong>about 52 km · 50 min by car</strong> on the A-64 and N-634. By bus with <strong>ALSA</strong>, ~20 daily services from Pepe Cosmen station (from €6, journey ~1 h 15 min, first bus 06:25 and last 22:15). By train <strong>Renfe Cercanías AM</strong>, ~1 h 50 min, with 3 services per day from €5.' },
  { q: 'And from Gijón?',
    a: 'From Gijón it\'s <strong>about 75 km · 55 min by car</strong> on the A-8 and AS-114. By <strong>ALSA bus</strong> there are <strong>4 direct services per day</strong>, with a journey of ~1 h 06 min and prices from €7. Buy your tickets at <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.' },
  { q: 'Is there parking at the office? Do you accept motorhomes?',
    a: 'Yes. We have <strong>private guarded parking with 300 spaces</strong> next to our reception offices in Arriondas, <strong>free and also suitable for motorhomes</strong>. You won\'t have any problem leaving your car while you do the descent — and the return transfer drops you off in the same place.' },
  { q: 'Do people come to the Sella descent without a car?',
    a: 'Lots of them. A significant share of our customers arrive by <strong>ALSA bus</strong> or <strong>Renfe Cercanías AM train</strong> from Oviedo or Gijón. Our shop is <strong>just 50 metres on foot</strong> from both the <strong>bus station</strong> and the <strong>train station</strong> of Arriondas — practically a <strong>door-to-door</strong> arrival. Leaving Oviedo by bus and starting the Sella descent without leaving the centre of Arriondas is perfectly feasible.' },
  { q: 'Until what time can we arrive?',
    a: `Your booking is <strong>Premium · open hours</strong>. Arrive at our facilities <strong>whenever it suits you between 10:30 and 12:30</strong>, with no obligation to keep to a specific time — it's a Premium perk. We kit you out on arrival and you set off down the river as soon as you're ready. The <strong>Cantabrian Hydrographic Confederation</strong> rules that <strong>river closes at 18:00</strong> · that's why we close arrivals at 12:30 (safe margin). Exceptions: the Saturday of the <a href="/en/international-sella-descent/">International Sella Descent</a> has a single departure at a specific time · and if there's a storm or river conditions requiring entry with an instructor, we'll let you know in advance.` },
  { q: 'How far is it from Madrid?',
    a: 'Madrid is <strong>about 440 km · 4 h 30 min by car</strong> on the A-6 (to Benavente), A-66 (Ruta de la Plata) and A-64 (Oviedo → Arriondas). Many travellers prefer to sleep the night before in Asturias — Oviedo, Gijón or Cangas de Onís — so they can start the day of the descent fresh.' },
  { q: 'How many buses/trains are there per day between Oviedo and Arriondas?',
    a: '<strong>ALSA: ~20 daily buses</strong> (approx. every 30 min). <strong>Renfe Cercanías AM: 3 trains per day</strong>. The bus is faster (~1 h 15 min) and more frequent; the train is more scenic (~1 h 50 min). Both stop in Arriondas, in the centre of town.' },
  { q: 'Can I leave backpacks or luggage before the descent?',
    a: 'Yes. At our offices you can leave small luggage or backpacks during the descent. When you return on our transfer, you\'ll have access to <strong>changing rooms with hot showers</strong> to change before continuing your day.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'How to get to Arriondas · Car, bus and train',
      description: 'Complete guide on how to get to Arriondas for the Sella descent: car, ALSA bus and Renfe train from the main cities of northern Spain. Private parking 300 spaces also for motorhomes.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/como-llegar-cta-lg.jpg`, width: 1920, height: 1080 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified:  '2026-05-12',
      articleSection: 'Planning · How to get there',
      keywords: ['how to get to Arriondas', 'how to get to the Sella', 'Sella descent without car', 'bus station Arriondas', 'train station Arriondas', 'parking Arriondas Sella descent', 'motorhomes Arriondas', 'ALSA Oviedo Arriondas', 'Renfe Cercanías AM Arriondas', 'distance Oviedo Arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'How to get to Arriondas (Asturias) for the Sella canoe descent' },
    },
    {
      '@type': 'Place',
      '@id': `${canonicalUrl}#place`,
      name: 'Aventura en el Sella · Arriondas',
      description: 'Aventura en el Sella facilities in Arriondas (Asturias). Private guarded parking with 300 spaces, also for motorhomes. Changing rooms with hot showers.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        addressCountry: 'ES',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude:  43.3874223,
        longitude: -5.1866022,
      },
      sameAs: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      url: canonicalUrl,
      amenityFeature: [
        { '@type': 'LocationFeatureSpecification', name: '50 m from the bus station (ALSA)',            value: true },
        { '@type': 'LocationFeatureSpecification', name: '50 m from the train station (Renfe Cercanías AM)', value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Private parking · 300 spaces',                value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Motorhomes accepted',                         value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Changing rooms with hot showers',             value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Lockers with key',                            value: true },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',              item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'How to get there',  item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/en/how-to-get-there/" translationKey="como_llegar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · Editorial con signpost card (distinto) ============== -->
  <section class="clh" aria-labelledby="clh-title">

    <div class="clh__shapes" aria-hidden="true">
      <span class="clh__shape clh__shape--1"></span>
      <span class="clh__shape clh__shape--2"></span>
    </div>
    <span class="clh__watermark" aria-hidden="true">Arriondas</span>

    <div class="clh__inner">
      <div class="clh__left">
        <nav class="clh__breadcrumb" aria-label="Breadcrumb">
          <a href={getLocalePath('home', lang)}>Home</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">How to get there</span>
        </nav>
        <span class="clh__eyebrow">— How to get to Arriondas</span>
        <h1 id="clh-title" class="clh__title">
          How to get<br/>
          <span class="serif-italic">to Arriondas.</span>
        </h1>
        <p class="clh__lead">
          Arriondas is in <strong>eastern central Asturias</strong>, 50 km from Oviedo and
          75 km from Gijón. Well connected by car (A-8 and A-64), ALSA bus and Renfe train.
          Our shop is <strong>50 metres on foot from the bus and train stations</strong> ·
          door-to-door from Oviedo, Gijón or Llanes.
        </p>
        <div class="clh__ctas">
          <a href="#clh-medios" class="clh__cta clh__cta--primary">See transport options</a>
          <a href={getLocalePath('reservar', lang)} class="clh__cta clh__cta--link">
            Book descent
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <aside class="clh__signpost" aria-label="50 metres from the bus and train stations of Arriondas">
        <header class="clh__sigHead">
          <span class="clh__sigKicker">— No car · no problem</span>
          <h2 class="clh__sigT"><span class="clh__sigBig">50&nbsp;m</span><br/><span class="serif-italic">from the stations</span></h2>
          <p class="clh__sigLead">
            Our shop is <strong>50 metres on foot</strong> from both the <strong>bus station</strong>
            and the <strong>train station</strong> of Arriondas. Door-to-door arrival from Oviedo, Gijón or Llanes.
          </p>
        </header>
        <ul class="clh__sigList">
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><circle cx="8.5" cy="15" r="1" fill="currentColor"/><circle cx="15.5" cy="15" r="1" fill="currentColor"/><path d="M7 19l-2 2"/><path d="M17 19l2 2"/></svg>
              <span>Bus station · ALSA</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 12h18"/><path d="M7 19l-2 3"/><path d="M17 19l2 3"/><circle cx="8" cy="16" r="1" fill="currentColor"/><circle cx="16" cy="16" r="1" fill="currentColor"/></svg>
              <span>Train station · Renfe AM</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="7" rx="1"/><path d="M5 11l2-5h10l2 5"/><circle cx="7.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg>
              <span>Own parking · 300 spaces</span>
            </span>
            <span class="clh__sigKm"><strong>0</strong><small> m</small></span>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ============== 2 · Distancias cards (grid 5) ============== -->
  <section class="cld">
    <div class="container container--xl">
      <header class="cld__header" data-reveal>
        <span class="cld__eyebrow">— Distance by car</span>
        <h2 class="cld__title">
          From the main<br/>
          <span class="serif-italic">northern cities.</span>
        </h2>
        <p class="cld__lead">
          Km, estimated time and main routes from the most common origins of our
          customers. Without heavy traffic and respecting limits, of course.
        </p>
      </header>

      <ol class="cld__grid">
        {ciudades.map((c, i) => (
          <li class="cld__item" data-reveal data-reveal-delay={(i % 3) + 1}>
            <a
              class="cld__link"
              href={`https://www.google.com/maps/dir/${encodeURIComponent(c.c + ', Spain')}/Aventura+en+el+Sella/@43.3874223,-5.1866022,9z/data=!4m13!4m12!1m5!1m1!1s0x0:0x0!2m2!1d${c.lng}!2d${c.lat}!1m5!1m1!1s0xd36195b04532889:0x9b2face87069ecfc!2m2!1d-5.1866022!2d43.3874223!3e0`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Open Google Maps with car route from ${c.c} to Aventura en el Sella in Arriondas`}
            >
            <span class="cld__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="cld__city">{c.c}</span>
            <div class="cld__stats">
              <div class="cld__stat">
                <strong>{c.km}<small>km</small></strong>
                <span>distance</span>
              </div>
              <div class="cld__stat">
                <strong>{c.tiempo}</strong>
                <span>by car</span>
              </div>
            </div>
            <p class="cld__route">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {c.ruta}
            </p>
            <span class="cld__open" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              View route on Google Maps
            </span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 3 · TABS 3 MEDIOS (Coche / Bus / Tren) ============== -->
  <section id="clh-medios" class="clt" aria-labelledby="clt-title">
    <div class="container container--xl">
      <header class="clt__head" data-reveal>
        <div class="clt__headL">
          <span class="clt__kicker">— Transport options</span>
          <h2 id="clt-title" class="clt__title">
            Choose your<br/>
            <span class="serif-italic">way to arrive.</span>
          </h2>
        </div>
        <div class="clt__tabs" role="tablist" aria-label="Choose transport option">
          {medios.map((m, i) => (
            <button type="button" role="tab" id={`clt-tab-${m.id}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`clt-panel-${m.id}`}
                    class={`clt__tab${i === 0 ? ' is-active' : ''}`}
                    data-tab={m.id} tabindex={i === 0 ? 0 : -1}>
              {m.tab}
            </button>
          ))}
        </div>
      </header>

      <div class="clt__card" data-reveal data-reveal-delay="1">
        {medios.map((m, i) => (
          <div class={`clt__panel${i === 0 ? ' is-active' : ''}`}
               id={`clt-panel-${m.id}`} role="tabpanel"
               aria-labelledby={`clt-tab-${m.id}`} data-panel={m.id} hidden={i !== 0}>
            <div class="clt__content">
              <span class={`clt__eyebrow clt__eyebrow--${m.id}`}>{m.eyebrow}</span>
              <h3 class="clt__route">{m.route}</h3>
              <div class="clt__stats">
                {m.stats.map(s => (
                  <div class="clt__stat">
                    <strong>{s.v}<small>{s.u}</small></strong>
                    <span>{s.l}</span>
                  </div>
                ))}
              </div>
              <p class="clt__desc" set:html={m.desc} />
              <ul class="clt__features">{m.features.map(f => <li>{f}</li>)}</ul>
              <a href={getLocalePath('reservar', lang)} class="clt__cta">
                Book descent
                <span class="clt__ctaIcon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            </div>
            <div class="clt__photo">
              <Picture src={m.photo} alt={`How to get to Arriondas ${m.tab.toLowerCase()}`} sizes="(min-width: 960px) 45vw, 100vw" bare />
              <div class="clt__badges" aria-hidden="true">
                {m.badges.map(b => <span class="clt__badge">{b}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 3b · ESTAMOS AQUÍ · Mapa Google Maps + card dirección ============== -->
  <section id="estamos-aqui" class="clmap" aria-labelledby="clmap-title">
    <div class="container container--xl">
      <header class="clmap__header" data-reveal>
        <span class="clmap__eyebrow">— We're here</span>
        <h2 id="clmap-title" class="clmap__title">
