  .cdt__tabKm {
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 500;
    opacity: 0.7;
  }
  .cdt__tab.is-active .cdt__tabKm { opacity: 0.85; }
  .cdt__tab:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }

  /* Card panel container */
  .cdt__card {
    position: relative;
    max-width: 1200px; margin: 0 auto;
    background: #fff;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
    box-shadow: 0 30px 60px rgba(26, 31, 46, 0.08);
    overflow: hidden;
  }

  /* Panel — crossfade + subtle translate */
  .cdt__panel {
    display: grid; grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 900px) { .cdt__panel { grid-template-columns: 1.1fr 1fr; } }
  .cdt__panel[hidden] { display: none; }
  .cdt__panel.is-active { animation: cdtPanelIn 500ms cubic-bezier(0.22, 1, 0.36, 1); }
  @keyframes cdtPanelIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cdt__content {
    padding: clamp(2rem, 4vw, 3.25rem);
    display: flex; flex-direction: column; align-items: flex-start;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .cdt__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
  }
  .cdt__eyebrow--coral { color: var(--color-primary); }

  .cdt__route {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900; line-height: 0.98;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }
  .cdt__arrow {
    display: inline-block;
    color: var(--color-primary);
    font-family: var(--font-serif); font-style: italic;
    margin: 0 0.2em;
    font-weight: 400;
  }

  .cdt__stats {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;
    width: 100%;
    padding: 1rem 0 0.5rem;
    border-top: 1px solid rgba(26, 31, 46, 0.08);
    border-bottom: 1px solid rgba(26, 31, 46, 0.08);
  }
  .cdt__stat {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 0.75rem 0.5rem 0.75rem 0;
  }
  .cdt__stat strong {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.2vw, 2.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    display: flex; align-items: baseline; gap: 0.15em;
    white-space: nowrap;
  }
  .cdt__stat strong small {
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .cdt__stat span:last-child {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cdt__desc {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cdt__desc strong { color: var(--color-text-primary); font-weight: 700; }

  .cdt__features {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;
    width: 100%;
  }
  @media (min-width: 500px) { .cdt__features { grid-template-columns: repeat(3, 1fr); } }
  .cdt__features li {
    padding: 0.55rem 0.9rem;
    background: rgba(61, 79, 58, 0.06);
    border: 1px solid rgba(61, 79, 58, 0.15);
    border-radius: 8px;
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.2px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background 200ms ease, border-color 200ms ease, transform 200ms ease;
  }
  .cdt__features li:hover {
    background: rgba(61, 79, 58, 0.12);
    border-color: rgba(61, 79, 58, 0.3);
    transform: translateY(-2px);
  }
  /* Stagger de entrada cuando el panel se activa */
  .cdt__panel.is-active .cdt__features li {
    animation: cdtFeatureIn 500ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .cdt__panel.is-active .cdt__features li:nth-child(1) { animation-delay: 180ms; }
  .cdt__panel.is-active .cdt__features li:nth-child(2) { animation-delay: 240ms; }
  .cdt__panel.is-active .cdt__features li:nth-child(3) { animation-delay: 300ms; }
  .cdt__panel.is-active .cdt__features li:nth-child(4) { animation-delay: 360ms; }
  .cdt__panel.is-active .cdt__features li:nth-child(5) { animation-delay: 420ms; }
  .cdt__panel.is-active .cdt__features li:nth-child(6) { animation-delay: 480ms; }
  @keyframes cdtFeatureIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cdt__cta {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #FBF8F1;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.2px; text-transform: uppercase;
    margin-top: 0.5rem;
    transition: all 240ms cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 10px 24px rgba(26, 31, 46, 0.2);
  }
  .cdt__cta:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(26, 31, 46, 0.32); }
  .cdt__ctaIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: #FBF8F1; color: var(--color-text-primary, #1A1F2E);
    transition: transform 240ms ease;
  }
  .cdt__cta:hover .cdt__ctaIcon { transform: rotate(-12deg) translateX(2px); }

  /* Photo + vertical badges + slide-from-left + diagonal glass shine */
  .cdt__photo {
    position: relative;
    min-height: 360px;
    overflow: hidden;
    border-radius: clamp(0.5rem, 1.5vw, 1rem);
    isolation: isolate;
    /* Slide entry: empieza desplazada y oculta */
    transform: translateX(-80px);
    opacity: 0;
    transition:
      transform 1100ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 900ms ease-out,
      box-shadow 380ms ease;
  }
  /* Cuando el panel está activo, las fotos entran desde la izquierda */
  .cdt__panel.is-active .cdt__photo {
    transform: translateX(0);
    opacity: 1;
  }
  .cdt__photo:hover {
    box-shadow: 0 24px 56px -22px rgba(26, 31, 46, 0.28);
  }
  .cdt__photo :global(picture),
  .cdt__photo :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    position: absolute; inset: 0;
    transition: transform 1400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cdt__photo:hover :global(img) { transform: scale(1.05); }

  /* Reflejo glass diagonal en hover · estilo premium */
  .cdt__photo::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0) 40%,
      rgba(255, 255, 255, 0.4) 50%,
      rgba(255, 255, 255, 0) 60%,
      transparent 70%
    );
    transform: translateX(-110%);
    pointer-events: none;
    z-index: 2;
  }
  .cdt__photo:hover::after {
    animation: cdtGlass 1100ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes cdtGlass {
    0%   { transform: translateX(-110%); }
    100% { transform: translateX(110%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cdt__photo,
    .cdt__photo :global(img),
    .cdt__photo::after { transition: none !important; animation: none !important; }
    .cdt__photo:hover :global(img) { transform: none; }
    .cdt__photo:hover { box-shadow: none; }
  }
  .cdt__badges {
    position: absolute;
    top: clamp(1rem, 2vw, 1.5rem);
    left: clamp(1rem, 2vw, 1.5rem);
    display: flex; flex-direction: column; gap: 0.5rem;
    z-index: 1;
  }
  .cdt__badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    background: rgba(26, 31, 46, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #FBF8F1;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.4px; text-transform: uppercase;
    transition: background 200ms ease, transform 200ms ease;
  }
  .cdt__badge svg { opacity: 0.85; flex-shrink: 0; }
  .cdt__badge:hover { background: var(--color-primary); transform: translateX(3px); }
  /* Stagger entrada badges cuando panel activo */
  .cdt__panel.is-active .cdt__badge {
    animation: cdtBadgeIn 500ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .cdt__panel.is-active .cdt__badge:nth-child(1) { animation-delay: 240ms; }
  .cdt__panel.is-active .cdt__badge:nth-child(2) { animation-delay: 340ms; }
  .cdt__panel.is-active .cdt__badge:nth-child(3) { animation-delay: 440ms; }
  @keyframes cdtBadgeIn {
    from { opacity: 0; transform: translateX(-14px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Stats con count-up sutil via scale pop */
  .cdt__panel.is-active .cdt__stat {
    animation: cdtStatIn 600ms cubic-bezier(0.34, 1.25, 0.64, 1) both;
  }
  .cdt__panel.is-active .cdt__stat:nth-child(1) { animation-delay: 120ms; }
  .cdt__panel.is-active .cdt__stat:nth-child(2) { animation-delay: 200ms; }
  .cdt__panel.is-active .cdt__stat:nth-child(3) { animation-delay: 280ms; }
  @keyframes cdtStatIn {
    from { opacity: 0; transform: scale(0.88); }
    to   { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 899.98px) {
    .cdt__photo { min-height: 280px; aspect-ratio: 4 / 3; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cdt__panel.is-active { animation: none; }
    .cdt__cta:hover { transform: none; }
  }

  /* ============== SEGURIDAD ============== */
  .cns { padding-block: clamp(5rem, 9vw, 7rem); background: var(--color-bg-base); }
  .cns__header {
    max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center;
  }
  .cns__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cns__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cns__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cns__lead {
    font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 auto;
    max-width: 640px;
  }
  .cns__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Grid 3×2 con número watermark sage muy tenue detrás del contenido */
  .cns__grid {
    list-style: none; padding: 0; margin: 0 auto clamp(3rem, 5vw, 4rem);
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.5rem);
    max-width: 1200px;
  }
  @media (min-width: 720px)  { .cns__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cns__grid { grid-template-columns: repeat(3, 1fr); } }

  .cns__item {
    position: relative;
    padding: clamp(3rem, 5vw, 4rem) clamp(1.25rem, 2.5vw, 1.75rem) clamp(1.25rem, 2.5vw, 1.75rem);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    transition: background 320ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cns__item:hover {
    background: rgba(233, 133, 111, 0.04);
    transform: translateY(-2px);
  }

  /* Trace animado del perímetro · coral · esquinas redondeadas como toda la web */
  .cns__trace {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    overflow: visible;
  }
  .cns__trace rect {
    /* CSS sizing del rect interno (soporte SVG2 en navegadores modernos) */
    x: 0.75px;
    y: 0.75px;
    width: calc(100% - 1.5px);
    height: calc(100% - 1.5px);
    rx: clamp(1rem, 2vw, 1.5rem);
    ry: clamp(1rem, 2vw, 1.5rem);
    fill: none;
    stroke: var(--color-primary, #E9856F);
    stroke-width: 1.5;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 760ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cns__item:hover .cns__trace rect {
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .cns__item, .cns__item:hover { transition: none; transform: none; }
    .cns__trace rect { transition: none; }
  }

  .cns__num {
    position: absolute;
    top: 0.6rem;
    left: 0.5rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 8vw, 7.5rem);
    line-height: 0.85;
    color: rgba(61, 79, 58, 0.12);
    letter-spacing: -0.04em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    transition: color 420ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 520ms cubic-bezier(0.34, 1.25, 0.64, 1);
  }
  .cns__item:hover .cns__num {
    color: rgba(61, 79, 58, 0.24);
    transform: translate(-4px, -6px) scale(1.04);
  }

  .cns__itemTitle {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 0.875rem;
  }
  .cns__itemText {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cns__itemText strong { color: var(--color-text-primary); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .cns__item,
    .cns__trace rect,
    .cns__num { transition: none; }
    .cns__item:hover .cns__num { transform: none; }
  }

  /* CTA oscuro con pill pattern (como el mock de referencia) */
  .cns__cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }
  .cns__ctaBtn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0.5rem 0.5rem 1.75rem;
    background: var(--color-text-primary, #1A1F2E);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 1.6px; text-transform: uppercase;
    transition: transform 260ms cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 260ms ease;
  }
  .cns__ctaBtn:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(26, 31, 46, 0.35);
  }
  .cns__ctaBtnIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #fff;
    color: var(--color-text-primary, #1A1F2E);
    transition: transform 260ms ease;
  }
  .cns__ctaBtn:hover .cns__ctaBtnIcon { transform: rotate(-12deg); }

  /* ============== COMPARATIVA · Barras horizontales editorial ============== */
  .cdc {
    padding-block: clamp(4rem, 8vw, 6rem);
    background:
      radial-gradient(ellipse 70% 55% at 100% 0%, rgba(244, 181, 163, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 0% 100%, rgba(61, 79, 58, 0.05) 0%, transparent 60%),
      var(--color-bg-warm, #F5F1E8);
    position: relative;
  }
  .cdc__header { max-width: 760px; margin: 0 auto clamp(3rem, 5vw, 4rem); text-align: center; }
  .cdc__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .cdc__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cdc__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cdc__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary); margin: 0;
  }
  .cdc__lead strong { color: var(--color-text-primary); font-weight: 700; }

  .cdc__bars {
    max-width: 960px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 1.5rem;
  }
  .cdc__bar { display: flex; flex-direction: column; gap: 0.625rem; }
  .cdc__barTop {
    display: flex; flex-direction: column; align-items: flex-start; gap: 0.125rem;
    font-family: var(--font-sans);
  }
  @media (min-width: 560px) {
    .cdc__barTop { flex-direction: row; justify-content: space-between; align-items: baseline; gap: 1rem; }
  }
  .cdc__barName { font-weight: 800; font-size: 1.0625rem; color: var(--color-text-primary); }
  .cdc__barTime { font-size: 0.8125rem; color: var(--color-text-muted); letter-spacing: 0.3px; }

  .cdc__track {
    background: rgba(26, 31, 46, 0.07);
    border-radius: 999px;
    height: 44px;
    overflow: hidden;
    position: relative;
  }
  .cdc__fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    display: flex; align-items: center; justify-content: flex-end;
    padding-right: 1.25rem;
    transition: width 1500ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: width;
  }
  .cdc__bars.is-visible .cdc__fill--mini { width: 50%;  transition-delay: 150ms; }
  .cdc__bars.is-visible .cdc__fill--comp { width: 100%; transition-delay: 450ms; }
  .cdc__fill--mini { background: linear-gradient(90deg, #4A5E47, #3D4F3A); }
  .cdc__fill--comp { background: linear-gradient(90deg, #F4B5A3, var(--color-primary)); }
  .cdc__fillLabel {
    font-family: var(--font-serif); font-style: italic;
    font-size: 1.0625rem; color: #FBF8F1; letter-spacing: 0.3px;
    opacity: 0;
    transition: opacity 500ms ease;
  }
  .cdc__bars.is-visible .cdc__fill--mini .cdc__fillLabel { opacity: 1; transition-delay: 1400ms; }
  .cdc__bars.is-visible .cdc__fill--comp .cdc__fillLabel { opacity: 1; transition-delay: 1800ms; }

  .cdc__axis {
    display: flex; justify-content: space-between;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.5rem 0 0;
    border-top: 1px dashed rgba(26, 31, 46, 0.2);
    margin-top: 0.5rem;
  }
  .cdc__foot {
    text-align: center; max-width: 640px; margin: 2rem auto 0;
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    color: var(--color-text-secondary);
  }
  .cdc__foot strong { color: var(--color-text-primary); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .cdc__fill { transition: none; }
    .cdc__fill--mini { width: 50%; }
    .cdc__fill--comp { width: 100%; }
    .cdc__fillLabel { opacity: 1; transition: none; }
  }

  /* ============== QUÉ LLEVAR ============== */
  .cnq {
    padding-block: clamp(5rem, 9vw, 7rem);
    /* bg-base · diferente del bg-warm de la sección anterior (cdc) */
    background: var(--color-bg-base, #FBF8F1);
    position: relative;
  }
  /* Hairline sutil sage entre cdc y cnq · marca el cambio de sección */
  .cnq::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(61, 79, 58, 0.18) 50%, transparent 100%);
  }
  .cnq__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .cnq__eyebrow,
  .cnf__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnq__title,
  .cnf__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cnq__title .serif-italic,
  .cnf__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cnq__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary); margin: 0;
  }
  .cnq__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* ==============================================================
     Consejos · 2 columnas editoriales · sin cards · sin flechas
     Hairlines top + kicker coral italic + display + body amplio
     Distinto visualmente de los factores (.cns) que ya son numerados
     ============================================================== */
  .cnqL {
    list-style: none;
    padding: 0;
    margin: clamp(3rem, 5vw, 4rem) auto 0;
    max-width: 1080px;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 800px) {
    .cnqL {
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(3rem, 5vw, 5rem);
      row-gap: clamp(2.5rem, 4.5vw, 3.75rem);
    }
  }

  .cnqItem {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid rgba(26, 31, 46, 0.12);
    transition: border-color 320ms ease;
  }
  .cnqItem:hover {
    border-top-color: var(--color-primary, #E9856F);
  }

  /* Kicker · coral italic 01 + uppercase "Consejo" */
  .cnqItem__kicker {
    display: inline-flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.125rem;
  }
  .cnqItem__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--color-primary, #E9856F);
  }
  .cnqItem__label {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    align-self: center;
  }

  .cnqItem__t {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.7vw, 1.375rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .cnqItem__s {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.05vw, 1.0625rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 50ch;
  }
  .cnqItem__s strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .cnqItem__s a {
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(61, 79, 58, 0.35);
    transition: color 200ms ease, border-color 200ms ease;
  }
  .cnqItem__s a:hover {
    color: var(--color-primary, #E9856F);
    border-bottom-color: var(--color-primary, #E9856F);
  }

  @media (prefers-reduced-motion: reduce) {
    .cnqItem { transition: none; }
  }
  .cnq__note {
    max-width: 860px; margin: 0 auto;
    display: flex; align-items: flex-start; gap: var(--s-2);
    padding: var(--s-3) var(--s-4);
    background: rgba(61, 79, 58, 0.06);
    border-left: 2px solid var(--color-sage, #3D4F3A);
    border-radius: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; line-height: 1.6;
    color: var(--color-text-secondary);
  }
  .cnq__note svg { color: var(--color-sage, #3D4F3A); flex-shrink: 0; margin-top: 3px; }
  .cnq__note strong { color: var(--color-text-primary); font-weight: 700; }

  /* ============== INTERLINKING · Photo + cards expandibles (image 30) ============== */
  .cdx {
    padding-block: clamp(4rem, 8vw, 6rem);
    background: linear-gradient(180deg, #1A1F2E 0%, #243040 100%);
    color: #FBF8F1;
    overflow: hidden;
  }
  .cdx__header {
    max-width: 900px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }
  .cdx__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    margin-bottom: 1rem;
  }
  .cdx__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.02em; text-transform: uppercase;
    color: #FBF8F1;
    margin: 0 0 1.25rem;
  }
  .cdx__title .serif-italic {
    color: var(--color-primary-soft, #F4B5A3);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    text-transform: none; letter-spacing: -0.01em;
  }
  .cdx__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: rgba(251, 248, 241, 0.78);
    margin: 0;
  }
  .cdx__lead strong { color: #FBF8F1; font-weight: 700; }

  .cdx__grid {
    display: grid; grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    max-width: 1200px; margin: 0 auto;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .cdx__grid { grid-template-columns: 1fr 1.05fr; gap: clamp(2.5rem, 4vw, 3.5rem); }
  }

  /* Panel Reserva (reemplaza a la foto · mismo alto que cards derechas) */
  .cdx__reserva {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.4);
    align-self: stretch;
    min-height: 100%;
  }
  .cdx__reservaBg {
    position: absolute; inset: 0;
    overflow: hidden;
  }
  .cdx__reservaBg :global(picture),
  .cdx__reservaBg :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    transform-origin: 50% 60%;
    animation: cdxReservaKen 24s ease-in-out infinite alternate;
  }
  @keyframes cdxReservaKen {
    0%   { transform: scale(1.02); }
    100% { transform: scale(1.12) translate(-1%, 1%); }
  }
  .cdx__reservaScrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 20, 30, 0.65) 0%, rgba(15, 20, 30, 0.55) 35%, rgba(15, 20, 30, 0.9) 100%),
      radial-gradient(ellipse 60% 45% at 15% 80%, rgba(61, 79, 58, 0.4) 0%, transparent 70%);
  }
  .cdx__reservaInner {
    position: relative;
    height: 100%;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex; flex-direction: column; gap: clamp(1rem, 2vw, 1.25rem);
    justify-content: flex-start;
  }
  .cdx__reservaKicker {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.875rem 0.4rem 0.625rem;
    background: rgba(251, 248, 241, 0.1);
    border: 1px solid rgba(251, 248, 241, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--color-primary-soft, #F4B5A3);
    align-self: flex-start;
  }
  .cdx__reservaDot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--color-primary);
    animation: cdxResPulse 2.2s ease-in-out infinite;
  }
  @keyframes cdxResPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(233, 133, 111, 0.5); }
    50%      { box-shadow: 0 0 0 6px rgba(233, 133, 111, 0); }
  }
  .cdx__reservaT {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.125rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: #FBF8F1;
    margin: 0;
  }
  .cdx__reservaT .serif-italic {
    color: var(--color-primary-soft, #F4B5A3);
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    text-transform: none; letter-spacing: -0.01em;
  }
  .cdx__reservaS {
    font-family: var(--font-sans); font-size: 0.875rem; line-height: 1.65;
    color: rgba(251, 248, 241, 0.8);
    margin: 0 0 0.25rem;
  }
  .cdx__reservaS strong { color: #FBF8F1; font-weight: 700; }

  .cdx__channels {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.625rem;
    margin-top: auto;
  }
  .cdx__ch {
    display: grid;
    grid-template-columns: auto 1fr auto; gap: 0.875rem;
    align-items: center;
    padding: 0.875rem 1rem;
    background: rgba(251, 248, 241, 0.08);
    border: 1px solid rgba(251, 248, 241, 0.14);
    border-radius: 0.75rem;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: all 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cdx__ch:hover {
    background: rgba(251, 248, 241, 0.14);
    border-color: rgba(244, 181, 163, 0.5);
    transform: translateX(3px);
  }
  .cdx__chIcon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(251, 248, 241, 0.12);
    color: var(--color-primary-soft, #F4B5A3);
    transition: background 260ms ease, color 260ms ease;
    flex-shrink: 0;
  }
  .cdx__ch--wa .cdx__chIcon { color: #25D366; }
  .cdx__ch:hover .cdx__chIcon {
    background: var(--color-primary);
    color: #FBF8F1;
  }
  .cdx__ch--wa:hover .cdx__chIcon {
    background: #25D366;
    color: #FBF8F1;
  }
  .cdx__chBody { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .cdx__chLabel {
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 800;
    color: #FBF8F1;
    letter-spacing: 0.3px;
  }
  .cdx__chValue {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 600;
    color: rgba(251, 248, 241, 0.65);
    letter-spacing: 0.3px;
  }
  .cdx__chArrow {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    color: rgba(251, 248, 241, 0.5);
    transition: transform 260ms ease, color 260ms ease;
    flex-shrink: 0;
  }
  .cdx__ch:hover .cdx__chArrow {
    color: var(--color-primary-soft, #F4B5A3);
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cdx__reservaBg :global(img),
    .cdx__reservaBg :global(picture),
    .cdx__reservaDot { animation: none; }
    .cdx__ch:hover, .cdx__ch:hover .cdx__chArrow { transform: none; }
  }

  /* Stacked cards list */
  .cdx__list {
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .cdx__item {
    background: rgba(251, 248, 241, 0.05);
    border: 1px solid rgba(251, 248, 241, 0.12);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: background 300ms ease, border-color 300ms ease;
  }
  .cdx__item[open] {
    background: rgba(251, 248, 241, 0.09);
    border-color: rgba(244, 181, 163, 0.4);
  }
  .cdx__item:hover:not([open]) {
    background: rgba(251, 248, 241, 0.07);
    border-color: rgba(251, 248, 241, 0.2);
  }

  /* Summary (header del card) */
  .cdx__sum {
    list-style: none;
    display: grid; grid-template-columns: 1fr auto; gap: 1rem;
    align-items: center;
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    position: relative;
    transition: padding 300ms ease;
  }
  .cdx__sum::-webkit-details-marker { display: none; }
  .cdx__item[open] .cdx__sum { padding-bottom: 0.625rem; }

  .cdx__eyerow {
    display: flex; align-items: center; gap: 0.75rem;
    grid-row: 1; grid-column: 1;
    margin-bottom: 0.375rem;
  }
  .cdx__num {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.875rem; color: var(--color-primary-soft, #F4B5A3);
    letter-spacing: 0.02em;
  }
  .cdx__smallE {
    font-family: var(--font-sans); font-size: 0.625rem; font-weight: 800;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(251, 248, 241, 0.55);
  }
  .cdx__t {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    font-weight: 800; line-height: 1.2; letter-spacing: -0.005em;
    color: #FBF8F1;
    margin: 0;
    grid-row: 2; grid-column: 1;
  }

  /* Chevron (flecha circular sage/coral en summary) */
  .cdx__chev {
    grid-row: 1 / span 2; grid-column: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    background: var(--color-primary);
    color: #FBF8F1;
    border-radius: 50%;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
                background-color 300ms ease;
    flex-shrink: 0;
  }
  .cdx__item[open] .cdx__chev {
    transform: rotate(90deg);
    background: var(--color-primary-soft, #F4B5A3);
    color: var(--color-text-primary, #1A1F2E);
  }
  .cdx__item:hover .cdx__chev {
    transform: translateX(3px);
  }
  .cdx__item[open]:hover .cdx__chev {
    transform: rotate(90deg) translateX(0);
  }

  /* Body expandible — animación CSS */
  .cdx__body {
    padding: 0 1.25rem 1.25rem;
    display: grid; grid-template-rows: 1fr;
    animation: cdxBodyIn 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes cdxBodyIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .cdx__body p {
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.65;
    color: rgba(251, 248, 241, 0.8);
    margin: 0.375rem 0 1rem;
  }
  .cdx__body p strong { color: #FBF8F1; font-weight: 700; }
  .cdx__link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--color-primary-soft, #F4B5A3);
    border-bottom: 1px solid rgba(244, 181, 163, 0.4);
    padding-bottom: 2px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .cdx__link:hover {
    color: #FBF8F1;
    border-color: #FBF8F1;
  }
  .cdx__link svg { transition: transform 200ms ease; }
  .cdx__link:hover svg { transform: translateX(3px); }

  @media (prefers-reduced-motion: reduce) {
    .cdx__body { animation: none; }
    .cdx__chev { transition: background-color 200ms ease; }
    .cdx__item[open] .cdx__chev { transform: rotate(90deg); }
    .cdx__item:hover .cdx__chev { transform: none; }
    .cdx__item[open]:hover .cdx__chev { transform: rotate(90deg); }
  }

  /* ============== FAQ ============== */
  .cnf { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-base); }
  .cnf__grid {
    display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 5vw, 4rem);
    max-width: 1200px; margin: 0 auto;
  }
  @media (min-width: 960px) { .cnf__grid { grid-template-columns: 1fr 1.3fr; } }

  .cnf__aside { position: sticky; top: 6rem; align-self: start; }
  @media (max-width: 959.98px) { .cnf__aside { position: static; } }

  .cnf__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnf__lead strong { color: var(--color-text-primary); font-weight: 700; }
  .cnf__lead a {
    color: var(--color-sage, #3D4F3A);
    font-weight: 600;
    border-bottom: 1px dashed var(--color-sage, #3D4F3A);
  }

  .cnf__list { display: flex; flex-direction: column; gap: var(--s-2); }

  .cnfI {
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: border-color 240ms;
  }
  .cnfI[open] { border-color: rgba(61, 79, 58, 0.35); }

  .cnfI__q {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: var(--s-3);
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 700;
    line-height: 1.4;
    color: var(--color-text-primary);
    list-style: none;
  }
  .cnfI__q::-webkit-details-marker { display: none; }
  .cnfI__chev {
    flex-shrink: 0; margin-top: 2px;
    color: var(--color-sage, #3D4F3A);
    transition: transform 240ms;
  }
  .cnfI[open] .cnfI__chev { transform: rotate(180deg); }

  .cnfI__a {
    padding: 0 1.25rem 1.25rem;
    font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnfI__a strong { color: var(--color-text-primary); font-weight: 700; }
  .cnfI__a a {
    color: var(--color-sage, #3D4F3A); font-weight: 600;
    border-bottom: 1px dashed var(--color-sage, #3D4F3A);
  }

  /* ============== CTA FINAL ============== */
  .cncta {
    position: relative;
    isolation: isolate;
    min-height: clamp(480px, 60vh, 620px);
    display: flex; align-items: center;
    overflow: hidden;
    color: #fff;
  }
  .cncta__bg {
    position: absolute; inset: 0; z-index: 0;
  }
  .cncta__bg :global(picture),
  .cncta__bg :global(img) {
    display: block; width: 100%; height: 100%; object-fit: cover;
    object-position: center;
  }
