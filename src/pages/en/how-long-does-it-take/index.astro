    max-width: 1200px; margin: 0 auto clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 820px) {
    .cdt__head { flex-direction: row; align-items: flex-end; gap: 2rem; }
  }
  .cdt__headL { min-width: 0; }
  .cdt__kicker {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 0.875rem;
  }
  .cdt__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
