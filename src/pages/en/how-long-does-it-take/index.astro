---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const lang = 'en';
const title = 'How long does the Sella River descent take? Times per route';
const description = 'How long the Sella River descent takes: 2-3 h Mini Sella (7 km), 4-5 h Full route (14.5 km). Factors, tips and booking without paying now — pets free.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/how-long-does-it-take/`;

// 5 factors that affect the duration
const factores = [
  { num: '01', title: 'The route you choose',     text: 'The <strong>Mini Sella</strong> (7 km) does not take the same time as the <strong>Full route</strong> (14.5 km). It is the most important difference in total duration.' },
  { num: '02', title: 'Your paddling pace',       text: 'Some groups paddle continuously and others go down very calmly. <strong>The more leisurely the pace, the longer the duration</strong>.' },
  { num: '03', title: 'The stops along the way',  text: 'Many people take time to stop, swim, rest or eat the picnic. It is one of the best parts — but it adds up to the total time.' },
  { num: '04', title: 'The flow and the day',     text: 'The <strong>river flow</strong>, the current and the peak season crowd can make the descent slightly faster or slightly slower.' },
  { num: '05', title: 'If you go with kids',      text: 'With small kids the <strong>pace is more relaxed</strong> and stops are more frequent. Total time is more flexible and adapts to them.' },
];

// 6 practical tips
const consejos = [
  { t: 'Book in advance',              s: 'Especially in peak season. Choose the departure that fits your day. <strong>Without paying now</strong> — pay by card before or on arrival.' },
  { t: 'Plan with a margin',           s: 'Add at least <strong>1 extra hour</strong> to the route time: reception, changing rooms, return transfer and stops add up to the total.' },
  { t: 'Open hours · 10:30–12:30',     s: 'As your booking is <strong>Premium</strong>, hours are open: you arrive at our facilities <strong>whenever it suits you between 10:30 and 12:30</strong>, without choosing a specific time. The Confederación Hidrográfica establishes that staying on the river is <strong>until 18:00</strong> · that is why we close arrivals at 12:30 (safe margin).' },
  { t: 'With kids, more flexibility',  s: 'Little ones may want to stop more, and that is part of the plan. If you go with kids, <strong>plan more margin</strong> and a leisurely pace.' },
  { t: 'Bring water and a snack',      s: 'The <strong>Asturian picnic</strong> is included in the booking. For intermediate stops, something extra always helps — especially in summer.' },
  { t: 'No rush',                      s: 'The descent is not a competition. Enjoying it at your own pace — stopping, swimming, observing — is part of its charm.' },
];

// Real questions (accordion)
const faqs = [
  { q: 'How long does the full Sella River descent take?',
    a: 'Normally between <strong>4 and 5 hours</strong>, with a 14.5 km route from Arriondas to Fríes. Time can vary according to the stops you make, the river flow and the group pace. If you paddle leisurely and stop to swim or eat, it gets close to 5 hours.' },
  { q: 'How long does the Mini Sella take?',
    a: 'The <strong>Mini Sella</strong> (Arriondas → Toraño, <strong>7 km</strong>) usually takes between <strong>2 and 3 hours</strong>. It is the ideal option if you have half a day, are going with small kids or want to combine the descent with other plans in Arriondas or Ribadesella.' },
  { q: 'How long does it take with kids?',
    a: 'With kids, the usual is that the <strong>pace is more leisurely and stops are more frequent</strong>. Many families choose the Mini Sella (2-3 h) so the little one enjoys without getting tired. If you do the Full route with kids, count more towards 5 h than 4. You can <a href="/en/with-kids/">read our complete guide to the descent with kids</a>.' },
  { q: 'Do you have to do it in one go?',
    a: 'No. One of the best things about the Sella River descent is that <strong>you can stop whenever you want</strong>: there are calm river beaches along the river where you can swim, rest or eat the picnic. You set the pace, there is no schedule on the water.' },
  { q: 'Does the duration change if it rains?',
    a: 'With light rain the activity is done the same and time hardly changes. If the <strong>flow rises a lot</strong>, the descent can be slightly faster (more current); if it is very low, slightly slower. We only suspend for objective safety reasons (strong flood or thunderstorm), in which case we offer <strong>free date change or full refund</strong>. If you pay in advance and need to cancel, you can do so <strong>up to 24 h before</strong> at no cost.' },
  { q: 'What is the most common average duration?',
    a: 'The most common reference for <strong>how long the Sella River descent takes</strong> is <strong>between 3 and 5 hours</strong>. Talking about the full route, the normal is around 4-4.5 h. In Mini Sella, around 2.5 h. They are guideline figures — each group goes at its own pace.' },
  { q: 'Can you choose the distance?',
    a: 'Yes. You have <strong>two routes</strong>: the <strong>Mini Sella</strong> (7 km, 2-3 h) and the <strong>Full route</strong> (14.5 km, 4-5 h). Also, if you choose the Full route and decide in the water to finish earlier, you can do it at <strong>Toraño</strong> (km 7) at no extra cost — just notify our team when you arrive there.' },
  { q: 'Does the Sella River descent last all day?',
    a: 'Not necessarily. The <strong>Mini Sella</strong> is done in half a day and leaves the afternoon free. The <strong>Full route</strong> occupies most of the day if you include stops, picnic and return transfer. Add at least <strong>1 extra hour</strong> to the route time for reception, equipment and return — that way you calculate realistically.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'How long does the Sella River descent take? Times per route',
      description: 'Complete guide on how long the Sella River descent takes: Mini Sella (7 km, 2-3 h), Full route (14.5 km, 4-5 h), factors that affect, recommendations and FAQ.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/sella-atardecer-lg.jpg`,
        width: 1920,
        height: 1280,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified: '2026-05-12',
      about: 'Duration of the Sella River canoe descent, times per route',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      inLanguage: 'en-GB',
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',                  item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'How long does it take', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/how-long-does-it-take/" translationKey="cuanto_dura">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Foto full-bleed con Ken Burns + overlay editorial ============== -->
  <section class="cdh" aria-labelledby="cdh-title">

    <div class="cdh__photo" aria-hidden="true">
      <Picture src="cuanto-dura-hero" alt="" sizes="100vw" bare />
    </div>
    <div class="cdh__scrim" aria-hidden="true"></div>
    <div class="cdh__grain" aria-hidden="true"></div>

    <div class="cdh__inner">
      <nav class="cdh__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">How long does it take</span>
      </nav>

      <span class="cdh__eyebrow">
        <span class="cdh__eyebrowDot" aria-hidden="true"></span>
        Descent duration
      </span>

      <h1 id="cdh-title" class="cdh__title">
        How long does<br/>
        <span class="serif-italic">the Sella take?</span>
      </h1>

      <p class="cdh__lead">
        Between <strong>3 and 5 hours</strong>, depending on the route you choose. Here
        is the clear guide to plan your day realistically.
      </p>

      <div class="cdh__ctas">
        <a href="/en/prices/" class="cdh__cta cdh__cta--primary">See prices</a>
        <a href="/en/book/" class="cdh__cta cdh__cta--link">
          Book now
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== TABS · Elige tu recorrido (Mini / Completo) ============== -->
  <section class="cdt" aria-labelledby="cdt-title">
    <div class="container container--xl">
      <header class="cdt__head" data-reveal>
        <div class="cdt__headL">
          <span class="cdt__kicker">— Available routes</span>
          <h2 id="cdt-title" class="cdt__title">
            Which one fits you?<br/>
            <span class="serif-italic">Choose your route.</span>
          </h2>
        </div>
        <div class="cdt__tabs" role="tablist" aria-label="Choose between Mini Sella or Full route">
          <button
            type="button"
            role="tab"
            id="cdt-tab-mini"
            aria-selected="true"
            aria-controls="cdt-panel-mini"
            class="cdt__tab is-active"
            data-tab="mini"
          >
            Mini Sella
            <span class="cdt__tabKm" aria-hidden="true">· 7 km</span>
          </button>
          <button
            type="button"
            role="tab"
            id="cdt-tab-comp"
            aria-selected="false"
            aria-controls="cdt-panel-comp"
            class="cdt__tab"
            data-tab="comp"
            tabindex="-1"
          >
            Full route
            <span class="cdt__tabKm" aria-hidden="true">· 14.5 km</span>
          </button>
        </div>
      </header>

      <div class="cdt__card" data-reveal data-reveal-delay="1">
        <!-- Panel MINI -->
        <div
          class="cdt__panel is-active"
          id="cdt-panel-mini"
          role="tabpanel"
          aria-labelledby="cdt-tab-mini"
          data-panel="mini"
        >
          <div class="cdt__content">
            <span class="cdt__eyebrow">Mini Sella</span>
            <h3 class="cdt__route">
              Arriondas
              <span class="cdt__arrow" aria-hidden="true">→</span>
              Toraño
            </h3>
            <div class="cdt__stats">
              <div class="cdt__stat">
                <strong>7<small>km</small></strong>
                <span>distance</span>
              </div>
              <div class="cdt__stat">
                <strong>2 – 3<small>h</small></strong>
                <span>duration</span>
              </div>
              <div class="cdt__stat">
                <strong>Half<small>day</small></strong>
                <span>day plan</span>
              </div>
            </div>
            <p class="cdt__desc">
              The <strong>short section of the Sella River descent</strong>, ideal for families with
              small kids, first time in a canoe or if you want to combine the day with other
              plans in Arriondas or Ribadesella. No technical difficulty, with
              <strong>river beaches</strong> and picnic areas to stop and
              eat the picnic at your own pace.
            </p>
            <ul class="cdt__features">
              <li>No technical rapids</li>
              <li>River beaches</li>
              <li>Kids 5+ welcome</li>
              <li>Dogs free</li>
              <li>Picnic included</li>
              <li>Transfer and parking</li>
            </ul>
            <a href="/en/book/" class="cdt__cta">
              Book the Mini Sella
              <span class="cdt__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </div>
          <div class="cdt__photo">
            <Picture src="cuanto-dura-mini" alt="Family doing the Mini Sella · Arriondas to Toraño section" sizes="(min-width: 960px) 45vw, 100vw" bare />
            <div class="cdt__badges" aria-hidden="true">
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
                Families
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c2-4 5-5 8-5s6 1 8 5"/></svg>
                Kids
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="1.5"/><circle cx="6" cy="7" r="1.5"/><circle cx="16" cy="7" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
                Pets
              </span>
            </div>
          </div>
        </div>

        <!-- Panel COMPLETO -->
        <div
          class="cdt__panel"
          id="cdt-panel-comp"
          role="tabpanel"
          aria-labelledby="cdt-tab-comp"
          data-panel="comp"
          hidden
        >
          <div class="cdt__content">
            <span class="cdt__eyebrow cdt__eyebrow--coral">Full route</span>
            <h3 class="cdt__route">
              Arriondas
              <span class="cdt__arrow" aria-hidden="true">→</span>
              Fríes
            </h3>
            <div class="cdt__stats">
              <div class="cdt__stat">
                <strong>14.5<small>km</small></strong>
                <span>distance</span>
              </div>
              <div class="cdt__stat">
                <strong>4 – 5<small>h</small></strong>
                <span>duration</span>
              </div>
              <div class="cdt__stat">
                <strong>Full<small>day</small></strong>
                <span>day plan</span>
              </div>
            </div>
            <p class="cdt__desc">
              The <strong>classic Sella River canoe descent route</strong>. More kilometres, more open landscape and a full day on the river with <strong>certified instructors</strong> at the start. Several <strong>river beaches and picnic areas</strong> along the route to stop, swim, rest and enjoy the Asturian picnic without rushing.
            </p>
            <ul class="cdt__features">
              <li>Classic full experience</li>
              <li>Open landscape</li>
              <li>Beaches and picnic areas</li>
              <li>Dogs free</li>
              <li>Picnic included</li>
              <li>Transfer and parking</li>
            </ul>
            <a href="/en/book/" class="cdt__cta">
              Book the Full route
              <span class="cdt__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </div>
          <div class="cdt__photo">
            <Picture src="cuanto-dura-completo" alt="Family and adults on the Full route of the Sella · Arriondas to Fríes" sizes="(min-width: 960px) 45vw, 100vw" bare />
            <div class="cdt__badges" aria-hidden="true">
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/></svg>
                Landscape
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12c2-4 4-4 6 0s4 4 6 0 4-4 6 0"/><path d="M3 18c2-4 4-4 6 0s4 4 6 0 4-4 6 0"/></svg>
                Long river
              </span>
              <span class="cdt__badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Full day
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============== 5 FACTORES · qué influye en la duración ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— What affects the time</span>
        <h2 class="cns__title">
          5 factors that change<br/>
          <span class="serif-italic">how long it takes</span>
        </h2>
        <p class="cns__lead">
          The <strong>Sella River descent time</strong> is not the same for everyone. These are the
          factors that make the same route last 3 h or almost 5 h depending on the group
          and how you want to live the experience.
        </p>
      </header>

      <ol class="cns__grid">
        {factores.map((f, i) => (
          <li class="cns__item" data-reveal data-reveal-delay={i + 1}>
            <svg class="cns__trace" aria-hidden="true">
              <rect pathLength="100" />
            </svg>
            <span class="cns__num" aria-hidden="true">{f.num}</span>
            <h3 class="cns__itemTitle">{f.title}</h3>
            <p class="cns__itemText" set:html={f.text} />
          </li>
        ))}
      </ol>

    </div>
  </section>

  <!-- ============== CTA INTERMEDIO · Quote + hairlines + pill sage (D) ============== -->
  <section class="cdm">
    <div class="container container--md">
      <div class="cdm__wrap" data-reveal>
        <p class="cdm__quote">
          We only work <em>by prior booking</em>. No rush:
          <strong>pay by card when you book, or on the day you pick up your canoe.</strong>
        </p>
        <div class="cdm__rule" aria-hidden="false">
          <span class="cdm__ruleLine" aria-hidden="true"></span>
          <a href="/en/book/" class="cdm__pill">
            <span class="cdm__pillDot" aria-hidden="true"></span>
            <span>Book my spot</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <span class="cdm__ruleLine" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== COMPARATIVA · Barras horizontales editorial ============== -->
  <section class="cdc">
    <div class="container container--xl">
      <header class="cdc__header" data-reveal>
        <span class="cdc__eyebrow">— Time compared</span>
        <h2 class="cdc__title">
          Visualise the<br/>
          <span class="serif-italic">time difference.</span>
        </h2>
        <p class="cdc__lead">
          Mini Sella versus Full route, <strong>side by side</strong>. So you see at a glance
          which route fits the hours you have available.
        </p>
      </header>

      <div class="cdc__bars" data-reveal>
        <div class="cdc__bar">
          <div class="cdc__barTop">
            <span class="cdc__barName">Mini Sella</span>
            <span class="cdc__barTime">2 – 3 h · 7 km · Arriondas → Toraño</span>
          </div>
          <div class="cdc__track">
            <div class="cdc__fill cdc__fill--mini">
              <span class="cdc__fillLabel">2 – 3 h</span>
            </div>
          </div>
        </div>
        <div class="cdc__bar">
          <div class="cdc__barTop">
            <span class="cdc__barName">Full route</span>
            <span class="cdc__barTime">4 – 5 h · 14.5 km · Arriondas → Fríes</span>
          </div>
          <div class="cdc__track">
            <div class="cdc__fill cdc__fill--comp">
              <span class="cdc__fillLabel">4 – 5 h</span>
            </div>
          </div>
        </div>
        <div class="cdc__axis" aria-hidden="true">
          <span>0h</span>
          <span>1h</span>
          <span>2h</span>
          <span>3h</span>
          <span>4h</span>
          <span>5h</span>
        </div>
      </div>

      <p class="cdc__foot" data-reveal data-reveal-delay="1">
        Includes <strong>paddling, stops and picnic</strong>. Add ~1 extra hour for reception, equipment and return transfer.
      </p>
    </div>
  </section>

  <!-- ============== QUÉ LLEVAR ============== -->
  <section class="cnq">
    <div class="container container--xl">
      <header class="cnq__header" data-reveal>
        <span class="cnq__eyebrow">— Plan realistically</span>
        <h2 class="cnq__title">
          Tips to calculate<br/>
          <span class="serif-italic">the time better</span>
        </h2>
        <p class="cnq__lead">
          If you are organising the day and want to forecast the duration realistically,
          these tips help you so <strong>you do not run short on hours</strong>.
        </p>
      </header>

      <ol class="cnqL" role="list">
        {consejos.map((c, i) => (
          <li class="cnqItem" data-reveal data-reveal-delay={(i % 2) + 1}>
            <span class="cnqItem__kicker">
              <span class="cnqItem__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="cnqItem__label">Tip</span>
            </span>
            <h3 class="cnqItem__t">{c.t}</h3>
            <p class="cnqItem__s" set:html={c.s} />
          </li>
        ))}
      </ol>

    </div>
  </section>


  <!-- ============== INTERLINKING · Photo + cards expandibles ============== -->
  <section class="cdx">
    <div class="container container--xl">
      <header class="cdx__header" data-reveal>
        <span class="cdx__eyebrow">— Before booking</span>
        <h2 class="cdx__title">
          Plan your<br/>
          <span class="serif-italic">Sella descent well.</span>
        </h2>
        <p class="cdx__lead">
          Before booking your canoe day, these are the pages that help you
          <strong>prepare the plan</strong>. Click each one to see the summary.
        </p>
      </header>

      <div class="cdx__grid">
        <!-- Panel RESERVA · 4 canales directos -->
        <aside class="cdx__reserva" data-reveal aria-labelledby="cdx-reserva-title">
          <div class="cdx__reservaBg" aria-hidden="true">
            <Picture src="rio-sella-hermoso" alt="" sizes="(min-width: 960px) 45vw, 100vw" bare />
            <div class="cdx__reservaScrim" aria-hidden="true"></div>
          </div>
          <div class="cdx__reservaInner">
            <span class="cdx__reservaKicker">
              <span class="cdx__reservaDot" aria-hidden="true"></span>
              Prior booking required
            </span>
            <h3 id="cdx-reserva-title" class="cdx__reservaT">
              Book your day<br/>
              <span class="serif-italic">your way.</span>
            </h3>
            <p class="cdx__reservaS">
              Any channel works — we reply in minutes. Pay by card when booking
              or <strong>on the day you pick up your canoe</strong>.
            </p>

            <ul class="cdx__channels">
              <li>
                <a href="tel:+34681093673" class="cdx__ch cdx__ch--phone">
                  <span class="cdx__chIcon" aria-hidden="true">
