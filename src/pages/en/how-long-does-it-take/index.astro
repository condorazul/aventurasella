    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }

  /* Tab switch */
  .cdt__tabs {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem;
    background: #fff;
    border: 1px solid rgba(26, 31, 46, 0.1);
    border-radius: 999px;
    box-shadow: 0 6px 16px rgba(26, 31, 46, 0.05);
    flex-wrap: wrap;
  }
  .cdt__tab {
    display: inline-flex; align-items: baseline; gap: 0.375rem;
    padding: 0.7rem 1.1rem;
    background: transparent;
    border: 0;
    border-radius: 999px;
    font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.3px;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 260ms cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
  }
  .cdt__tab:hover:not(.is-active) { color: var(--color-text-primary); }
  .cdt__tab.is-active {
    background: var(--color-text-primary, #1A1F2E);
    color: #FBF8F1;
    box-shadow: 0 6px 16px rgba(26, 31, 46, 0.25);
