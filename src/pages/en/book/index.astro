---
/**
 * /en/book/ · Official booking page · English
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const title = 'Book the Sella descent · Flexible change or cancellation · From €30';
const description = 'Book your Sella river canoe descent online from Arriondas. No payment now, flexible change or cancellation before the day, instant confirmation by WhatsApp and email. 4.5★ · 147 real reviews.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/book/`;

const tarifas = [
  {
    img: 'reservar-tarifa-adultos',
    imgAlt: 'Group of adults descending the Sella by canoe from Arriondas · adult rate of the descent',
    badge: 'Most booked',
    title: 'Adults',
    age: 'From 13 years',
    price: '40',
    note: 'Canoe, paddle, life jacket, Asturian picnic and transfer · all inclusive',
  },
  {
    img: 'precios-ninos',
    imgAlt: 'Children paddling on the Sella · children rate of the descent',
    badge: 'Children',
    title: 'Children',
    age: 'Up to 12 years',
    price: '30',
    note: 'Minimum age 5 years · 1.15 m tall',
  },
  {
    img: 'con-perro-cta',
    imgAlt: 'Dog with life jacket in canoe · Sella descent with pets for free',
    badge: 'Pets · free',
    title: 'With dog',
    age: 'Up to 25 kg',
    price: '0',
    note: 'Canine life jacket included while stocks last',
  },
];

const pasos = [
  { num: '01', title: 'Book your day',           text: 'Pick date, route and number of people in the calendar. <strong>No payment now</strong>: we hold your spot instantly.' },
  { num: '02', title: 'Come to Arriondas',       text: 'We wait for you at C/ Juan Carlos I, 18. Private guarded parking, changing rooms, hot showers and lockers with key.' },
  { num: '03', title: 'You set off by canoe',    text: 'Mini class with a certified instructor, paddle, life jacket, watertight barrel and Asturian picnic. Premium open time slot 10:30–12:30.' },
  { num: '04', title: 'We pick you up',          text: 'Return transfer from Toraño (mini route) or Fríes (full route). Comfortable ride back · no extra car, no waiting.' },
];

const faqs = [
  {
    q: 'Do I have to pay now to book?',
    a: 'No. You can <strong>book without paying anything now</strong>. We hold your spot and you choose between paying online in advance (card or bank transfer) or on the day at the canoe pick-up (card, Bizum, cash or instant transfer).',
  },
  {
    q: 'What is the cancellation policy?',
    a: 'You can <strong>change or cancel your booking at any time before the day of the activity</strong>, at no cost. If you paid by <strong>card in advance</strong>, to process the refund we need you to let us know at least <strong>24 h before</strong>. Reach us by WhatsApp or email and we will help you move the date or refund the amount. If we reschedule due to weather or river conditions, free change or full refund.',
  },
  {
    q: 'When do I get the confirmation?',
    a: 'Instantly, automatically by email. You will receive: confirmed date, chosen route, Premium open time slot (flexible arrival 10:30–12:30), arrival instructions and a direct WhatsApp in case anything comes up.',
  },
  {
    q: 'How far in advance should I book?',
    a: 'In low season, the day before is usually enough. In <strong>July-August, weekends and holidays</strong> we recommend 3-7 days in advance. The calendar shows in real time which days have spots left.',
  },
  {
    q: 'What if it rains on my booking date?',
    a: 'On the Sella many days are paddled under cloudy skies without any issue · it is part of the green charm of Asturias. If there is a <strong>weather warning or the river is in spate</strong>, we reschedule at no cost or refund in full. We always decide on the safe side.',
  },
  {
    q: 'Are there group discounts?',
    a: 'From <strong>15 people</strong> upwards we offer special conditions (dedicated time slot, Asturian picnic, company invoice). Write to us at <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a> with date, number of people and ages · we will send you a closed quote.',
  },
];

const resources = [
  { img: 'reservar-resource-precios',   imgAlt: 'Orange canoe on the bank of the Sella · detailed rates of the descent', title: 'Detailed prices', text: 'Prices by age, what they include and route comparison.',           href: getLocalePath('precios', 'en'),         cta: 'See prices' },
  { img: 'reservar-resource-recorrido', imgAlt: 'View of the Sella river in Asturias · route and map of the descent',    title: 'Route and map',   text: 'Mini route (7 km · 2-3 h) or full route (14.5 km · 4-5 h).',         href: getLocalePath('recorrido_mapa', 'en'),  cta: 'See route' },
  { img: 'reservar-resource-premium',   imgAlt: 'Families and adults paddling on the Sella · Premium Booking all inclusive', title: 'Premium Booking', text: 'Lockers, Asturian picnic and open time slot 10:30–12:30.', href: getLocalePath('reserva_premium', 'en'), cta: 'See Premium' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, 'en'),
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'en-GB',
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#business` },
      mainEntityOfPage: canonicalUrl,
      datePublished: '2026-05-14',
      dateModified: '2026-05-14',
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Sella canoe descent online booking',
      description: 'Online booking service for the tourist Sella descent from Arriondas (Asturias). Flexible change or cancellation before the day (24 h if you paid by card). No payment now.',
      provider: { '@id': `${baseUrl}/#business` },
      serviceType: 'Canoe rental and guided river descent',
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturias, Spain' },
      offers: [
        { '@type': 'Offer', name: 'Children up to 12 years', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
        { '@type': 'Offer', name: 'Adults',                   price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: canonicalUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Book', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} currentPath="/en/book/" translationKey="reservar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preload" as="image" href="/images/optimized/hero-canoa-lago-lg.avif" type="image/avif" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>

  <section class="rsvH" aria-labelledby="rsvH-title">
    <div class="rsvH__media" aria-hidden="true">
      <Picture src="hero-canoa-lago" alt="Canoe on the Sella river at sunset · Sella descent from Arriondas" priority="high" sizes="100vw" aspectRatio="16 / 10" />
      <div class="rsvH__overlay"></div>
    </div>

    <div class="rsvH__inner">
      <nav class="rsvH__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Book</span>
      </nav>

      <span class="rsvH__eyebrow">
        <span class="rsvH__eyebrow-dot" aria-hidden="true"></span>
        Book in 2 minutes · no payment now
      </span>

      <h1 id="rsvH-title" class="rsvH__title">
        Book your<br/>
        <span class="serif-italic">Sella descent</span>
      </h1>

      <p class="rsvH__lead">
        Pick day, route and number of people. The canoe, gear, picnic, transfer and everything else · already included. <strong>No payment now</strong> · pay online or on the day you pick up the canoe in Arriondas.
      </p>

      <div class="rsvH__ctas">
        <a class="rsvH__cta rsvH__cta--primary" href="#booking-widget">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Go to calendar</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="https://wa.me/34681093673?text=Hello%2C%20I%27d%20like%20to%20book%20the%20Sella%20descent" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.87 11.87 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.56 4.18 1.62 6L0 24l6.18-1.6A11.9 11.9 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a class="rsvH__cta rsvH__cta--ghost" href="tel:+34681093673" aria-label="Call +34 681 09 36 73">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          <span>+34 681 09 36 73</span>
        </a>
      </div>

      <ul class="rsvH__trust" role="list">
        <li><span class="rsvH__trustNum">4.5★</span><span class="rsvH__trustLabel">147 real reviews</span></li>
        <li><span class="rsvH__trustNum">Flexible</span><span class="rsvH__trustLabel">change before the day</span></li>
        <li><span class="rsvH__trustNum">25 years</span><span class="rsvH__trustLabel">in Arriondas</span></li>
        <li><span class="rsvH__trustNum">€0</span><span class="rsvH__trustLabel">to book</span></li>
      </ul>
    </div>
  </section>

  <section class="rsvB" aria-labelledby="rsvB-title">
    <div class="rsvB__inner">
      <header class="rsvB__header">
        <span class="rsvB__eyebrow">— Live calendar</span>
        <h2 id="rsvB-title" class="rsvB__title">
          Pick your day<br/>
          <span class="serif-italic">in less than 2 minutes</span>
        </h2>
        <p class="rsvB__lead">
          Real-time availability · days with spots in green · no surprises. <strong>Instant confirmation by WhatsApp and email</strong> · quick, easy, no endless forms.
        </p>
      </header>

      <div id="booking-widget" class="rsvB__slot" aria-live="polite">
        <div class="rsvB__placeholder">
          <span class="rsvB__placeholderIcon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <p class="rsvB__placeholderTitle">Booking calendar</p>
          <p class="rsvB__placeholderText">
            We are loading the real-time calendar. If it does not appear in a few seconds, reach us on <a href="https://wa.me/34681093673" target="_blank" rel="noopener noreferrer">WhatsApp</a> or call <a href="tel:+34681093673">+34 681 09 36 73</a> · we book you instantly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rsvT" aria-labelledby="rsvT-title">
    <div class="rsvT__inner">
      <header class="rsvT__header">
        <span class="rsvT__eyebrow">— Book with peace of mind</span>
        <h2 id="rsvT-title" class="rsvT__title">
          No payment now,<br/>
          <span class="serif-italic">no fine print.</span>
        </h2>
      </header>

      <div class="rsvT__grid">
        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-pago" alt="Bank of the Sella river in Arriondas · flexible payment to book the descent" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag">Flexible payment</span>
            <h3 class="rsvT__cardTitle">Pay online or on arrival</h3>
            <ul class="rsvT__cardList">
              <li>Card online when booking</li>
              <li>Or on the day: card, Bizum, cash or bank transfer</li>
              <li>No deposit · no hidden extras</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-cambios" alt="Group of girls paddling together on the Sella descent · flexible change or cancellation" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--sage">Flexible changes and cancellations</span>
            <h3 class="rsvT__cardTitle">Change or cancel before the day · at no cost</h3>
            <ul class="rsvT__cardList">
              <li>Change or cancel at any time before the day of the activity</li>
              <li>If you paid by card, the refund needs 24 h notice</li>
              <li>If it rains hard or the river rises, we reschedule or refund</li>
            </ul>
          </div>
        </article>

        <article class="rsvT__card">
          <div class="rsvT__cardMedia"><Picture src="reservar-trust-equipo" alt="Aventura en el Sella team in Arriondas · real people who take care of you" sizes="(min-width: 960px) 33vw, 100vw" aspectRatio="4 / 3" /></div>
          <div class="rsvT__cardBody">
            <span class="rsvT__cardTag rsvT__cardTag--coral">Human confirmation</span>
            <h3 class="rsvT__cardTitle">Real people, not bots</h3>
            <ul class="rsvT__cardList">
              <li>We confirm by email + WhatsApp</li>
              <li>We answer from 9:30 to 19:00 every day in season</li>
              <li>25 years welcoming adventurers in Arriondas</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="rsvP" aria-labelledby="rsvP-title">
    <div class="rsvP__inner">
      <header class="rsvP__header">
        <span class="rsvP__eyebrow">— Standard rates</span>
        <h2 id="rsvP-title" class="rsvP__title">
          Price per person per day,<br/>
          <span class="serif-italic">all inclusive.</span>
        </h2>
        <p class="rsvP__lead">
          Same price for the mini route (7 km · 2-3 h) and the full route (14.5 km · 4-5 h). <strong>Premium Booking included at no extra cost</strong> · pets always free.
        </p>
      </header>

      <p class="rsvP__premiumBadge">
        <span class="rsvP__premiumStar" aria-hidden="true">✦</span>
        <span><strong>Premium Booking · All inclusive</strong> on any rate · lockers, changing rooms, hot showers, Asturian picnic, transfer and private guarded parking</span>
      </p>

      <div class="rsvP__grid">
        {tarifas.map(t => (
          <article class="rsvP__card">
            <div class="rsvP__cardMedia">
              <Picture src={t.img} alt={t.imgAlt} sizes="(min-width: 960px) 25vw, 50vw" aspectRatio="4 / 5" />
              <span class="rsvP__cardBadge">{t.badge}</span>
            </div>
            <div class="rsvP__cardBody">
              <h3 class="rsvP__cardTitle">{t.title}</h3>
              <p class="rsvP__cardAge">{t.age}</p>
              <p class="rsvP__cardPrice">
                {t.price === '0' ? (
                  <span class="rsvP__cardFree">Free</span>
                ) : (
                  <>
                    <span class="rsvP__cardCurrency">€</span>
                    <span class="rsvP__cardAmount">{t.price}</span>
                    <span class="rsvP__cardUnit">/day</span>
                  </>
                )}
              </p>
              <p class="rsvP__cardNote">{t.note}</p>
              <a class="rsvP__cardLink" href="#booking-widget">
                Book
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="rsvP__foot">
        Looking for family, school group or hen/stag party rates? <a href={getLocalePath('precios', 'en')}>See all rates in detail</a>.
      </p>
    </div>
  </section>

  <section class="rsvS" aria-labelledby="rsvS-title">
    <div class="rsvS__inner">
      <header class="rsvS__header">
        <span class="rsvS__eyebrow">— How it works</span>
        <h2 id="rsvS-title" class="rsvS__title">
          Book your descent<br/>
          <span class="serif-italic">in 4 steps.</span>
        </h2>
        <div class="rsvS__times">
          <div><strong>Open time slot</strong><span>Flexible arrival 10:30 – 12:30</span></div>
          <div><strong>Pick-ups</strong><span>From 13:00 to 18:00 from Toraño / Fríes</span></div>
        </div>
      </header>

      <ol class="rsvS__list" role="list">
        {pasos.map(p => (
          <li class="rsvS__step">
            <span class="rsvS__stepNum">{p.num}</span>
            <h3 class="rsvS__stepTitle">{p.title}</h3>
            <p class="rsvS__stepText" set:html={p.text}></p>
          </li>
        ))}
      </ol>

      <p class="rsvS__foot">
        <a href={getLocalePath('cuanto_dura', 'en')}>See how the descent works in detail</a> · real times per route and time of day.
      </p>
    </div>
  </section>

  <section class="rsvO" aria-labelledby="rsvO-title">
    <div class="rsvO__inner">
      <header class="rsvO__header">
        <span class="rsvO__eyebrow">— Prefer to talk to someone?</span>
        <h2 id="rsvO-title" class="rsvO__title">
          Other ways<br/>
          <span class="serif-italic">to book.</span>
        </h2>
        <p class="rsvO__lead">
          Always book in advance · we confirm right away in office hours. Real person from the team, never a bot.
        </p>
      </header>

      <div class="rsvO__row" role="list">
        <a class="rsvO__item" href="https://wa.me/34681093673?text=Hello%2C%20I%27d%20like%20to%20book%20the%20Sella%20descent" target="_blank" rel="noopener noreferrer" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
          </span>
          <span class="rsvO__itemTag">Instant reply</span>
          <h3 class="rsvO__itemTitle">WhatsApp</h3>
          <p class="rsvO__itemText">We reply in minutes during office hours. No forms, no waiting.</p>
          <span class="rsvO__itemValue">Open chat</span>
          <span class="rsvO__itemCta" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a class="rsvO__item" href="tel:+34681093673" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <span class="rsvO__itemTag">9:30 – 19:00 in season</span>
          <h3 class="rsvO__itemTitle">Phone</h3>
          <p class="rsvO__itemText">No automated menus. You dial and a real person from the team answers, not a call-centre.</p>
          <span class="rsvO__itemValue">+34 681 09 36 73</span>
          <span class="rsvO__itemCta" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a class="rsvO__item" href="mailto:reservas@aventuraenelsella.es?subject=Sella%20descent%20booking" role="listitem">
          <span class="rsvO__itemIcon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span class="rsvO__itemTag">For groups or longer enquiries</span>
          <h3 class="rsvO__itemTitle">Email</h3>
          <p class="rsvO__itemText">Ideal for booking groups, hen/stag parties or tailored quotes. Reply within 24 h.</p>
          <span class="rsvO__itemValue">reservas@aventuraenelsella.es</span>
          <span class="rsvO__itemCta" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="rsvF" aria-labelledby="rsvF-title">
    <div class="rsvF__inner">
