---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';
import { getLocalePath } from '@utils/i18n';

const lang = 'en';
const title = 'Premium Booking · all-inclusive Sella River descent';
const description = 'Premium Sella River descent · €40 adult · €30 child · pets free. All inclusive + Asturian picnic (tuna pie, traditional bun) as a gift.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/en/premium-booking/`;

// What's included items · editorial 4×4 grid (13 items, picnic full-width last row)
const includesPremium = [
  { icon: 'parking',   name: 'Private parking',           nota: 'Guarded and free · 300 spaces · campervans welcome · next to base',           highlight: false },
  { icon: 'canoa',     name: 'Unsinkable canoe',          nota: 'Unsinkable system · 1 to 3 seats · certified · daily maintenance',            highlight: false },
  { icon: 'chaleco',   name: 'Certified life jacket',     nota: 'CHC required · adult and child sizes · fit verified',                         highlight: false },
  { icon: 'pala',      name: 'Double paddle',             nota: 'Double-blade aluminium · one per person · light and ergonomic',               highlight: false },
  { icon: 'neopreno',  name: 'Wetsuit',                   nota: 'On set cold dates · thermal protection against cold water',                   highlight: false },
  { icon: 'bidon',     name: 'Watertight barrel',         nota: 'Your stuff stays dry the whole descent · phone · wallet · clothes',           highlight: false },
  { icon: 'rampa',     name: 'Boarding ramp',             nota: 'Optional and free · use the ramp or board straight from the riverbank',      highlight: false },
  { icon: 'monitor',   name: 'Certified instructor',      nota: 'Safety briefing · paddling mini-class · Asturian team',                       highlight: false },
  { icon: 'transfer',  name: 'Return transfer',           nota: 'We pick you up at Toraño (Mini) or Fríes (Full) and back to base',           highlight: false },
  { icon: 'duchas',    name: 'Changing rooms with showers', nota: 'Comfortable change before and after · hot water when you finish',          highlight: false },
  { icon: 'taquilla',  name: 'Locked lockers',            nota: 'Your stuff safe · what others charge extra for, included in the price',       highlight: false },
  { icon: 'seguro',    name: 'Mandatory insurance',       nota: 'Civil liability and accidents · included at no extra cost',                   highlight: false },
  { icon: 'picnic',    name: 'Asturian picnic',           nota: 'Tuna pie · traditional bun · 500 ml water bottle · inside the barrel',       highlight: true  },
];

// Current price (confirmed 2026-04-10 · project_premium_strategy.md)
const tarifas = [
  { label: 'Adult',          from: 13, to: 99, price: '40', unit: '€' },
  { label: 'Child',          from: 5,  to: 12, price: '30', unit: '€' },
  { label: 'Pets',           from: 0,  to: 0,  price: 'Free', unit: '' },
];

// Real testimonials (reference_reviews.md)
const testimonios = [
  { initial: 'N', name: 'Nacho A.',    source: 'TripAdvisor', date: 'August 2025', context: 'Couples', rating: 5,
    text: 'Everything punctual and very kind. A once-in-a-lifetime experience, recommended for young and old alike.' },
  { initial: 'C', name: 'Carlos S.',   source: 'TripAdvisor', date: 'May 2025',    context: 'Friends', rating: 5,
    text: 'Totally worth it. You get changing rooms and can shower after the activity. They give you fun instructions, a barrel to put lots of things inside, and the rest is what the river gives you.' },
  { initial: 'A', name: 'Anaïs Suárez', source: 'Google',    date: 'October 2025', context: 'Experience', rating: 5,
    text: 'Great service, attentive and very friendly staff. The experience was amazing, I absolutely loved it.' },
];

const faqs = [
  { q: 'What exactly is included in the Premium Sella River descent booking?',
    a: 'Everything you need to paddle the Sella without worrying about a thing: <strong>private guarded parking (300 spaces · campervans welcome), unsinkable canoe (1-3 seats), certified life jacket, double paddle, wetsuit on cold dates, watertight barrel, optional boarding ramp (or board straight from the riverbank), certified instructor, return transfer, changing rooms with hot showers, locked lockers (which other companies charge extra for), mandatory insurance and the <em>Asturian picnic as a gift</em></strong>. That is 13 things, all in the price. No hidden extras.' },
  { q: 'How much does the Premium descent cost?',
    a: '<strong>€40 per adult</strong> (from 13 years on) and <strong>€30 per child</strong> (from 5 to 12 years). <strong>Pets travel free</strong>. The price is the same for the Mini Sella (7 km) and the Full Descent (14.5 km) — no surprises.' },
  { q: 'How is Premium different from the basic descent other operators offer?',
    a: 'Competitors in the Sella valley usually offer between €15 and €35 with no picnic, just the canoe and life jacket. Our <strong>Premium booking costs a little more but includes: private guarded parking, our own boarding ramp (optional and free — if you prefer, you board straight from the river), canoe with unsinkable system, wetsuit on cold dates, Asturian picnic, transfer, changing rooms with hot showers, <em>locked lockers</em> and insurance — all things other operators charge extra for or do not offer at all</strong>. It is the no-surprises version.' },
  { q: 'What does the Asturian picnic include?',
    a: 'Traditional Asturian cooking: a <strong>tuna pie</strong>, a <strong>traditional Asturian bun</strong> (chorizo baked in bread) and a <strong>500 ml water bottle</strong>. Everything inside the watertight barrel so it arrives dry and fresh. You can enjoy it wherever you like along the route — on a river beach, on a bank or after the last rapid. <em>The picnic is fixed and the same for all customers — we do not have a vegan or vegetarian option. If you have a specific allergy (gluten, nuts...), let us know when booking and we will confirm the ingredients.</em>' },
  { q: 'Do I have to pick a start time?',
    a: 'No. Your booking is <strong>Premium · open hours</strong>: arrive at our Arriondas base <strong>whenever it suits you between 10:30 and 12:30</strong>, without choosing a specific time. It is one of the <strong>Premium perks</strong> · we kit you out on arrival and you head out as soon as you are ready. <strong>Exceptions</strong>: the Saturday of the <a href="' + getLocalePath('descenso_internacional', lang) + '">International Sella Descent</a> does have a single fixed start time · and if a storm or river conditions require a specific time or instructor-led launch, we let you know in advance. The Hydrographic Confederation requires you to be off the river by 18:00.' },
  { q: 'Do I have to pay now when booking?',
    a: 'No. You can pay <strong>by card when booking or on the day you pick up the canoe</strong>. Whichever you prefer.' },
  { q: 'Can I book on the same day?',
    a: 'Yes — <strong>as long as the booking calendar shows availability</strong> for that day. Our honest recommendation is <strong>to book in advance</strong>, especially in high season (July-August) and weekends, when slots fill up fast. The <a href="' + getLocalePath('reservar', lang) + '">online calendar</a> shows free days in real time. Booking takes 2 minutes and <strong>you do not have to pay anything at that moment</strong>.' },
  { q: 'Can I cancel the Premium booking?',
    a: 'Yes. You can <strong>change or cancel your booking at any time before the day of the activity</strong>, at no cost. If you paid by <strong>card in advance</strong>, to process the refund we need you to let us know at least <strong>24 h before</strong>. If the weather is bad or the Hydrographic Confederation closes the river, we reschedule or refund the full amount.' },
  { q: 'Is there an option higher than Premium?',
    a: 'There are no more categories. <strong>All our bookings are Premium</strong> — it is our standard way of doing things: all inclusive, picnic as a gift, no misleading plans with different "tiers". What you see is what you get.' },
  { q: 'Can I gift a Premium descent?',
    a: 'Yes, it works very well as a <strong>birthday, anniversary or experience gift</strong>. You book the date and we issue a gift card in the recipient\u2019s name. <a href="' + getLocalePath('contacto', lang) + '">Write to us</a> and we will arrange it.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl, lang),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Premium Booking for the Sella River descent — All Inclusive + Asturian Picnic',
      description: 'Premium Booking for the Sella River descent: €40 adult, €30 child, pets free, Asturian picnic included. Everything in the price.',
      inLanguage: 'en-GB',
      mainEntityOfPage: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`, width: 1920, height: 1280 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-22',
      dateModified:  '2026-05-12',
      about: 'Premium all-inclusive Sella River descent with Asturian picnic from Arriondas',
    },
    {
      '@type': 'Product',
      '@id': `${baseUrl}/#product`,
      name: 'Sella River descent · Premium Booking',
      description: 'Sella River canoe descent all inclusive with Asturian picnic as a gift (tuna pie, traditional bun and water). From Arriondas, 14.5 km (Full) or 7 km (Mini Sella).',
      image: `${baseUrl}/images/optimized/rio-sella-hermoso-lg.jpg`,
      brand: { '@type': 'Brand', name: 'Aventura en el Sella' },
      aggregateRating: { '@type': 'AggregateRating', ratingValue: 4.5, reviewCount: 147, bestRating: 5, worstRating: 1 },
      offers: [
        { '@type': 'Offer', name: 'Adult', price: '40', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/en/book/` },
        { '@type': 'Offer', name: 'Child', price: '30', priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${baseUrl}/en/book/` },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',             item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Premium Booking',  item: canonicalUrl },
      ],
    },
  ],
};

// Minimal stroke-based icons for "What's included"
const iconPaths = {
  parking:  '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M10 8v8M10 8h3.5a2.5 2.5 0 0 1 0 5H10"/>',
  canoa:    '<path d="M3 14c3 3 7 4 9 4s6-1 9-4"/><path d="M5 14l2-8h10l2 8"/><line x1="12" y1="6" x2="12" y2="14"/>',
  chaleco:  '<path d="M7 4h10v4l-2 2v10H9V10L7 8z"/><line x1="9" y1="14" x2="15" y2="14"/>',
  neopreno: '<path d="M8 4l-2 2v4l2 1v11h8V11l2-1V6l-2-2zM10 4v2h4V4"/>',
  pala:     '<line x1="5.5" y1="12" x2="18.5" y2="12"/><ellipse cx="3" cy="12" rx="2.5" ry="4.5"/><ellipse cx="21" cy="12" rx="2.5" ry="4.5"/>',
  rampa:    '<line x1="3" y1="20" x2="21" y2="20"/><path d="M5 20V13h14v7"/><path d="M3 10c3 2 6 2 9 0s6-2 9 0"/>',
  bidon:    '<path d="M8 4h8v3H8zM7 7h10v14H7zM7 12h10M7 17h10"/>',
  transfer: '<rect x="3" y="8" width="18" height="10" rx="2"/><circle cx="8" cy="18" r="1.5"/><circle cx="16" cy="18" r="1.5"/><line x1="3" y1="12" x2="21" y2="12"/>',
  duchas:   '<circle cx="7" cy="5" r="2"/><path d="M5 7v3h4V7M3 10h8M5 10v4M7 10v6M9 10v4"/>',
  taquilla: '<rect x="5" y="11" width="14" height="10" rx="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/>',
  monitor:  '<circle cx="12" cy="8" r="3"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>',
  seguro:   '<path d="M12 3L5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  picnic:   '<path d="M4 11h16l-2 10H6z"/><path d="M8 11V6a4 4 0 0 1 8 0v5"/><line x1="10" y1="15" x2="10" y2="18"/><line x1="14" y1="15" x2="14" y2="18"/>',
};

const starSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
---

<BaseLayout title={title} description={description} currentPath="/en/premium-booking/" translationKey="reserva_premium">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO ============== -->
  <section class="rpH" aria-labelledby="rpH-title">
    <span class="rpH__watermark" aria-hidden="true">Premium</span>

    <div class="rpH__inner">
      <nav class="rpH__breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Premium Booking</span>
      </nav>

      <div class="rpH__grid">
        <div class="rpH__main">
          <span class="rpH__eyebrow">— For your perfect day on the Sella</span>

          <h1 id="rpH-title" class="rpH__title">
            All of the Sella.<br/>
            <span class="serif-italic">Without a thing to worry about.</span>
          </h1>

          <div class="rpH__deluxe" aria-hidden="true">
            <span class="rpH__deluxeMark"></span>
            <span class="rpH__deluxeWord">Premium</span>
            <span class="rpH__deluxeMark"></span>
          </div>

          <p class="rpH__lead">
            The Sella River descent with <strong>everything included</strong> — canoe, life jacket, paddle, barrel, transfer, hot showers and <strong>Asturian picnic as a gift</strong>. A single honest fare, no extras, no surprises.
          </p>

          <div class="rpH__stats">
            <span class="rpH__statsKicker">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              All inclusive · no extras
            </span>
            <div class="rpH__statsRow">
              <div class="rpH__stat">
                <strong>40<small>€</small></strong>
                <span>Adult</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>30<small>€</small></strong>
                <span>Child · 5–12</span>
              </div>
              <div class="rpH__statSep" aria-hidden="true"></div>
              <div class="rpH__stat">
                <strong>Free</strong>
                <span>Pets</span>
              </div>
            </div>
          </div>

          <div class="rpH__ctas">
            <a href={getLocalePath('reservar', lang)} class="rpH__cta rpH__cta--primary">
              Book now
              <span class="rpH__ctaIcon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
            <a href="#rpH-incluye" class="rpH__cta rpH__cta--ghost">
              See what is included
            </a>
          </div>
        </div>

        <aside class="rpH__contact" aria-labelledby="rpH-contact-kicker">
          <span class="rpH__contactKicker" id="rpH-contact-kicker">— Want to talk?</span>
          <ul class="rpH__contactList" role="list">
            <li>
              <a href="tel:+34681093673" class="rpH__contactPill rpH__contactPill--primary" aria-label="Call 681 09 36 73">
                <strong>Call us</strong>
                <small>+34 681 09 36 73</small>
              </a>
            </li>
            <li>
              <a href="https://wa.me/34681093673?text=Hi%2C%20I%20have%20a%20question%20about%20the%20Premium%20Booking" target="_blank" rel="noopener noreferrer" class="rpH__contactPill" aria-label="WhatsApp">
                <strong>WhatsApp</strong>
                <small>Reply in minutes</small>
              </a>
            </li>
            <li>
              <a href="mailto:reservas@aventuraenelsella.es" class="rpH__contactPill" aria-label="Email">
                <strong>Email</strong>
                <small>Bookings and questions</small>
              </a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============== 2 · WHAT IS PREMIUM? ============== -->
  <section class="rpQ" aria-labelledby="rpQ-title">
    <div class="container container--xl">
      <div class="rpQ__grid">
        <header class="rpQ__head" data-reveal>
          <span class="rpQ__eyebrow">— What Premium means in our house</span>
          <h2 id="rpQ-title" class="rpQ__title">
            Not more expensive.<br/>
            <span class="serif-italic">All inclusive.</span>
          </h2>
        </header>
        <div class="rpQ__body" data-reveal data-reveal-delay="1">
          <p class="rpQ__lead">
            "Premium" here does not mean pompous or fancy. It means <strong>one single honest fare</strong> with absolutely everything you need in the canoe — plus an <strong>Asturian picnic waiting for you</strong> inside the watertight barrel.
          </p>
          <p class="rpQ__lead">
            Sella valley operators charge between €15 and €35 for the basic canoe. Our <strong>€40 per adult</strong> rate is just a few euros more, but it includes what others sell as extras or do not offer at all: <strong>private guarded parking</strong>, unsinkable canoe, <strong>our own boarding ramp</strong> (optional and free), wetsuit on cold dates, barrel, transfer, changing rooms with hot showers, <strong>locked lockers</strong>, insurance and the <strong>Asturian picnic</strong>. <em>No surprises at the end of the day.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 3 · WHAT IS INCLUDED ============== -->
  <section class="rpI" id="rpH-incluye" aria-labelledby="rpI-title">
    <div class="container container--xl">
      <header class="rpI__header" data-reveal>
        <span class="rpI__eyebrow">— 13 things included</span>
        <h2 id="rpI-title" class="rpI__title">
          What you get<br/>
          <span class="serif-italic">with the Premium booking.</span>
        </h2>
        <p class="rpI__lead">
          Everything on the list is in the price. Nothing is charged extra. <strong>Nothing.</strong>
        </p>
      </header>

      <ol class="rpI__grid">
        {includesPremium.map((item, i) => (
          <li class={`rpI__cell${item.highlight ? ' is-highlight' : ''}`}>
            <span class="rpI__cellNum" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="rpI__cellBody">
              <span class="rpI__cellIcon" aria-hidden="true">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[item.icon]} />
              </span>
              <h3 class="rpI__cellName">{item.name}</h3>
              <p class="rpI__cellNota">{item.nota}</p>
              {item.highlight && <span class="rpI__cellBadge">GIFT</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 4 · NAVY BANNER ============== -->
  <section class="rpB" aria-label="Call to action · book Premium">
    <div class="container container--xl">
      <div class="rpB__inner" data-reveal>
        <div class="rpB__text">
          <span class="rpB__eyebrow">— Aventura en el Sella</span>
          <h2 class="rpB__title">Ready for the river <span class="serif-italic">and the picnic?</span></h2>
        </div>
        <a href={getLocalePath('reservar', lang)} class="rpB__cta">
          <span>Book now</span>
          <span class="rpB__ctaIcon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== 5 · ASTURIAN PICNIC ============== -->
  <section class="rpP" aria-labelledby="rpP-title">
    <div class="container container--xl">
      <div class="rpP__split">
        <div class="rpP__media" data-reveal data-reveal-type="slide-right">
          <Picture src="fiesta-sella" alt="Atmosphere and Asturian picnic on the Sella River descent · all-inclusive Premium Booking" sizes="(min-width: 960px) 45vw, 100vw" bare />
          <span class="rpP__mediaTag">Included · Gift</span>
        </div>
        <div class="rpP__body" data-reveal data-reveal-delay="1">
          <span class="rpP__eyebrow">— What sets it apart</span>
          <h2 id="rpP-title" class="rpP__title">
            Asturian picnic<br/>
            <span class="serif-italic">inside the barrel.</span>
          </h2>
          <p class="rpP__lead">
            Pure Asturian cooking: a <strong>tuna pie</strong>, a <strong>traditional Asturian bun</strong> (chorizo baked in bread) and a <strong>500 ml water bottle</strong>. Simple, honest, tasty — inside the watertight barrel so it arrives dry and fresh.
          </p>
          <ul class="rpP__list">
            <li><span class="rpP__listDot" aria-hidden="true"></span>Eat it on a <strong>river beach</strong> — Pozo del Arco is the team\u2019s favourite.</li>
            <li><span class="rpP__listDot" aria-hidden="true"></span>Or stop at one of the <strong>6 riverside bars</strong> and open it there at your own pace.</li>
            <li><span class="rpP__listDot" aria-hidden="true"></span>The picnic is <strong>fixed — the same for all customers</strong>. No vegan or vegetarian option.</li>
          </ul>
          <a href={getLocalePath('recorrido_mapa', lang)} class="rpP__link">
            See the riverside bars on the route
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 6 · PRICING ============== -->
  <section class="rpT" aria-labelledby="rpT-title">
    <div class="container container--xl">
      <header class="rpT__header" data-reveal>
        <span class="rpT__eyebrow">— Honest pricing</span>
        <h2 id="rpT-title" class="rpT__title">
          One fare.<br/>
          <span class="serif-italic">No small print.</span>
        </h2>
        <p class="rpT__lead">
          Same price for the Mini Sella (7 km) and the Full Descent (14.5 km). The Asturian picnic is always included. Pay by card when booking or <strong>the day you pick up the canoe</strong> — your choice.
        </p>
      </header>

      <div class="rpT__split">
        {tarifas.map(t => (
          <div class="rpT__col">
            <span class="rpT__colLabel">{t.label}</span>
            <strong class="rpT__colPrice">
              {t.price}
              {t.unit && <small>{t.unit}</small>}
            </strong>
            <span class="rpT__colNota">
              {t.label === 'Adult' && 'from age 13'}
              {t.label === 'Child' && 'from 5 to 12 years'}
              {t.label === 'Pets'  && 'dog life jacket included'}
            </span>
          </div>
        ))}
      </div>

      <div class="rpT__notes" data-reveal>
        <ul class="rpT__notesList">
          <li><span class="rpT__noteDot" aria-hidden="true"></span><strong>No payment now</strong> — pay by card when booking or on the day of the descent.</li>
          <li><span class="rpT__noteDot" aria-hidden="true"></span><strong>Flexible changes and cancellations</strong> before the day · if you paid by card, refund needs 24 h notice.</li>
