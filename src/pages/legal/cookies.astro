---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Política de cookies · Aventura en el Sella';
const description = 'Política de cookies de Aventura en el Sella. Qué cookies utilizamos, para qué sirven y cómo puedes configurarlas o desactivarlas.';
const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/legal/cookies/`;
const lastUpdated = '2026-04-20';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#page`,
  name: 'Política de cookies',
  description,
  inLanguage: 'es-ES',
  url: canonicalUrl,
  isPartOf: { '@type': 'WebSite', name: 'Aventura en el Sella', url: baseUrl },
  dateModified: lastUpdated,
};

// Tabla de cookies usadas (pendiente confirmación con cliente · placeholders editables)
const cookies = [
  { nombre: 'astro-*',                tipo: 'Técnica · propia',      duracion: 'Sesión',     finalidad: 'Funcionamiento básico del sitio web (navegación, rendering, preferencias).' },
  { nombre: '_ga / _ga_*',            tipo: 'Analítica · Google',    duracion: '24 meses',    finalidad: 'Estadísticas de uso agregadas (páginas visitadas, dispositivo, duración).' },
  { nombre: '_gid',                   tipo: 'Analítica · Google',    duracion: '24 horas',    finalidad: 'Distinguir usuarios en sesiones cortas.' },
  { nombre: 'cookies-consent',        tipo: 'Técnica · propia',      duracion: '6 meses',     finalidad: 'Recordar tu elección en el banner de cookies.' },
];
---

<BaseLayout title={title} description={description} currentPath="/legal/cookies/" translationKey="legal_cookies">
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="lgl">

    <div class="lgl__inner">
      <nav class="lgl__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/legal/aviso-legal/">Legal</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Cookies</span>
      </nav>

      <span class="lgl__eyebrow">— Información legal</span>
      <h1 class="lgl__title">Política de cookies</h1>
      <p class="lgl__updated">Última actualización: <time datetime={lastUpdated}>20 de abril de 2026</time></p>

      <nav class="lgl__toc" aria-label="Índice de contenidos">
        <h2 class="lgl__tocTitle">Índice</h2>
        <ol>
          <li><a href="#que-son">1. ¿Qué son las cookies?</a></li>
          <li><a href="#tipos">2. Tipos de cookies que utilizamos</a></li>
          <li><a href="#detalle">3. Detalle de las cookies</a></li>
          <li><a href="#consentimiento">4. Consentimiento</a></li>
          <li><a href="#configurar">5. Cómo configurar o desactivar las cookies</a></li>
          <li><a href="#terceros">6. Cookies de terceros</a></li>
          <li><a href="#actualizaciones">7. Actualizaciones</a></li>
        </ol>
      </nav>

      <article class="lgl__prose">

        <section id="que-son">
          <h2>1. ¿Qué son las cookies?</h2>
          <p>
            Las cookies son pequeños archivos de texto que los sitios web almacenan en tu
            dispositivo (ordenador, móvil, tableta) cuando los visitas. Permiten recordar
            información sobre la visita —como el idioma preferido, el estado de tu sesión o
            estadísticas agregadas de uso— para mejorar tu experiencia en futuros accesos.
          </p>
          <p>
            El uso de cookies en este sitio web se rige por la
            <strong>Ley 34/2002, de Servicios de la Sociedad de la Información (LSSI-CE, artículo 22.2)</strong>,
            el <strong>Reglamento (UE) 2016/679 (RGPD)</strong> y la
            <strong>Ley Orgánica 3/2018 de Protección de Datos (LOPDGDD)</strong>, así como por las
            <strong>directrices de la AEPD</strong> sobre uso de cookies.
          </p>
        </section>

        <section id="tipos">
          <h2>2. Tipos de cookies que utilizamos</h2>
          <p>Clasificamos las cookies por <strong>titularidad</strong>, <strong>finalidad</strong> y <strong>duración</strong>:</p>
          <ul>
            <li><strong>Según titularidad:</strong>
              <ul>
                <li><strong>Propias:</strong> gestionadas directamente por nosotros.</li>
                <li><strong>De terceros:</strong> gestionadas por un proveedor externo (p. ej. Google Analytics).</li>
              </ul>
            </li>
            <li><strong>Según finalidad:</strong>
              <ul>
                <li><strong>Técnicas (estrictamente necesarias):</strong> permiten la navegación y el uso de las funcionalidades básicas. <strong>No requieren consentimiento</strong>.</li>
                <li><strong>De preferencias o personalización:</strong> recuerdan tus ajustes.</li>
                <li><strong>Analíticas:</strong> permiten medir el uso del sitio de forma agregada y anónima.</li>
                <li><strong>Publicitarias o de marketing:</strong> se utilizan para rastrear a los visitantes en los sitios web con la intención de mostrar anuncios relevantes. <strong>Actualmente no utilizamos cookies de marketing activas</strong> en este sitio. Esta categoría está prevista para posibles integraciones futuras (Google Ads, Meta Pixel, etc.) que siempre requerirán tu <strong>consentimiento previo</strong>.</li>
              </ul>
            </li>
            <li><strong>Según duración:</strong>
              <ul>
                <li><strong>De sesión:</strong> se eliminan al cerrar el navegador.</li>
                <li><strong>Persistentes:</strong> permanecen en tu dispositivo durante un plazo determinado.</li>
              </ul>
            </li>
          </ul>
        </section>

        <section id="detalle">
          <h2>3. Detalle de las cookies</h2>
          <p>A continuación, el listado de cookies utilizadas actualmente en este sitio web:</p>
          <div class="lgl__table">
            <table>
              <thead>
                <tr>
                  <th scope="col">Nombre</th>
                  <th scope="col">Tipo</th>
                  <th scope="col">Duración</th>
                  <th scope="col">Finalidad</th>
                </tr>
              </thead>
              <tbody>
                {cookies.map(c => (
                  <tr>
                    <td><code>{c.nombre}</code></td>
                    <td>{c.tipo}</td>
                    <td>{c.duracion}</td>
                    <td>{c.finalidad}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="lgl__note">
            <strong>Nota:</strong> esta tabla se mantiene actualizada. Si detectas alguna cookie no listada,
            escríbenos a <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a>.
          </p>
        </section>

        <section id="consentimiento">
          <h2>4. Consentimiento</h2>
          <p>
            Al entrar por primera vez en el sitio web, te mostramos un <strong>banner informativo</strong>
            donde puedes:
          </p>
          <ul>
            <li><strong>Aceptar</strong> todas las cookies.</li>
            <li><strong>Rechazar</strong> las cookies no estrictamente necesarias.</li>
            <li><strong>Configurar</strong> tus preferencias por categoría.</li>
          </ul>
          <p>
            Las cookies <strong>técnicas</strong> son imprescindibles para el funcionamiento del sitio y
            no requieren consentimiento conforme al artículo 22.2 LSSI-CE. Las demás categorías
            sólo se activan si aceptas expresamente.
          </p>
          <p>
            Puedes <strong>modificar o retirar tu consentimiento</strong> en cualquier momento desde el
            enlace "Configurar cookies" del pie de página, sin que ello afecte a la licitud del
            tratamiento previo.
          </p>
        </section>

        <section id="configurar">
          <h2>5. Cómo configurar o desactivar las cookies</h2>
          <p>
            Además del banner de nuestro sitio, puedes gestionar las cookies directamente desde tu
            navegador. A continuación, enlaces a las guías oficiales:
          </p>
          <ul>
            <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer">Google Chrome</a></li>
            <li><a href="https://support.mozilla.org/es/kb/habilitar-y-deshabilitar-cookies-sitios-web-rastrear-preferencias" target="_blank" rel="noopener noreferrer">Mozilla Firefox</a></li>
            <li><a href="https://support.apple.com/es-es/guide/safari/sfri11471/mac" target="_blank" rel="noopener noreferrer">Apple Safari</a></li>
            <li><a href="https://support.microsoft.com/es-es/windows/eliminar-y-administrar-cookies-168dab11-0753-043d-7c16-ede5947fc64d" target="_blank" rel="noopener noreferrer">Microsoft Edge</a></li>
          </ul>
          <p>
            <strong>Importante:</strong> si desactivas todas las cookies, algunas funcionalidades del sitio
            pueden dejar de operar correctamente.
          </p>
        </section>

        <section id="terceros">
          <h2>6. Cookies de terceros</h2>
          <p>
            Cuando utilizas determinadas funcionalidades (por ejemplo, ver un mapa de Google,
            estadísticas con Google Analytics o pagar mediante una pasarela externa), pueden
            instalarse cookies de terceros. Estos proveedores se rigen por sus propias políticas
            de privacidad:
          </p>
          <ul>
            <li><strong>Google LLC</strong> (Google Analytics, Google Maps, posibles integraciones futuras de Google Ads): <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a></li>
            <li><strong>Pasarela de pago</strong>: cuando procesamos cobros online con tarjeta utilizamos una <strong>pasarela de pago externa certificada</strong> y con medidas de seguridad PCI-DSS. La pasarela se rige por su propia política de privacidad y no almacenamos datos de tarjetas en nuestros sistemas.</li>
          </ul>
        </section>

        <section id="actualizaciones">
          <h2>7. Actualizaciones</h2>
          <p>
            Podremos actualizar esta Política de Cookies cuando cambien las cookies utilizadas o
            la normativa aplicable. La fecha de la última actualización figura al inicio del
            documento. Te recomendamos revisarla periódicamente.
          </p>
        </section>

        <div class="lgl__contact" aria-label="Contacto cookies">
          <p>
            Para dudas sobre esta Política de Cookies, escríbenos a
            <a href="mailto:info@aventuraenelsella.es">info@aventuraenelsella.es</a>
            o llama al <a href="tel:+34681093673">+34 681 09 36 73</a>.
          </p>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .lgl {
    position: relative;
    background:
      radial-gradient(ellipse 60% 45% at 10% 0%, rgba(61, 79, 58, 0.05) 0%, transparent 60%),
      var(--color-bg-base);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    min-height: 80vh;
  }
  .lgl__inner { max-width: 900px; margin: 0 auto; padding: clamp(7rem, 14vw, 10rem) clamp(1.5rem, 4vw, 3rem) 0; }
  .lgl__breadcrumb {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
    font-family: var(--font-sans); font-size: 0.6875rem;
    letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(26, 31, 46, 0.4);
    margin-bottom: 1.5rem;
  }
  .lgl__breadcrumb a { color: var(--color-sage, #3D4F3A); transition: color 200ms; }
  .lgl__breadcrumb a:hover { color: var(--color-primary); }
  .lgl__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: 1rem;
  }
  .lgl__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }
  .lgl__updated {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .lgl__toc {
    background: rgba(61, 79, 58, 0.04);
    border: 1px solid rgba(61, 79, 58, 0.12);
    border-radius: 0.875rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .lgl__tocTitle {
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin: 0 0 1rem;
  }
  .lgl__toc ol { padding-left: 1.25rem; margin: 0; columns: 1; column-gap: 2rem; font-family: var(--font-sans); font-size: 0.9375rem; color: var(--color-text-secondary); }
  @media (min-width: 720px) { .lgl__toc ol { columns: 2; } }
  .lgl__toc ol li { margin-bottom: 0.5rem; }
  .lgl__toc a { color: var(--color-text-primary); transition: color 200ms; border-bottom: 1px solid transparent; }
  .lgl__toc a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  .lgl__prose { font-family: var(--font-sans); font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary); }
  .lgl__prose section { padding-top: clamp(2rem, 4vw, 3rem); scroll-margin-top: 5rem; }
  .lgl__prose section:first-child { padding-top: 0; }
  .lgl__prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 900; line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .lgl__prose p { margin: 0 0 1rem; color: var(--color-text-secondary); }
  .lgl__prose p strong { color: var(--color-text-primary); font-weight: 700; }
  .lgl__prose ul { padding-left: 1.25rem; margin: 0 0 1rem; }
  .lgl__prose ul li { margin-bottom: 0.5rem; color: var(--color-text-secondary); }
  .lgl__prose ul ul { margin-top: 0.5rem; }

  .lgl__table {
    overflow-x: auto;
    margin: 0 0 1rem;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: 0.75rem;
  }
  .lgl__table table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans); font-size: 0.875rem;
    background: #fff;
  }
  .lgl__table thead {
    background: rgba(61, 79, 58, 0.06);
  }
  .lgl__table th {
    padding: 0.875rem 1rem;
    text-align: left;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(26, 31, 46, 0.08);
  }
  .lgl__table td {
    padding: 0.875rem 1rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(26, 31, 46, 0.05);
    vertical-align: top;
  }
  .lgl__table tr:last-child td { border-bottom: 0; }
  .lgl__table code {
    font-family: 'SFMono-Regular', 'Consolas', 'Liberation Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-text-primary);
    background: rgba(61, 79, 58, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .lgl__note {
    padding: 0.875rem 1.25rem;
    background: rgba(232, 179, 57, 0.1);
    border-left: 3px solid #E8B339;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.9375rem;
  }
  .lgl__note strong { color: var(--color-text-primary); font-weight: 800; }

  .lgl__placeholder {
    display: inline-block;
    padding: 2px 8px;
    background: rgba(232, 179, 57, 0.18);
    border: 1px dashed rgba(232, 179, 57, 0.5);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8125rem;
    color: #8B6914;
  }
  .lgl__prose a {
    color: var(--color-sage, #3D4F3A);
    border-bottom: 1px solid rgba(61, 79, 58, 0.4);
    transition: color 200ms, border-color 200ms;
  }
  .lgl__prose a:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .lgl__contact {
    margin-top: clamp(3rem, 5vw, 4rem);
    padding: 1.5rem 1.75rem;
    background: rgba(61, 79, 58, 0.06);
    border-left: 3px solid var(--color-sage, #3D4F3A);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .lgl__contact p { margin: 0; }
</style>
