  .cni__featureText strong { color: var(--color-text-primary); font-weight: 700; }

  .cni__cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.875rem 1.375rem;
    background: var(--color-sage, #3D4F3A);
