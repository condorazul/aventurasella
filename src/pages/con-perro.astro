---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';
import { localBusinessSchema } from '@data/business-schema';

const title = 'Descenso del Sella con perro · Aventura con tu mascota';
const description = 'Descenso del Sella con perro: mascotas gratis, chaleco canino incluido (hasta agotar existencias), monitores dog-friendly. Reserva sin pagar ahora.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/con-perro/`;
const ogImage = '/images/optimized/con-perro-cta-lg.jpg';

// 6 pasos de la jornada (adaptado para llegar con mascota)
const jornada = [
  { num: '01', title: 'Llegada con tu perro',       text: 'Te recibimos en Arriondas. <strong>Parking privado gratuito</strong> para evitar estrés al llegar. Os explicamos el plan del día y resolvemos dudas sobre la actividad con tu mascota.' },
  { num: '02', title: 'Valoración previa',          text: 'Miramos cómo está el perro — <strong>tranquilo, nervioso, tamaño, confianza con el agua</strong> — y ajustamos la canoa más adecuada para que la jornada sea cómoda para los dos.' },
  { num: '03', title: 'Briefing con monitor',       text: '<strong>Monitores con experiencia dog-friendly</strong> explican cómo colocar al perro en la canoa, qué hacer si se mueve y las pautas básicas. <strong>Todo claro antes de entrar al agua</strong>.' },
  { num: '04', title: 'Embarque tranquilo',         text: 'Salida desde nuestra rampa privada de 35 m al río. El perro baja <strong>suelto dentro de la canoa</strong>, nunca atado — es lo más seguro si hay movimiento o vuelco.' },
  { num: '05', title: 'Paradas cuando haga falta',  text: 'Hay playas fluviales tranquilas para <strong>parar, beber agua, estirar patas</strong> y que el perro respire. Sin prisa, <strong>al ritmo que pide tu mascota</strong>.' },
  { num: '06', title: 'Regreso y vestuarios',       text: '<strong>Nuestro transfer</strong> os lleva de vuelta. Vestuarios con duchas calientes para ti y zona exterior con agua para secar al perro. Día completo resuelto.' },
];

// Checklist qué llevar (items dog-specific)
const llevar = [
  { icon: 'leash',    t: 'Correa + arnés',                s: 'Obligatoria en tierra (embarque, accesos, vestuarios). Arnés cómodo mejor que collar' },
  { icon: 'bowl',     t: 'Agua y cuenco plegable',        s: 'Esencial si hace calor. Paramos tantas veces como haga falta para hidratarlo' },
  { icon: 'towel',    t: 'Toalla para el perro',          s: 'Mejor separada de la tuya · al final del recorrido sale empapado y agradeces no compartir' },
  { icon: 'bag',      t: 'Bolsas higiénicas',             s: 'Respetar el río y sus orillas. Todo lo que baja, sube con nosotros' },
  { icon: 'human',    t: 'Tu equipo personal',            s: 'Ropa cómoda que se moje, calzado sujeto, toalla y muda. Como cualquier descenso' },
];

// Beneficios concretos (USPs dog-friendly)
const beneficios = [
  { t: 'Mascotas 100% gratis',          s: 'Tu perro no paga. Viene con vosotros en la canoa sin coste extra — excepto el sábado del Descenso Internacional.' },
  { t: 'Monitores dog-friendly',        s: 'Con experiencia real bajando el Sella con mascotas. En la clase explicativa previa te enseñan qué mirar antes de entrar al agua y cómo actuar si tu perro se inquieta durante el descenso.' },
  { t: 'Plan tranquilo y adaptable',    s: 'El Sella turístico es fluvial suave — corriente tranquila, paradas cuando pide, sin white-water ni exigencia deportiva.' },
  { t: 'Pautas claras antes de salir',  s: 'Briefing específico sobre cómo colocar al perro, qué hacer si se mueve y cómo mantener la canoa equilibrada con él a bordo.' },
  { t: 'Vestuarios + parking privado',  s: 'Duchas calientes para ti + zona exterior con agua para enjuagar al perro al terminar. Parking vigilado todo el día.' },
  { t: 'Un perro por canoa',            s: 'Para asegurar espacio, equilibrio y comodidad. Si vienes con más de uno, te ayudamos a coordinar las embarcaciones.' },
  { t: 'Sin pagar ahora',               s: 'Reserva sin adelantar dinero. Paga con tarjeta antes o el día al recoger la canoa — como prefieras.' },
  { t: 'Cambia o cancela',              s: 'Cambios y cancelaciones flexibles antes del día. Si pagaste con tarjeta, reembolso avisando con 24 h.' },
];

// Dudas reales sobre bajar con perro (acordeón)
const faqs = [
  { q: '¿Cuánto cuesta bajar el Sella con perro?',
    a: 'El perro <strong>no paga</strong> — las mascotas vienen gratis en la canoa. Las personas: <strong>40 € por adulto</strong> (desde 13 años) y <strong>30 € por niño</strong> (5-12 años, <strong>edad mínima 5 años cumplidos y 1,15 m de altura</strong>). La única excepción es el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional del Sella</a>, que por el ruido del evento no se admiten mascotas. Puedes <a href="/precios/">ver el desglose completo de precios</a>.' },
  { q: '¿Se puede hacer el descenso del Sella con perro?',
    a: 'Sí, es una de las actividades dog-friendly más populares del río. Lo único que pedimos es <strong>sentido común con el perro</strong>: valorar si tolera el agua, si se queda tranquilo durante un rato, y si obedece órdenes básicas. Si es un perro sociable y equilibrado, la experiencia suele ir muy bien.' },
  { q: '¿Mi perro puede subir al transfer de regreso?',
    a: 'Sí, sin problema. <strong>Tu mascota podrá subir a nuestro transfer de regreso</strong> al finalizar el trayecto que hayas elegido (Mini Sella o Completo). Sube contigo en la furgoneta junto al resto del grupo, igual que la canoa — <strong>sin coste adicional</strong>.' },
  { q: '¿Tiene que ir mi perro con chaleco salvavidas?',
    a: 'No es obligatorio, pero <strong>es recomendable si tu perro no nada bien o si es de tamaño pequeño/mediano</strong>. <strong>El chaleco canino lo ponemos nosotros</strong> sin coste extra · tenemos varias tallas en la tienda <em>hasta agotar existencias</em>. Por eso <a href="/reservar/">reservar con antelación es clave</a> · cuando llega el verano vuelan. Si vienes con perro y quieres asegurarte, avísanos al reservar y guardamos el chaleco a tu nombre.' },
  { q: '¿Puede ir atado a la canoa?',
    a: '<strong>No, nunca.</strong> Si hay un vuelco, una correa amarrada es un riesgo serio tanto para el perro como para las personas. Dentro de la canoa <strong>va suelto</strong>. Fuera del agua (embarque, accesos, vestuarios) sí debe ir con correa.' },
  { q: '¿Cuántos perros pueden ir por canoa?',
    a: 'Por seguridad y equilibrio, <strong>lo habitual es un perro por canoa</strong>. Si venís con más de uno, los repartimos entre las canoas del grupo. Para casos especiales (perro pequeño + perro pequeño tranquilos) podemos valorarlo al llegar.' },
  { q: '¿Pueden ir perros grandes?',
    a: 'Sí, siempre que sea un perro <strong>tranquilo, acostumbrado a salir y que tolere el agua</strong>. Los perros grandes ocupan más espacio y afectan más al equilibrio, por eso lo valoramos antes del embarque. Un perro grande tranquilo suele ir mucho mejor que un perro pequeño muy nervioso.' },
  { q: '¿Hace falta que mi perro sepa nadar?',
    a: 'No es imprescindible, pero ayuda saberlo antes. Si tu perro <strong>no tiene experiencia en el agua</strong> o no transmite seguridad nadando, <strong>es mejor ir con chaleco canino</strong> · te lo ponemos nosotros hasta agotar existencias. El Sella turístico tiene corriente tranquila, pero el chaleco da un plus real.' },
  { q: '¿Qué hago si mi perro se estresa o no quiere seguir?',
    a: 'Paramos. Hay <strong>playas fluviales tranquilas</strong> donde el perro puede bajar, estirar patas, beber agua y respirar. Si se estresa mucho, podemos buscar una salida anticipada desde la orilla y coordinar el regreso. <strong>Nadie baja contra la voluntad de su perro</strong>.' },
  { q: '¿Es mejor bajar con perro en la ruta Mini o Completa?',
    a: 'Para perros no muy acostumbrados o con edad avanzada, recomendamos la <strong>Mini Sella</strong> (Arriondas → Toraño, 7 km, 2-3 h) — ritmo tranquilo y menos tiempo en agua. Para perros activos y en forma, la <strong>Completa</strong> (Arriondas → Fríes, 14,5 km, 4-5 h) es perfectamente viable con paradas.' },
  { q: '¿Hay que reservar con antelación?',
    a: 'Sí, <strong>especialmente en temporada alta</strong>. Reserva sin pagar ahora: confirmas plaza, pagas con tarjeta antes o el día al recoger la canoa. Si cancelas antes del día, sin coste; si pagaste con tarjeta, reembolso avisando con 24 h de antelación.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    localBusinessSchema(baseUrl),
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Descenso del Sella con perro: guía completa para disfrutar con tu mascota',
      description: 'Guía para hacer el descenso del Sella con perro: normas, chaleco canino incluido (hasta agotar existencias), cómo se coloca el perro en la canoa, qué llevar y por qué es el plan dog-friendly estrella de Asturias.',
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: {
        '@type': 'ImageObject',
        url: `${baseUrl}/images/optimized/con-perro-cta-lg.jpg`,
        width: 1920,
        height: 1080,
      },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-19',
      dateModified:  '2026-05-11',
      articleSection: 'Mascotas',
      keywords: ['descenso del sella con perro', 'descenso del sella mascotas gratis', 'canoa con perro sella', 'chaleco canino sella', 'dog-friendly arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Descenso del Sella con perro · actividad dog-friendly en Asturias' },
    },
    {
      '@type': 'Service',
      '@id': `${canonicalUrl}#service`,
      name: 'Descenso del Sella con perro',
      description: 'Actividad de descenso del Sella en canoa dog-friendly. Mascotas gratis. Chaleco canino incluido sin coste extra (hasta agotar existencias). Monitores con experiencia canina, briefing específico, pautas claras. Todo incluido: canoa, chaleco humano homologado, chaleco canino, transfer, parking y vestuarios con zona exterior para secar al perro.',
      serviceType: 'Descenso del Sella dog-friendly',
      category: 'Turismo activo · Mascotas',
      url: canonicalUrl,
      provider: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      areaServed: { '@type': 'Place', name: 'Arriondas, Asturias' },
      audience: { '@type': 'Audience', audienceType: 'Familias y dueños con mascotas' },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'EUR',
        lowPrice: '0.00',
        highPrice: '40.00',
        offerCount: 3,
        availability: 'https://schema.org/InStock',
        url: `${baseUrl}/reservar/`,
        offers: [
          { '@type': 'Offer', name: 'Mascota',            price: '0.00',  priceCurrency: 'EUR', url: `${baseUrl}/reservar/`, description: 'Gratis · todas las mascotas viajan sin coste' },
          { '@type': 'Offer', name: 'Niño (5-12 años)',   price: '30.00', priceCurrency: 'EUR', url: `${baseUrl}/reservar/` },
          { '@type': 'Offer', name: 'Adulto (13+ años)',  price: '40.00', priceCurrency: 'EUR', url: `${baseUrl}/reservar/` },
        ],
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.5',
        reviewCount: '147',
        bestRating: '5',
        worstRating: '1',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',          item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Con perro',       item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/con-perro/" translationKey="con_perro">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== HERO · Cream luminoso ============== -->
  <section class="cnh cnh--cream" aria-labelledby="cnh-title">

    <div class="cnh__inner">
      <nav class="cnh__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Con perro</span>
      </nav>

      <span class="cnh__eyebrow">
        <span class="cnh__eyebrow-dot" aria-hidden="true"></span>
        Dog-friendly · Temporada 2026
      </span>

      <h1 id="cnh-title" class="cnh__title">
        Descenso del Sella<br/>
        <span class="serif-italic">con <span class="cnh__underlined">perro<svg class="cnh__swoosh" width="200" height="18" viewBox="0 0 200 18" fill="none" aria-hidden="true"><path d="M3 14C30 6 74 4 118 8c27 2.5 54 6 78 4" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/></svg></span></span>
      </h1>

      <p class="cnh__lead">
        <strong>Aventura con tu mascota en Asturias</strong>. Una jornada dog-friendly pensada
        al detalle — con pautas claras antes de salir, monitores con experiencia canina
        y un río tranquilo para disfrutar juntos. <strong>El perro viene gratis</strong>.
      </p>

      <div class="cnh__stats">
        <div class="cnh__stat">
          <span class="cnh__stat-value">Gratis</span>
          <span class="cnh__stat-label">Tu perro no paga</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">40 €</span>
          <span class="cnh__stat-label">Por persona · todo incluido</span>
        </div>
        <div class="cnh__stat-divider" aria-hidden="true"></div>
        <div class="cnh__stat">
          <span class="cnh__stat-value">4.5 ⭐</span>
          <span class="cnh__stat-label">147 reseñas</span>
        </div>
      </div>

      <div class="cnh__ctas">
        <a href="/reservar/" class="cnh__cta cnh__cta--primary">
          Reservar con mi perro
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+34681093673" class="cnh__cta cnh__cta--phone" aria-label="Llamar al 681 093 673">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Llamar</span>
        </a>
        <a href="/precios/" class="cnh__cta cnh__cta--ghost">
          Ver precios y modalidades
        </a>
      </div>
    </div>
  </section>

  <!-- ============== INTRO · ¿Se puede bajar con perro? · Editorial con collage ============== -->
  <section class="cni">
    <div class="container container--xl">
      <div class="cni__grid">
        <!-- Collage izquierda: foto grande + foto pequeña superpuesta + tarjeta contacto -->
        <div class="cni__media" data-reveal>
          <div class="cni__mediaMain">
            <Picture src="con-perro-intro-1" alt="Perro a bordo de una canoa en el descenso del Sella" sizes="(min-width: 960px) 44vw, 90vw" aspectRatio="1 / 1" bare />
          </div>
          <div class="cni__mediaSmall" aria-hidden="true">
            <Picture src="con-perro-intro-2" alt="Perro disfrutando del río Sella en compañía de su familia" sizes="220px" aspectRatio="1 / 1" bare />
          </div>
          <a class="cni__contact" href="https://wa.me/34681093673?text=Hola,%20tengo%20una%20duda%20sobre%20bajar%20el%20Sella%20con%20mi%20perro" target="_blank" rel="noopener noreferrer">
            <span class="cni__contactIcon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-1-.5-2-.8-2.9-1.9-.7-.6-1.2-1.4-1.6-2.1-.2-.3 0-.5.1-.7.1-.2.3-.4.5-.6.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5-.2 0-.4 0-.6 0-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6 0 1.6 1.1 3.1 1.3 3.3.2.2 2.3 3.6 5.7 5 3.4 1.4 3.4.9 4 .9.6-.1 1.8-.8 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3z"/></svg>
            </span>
            <div class="cni__contactBody">
              <strong>Dudas con tu perro?</strong>
              <span>WhatsApp · respondemos rápido</span>
            </div>
          </a>
        </div>

        <!-- Contenido derecha -->
        <div class="cni__content" data-reveal data-reveal-delay="2">
          <span class="cni__eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            La pregunta de siempre
          </span>
          <h2 class="cni__title">
            ¿Se puede bajar<br/>
            el Sella <span class="serif-italic">con perro?</span>
          </h2>
          <p class="cni__lead">
            <strong>Sí, y las mascotas vienen totalmente gratis.</strong> El Sella es uno de los
            planes dog-friendly estrella de Asturias — río tranquilo, paradas cuando el
            perro lo pide, y un equipo que sabe qué mirar antes de entrar al agua.
          </p>

          <ul class="cni__features">
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="11" cy="4.5" r="1.5"/><circle cx="6.5" cy="7.5" r="1.5"/><circle cx="15.5" cy="7.5" r="1.5"/><path d="M11 11c-4 0-6 4-6 6 0 1.66 1.34 3 3 3h6c1.66 0 3-1.34 3-3 0-2-2-6-6-6z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Mascotas 100% gratis</h3>
                <p class="cni__featureText">Tu perro no paga. Viene contigo en la canoa <strong>sin coste extra</strong>. La única excepción es el sábado del Descenso Internacional.</p>
              </div>
            </li>
            <li class="cni__feature">
              <span class="cni__featureIcon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </span>
              <div class="cni__featureBody">
                <h3 class="cni__featureTitle">Monitores dog-friendly</h3>
                <p class="cni__featureText">Con experiencia real bajando el Sella con mascotas. <strong>Saben qué mirar antes de entrar al agua</strong> y cómo preparar la jornada para los dos.</p>
              </div>
            </li>
          </ul>

          <a href="/reservar/" class="cni__cta">
            Reservar con mi perro
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== JORNADA · 6 pasos ============== -->
  <section class="cnj">
    <div class="container container--xl">
      <header class="cnj__header" data-reveal>
        <span class="cnj__eyebrow">— Cómo es el día con tu perro</span>
        <h2 class="cnj__title">
          Una jornada en el Sella,<br/>
          <span class="serif-italic">paso a paso</span>
        </h2>
        <p class="cnj__lead">
          Saber cómo transcurre el día ayuda a decidirse. Así preparamos la
          experiencia para que <strong>tú y tu perro estéis cómodos y seguros</strong> de principio
          a fin — sin prisas, sin sorpresas.
        </p>
      </header>

      <ol class="cnjT">
        {jornada.map((j, i) => (
          <li class={`cnjT__step ${i % 2 === 0 ? 'cnjT__step--left' : 'cnjT__step--right'}`} data-reveal>
            <span class="cnjT__node" aria-hidden="true">{j.num}</span>
            <div class="cnjT__body">
              <h3 class="cnjT__title">{j.title}</h3>
              <p class="cnjT__text" set:html={j.text} />
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- ============== SEGURIDAD ============== -->
  <section class="cns">
    <div class="container container--xl">
      <header class="cns__header" data-reveal>
        <span class="cns__eyebrow">— Seguridad y confianza</span>
        <h2 class="cns__title">
          Qué mirar con tu perro,<br/>
          <span class="serif-italic">y cómo lo resolvemos</span>
        </h2>
        <p class="cns__lead">
          La primera pregunta siempre es <strong>"¿es seguro para mi perro?"</strong> — y es
          lógica. La respuesta corta es sí, cuando se hace con sentido común, pautas
          claras y una valoración honesta de cómo es tu mascota.
        </p>
      </header>

      <ol class="cns__grid">
        <li class="cns__item" data-reveal data-reveal-delay="1">
          <span class="cns__num" aria-hidden="true">01</span>
          <h3 class="cns__itemTitle">Mascotas 100% gratis</h3>
