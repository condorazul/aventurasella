  .cni__cta:hover svg { transform: translateX(3px); }

  /* ============== JORNADA ============== */
  .cnj { padding-block: clamp(4rem, 8vw, 6rem); background: var(--color-bg-warm, #F5F1E8); }
  .cnj__header { max-width: 760px; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .cnj__eyebrow,
  .cns__eyebrow,
  .cnr__eyebrow {
    display: inline-block;
    font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--color-sage, #3D4F3A);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .cnj__title,
  .cns__title,
  .cnr__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1;
    letter-spacing: -0.015em; text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--s-5);
  }
  .cnj__title .serif-italic,
  .cns__title .serif-italic,
  .cnr__title .serif-italic {
    color: var(--color-sage, #3D4F3A); font-family: var(--font-serif);
    font-weight: 400; font-style: italic; text-transform: none;
    letter-spacing: -0.01em;
  }
  .cnj__lead {
    font-family: var(--font-sans); font-size: 1rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnj__lead strong { color: var(--color-text-primary); font-weight: 700; }

  /* Timeline vertical · línea central sage + círculos numerados · alterna izq/dcha */
  .cnjT {
    list-style: none; padding: 0; margin: 0 auto;
    max-width: 1000px;
    position: relative;
    --timeline-progress: 0%;
  }
  /* Línea base sage subtle más gruesa · z-index 0 para pasar por DEBAJO de los nodos */
  .cnjT::before {
    content: ""; position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 3px;
    background: rgba(61, 79, 58, 0.22);
    transform: translateX(-50%);
    border-radius: 3px;
    z-index: 0;
  }
  /* Línea coral que se pinta a medida que haces scroll · z-index 0 para pasar por DEBAJO de los nodos */
  .cnjT::after {
    content: ""; position: absolute;
    left: 50%; top: 0;
    width: 3px;
    height: var(--timeline-progress, 0%);
    background: linear-gradient(180deg, var(--color-primary, #e9856f) 0%, var(--color-primary-active, #c85c44) 100%);
    transform: translateX(-50%);
    border-radius: 3px;
    transition: height 60ms linear;
    pointer-events: none;
    box-shadow: 0 0 12px rgba(233, 133, 111, 0.35);
    z-index: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .cnjT { --timeline-progress: 100%; }
    .cnjT::after { transition: none; }
  }
  .cnjT__step {
    position: relative;
    z-index: 1;          /* sube el step por encima del ::after coral · circulos tapan la línea */
    display: grid;
    grid-template-columns: 1fr 72px 1fr;
    align-items: start;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .cnjT__step:last-child { margin-bottom: 0; }

  .cnjT__node {
    grid-column: 2;
    justify-self: center;
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--color-sage, #3D4F3A);
    color: #FBF8F1;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 24px rgba(61, 79, 58, 0.28);
    position: relative;
    z-index: 1;
  }
  .cnjT__body { min-width: 0; }
  .cnjT__title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.3125rem);
    font-weight: 800; line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 0.625rem;
  }
  .cnjT__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem; line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .cnjT__text strong { color: var(--color-text-primary); font-weight: 700; }

  .cnjT__step--left .cnjT__body {
    grid-column: 1;
    text-align: right;
    padding-right: 1rem;
  }
  .cnjT__step--right .cnjT__body {
    grid-column: 3;
    padding-left: 1rem;
  }

  @media (max-width: 767.98px) {
    /* En mobile la timeline se alinea a la izquierda · ambas líneas (base sage + progress coral)
     * deben coincidir con el centro del círculo del nodo (left: 28px = 56px node / 2). */
    .cnjT::before,
    .cnjT::after { left: 28px; }
    .cnjT__step,
    .cnjT__step--left,
    .cnjT__step--right {
      grid-template-columns: 56px 1fr;
      gap: 1rem;
    }
    .cnjT__step--left .cnjT__node,
    .cnjT__step--right .cnjT__node {
      grid-column: 1;
      justify-self: start;
    }
    .cnjT__step--left .cnjT__body,
    .cnjT__step--right .cnjT__body {
      grid-column: 2;
      text-align: left;
      padding: 0;
    }
  }

  /* ============== SEGURIDAD ============== */
  .cns { padding-block: clamp(5rem, 9vw, 7rem); background: var(--color-bg-base); }
