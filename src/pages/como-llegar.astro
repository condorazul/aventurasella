  .clx__t { font-family: var(--font-display); font-size: clamp(1.0625rem, 1.6vw, 1.25rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.005em; color: #FBF8F1; margin: 0; grid-row: 2; grid-column: 1; }
  .clx__chev { grid-row: 1 / span 2; grid-column: 2; display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: var(--color-primary); color: #FBF8F1; border-radius: 50%; transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1), background-color 300ms ease; flex-shrink: 0; }
