  /* Card con radial fill SAGE (variante del consejos /mejor-epoca/ pero sage) */
  .clqItem {
    position: relative;
    background: #fff;
    border: 1px solid rgba(26, 31, 46, 0.08);
    border-radius: 1.25rem;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    min-height: 180px;
