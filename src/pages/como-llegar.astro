  .clt__panel[hidden] { display: none; }
  .clt__panel.is-active { animation: cltPanelIn 500ms cubic-bezier(0.22, 1, 0.36, 1); }
  @keyframes cltPanelIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 899.98px) {
    .clt__card {
      display: flex;
      max-width: none;
      margin: 0 -1rem;
      padding: 0.5rem 1rem;
      gap: 1rem;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      overflow-x: auto;
      overflow-y: visible;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 1rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .clt__card::-webkit-scrollbar { display: none; }
    /* Anulamos `[hidden]` para que las 3 fichas estén presentes en el track */
    .clt__panel,
    .clt__panel[hidden] {
      display: grid !important;
      flex: 0 0 100%;
      width: 100%;
      scroll-snap-align: start;
      background: #fff;
      border: 1px solid rgba(26, 31, 46, 0.08);
