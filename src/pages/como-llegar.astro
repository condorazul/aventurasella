---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/ui/Picture.astro';

const title = 'Cómo llegar a Arriondas · A 50 m de las estaciones de bus y tren';
const description = 'Cómo llegar a Arriondas para el descenso del Sella: a 50 m de las estaciones de bus y tren. Coche (A-8, A-64), ALSA o Renfe. Parking 300 plazas + autocaravanas.';

const baseUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://aventuraenelsella.es';
const canonicalUrl = `${baseUrl}/como-llegar/`;
const ogImage = '/images/optimized/como-llegar-cta-lg.jpg';

// Ciudades origen más relevantes · distancias por carretera (rutas recomendadas)
// lat/lng: centro de cada ciudad · Google Maps los necesita en el `data=` de la
// URL de direcciones para poder calcular la ruta cuando el destino se fija con FTID.
const ciudades = [
  { c: 'Oviedo',    lat: 43.36029, lng: -5.84476, km: 52,  tiempo: '50 min',     ruta: 'A-64 + N-634',      destacado: true  },
  { c: 'Gijón',     lat: 43.53573, lng: -5.66152, km: 75,  tiempo: '55 min',     ruta: 'A-8 + AS-114',       destacado: true  },
  { c: 'Santander', lat: 43.46472, lng: -3.80444, km: 160, tiempo: '1 h 55 min', ruta: 'A-8',                destacado: false },
  { c: 'Bilbao',    lat: 43.26271, lng: -2.92528, km: 255, tiempo: '2 h 45 min', ruta: 'A-8',                destacado: false },
  { c: 'Madrid',    lat: 40.41678, lng: -3.70379, km: 440, tiempo: '4 h 30 min', ruta: 'A-6 + A-66 + A-64',  destacado: false },
];

// 3 medios de transporte en tabs
const medios = [
  {
    id: 'coche',
    tab: 'En coche',
    eyebrow: 'En coche',
    route: 'La opción más flexible',
    stats: [
      { v: '52',  u: 'km',  l: 'desde Oviedo' },
      { v: '75',  u: 'km',  l: 'desde Gijón' },
      { v: 'A-8', u: '',    l: 'autovía' },
    ],
    desc: 'La forma más cómoda de llegar a Arriondas es <strong>en coche por la A-8</strong> (autovía del Cantábrico) desde Santander, Bilbao o Gijón, o por la <strong>A-64 + N-634</strong> desde Oviedo. Los accesos están bien señalizados, la última parte es por vía secundaria (AS-114 o N-634) que atraviesa pueblos asturianos preciosos. Junto a nuestras oficinas tenemos <strong>parking privado y vigilado con 300 plazas — también para autocaravanas</strong>, gratuito y sin restricciones.',
    features: ['A-8 autovía', 'A-64 directa Oviedo', 'AS-114 desde Gijón', 'Aparcamiento gratis', 'Flexibilidad total', 'Sin horarios'],
    photo: 'como-llegar-coche',
    badges: ['Flexible', 'Directo', 'Cómodo'],
  },
  {
    id: 'bus',
    tab: 'En autobús',
    eyebrow: 'Autobús ALSA',
    route: 'Económico y frecuente',
    stats: [
      { v: '~1h15', u: '',  l: 'desde Oviedo' },
      { v: '~1h06', u: '',  l: 'desde Gijón' },
      { v: 'Desde 6€', u: '', l: 'ida' },
    ],
    desc: '<strong>ALSA</strong> conecta Arriondas con las principales ciudades asturianas. Desde <strong>Oviedo (estación Pepe Cosmen)</strong> hay <strong>~20 autobuses al día</strong> (aprox. cada 30 min, primer servicio 06:25 y último 22:15), duración ~1 h 15 min. Desde <strong>Gijón</strong> hay 4 servicios directos al día, duración ~1 h 06 min. La parada en Arriondas está en la <strong>estación de autobuses</strong>, a pocos minutos andando de nuestras oficinas. Consulta y compra en <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.',
    features: ['~20 servicios/día Oviedo', '4 servicios/día Gijón', 'Desde 6€ ida', 'Estación céntrica', 'Sin coche propio', 'Compra online'],
    photo: 'como-llegar-bus',
    badges: ['ALSA', 'Frecuente', 'Económico'],
  },
  {
    id: 'tren',
    tab: 'En tren',
    eyebrow: 'Renfe Cercanías AM',
    route: 'Viaje escénico por Asturias',
    stats: [
      { v: '~1h50', u: '',  l: 'desde Oviedo' },
      { v: '3/día', u: '',  l: 'frecuencia' },
      { v: 'Desde 5€', u: '', l: 'ida' },
    ],
    desc: 'La línea <strong>Renfe Cercanías AM</strong> (antigua FEVE) de Oviedo a Llanes <strong>tiene parada en Arriondas</strong>. Viaje más lento pero muy escénico por paisajes asturianos: <strong>~1 h 50 min</strong>, primer tren sobre las 07:57 y último sobre las 19:07, <strong>3 servicios al día</strong>. Desde 5 € el trayecto. La estación de Arriondas está en el centro del pueblo. Consulta horarios actualizados en <a href="https://www.renfe.com/es/es/cercanias/cercanias-am" target="_blank" rel="noopener noreferrer">renfe.com/cercanias-am</a>.',
    features: ['Cercanías AM', '3 trenes/día', 'Desde 5€ ida', 'Estación centro', 'Paisaje escénico', 'Sin coche'],
    photo: 'como-llegar-tren',
    badges: ['Renfe', 'Escénico', 'Tranquilo'],
  },
];

// Consejos prácticos (6)
const consejos = [
  { t: 'Horario abierto · 10:30–12:30', s: 'Como tu reserva es <strong>Premium</strong>, el horario es abierto: llega a nuestras instalaciones <strong>cuando te venga bien entre las 10:30 y las 12:30</strong>, sin necesidad de elegir hora concreta. Te equipamos al llegar y sales al río según estés listo.' },
  { t: 'Temporada alta · evita puentes', s: 'En julio y agosto, especialmente fines de semana, la A-8 puede tener tráfico denso hacia Asturias. Si vienes desde Madrid o Santander, sal pronto o plantea la ida la tarde anterior.' },
  { t: 'Parking privado · 300 plazas', s: 'Disponemos de <strong>parking privado y vigilado, gratuito, con capacidad para 300 coches y también para autocaravanas</strong>. Sin preocupaciones — deja el coche y te encargamos del resto.' },
  { t: 'Bus · compra con antelación', s: 'En temporada alta los billetes de ALSA se agotan. Compra <strong>1-2 días antes</strong> online si vienes en bus desde Oviedo o Gijón, especialmente en agosto.' },
  { t: 'Tren · consulta frecuencias', s: 'La línea Renfe Cercanías AM tiene <strong>pocas frecuencias al día</strong> (3-4 servicios). Verifica los horarios de ida y vuelta antes de planificar tu jornada.' },
  { t: 'Desde Madrid · plantea dormir cerca', s: 'Si vienes desde Madrid, son <strong>4 h 30 en coche</strong>. Puede ser más cómodo dormir la víspera en Oviedo, Gijón o Cangas de Onís y bajar el Sella fresco al día siguiente.' },
];

// FAQ específico cómo llegar (8) · datos verificados con ALSA y Renfe oficial
const faqs = [
  { q: '¿Cómo se llega a Arriondas desde Oviedo?',
    a: 'Desde Oviedo son <strong>unos 52 km · 50 min en coche</strong> por la A-64 y N-634. En autobús con <strong>ALSA</strong>, ~20 servicios diarios desde la estación Pepe Cosmen (desde 6 €, duración ~1 h 15 min, primer bus 06:25 y último 22:15). En tren <strong>Renfe Cercanías AM</strong>, ~1 h 50 min, con 3 servicios al día desde 5 €.' },
  { q: '¿Y desde Gijón?',
    a: 'Desde Gijón son <strong>unos 75 km · 55 min en coche</strong> por la A-8 y AS-114. En <strong>autobús ALSA</strong> hay <strong>4 servicios directos al día</strong>, con duración de ~1 h 06 min y precios desde 7 €. Compra los billetes en <a href="https://www.alsa.com" target="_blank" rel="noopener noreferrer">alsa.com</a>.' },
  { q: '¿Hay parking en la oficina? ¿Aceptáis autocaravanas?',
    a: 'Sí. Disponemos de <strong>parking privado y vigilado con 300 plazas</strong> junto a nuestras oficinas de recepción en Arriondas, <strong>gratuito y también apto para autocaravanas</strong>. No tendrás problemas para dejar el coche mientras hacéis el descenso — y el transfer de regreso te deja en el mismo lugar.' },
  { q: '¿Viene gente sin coche al descenso del Sella?',
    a: 'Muchísima. Una parte importante de nuestros clientes llega en <strong>autobús ALSA</strong> o <strong>tren Renfe Cercanías AM</strong> desde Oviedo o Gijón. Nuestra tienda está a <strong>solo 50 metros andando</strong> tanto de la <strong>estación de autobuses</strong> como de la <strong>estación de tren</strong> de Arriondas — es prácticamente una llegada <strong>puerta-a-puerta</strong>. Salir de Oviedo en bus y empezar el descenso del Sella sin moverte del centro de Arriondas es perfectamente viable.' },
  { q: '¿Hasta qué hora podemos llegar?',
    a: 'Tu reserva es <strong>Premium · horario abierto</strong>. Llega a nuestras instalaciones <strong>cuando te venga bien entre las 10:30 y las 12:30</strong>, sin obligación de cumplir hora concreta — es una ventaja Premium. Te equipamos al llegar y sales al río según estés listo. La <strong>Confederación Hidrográfica</strong> marca que la <strong>permanencia en el río es hasta las 18:00 h</strong> · por eso cerramos llegadas a las 12:30 (margen seguro). Excepciones: el sábado del <a href="/descenso-internacional-del-sella/">Descenso Internacional</a> tiene salida única en hora concreta · y si hay temporal o condiciones del río que requieran entrada con monitor, te avisamos con antelación.' },
  { q: '¿Qué distancia hay desde Madrid?',
    a: 'Madrid está a <strong>unos 440 km · 4 h 30 min en coche</strong> por la A-6 (hasta Benavente), A-66 (Ruta de la Plata) y A-64 (Oviedo → Arriondas). Muchos viajeros prefieren dormir la víspera en Asturias — Oviedo, Gijón o Cangas de Onís — para empezar el día del descenso frescos.' },
  { q: '¿Cuántos buses/trenes hay al día entre Oviedo y Arriondas?',
    a: '<strong>ALSA: ~20 autobuses diarios</strong> (aprox. cada 30 min). <strong>Renfe Cercanías AM: 3 trenes al día</strong>. El bus es más rápido (~1 h 15 min) y frecuente; el tren es más escénico (~1 h 50 min). Ambos paran en Arriondas, en el centro del pueblo.' },
  { q: '¿Puedo dejar mochilas o equipaje antes del descenso?',
    a: 'Sí. En nuestras oficinas puedes dejar equipaje pequeño o mochilas durante el descenso. Al regresar en nuestro transfer, tendrás acceso a <strong>vestuarios con duchas calientes</strong> para cambiarte antes de seguir tu día.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: 'Cómo llegar a Arriondas · Coche, bus y tren',
      description: 'Guía completa sobre cómo llegar a Arriondas para el descenso del Sella: coche, autobús ALSA y tren Renfe desde las principales ciudades del norte de España. Parking privado 300 plazas también para autocaravanas.',
      inLanguage: 'es-ES',
      mainEntityOfPage: canonicalUrl,
      url: canonicalUrl,
      image: { '@type': 'ImageObject', url: `${baseUrl}/images/optimized/como-llegar-cta-lg.jpg`, width: 1920, height: 1080 },
      author:    { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl },
      publisher: { '@type': 'Organization', name: 'Aventura en el Sella', url: baseUrl, logo: { '@type': 'ImageObject', url: `${baseUrl}/images/logo/logo.svg` } },
      datePublished: '2026-04-20',
      dateModified:  '2026-05-11',
      articleSection: 'Planificación · Cómo llegar',
      keywords: ['cómo llegar a Arriondas', 'cómo llegar al Sella', 'descenso del Sella sin coche', 'estación bus Arriondas', 'estación tren Arriondas', 'parking Arriondas descenso Sella', 'autocaravanas Arriondas', 'ALSA Oviedo Arriondas', 'Renfe Cercanías AM Arriondas', 'distancia Oviedo Arriondas'],
      isPartOf: { '@type': 'WebSite', '@id': `${baseUrl}/#website`, name: 'Aventura en el Sella', url: baseUrl },
      about: { '@type': 'Thing', name: 'Cómo llegar a Arriondas (Asturias) para el descenso del Sella en canoa' },
    },
    {
      '@type': 'Place',
      '@id': `${canonicalUrl}#place`,
      name: 'Aventura en el Sella · Arriondas',
      description: 'Instalaciones de Aventura en el Sella en Arriondas (Asturias). Parking privado y vigilado con 300 plazas, también para autocaravanas. Vestuarios con duchas calientes.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Arriondas',
        addressRegion: 'Asturias',
        addressCountry: 'ES',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude:  43.3874223,
        longitude: -5.1866022,
      },
      sameAs: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      hasMap: 'https://www.google.com/maps/place/Aventura+en+el+Sella/@43.3874223,-5.1866022,17z/data=!4m6!3m5!1s0xd36195b04532889:0x9b2face87069ecfc!16s%2Fg%2F11s4chj1vp',
      url: canonicalUrl,
      amenityFeature: [
        { '@type': 'LocationFeatureSpecification', name: 'A 50 m de la estación de autobuses (ALSA)',   value: true },
        { '@type': 'LocationFeatureSpecification', name: 'A 50 m de la estación de tren (Renfe Cercanías AM)', value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Parking privado · 300 plazas',                value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Autocaravanas admitidas',                     value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Vestuarios con duchas calientes',             value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Taquillas con llave',                         value: true },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map(f => ({
        '@type': 'Question', name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio',      item: baseUrl },
        { '@type': 'ListItem', position: 2, name: 'Cómo llegar', item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} currentPath="/como-llegar/" translationKey="como_llegar">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============== 1 · HERO · Editorial con signpost card (distinto) ============== -->
  <section class="clh" aria-labelledby="clh-title">

    <div class="clh__shapes" aria-hidden="true">
      <span class="clh__shape clh__shape--1"></span>
      <span class="clh__shape clh__shape--2"></span>
    </div>
    <span class="clh__watermark" aria-hidden="true">Arriondas</span>

    <div class="clh__inner">
      <div class="clh__left">
        <nav class="clh__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Cómo llegar</span>
        </nav>
        <span class="clh__eyebrow">— Cómo llegar a Arriondas</span>
        <h1 id="clh-title" class="clh__title">
          Cómo llegar<br/>
          <span class="serif-italic">a Arriondas.</span>
        </h1>
        <p class="clh__lead">
          Arriondas está en el <strong>centro oriental de Asturias</strong>, a 50 km de Oviedo y
          75 km de Gijón. Bien conectada en coche (A-8 y A-64), en autobús ALSA y en tren Renfe.
          Nuestra tienda está a <strong>50 metros andando de las estaciones de bus y tren</strong> ·
          puerta-a-puerta desde Oviedo, Gijón o Llanes.
        </p>
        <div class="clh__ctas">
          <a href="#clh-medios" class="clh__cta clh__cta--primary">Ver medios de transporte</a>
          <a href="/reservar/" class="clh__cta clh__cta--link">
            Reservar descenso
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <aside class="clh__signpost" aria-label="A 50 metros de las estaciones de bus y tren de Arriondas">
        <header class="clh__sigHead">
          <span class="clh__sigKicker">— Sin coche · sin problema</span>
          <h2 class="clh__sigT">A <span class="clh__sigBig">50&nbsp;m</span><br/><span class="serif-italic">de las estaciones</span></h2>
          <p class="clh__sigLead">
            Nuestra tienda está a <strong>50 metros andando</strong> tanto de la <strong>estación de autobuses</strong>
            como de la <strong>estación de tren</strong> de Arriondas. Llegada puerta-a-puerta desde Oviedo, Gijón o Llanes.
          </p>
        </header>
        <ul class="clh__sigList">
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><circle cx="8.5" cy="15" r="1" fill="currentColor"/><circle cx="15.5" cy="15" r="1" fill="currentColor"/><path d="M7 19l-2 2"/><path d="M17 19l2 2"/></svg>
              <span>Estación de bus · ALSA</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow is-featured">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 12h18"/><path d="M7 19l-2 3"/><path d="M17 19l2 3"/><circle cx="8" cy="16" r="1" fill="currentColor"/><circle cx="16" cy="16" r="1" fill="currentColor"/></svg>
              <span>Estación tren · Renfe AM</span>
            </span>
            <span class="clh__sigKm"><strong>50</strong><small> m</small></span>
          </li>
          <li class="clh__sigRow">
            <span class="clh__sigCity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="7" rx="1"/><path d="M5 11l2-5h10l2 5"/><circle cx="7.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg>
              <span>Parking propio · 300 plazas</span>
            </span>
            <span class="clh__sigKm"><strong>0</strong><small> m</small></span>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ============== 2 · Distancias cards (grid 5) ============== -->
  <section class="cld">
    <div class="container container--xl">
      <header class="cld__header" data-reveal>
        <span class="cld__eyebrow">— Distancia en coche</span>
        <h2 class="cld__title">
          Desde las principales<br/>
          <span class="serif-italic">ciudades del norte.</span>
        </h2>
        <p class="cld__lead">
          Km, tiempo estimado y rutas principales desde los orígenes más habituales de nuestros
          clientes. Sin tráfico denso y cumpliendo límites, por supuesto.
        </p>
      </header>

      <ol class="cld__grid">
        {ciudades.map((c, i) => (
          <li class="cld__item" data-reveal data-reveal-delay={(i % 3) + 1}>
            <a
              class="cld__link"
              href={`https://www.google.com/maps/dir/${encodeURIComponent(c.c + ', España')}/Aventura+en+el+Sella/@43.3874223,-5.1866022,9z/data=!4m13!4m12!1m5!1m1!1s0x0:0x0!2m2!1d${c.lng}!2d${c.lat}!1m5!1m1!1s0xd36195b04532889:0x9b2face87069ecfc!2m2!1d-5.1866022!2d43.3874223!3e0`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Abrir Google Maps con ruta en coche desde ${c.c} a Aventura en el Sella en Arriondas`}
            >
            <span class="cld__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="cld__city">{c.c}</span>
            <div class="cld__stats">
              <div class="cld__stat">
                <strong>{c.km}<small>km</small></strong>
                <span>distancia</span>
              </div>
              <div class="cld__stat">
                <strong>{c.tiempo}</strong>
                <span>en coche</span>
              </div>
            </div>
            <p class="cld__route">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {c.ruta}
            </p>
            <span class="cld__open" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              Ver ruta en Google Maps
            </span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============== 3 · TABS 3 MEDIOS (Coche / Bus / Tren) ============== -->
  <section id="clh-medios" class="clt" aria-labelledby="clt-title">
    <div class="container container--xl">
      <header class="clt__head" data-reveal>
        <div class="clt__headL">
          <span class="clt__kicker">— Medios de transporte</span>
          <h2 id="clt-title" class="clt__title">
            Elige tu<br/>
            <span class="serif-italic">forma de llegar.</span>
          </h2>
        </div>
        <div class="clt__tabs" role="tablist" aria-label="Elegir medio de transporte">
          {medios.map((m, i) => (
            <button type="button" role="tab" id={`clt-tab-${m.id}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`clt-panel-${m.id}`}
                    class={`clt__tab${i === 0 ? ' is-active' : ''}`}
                    data-tab={m.id} tabindex={i === 0 ? 0 : -1}>
              {m.tab}
            </button>
          ))}
        </div>
      </header>

      <div class="clt__card" data-reveal data-reveal-delay="1">
        {medios.map((m, i) => (
          <div class={`clt__panel${i === 0 ? ' is-active' : ''}`}
               id={`clt-panel-${m.id}`} role="tabpanel"
